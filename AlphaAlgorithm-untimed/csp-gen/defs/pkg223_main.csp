				-- Definition of the behaviour of state machines (default, optimised, visible, visible and optimised)
				FVS__(id__,
						    const_pkg223__Communication_id,
						    const_pkg223__Communication_RC) = STM_VS_O(id__,
						    const_pkg223__Communication_id,
						    const_pkg223__Communication_RC)
				
