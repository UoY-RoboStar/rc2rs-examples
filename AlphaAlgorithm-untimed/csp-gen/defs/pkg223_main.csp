						    const_pkg223__Communication_RC) [|shared_variable_events|] SKIP
				HUP__(id__,
						    const_pkg223__Communication_id,
						    const_pkg223__Communication_RC) = O__(id__,
						    const_pkg223__Communication_id,
						    const_pkg223__Communication_RC) [|{share__}|] SKIP
				
				-- Shared memory
				-- Shared memory variables
				
