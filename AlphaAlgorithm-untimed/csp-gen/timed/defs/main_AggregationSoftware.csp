									 						transSync = {|internal__.NID_i1,obstacle__.NID_Move.in,internal__.NID_Avoid|}
									 					within
									 						((
									 						 (((-- RULE composeNodes(nc:NodeContainer)^nops : CSPProcess
									 						   i1::VS_O__(id__,
									 						   		    const_aggregation_Movement_lv,
									 						   		    const_aggregation_Movement_av,
									 						   		    const_aggregation_Movement_MB,
									 						   		    const_aggregation_Movement_alpha)
									 						   [| { share__, terminate } |] (
									 						   Move::VS_O__(id__,
									 						   		    const_aggregation_Movement_lv,
									 						   		    const_aggregation_Movement_av,
									 						   		    const_aggregation_Movement_MB,
									 						   		    const_aggregation_Movement_alpha)
									 						   [| { share__, terminate } |] (
									 						   Avoid::VS_O__(id__,
									 						   		    const_aggregation_Movement_lv,
									 						   		    const_aggregation_Movement_av,
									 						   		    const_aggregation_Movement_MB,
									 						   		    const_aggregation_Movement_alpha)
									 						   )
									 						   )
									 						 )
									 						 [[Move::interrupt <- x__ | x__ <- {|interrupt,obstacle__.NID_Move.in|}]]
									 						 [[Avoid::interrupt <- x__ | x__ <- {|interrupt,internal__.NID_Avoid|}]]
									 						 [[i1::interrupt <- x__ | x__ <- {|internal__.NID_i1|}]]
									 						 )
									 						  [[ share__ <- x__ | x__ <- {| share__,setR_p |} ]] 
									 						 )
									 						 [| union(union(union(flowevts,transSync),{terminate}),{|share__
									 						 			,setR_p
									 						 			|}) |]
									 						 ((i1::enter -> Transitions(id__,
									 						 		    const_aggregation_Movement_lv,
									 						 		    const_aggregation_Movement_av,
									 						 		    const_aggregation_Movement_MB,
									 						 		    const_aggregation_Movement_alpha))
									 						  [[ share__ <- x__ | x__ <- {| share__ |} ]]
									 						  [[set_p <- setR_p]]
									 						 )
									 						)
									 						 [[setR_p <- set_p]]
									 						)
									 					)
									 					 \ hideSet)
									 					[[
									 						neighbours__.x____ <- neighbours,
									 						obstacle__.x____ <- obstacle
									 						| x____ <- NIDS
									 					]]
									 				)
									 				[| {|get_CLID_Avoid,Avoid::entered,terminate|} |]
									 				dbisim(Clock_CLID_Avoid(id__,0,
									 						          const_aggregation_Movement_lv,
									 						          const_aggregation_Movement_av,
									 						          const_aggregation_Movement_MB,
									 						          const_aggregation_Movement_alpha))
									 			)\{|get_CLID_Avoid|}
									 		)
									 		[| {|get_CLID_Move,Move::entered,terminate|} |]
									 		dbisim(Clock_CLID_Move(id__,0,
									 				          const_aggregation_Movement_lv,
									 				          const_aggregation_Movement_av,
									 				          const_aggregation_Movement_MB,
									 				          const_aggregation_Movement_alpha))
									 	)\{|get_CLID_Move|}
									 )
									 ))
									  [[ share__ <- x__ | x__ <- {| share__,setR_turned,clockResetR.CLID_MBC,setR_p,setR_n |} ]] 
									  [[set_turned <- setL_turned,clockReset.CLID_MBC <- clockResetL.CLID_MBC,set_p <- setL_p,set_n <- setL_n]]
									 )
									 [| union(union(enteredSS,{| interrupt, terminate |}),{|share__
									 			,setL_turned
									 			,clockResetL.CLID_MBC
									 			,setL_p
									 			,setL_n
									 			,setR_turned
									 			 			,clockResetR.CLID_MBC
									 			 			,setR_p
									 			 			,setR_n
									 			|}) |]
									 ((During)
									  [[ share__ <- x__ | x__ <- {| share__,setL_turned,clockResetL.CLID_MBC,setL_p,setL_n |} ]]
									  [[set_turned <- setR_turned,clockReset.CLID_MBC <- clockResetR.CLID_MBC,set_p <- setR_p,set_n <- setR_n]]
									 )
									)[[setL_turned <- set_turned,clockResetL.CLID_MBC <- clockReset.CLID_MBC,setL_p <- set_p,setL_n <- set_n]]
									 [[setR_turned <- set_turned,clockResetR.CLID_MBC <- clockReset.CLID_MBC,setR_p <- set_p,setR_n <- set_n]]
									)\{terminate} 
								)
								During 		= share__choice(([] e__ : enteredSS @ e__ -> SKIP))
										 	  ; entered -> ((CRUN(enteredSS) ||| SKIP ; SStop) /\ interrupt -> share__choice(terminate -> SKIP))
							within
								Inactive [| {terminate} |> SKIP)
							
							Transitions(id__,
									    const_aggregation_Movement_lv,
									    const_aggregation_Movement_av,
									    const_aggregation_Movement_MB,
									    const_aggregation_Movement_alpha) = ((let
								Trans = TimeOut_1(
									 (share__ -> SKIP
									 [] dbisim((true)&(internal__!NID_i1 -> SKIP ;  ((SKIP ; Move::enter -> SKIP))))
									 [] dbisim((true)&(obstacle__!NID_Move.in?p:{p|p <- main_Position, true} -> share__choice(set_p!p -> SKIP) ;  share__choice(exit -> SKIP) ; (share__choice(exited -> SKIP) ; SKIP ; Avoid::enter -> SKIP)))
									 [] dbisim((true)&(internal__!NID_Avoid -> SKIP ;  share__choice(exit -> SKIP) ; (share__choice(exited -> SKIP) ; SKIP ; Move::enter -> SKIP)))
									 []
									 (interrupt -> share__choice(exit -> SKIP) ; share__choice(exited -> terminate -> SKIP))
									 []
									 terminate -> SKIP
									 )
								,SKIP);Trans
							within
								Trans [|{terminate}|> SKIP
							)
							)
							
							
							-- Clocks
							Clock_CLID_Move(id__,x__,
									          const_aggregation_Movement_lv,
									          const_aggregation_Movement_av,
									          const_aggregation_Movement_MB,
									          const_aggregation_Movement_alpha) = 
								TimeOut_1(
									Move::entered -> Clock_CLID_Move(id__,0,
											          const_aggregation_Movement_lv,
											          const_aggregation_Movement_av,
											          const_aggregation_Movement_MB,
											          const_aggregation_Movement_alpha)
									[]
									get_CLID_Move!x__ -> Clock_CLID_Move(id__,x__,
											          const_aggregation_Movement_lv,
											          const_aggregation_Movement_av,
											          const_aggregation_Movement_MB,
											          const_aggregation_Movement_alpha)
									[]
									terminate -> SKIP,Clock_CLID_Move(id__,clock_type_plus(x__,1,CLID_Move_clock_type(id__,
											          const_aggregation_Movement_lv,
											          const_aggregation_Movement_av,
											          const_aggregation_Movement_MB,
											          const_aggregation_Movement_alpha)),
											          const_aggregation_Movement_lv,
											          const_aggregation_Movement_av,
											          const_aggregation_Movement_MB,
											          const_aggregation_Movement_alpha))
							Clock_CLID_Avoid(id__,x__,
									          const_aggregation_Movement_lv,
									          const_aggregation_Movement_av,
									          const_aggregation_Movement_MB,
									          const_aggregation_Movement_alpha) = 
								TimeOut_1(
									Avoid::entered -> Clock_CLID_Avoid(id__,0,
											          const_aggregation_Movement_lv,
											          const_aggregation_Movement_av,
											          const_aggregation_Movement_MB,
											          const_aggregation_Movement_alpha)
									[]
									get_CLID_Avoid!x__ -> Clock_CLID_Avoid(id__,x__,
											          const_aggregation_Movement_lv,
											          const_aggregation_Movement_av,
											          const_aggregation_Movement_MB,
											          const_aggregation_Movement_alpha)
									[]
									terminate -> SKIP,Clock_CLID_Avoid(id__,clock_type_plus(x__,1,CLID_Avoid_clock_type(id__,
											          const_aggregation_Movement_lv,
											          const_aggregation_Movement_av,
											          const_aggregation_Movement_MB,
											          const_aggregation_Movement_alpha)),
											          const_aggregation_Movement_lv,
											          const_aggregation_Movement_av,
											          const_aggregation_Movement_MB,
											          const_aggregation_Movement_alpha))
							
							StateClocks(id__,
									          const_aggregation_Movement_lv,
									          const_aggregation_Movement_av,
									          const_aggregation_Movement_MB,
									          const_aggregation_Movement_alpha) = dbisim(Clock_CLID_Move(id__,0,
									          const_aggregation_Movement_lv,
									          const_aggregation_Movement_av,
									          const_aggregation_Movement_MB,
									          const_aggregation_Movement_alpha))
							[| { terminate } |] (
							dbisim(Clock_CLID_Avoid(id__,0,
									          const_aggregation_Movement_lv,
									          const_aggregation_Movement_av,
									          const_aggregation_Movement_MB,
									          const_aggregation_Movement_alpha))
							)
							
							stateClockSync = {|get_CLID_Move,Move::entered,get_CLID_Avoid,Avoid::entered|}
						}
					
					endmodule
					----------------------------------------------------------------------
					
					
					----------------------------------------------------------------------
					-- State: Turning
					module Turning
					
					enterSS = 
							{|			i1::enter,
								j1::enter,
								Turn180::enter,
								RandomTurn::enter,
								f1::enter
							|}
					enteredSS = 
							{|			Turn180::entered,
								RandomTurn::entered,
								f1::entered
							|}
					exports
					
						--  Declarations
						
						channel enter, entered, interrupt
						channel enteredL, enteredR
						
										
						-- declaring identifiers of transitions
						datatype NIDS = 
						              NID_i1|
						              NID_j1|
						              NID_Turn180|
						              NID_RandomTurn|
						              NID_f1
						
						channel internal__ : NIDS
						channel neighbours__: NIDS.InOut.core_nat
						channel obstacle__: NIDS.InOut.main_Position
						
						channel get_CLID_Turn180 : core_clock_type 
						channel get_CLID_RandomTurn : core_clock_type 
						--channel increment__
						
						CLID_Turn180_clock_type(id__,
								          const_aggregation_Movement_lv,
								          const_aggregation_Movement_av,
								          const_aggregation_Movement_MB,
								          const_aggregation_Movement_alpha) = 
							let
								max = (clock_type_max(Union({
						{}
						}))+1)
							ctype = {0..max}
						within
							if member(max,core_clock_type) then ctype else error("core_clock_type is not wide enough")
						
						CLID_RandomTurn_clock_type(id__,
								          const_aggregation_Movement_lv,
								          const_aggregation_Movement_av,
								          const_aggregation_Movement_MB,
								          const_aggregation_Movement_alpha) = 
							let
								max = (clock_type_max(Union({
						{}
						}))+1)
							ctype = {0..max}
						within
							if member(max,core_clock_type) then ctype else error("core_clock_type is not wide enough")
						
						
						--	Nodes
						-- declaring all nodes
						
						----------------------------------------------------------------------
						-- Initial: i1
						module i1
						exports
						
							channel enter, interrupt
							
							Timed(OneStep) {
								D__(id__,
										    const_aggregation_Movement_lv,
										    const_aggregation_Movement_av,
										    const_aggregation_Movement_MB,
										    const_aggregation_Movement_alpha) = 
									dbisim(let
										Inactive 	= share__choice(enter -> SKIP [] terminate -> SKIP) ; Active
										
										Termination = terminate -> SKIP
										
										Active 		= share__choice(interrupt -> SKIP) ; Inactive
									within
										Inactive [| {terminate} |> SKIP)
								
								VS_O__(id__,
										    const_aggregation_Movement_lv,
										    const_aggregation_Movement_av,
										    const_aggregation_Movement_MB,
										    const_aggregation_Movement_alpha) = D__(id__,
										    const_aggregation_Movement_lv,
										    const_aggregation_Movement_av,
										    const_aggregation_Movement_MB,
										    const_aggregation_Movement_alpha)
							}
						
						endmodule
						----------------------------------------------------------------------
						
						
						----------------------------------------------------------------------
						-- Junction: j1
						module j1
						exports
						
							channel enter, interrupt
							
							Timed(OneStep) {
								D__(id__,
										    const_aggregation_Movement_lv,
										    const_aggregation_Movement_av,
										    const_aggregation_Movement_MB,
										    const_aggregation_Movement_alpha) = 
									dbisim(let
										Inactive 	= share__choice(enter -> SKIP [] terminate -> SKIP) ; Active
										
										Active 		= share__choice(interrupt -> SKIP) ; Inactive
									within
										Inactive [| {terminate} |> SKIP)
									
								VS_O__(id__,
										    const_aggregation_Movement_lv,
										    const_aggregation_Movement_av,
										    const_aggregation_Movement_MB,
										    const_aggregation_Movement_alpha) = D__(id__,
										    const_aggregation_Movement_lv,
										    const_aggregation_Movement_av,
										    const_aggregation_Movement_MB,
										    const_aggregation_Movement_alpha)
							}
						
						endmodule
						----------------------------------------------------------------------
						
						
						----------------------------------------------------------------------
						-- State: Turn180
						module Turn180
						
						enterSS = {}
						
						enteredSS = {}
						
						exports
						
							--  Declarations
							
							channel enter, entered, interrupt
							channel enteredL, enteredR
							
											
							
							--channel increment__
							
							
							--	Nodes
							-- declaring all nodes
							
							
							Timed(OneStep) {
								--	Rule: behaviours(Node)
								--  Note that FDR has problems with efficiently compiling the process below
								-- 	if using a different recursion pattern.
								D__(id__,
										    const_aggregation_Movement_lv,
										    const_aggregation_Movement_av,
										    const_aggregation_Movement_MB,
										    const_aggregation_Movement_alpha) = 
								dbisim(let
									-- IMPLEMENTATION NOTE: 
									-- The following should be defined as: Inactive = share__choice(Activation [] Termination),
									-- however FDR struggles with that form in certain cases. So we use the exception operator
									-- instead to 'terminate'.
									
									Inactive 	= share__choice(enter -> SKIP [] terminate -> SKIP) ; Active
									
									Termination = terminate -> SKIP
									
									Active 		= true&CALL__move(
												id__,
											    const_aggregation_Movement_lv,
											    const_aggregation_Movement_av,
											    const_aggregation_Movement_MB,
											    const_aggregation_Movement_alpha,
												0,
												const_aggregation_Movement_av
											);SHARE_WAIT(Mathematics_floor(Div(180, no_zero_div(const_aggregation_Movement_av), core_real))) ; 
											 	  Behaviour ; 
											 	  share__choice(exit -> SKIP) ; SKIP ; 
											 	  share__choice(exited -> SKIP) ; Inactive
								
									Behaviour 	= entered -> During
									During 		= ((SKIP ; SStop) /\ interrupt -> SKIP)
								within
									Inactive [| {terminate} |> SKIP)
									
								VS_O__(id__,
										    const_aggregation_Movement_lv,
										    const_aggregation_Movement_av,
										    const_aggregation_Movement_MB,
										    const_aggregation_Movement_alpha) = 
								dbisim(let
									Inactive 	= share__choice(enter -> SKIP [] terminate -> SKIP) ; Active
									
									Termination = terminate -> SKIP
									
									Active 		= true&CALL__move(
												id__,
											    const_aggregation_Movement_lv,
											    const_aggregation_Movement_av,
											    const_aggregation_Movement_MB,
											    const_aggregation_Movement_alpha,
												0,
												const_aggregation_Movement_av
											);SHARE_WAIT(Mathematics_floor(Div(180, no_zero_div(const_aggregation_Movement_av), core_real))) ; 
											 	  Behaviour ; 
											 	  share__choice(exit -> SKIP) ; SKIP ; 
											 	  share__choice(exited -> SKIP) ; Inactive
								
									Behaviour 	= entered -> During
									During 		= ((SKIP ; SStop) /\ interrupt -> SKIP)
								within
									Inactive [| {terminate} |> SKIP)
								
								
								-- Clocks
								
								StateClocks(id__,
										          const_aggregation_Movement_lv,
										          const_aggregation_Movement_av,
										          const_aggregation_Movement_MB,
										          const_aggregation_Movement_alpha) = terminate -> SKIP
								
								stateClockSync = {||}
							}
						
						endmodule
						----------------------------------------------------------------------
						
						
						----------------------------------------------------------------------
						-- State: RandomTurn
						module RandomTurn
						
						enterSS = {}
						
						enteredSS = {}
						
						exports
						
							--  Declarations
							
							channel enter, entered, interrupt
							channel enteredL, enteredR
							
											
							
							--channel increment__
							
							
							--	Nodes
							-- declaring all nodes
							
							
							Timed(OneStep) {
								--	Rule: behaviours(Node)
								--  Note that FDR has problems with efficiently compiling the process below
								-- 	if using a different recursion pattern.
								D__(id__,
										    const_aggregation_Movement_lv,
										    const_aggregation_Movement_av,
										    const_aggregation_Movement_MB,
										    const_aggregation_Movement_alpha) = 
								dbisim(let
									-- IMPLEMENTATION NOTE: 
									-- The following should be defined as: Inactive = share__choice(Activation [] Termination),
									-- however FDR struggles with that form in certain cases. So we use the exception operator
									-- instead to 'terminate'.
									
									Inactive 	= share__choice(enter -> SKIP [] terminate -> SKIP) ; Active
									
									Termination = terminate -> SKIP
									
									Active 		= true&CALL__move(
												id__,
											    const_aggregation_Movement_lv,
											    const_aggregation_Movement_av,
											    const_aggregation_Movement_MB,
											    const_aggregation_Movement_alpha,
												0,
												const_aggregation_Movement_av
											);SHARE_WAIT(Mathematics_floor(Div(Mult(Mathematics_random(), 360, core_real), no_zero_div(const_aggregation_Movement_av), core_real))) ; 
											 	  Behaviour ; 
											 	  share__choice(exit -> SKIP) ; SKIP ; 
											 	  share__choice(exited -> SKIP) ; Inactive
								
									Behaviour 	= entered -> During
									During 		= ((SKIP ; SStop) /\ interrupt -> SKIP)
								within
									Inactive [| {terminate} |> SKIP)
									
								VS_O__(id__,
										    const_aggregation_Movement_lv,
										    const_aggregation_Movement_av,
										    const_aggregation_Movement_MB,
										    const_aggregation_Movement_alpha) = 
								dbisim(let
									Inactive 	= share__choice(enter -> SKIP [] terminate -> SKIP) ; Active
									
									Termination = terminate -> SKIP
									
									Active 		= true&CALL__move(
												id__,
											    const_aggregation_Movement_lv,
											    const_aggregation_Movement_av,
											    const_aggregation_Movement_MB,
											    const_aggregation_Movement_alpha,
												0,
												const_aggregation_Movement_av
											);SHARE_WAIT(Mathematics_floor(Div(Mult(Mathematics_random(), 360, core_real), no_zero_div(const_aggregation_Movement_av), core_real))) ; 
											 	  Behaviour ; 
											 	  share__choice(exit -> SKIP) ; SKIP ; 
											 	  share__choice(exited -> SKIP) ; Inactive
								
									Behaviour 	= entered -> During
									During 		= ((SKIP ; SStop) /\ interrupt -> SKIP)
								within
									Inactive [| {terminate} |> SKIP)
								
								
								-- Clocks
								
								StateClocks(id__,
										          const_aggregation_Movement_lv,
										          const_aggregation_Movement_av,
										          const_aggregation_Movement_MB,
										          const_aggregation_Movement_alpha) = terminate -> SKIP
								
								stateClockSync = {||}
							}
						
						endmodule
						----------------------------------------------------------------------
						
						
						----------------------------------------------------------------------
						-- Final state: f1
						module f1
						
						exports
						
							channel enter, entered, interrupt
							channel enteredL, enteredR
							
							Timed(OneStep) {
								--	Rule: behaviours(Node)
								D__(id__,
										    const_aggregation_Movement_lv,
										    const_aggregation_Movement_av,
										    const_aggregation_Movement_MB,
										    const_aggregation_Movement_alpha) = 
									dbisim(let
										Inactive 	= share__choice(enter -> SKIP [] terminate -> SKIP) ; Entering
										
										Entering 	= entered -> SKIP ; Active
										Active		= share__choice(terminate -> SKIP [] interrupt -> SKIP) ; Interrupted
										Interrupted	= share__choice(exit -> exited -> Inactive)
									within
										Inactive [| {terminate} |> SKIP)
									
								VS_O__(id__,
										    const_aggregation_Movement_lv,
										    const_aggregation_Movement_av,
										    const_aggregation_Movement_MB,
										    const_aggregation_Movement_alpha) = D__(id__,
										    const_aggregation_Movement_lv,
										    const_aggregation_Movement_av,
										    const_aggregation_Movement_MB,
										    const_aggregation_Movement_alpha)
							}
						
						endmodule
						----------------------------------------------------------------------
						
						
						
						Timed(OneStep) {
							--	Rule: behaviours(Node)
							--  Note that FDR has problems with efficiently compiling the process below
							-- 	if using a different recursion pattern.
							D__(id__,
									    const_aggregation_Movement_lv,
									    const_aggregation_Movement_av,
									    const_aggregation_Movement_MB,
									    const_aggregation_Movement_alpha) = 
							dbisim(let
								-- IMPLEMENTATION NOTE: 
								-- The following should be defined as: Inactive = share__choice(Activation [] Termination),
								-- however FDR struggles with that form in certain cases. So we use the exception operator
								-- instead to 'terminate'.
								
								Inactive 	= share__choice(enter -> SKIP [] terminate -> SKIP) ; Active
								
								Termination = terminate -> SKIP
								
								Active 		= true&(share__choice(neighbours.in?n -> (SStop /\ set_n!n -> SKIP)));share__choice(true & (share__choice(set_turned!false -> SKIP))) ; 
										 	  Behaviour ; 
										 	  share__choice(exit -> SKIP) ; SKIP ; 
										 	  share__choice(exited -> SKIP) ; Inactive
							
							
								Behaviour 	= dbisim(
									((
									 (((dbisim(
									 	sbisim(
									 		dbisim(
									 			sbisim(
									 				(let
									 					-- IMPLEMENTATION NOTE:
									 					-- Here the 'enter' channel set is calculated explicitly because of the use of CSPM 
									 					-- modules for defining the semantics of each node.
									 					enterSS = {|
									 					i1::enter,
									 					j1::enter,
									 					Turn180::enter,
									 					RandomTurn::enter,
									 					f1::enter
									 					|}
									 					hideSet = union(enterSS,{|exit,exited,internal__|})
									 				within 
									 					((let
									 						-- IMPLEMENTATION NOTE: the channel set 'enter' is calculated explicitly
									 						-- because CSPM modules are used for the semantics of Node.
									 						flowevts = union(enterSS,{|exit,exited,interrupt|})
									 						transSync = {|internal__.NID_i1,internal__.NID_j1,internal__.NID_j1,internal__.NID_Turn180,internal__.NID_RandomTurn|}
									 					within
									 						((
									 						 (((-- RULE composeNodes(nc:NodeContainer)^nops : CSPProcess
									 						   i1::D__(id__,
									 						   		    const_aggregation_Movement_lv,
									 						   		    const_aggregation_Movement_av,
									 						   		    const_aggregation_Movement_MB,
									 						   		    const_aggregation_Movement_alpha)
									 						   [| { share__, terminate } |] (
									 						   j1::D__(id__,
									 						   		    const_aggregation_Movement_lv,
