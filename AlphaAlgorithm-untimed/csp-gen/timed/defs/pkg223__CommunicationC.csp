					Memory(id__)
				)
				\ union(
					{|
					|},
					{|
					|}
				)
				[|{|terminate|}|>SKIP
				,<visibleMemoryEvents,{tock}>)
				
				-- VS version
				VS__(id__,
						    const_pkg223__CommunicationC_stm_ref0_id,
						    const_pkg223__CommunicationC_stm_ref0_RC) = prioritise(	((
						let
							const_pkg223__Communication_id = const_pkg223__CommunicationC_stm_ref0_id
							const_pkg223__Communication_RC = const_pkg223__CommunicationC_stm_ref0_RC
						within 
