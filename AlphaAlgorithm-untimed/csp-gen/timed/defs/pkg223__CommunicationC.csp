					Memory(id__)
				)
				\ union(
					{|
					|},
					{|
					|}
				)
				[|{|terminate|}|>SKIP
				,<visibleMemoryEvents,{tock}>)
			
				-- O version (optimised) THESE TWO PROCESSES SHOULD BE KEPT IN SYNC WITH THE ABOVE TWO
				O__(id__,
						    const_pkg223__CommunicationC_stm_ref0_id,
						    const_pkg223__CommunicationC_stm_ref0_RC) = dbisim(prioritise(	((
						let
							const_pkg223__Communication_id = const_pkg223__CommunicationC_stm_ref0_id
							const_pkg223__Communication_RC = const_pkg223__CommunicationC_stm_ref0_RC
						within 
						stm_ref0::O__(id__,
								    const_pkg223__Communication_id,
								    const_pkg223__Communication_RC)[[
							stm_ref0::terminate <- terminate,
							stm_ref0::robots <- robots,
							stm_ref0::receive <- receive,
							stm_ref0::broadcast <- broadcast
