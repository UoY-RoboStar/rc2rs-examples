							    const_pkg223__normal_Communication_Broadcast_entry_id))
					[[
						OP_normal_Communication_Broadcast_entry::broadcast <- broadcast
					]]
					CALL__clone_normal_Communication_Receive_t3_op(id__,
							    const_pkg223__Communication_id,
							    const_pkg223__Communication_RC,
							    const_pkg223__clone_normal_Communication_Receive_t3_op_id) = (OP_clone_normal_Communication_Receive_t3_op::O__(id__,
							    const_pkg223__clone_normal_Communication_Receive_t3_op_id))
					[[
						OP_clone_normal_Communication_Receive_t3_op::receive <- receive
