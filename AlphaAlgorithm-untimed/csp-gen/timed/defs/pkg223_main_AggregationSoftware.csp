					]]
					CALL__normal_Communication_Receive_t5_op(id__,
							    const_pkg223__Communication_id,
							    const_pkg223__Communication_RC) = (OP_normal_Communication_Receive_t5_op::O__(id__))
					[[
						OP_normal_Communication_Receive_t5_op::robots <- robots
					]]
					[[
						OP_normal_Communication_Receive_t5_op::get_neighs <- get_neighs,
						OP_normal_Communication_Receive_t5_op::set_neighs <- set_neighs
