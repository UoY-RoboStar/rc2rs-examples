									 [| union(union(enteredSS,{| interrupt, terminate |}),{|share__
									 			,setL_y
									 			,setL_neighs
									 			,clockResetL.CLID_RCC
									 			,setL_x
									 			,setR_y
									 			 			,setR_neighs
									 			 			,clockResetR.CLID_RCC
									 			 			,setR_x
									 			|}) |]
									 ((During)
									  [[ share__ <- x__ | x__ <- {| share__,setL_y,setL_neighs,clockResetL.CLID_RCC,setL_x |} ]]
									  [[set_y <- setR_y,set_neighs <- setR_neighs,clockReset.CLID_RCC <- clockResetR.CLID_RCC,set_x <- setR_x]]
									 )
									)[[setL_y <- set_y,setL_neighs <- set_neighs,clockResetL.CLID_RCC <- clockReset.CLID_RCC,setL_x <- set_x]]
									 [[setR_y <- set_y,setR_neighs <- set_neighs,clockResetR.CLID_RCC <- clockReset.CLID_RCC,setR_x <- set_x]]
									)\{terminate} 
								)
								During 		= share__choice(([] e__ : enteredSS @ e__ -> SKIP))
										 	  ; entered -> ((CRUN(enteredSS) ||| SKIP ; SStop) /\ interrupt -> share__choice(terminate -> SKIP))
							within
								Inactive [| {terminate} |> SKIP)
							
							Transitions(id__,
									    const_pkg223__Communication_id,
									    const_pkg223__Communication_RC) = ((let
								Trans = TimeOut_1(
									 (share__ -> SKIP
									 [] dbisim((true)&(internal__!NID_i -> SKIP ;  ((SKIP ; EmptyCycle::enter -> SKIP))))
									 []
									 (interrupt -> share__choice(exit -> SKIP) ; share__choice(exited -> terminate -> SKIP))
									 []
									 terminate -> SKIP
									 )
								,SKIP);Trans
							within
								Trans [|{terminate}|> SKIP
							)
							)
							
							
							-- Clocks
							Clock_CLID_EmptyCycle(id__,x__,
									          const_pkg223__Communication_id,
									          const_pkg223__Communication_RC) = 
								TimeOut_1(
									EmptyCycle::entered -> Clock_CLID_EmptyCycle(id__,0,
											          const_pkg223__Communication_id,
											          const_pkg223__Communication_RC)
									[]
									get_CLID_EmptyCycle!x__ -> Clock_CLID_EmptyCycle(id__,x__,
											          const_pkg223__Communication_id,
											          const_pkg223__Communication_RC)
									[]
									terminate -> SKIP,Clock_CLID_EmptyCycle(id__,clock_type_plus(x__,1,CLID_EmptyCycle_clock_type(id__,
											          const_pkg223__Communication_id,
											          const_pkg223__Communication_RC)),
											          const_pkg223__Communication_id,
											          const_pkg223__Communication_RC))
							
							StateClocks(id__,
									          const_pkg223__Communication_id,
									          const_pkg223__Communication_RC) = dbisim(Clock_CLID_EmptyCycle(id__,0,
									          const_pkg223__Communication_id,
									          const_pkg223__Communication_RC))
							
							stateClockSync = {|get_CLID_EmptyCycle,EmptyCycle::entered|}
						}
					
					endmodule
					----------------------------------------------------------------------
					
					
					----------------------------------------------------------------------
					-- State: Receive
					module Receive
					
					enterSS = 
							{|			i::enter,
								EmptyCycle::enter
							|}
					enteredSS = 
							{|			EmptyCycle::entered
							|}
					exports
					
						--  Declarations
						
						channel enter, entered, interrupt
						channel enteredL, enteredR
						
										
						-- declaring identifiers of transitions
						datatype NIDS = 
						              NID_i|
						              NID_EmptyCycle
						
						channel internal__ : NIDS
						channel broadcast__: NIDS.InOut.main_ID
						channel receive__: NIDS.InOut.{(x0__,x1__) | x0__ <- main_ID,x1__ <- main_ID}
						channel robots__: NIDS.InOut.core_nat
						
						channel get_CLID_EmptyCycle : core_clock_type 
						--channel increment__
						
						CLID_EmptyCycle_clock_type(id__,
								          const_pkg223__Communication_id,
								          const_pkg223__Communication_RC) = 
							let
								max = (clock_type_max(Union({
						}))+1)
							ctype = {0..max}
						within
							if member(max,core_clock_type) then ctype else error("core_clock_type is not wide enough")
						
						
						--	Nodes
						-- declaring all nodes
						
						----------------------------------------------------------------------
						-- Initial: i
						module i
						exports
						
							channel enter, interrupt
							
							Timed(OneStep) {
								D__(id__,
										    const_pkg223__Communication_id,
										    const_pkg223__Communication_RC) = 
									dbisim(let
										Inactive 	= share__choice(enter -> SKIP [] terminate -> SKIP) ; Active
										
										Termination = terminate -> SKIP
										
										Active 		= share__choice(interrupt -> SKIP) ; Inactive
									within
										Inactive [| {terminate} |> SKIP)
								
								VS_O__(id__,
										    const_pkg223__Communication_id,
										    const_pkg223__Communication_RC) = D__(id__,
										    const_pkg223__Communication_id,
										    const_pkg223__Communication_RC)
							}
						
						endmodule
						----------------------------------------------------------------------
						
						
						----------------------------------------------------------------------
						-- State: EmptyCycle
						module EmptyCycle
						
						enterSS = {}
						
						enteredSS = {}
						
						exports
						
							--  Declarations
							
							channel enter, entered, interrupt
							channel enteredL, enteredR
							
											
							
							--channel increment__
							
							
							--	Nodes
							-- declaring all nodes
							
							
							Timed(OneStep) {
								--	Rule: behaviours(Node)
								--  Note that FDR has problems with efficiently compiling the process below
								-- 	if using a different recursion pattern.
								D__(id__,
										    const_pkg223__Communication_id,
										    const_pkg223__Communication_RC) = 
								dbisim(let
									-- IMPLEMENTATION NOTE: 
									-- The following should be defined as: Inactive = share__choice(Activation [] Termination),
									-- however FDR struggles with that form in certain cases. So we use the exception operator
									-- instead to 'terminate'.
									
									Inactive 	= share__choice(enter -> SKIP [] terminate -> SKIP) ; Active
									
									Termination = terminate -> SKIP
									
									Active 		= SKIP ; 
											 	  Behaviour ; 
											 	  share__choice(exit -> SKIP) ; SKIP ; 
											 	  share__choice(exited -> SKIP) ; Inactive
								
									Behaviour 	= entered -> During
									During 		= ((SKIP ; SStop) /\ interrupt -> SKIP)
								within
									Inactive [| {terminate} |> SKIP)
									
								VS_O__(id__,
										    const_pkg223__Communication_id,
										    const_pkg223__Communication_RC) = 
								dbisim(let
									Inactive 	= share__choice(enter -> SKIP [] terminate -> SKIP) ; Active
									
									Termination = terminate -> SKIP
									
									Active 		= SKIP ; 
											 	  Behaviour ; 
											 	  share__choice(exit -> SKIP) ; SKIP ; 
											 	  share__choice(exited -> SKIP) ; Inactive
								
									Behaviour 	= entered -> During
									During 		= ((SKIP ; SStop) /\ interrupt -> SKIP)
								within
									Inactive [| {terminate} |> SKIP)
								
								
								-- Clocks
								
								StateClocks(id__,
										          const_pkg223__Communication_id,
										          const_pkg223__Communication_RC) = terminate -> SKIP
								
								stateClockSync = {||}
							}
						
						endmodule
						----------------------------------------------------------------------
						
						
						
						Timed(OneStep) {
							--	Rule: behaviours(Node)
							--  Note that FDR has problems with efficiently compiling the process below
							-- 	if using a different recursion pattern.
							D__(id__,
									    const_pkg223__Communication_id,
									    const_pkg223__Communication_RC) = 
							dbisim(let
								-- IMPLEMENTATION NOTE: 
								-- The following should be defined as: Inactive = share__choice(Activation [] Termination),
								-- however FDR struggles with that form in certain cases. So we use the exception operator
								-- instead to 'terminate'.
								
								Inactive 	= share__choice(enter -> SKIP [] terminate -> SKIP) ; Active
								
								Termination = terminate -> SKIP
								
								Active 		= SKIP ; 
										 	  Behaviour ; 
										 	  share__choice(exit -> SKIP) ; SKIP ; 
										 	  share__choice(exited -> SKIP) ; Inactive
							
							
								Behaviour 	= dbisim(
									((
									 (((dbisim(
									 	sbisim(
									 		(let
									 			-- IMPLEMENTATION NOTE:
									 			-- Here the 'enter' channel set is calculated explicitly because of the use of CSPM 
									 			-- modules for defining the semantics of each node.
									 			enterSS = {|
									 			i::enter,
									 			EmptyCycle::enter
									 			|}
									 			hideSet = union(enterSS,{|exit,exited,internal__|})
									 		within 
									 			((let
									 				-- IMPLEMENTATION NOTE: the channel set 'enter' is calculated explicitly
									 				-- because CSPM modules are used for the semantics of Node.
									 				flowevts = union(enterSS,{|exit,exited,interrupt|})
									 				transSync = {|internal__.NID_i|}
									 			within
									 				((
									 				 (((-- RULE composeNodes(nc:NodeContainer)^nops : CSPProcess
									 				   i::D__(id__,
									 				   		    const_pkg223__Communication_id,
									 				   		    const_pkg223__Communication_RC)
									 				   [| { share__, terminate } |] (
									 				   EmptyCycle::D__(id__,
									 				   		    const_pkg223__Communication_id,
									 				   		    const_pkg223__Communication_RC)
									 				   )
									 				 )
									 				 [[EmptyCycle::interrupt <- x__ | x__ <- {|interrupt|}]]
									 				 [[i::interrupt <- x__ | x__ <- {|internal__.NID_i|}]]
									 				 )
									 				  [[ share__ <- x__ | x__ <- {| share__ |} ]] 
									 				 )
									 				 [| union(union(union(flowevts,transSync),{terminate}),{|share__
									 				|}) |]
									 				 ((i::enter -> Transitions(id__,
									 				 		    const_pkg223__Communication_id,
									 				 		    const_pkg223__Communication_RC))
									 				  [[ share__ <- x__ | x__ <- {| share__ |} ]]
									 				 )
									 				)
									 				)
									 			)
									 			 \ hideSet)
									 			[[
									 				broadcast__.x____ <- broadcast,
									 				receive__.x____ <- receive,
									 				robots__.x____ <- robots
									 				| x____ <- NIDS
									 			]]
									 		)
									 		[| {|get_CLID_EmptyCycle,EmptyCycle::entered,terminate|} |]
									 		dbisim(Clock_CLID_EmptyCycle(id__,0,
									 				          const_pkg223__Communication_id,
									 				          const_pkg223__Communication_RC))
									 	)\{|get_CLID_EmptyCycle|}
									 )
									 ))
									  [[ share__ <- x__ | x__ <- {| share__,setR_y,setR_neighs,clockResetR.CLID_RCC,setR_x |} ]] 
									  [[set_y <- setL_y,set_neighs <- setL_neighs,clockReset.CLID_RCC <- clockResetL.CLID_RCC,set_x <- setL_x]]
									 )
									 [| union(union(enteredSS,{| interrupt, terminate |}),{|share__
									 			,setL_y
									 			,setL_neighs
									 			,clockResetL.CLID_RCC
									 			,setL_x
									 			,setR_y
									 			 			,setR_neighs
									 			 			,clockResetR.CLID_RCC
									 			 			,setR_x
									 			|}) |]
									 ((During)
									  [[ share__ <- x__ | x__ <- {| share__,setL_y,setL_neighs,clockResetL.CLID_RCC,setL_x |} ]]
									  [[set_y <- setR_y,set_neighs <- setR_neighs,clockReset.CLID_RCC <- clockResetR.CLID_RCC,set_x <- setR_x]]
									 )
									)[[setL_y <- set_y,setL_neighs <- set_neighs,clockResetL.CLID_RCC <- clockReset.CLID_RCC,setL_x <- set_x]]
									 [[setR_y <- set_y,setR_neighs <- set_neighs,clockResetR.CLID_RCC <- clockReset.CLID_RCC,setR_x <- set_x]]
									)\union(enteredSS,{terminate}) 
								)
								During 		= share__choice(([] e__ : enteredSS @ e__ -> SKIP))
										 	  ; entered -> ((CRUN(enteredSS) ||| SKIP ; SStop) /\ interrupt -> share__choice(terminate -> SKIP))
							within
								Inactive [| {terminate} |> SKIP)
								
							VS_O__(id__,
									    const_pkg223__Communication_id,
									    const_pkg223__Communication_RC) = 
							dbisim(let
								Inactive 	= share__choice(enter -> SKIP [] terminate -> SKIP) ; Active
								
								Termination = terminate -> SKIP
								
								Active 		= SKIP ; 
										 	  Behaviour ; 
										 	  share__choice(exit -> SKIP) ; SKIP ; 
										 	  share__choice(exited -> SKIP) ; Inactive
							
							
								Behaviour 	= dbisim(
									((
									 (((dbisim(
									 	sbisim(
									 		(let
									 			-- IMPLEMENTATION NOTE:
									 			-- Here the 'enter' channel set is calculated explicitly because of the use of CSPM 
									 			-- modules for defining the semantics of each node.
									 			enterSS = {|
									 			i::enter,
									 			EmptyCycle::enter
									 			|}
									 			hideSet = union(enterSS,{|exit,exited,internal__|})
									 		within 
									 			((let
									 				-- IMPLEMENTATION NOTE: the channel set 'enter' is calculated explicitly
									 				-- because CSPM modules are used for the semantics of Node.
									 				flowevts = union(enterSS,{|exit,exited,interrupt|})
									 				transSync = {|internal__.NID_i|}
									 			within
									 				((
									 				 (((-- RULE composeNodes(nc:NodeContainer)^nops : CSPProcess
									 				   i::VS_O__(id__,
									 				   		    const_pkg223__Communication_id,
									 				   		    const_pkg223__Communication_RC)
									 				   [| { share__, terminate } |] (
									 				   EmptyCycle::VS_O__(id__,
									 				   		    const_pkg223__Communication_id,
									 				   		    const_pkg223__Communication_RC)
									 				   )
									 				 )
									 				 [[EmptyCycle::interrupt <- x__ | x__ <- {|interrupt|}]]
									 				 [[i::interrupt <- x__ | x__ <- {|internal__.NID_i|}]]
									 				 )
									 				  [[ share__ <- x__ | x__ <- {| share__ |} ]] 
									 				 )
									 				 [| union(union(union(flowevts,transSync),{terminate}),{|share__
									 				|}) |]
									 				 ((i::enter -> Transitions(id__,
									 				 		    const_pkg223__Communication_id,
									 				 		    const_pkg223__Communication_RC))
									 				  [[ share__ <- x__ | x__ <- {| share__ |} ]]
									 				 )
									 				)
									 				)
									 			)
									 			 \ hideSet)
									 			[[
									 				broadcast__.x____ <- broadcast,
									 				receive__.x____ <- receive,
									 				robots__.x____ <- robots
									 				| x____ <- NIDS
									 			]]
									 		)
									 		[| {|get_CLID_EmptyCycle,EmptyCycle::entered,terminate|} |]
									 		dbisim(Clock_CLID_EmptyCycle(id__,0,
									 				          const_pkg223__Communication_id,
									 				          const_pkg223__Communication_RC))
									 	)\{|get_CLID_EmptyCycle|}
									 )
									 ))
									  [[ share__ <- x__ | x__ <- {| share__,setR_y,setR_neighs,clockResetR.CLID_RCC,setR_x |} ]] 
									  [[set_y <- setL_y,set_neighs <- setL_neighs,clockReset.CLID_RCC <- clockResetL.CLID_RCC,set_x <- setL_x]]
									 )
									 [| union(union(enteredSS,{| interrupt, terminate |}),{|share__
									 			,setL_y
									 			,setL_neighs
									 			,clockResetL.CLID_RCC
									 			,setL_x
									 			,setR_y
									 			 			,setR_neighs
									 			 			,clockResetR.CLID_RCC
									 			 			,setR_x
									 			|}) |]
									 ((During)
									  [[ share__ <- x__ | x__ <- {| share__,setL_y,setL_neighs,clockResetL.CLID_RCC,setL_x |} ]]
									  [[set_y <- setR_y,set_neighs <- setR_neighs,clockReset.CLID_RCC <- clockResetR.CLID_RCC,set_x <- setR_x]]
									 )
									)[[setL_y <- set_y,setL_neighs <- set_neighs,clockResetL.CLID_RCC <- clockReset.CLID_RCC,setL_x <- set_x]]
									 [[setR_y <- set_y,setR_neighs <- set_neighs,clockResetR.CLID_RCC <- clockReset.CLID_RCC,setR_x <- set_x]]
									)\{terminate} 
								)
								During 		= share__choice(([] e__ : enteredSS @ e__ -> SKIP))
										 	  ; entered -> ((CRUN(enteredSS) ||| SKIP ; SStop) /\ interrupt -> share__choice(terminate -> SKIP))
							within
								Inactive [| {terminate} |> SKIP)
							
							Transitions(id__,
									    const_pkg223__Communication_id,
									    const_pkg223__Communication_RC) = ((let
								Trans = TimeOut_1(
									 (share__ -> SKIP
									 [] dbisim((true)&(internal__!NID_i -> SKIP ;  ((SKIP ; EmptyCycle::enter -> SKIP))))
									 []
									 (interrupt -> share__choice(exit -> SKIP) ; share__choice(exited -> terminate -> SKIP))
									 []
									 terminate -> SKIP
									 )
								,SKIP);Trans
							within
								Trans [|{terminate}|> SKIP
							)
							)
							
							
							-- Clocks
							Clock_CLID_EmptyCycle(id__,x__,
									          const_pkg223__Communication_id,
									          const_pkg223__Communication_RC) = 
								TimeOut_1(
									EmptyCycle::entered -> Clock_CLID_EmptyCycle(id__,0,
											          const_pkg223__Communication_id,
											          const_pkg223__Communication_RC)
									[]
									get_CLID_EmptyCycle!x__ -> Clock_CLID_EmptyCycle(id__,x__,
											          const_pkg223__Communication_id,
											          const_pkg223__Communication_RC)
									[]
									terminate -> SKIP,Clock_CLID_EmptyCycle(id__,clock_type_plus(x__,1,CLID_EmptyCycle_clock_type(id__,
											          const_pkg223__Communication_id,
											          const_pkg223__Communication_RC)),
											          const_pkg223__Communication_id,
											          const_pkg223__Communication_RC))
							
							StateClocks(id__,
									          const_pkg223__Communication_id,
									          const_pkg223__Communication_RC) = dbisim(Clock_CLID_EmptyCycle(id__,0,
									          const_pkg223__Communication_id,
									          const_pkg223__Communication_RC))
							
							stateClockSync = {|get_CLID_EmptyCycle,EmptyCycle::entered|}
						}
					
					endmodule
					----------------------------------------------------------------------
					
					-- END of Nodes --
					
					Timed(OneStep) {
					-- Operation calls --
					-- Only the undefined operations are declared here.
					-- If the state machine is in isolation, all required operations will be undefined.
					-- If it is in the context of a controller, the required operations not provided by the
					-- controller will be declared here, and the defined operations will be defined in the
					-- context of the Controller module, and therefore within scope of the state machine module.
					
					CALL__normal_Communication_Receive_t2_op(id__,
							    const_pkg223__Communication_id,
							    const_pkg223__Communication_RC) = (OP_normal_Communication_Receive_t2_op::O__(id__))
					[[
						OP_normal_Communication_Receive_t2_op::get_x <- get_x,
						OP_normal_Communication_Receive_t2_op::set_x <- set_x,
						OP_normal_Communication_Receive_t2_op::get_neighs <- get_neighs,
						OP_normal_Communication_Receive_t2_op::set_neighs <- set_neighs
					]]
					CALL__normal_Communication_Receive_t3_op(id__,
							    const_pkg223__Communication_id,
							    const_pkg223__Communication_RC,
							    const_pkg223__normal_Communication_Receive_t3_op_id) = (OP_normal_Communication_Receive_t3_op::O__(id__,
							    const_pkg223__normal_Communication_Receive_t3_op_id))
					[[
						OP_normal_Communication_Receive_t3_op::receive <- receive
					]]
					[[
						OP_normal_Communication_Receive_t3_op::get_y <- get_y,
						OP_normal_Communication_Receive_t3_op::set_y <- set_y
					]]
					CALL__clone_normal_Communication_Receive_t5_op(id__,
							    const_pkg223__Communication_id,
							    const_pkg223__Communication_RC) = (OP_clone_normal_Communication_Receive_t5_op::O__(id__))
					[[
						OP_clone_normal_Communication_Receive_t5_op::robots <- robots
					]]
					[[
						OP_clone_normal_Communication_Receive_t5_op::get_neighs <- get_neighs,
						OP_clone_normal_Communication_Receive_t5_op::set_neighs <- set_neighs
					]]
					CALL__clone_normal_Communication_Broadcast_entry(id__,
							    const_pkg223__Communication_id,
							    const_pkg223__Communication_RC,
							    const_pkg223__clone_normal_Communication_Broadcast_entry_id) = (OP_clone_normal_Communication_Broadcast_entry::O__(id__,
							    const_pkg223__clone_normal_Communication_Broadcast_entry_id))
					[[
						OP_clone_normal_Communication_Broadcast_entry::broadcast <- broadcast
