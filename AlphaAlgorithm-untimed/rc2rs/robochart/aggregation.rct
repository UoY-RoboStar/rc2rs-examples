	clone_normal_Movement_Turning_RandomTurn_t5_op ( )
}

interface I_clone_normal_Movement_MovementAndAvoidance_Avoid_entry {
	clone_normal_Movement_MovementAndAvoidance_Avoid_entry ( )
}

