package pkg223_aggregation 
import Mathematics::floor import main::Position import Mathematics::random interface MovingHw {
	move ( l : real , a : real )
}

interface ObstacleHw { 
	event obstacle : Position
}

interface SensingHw {
	event neighbours : nat
}
 
