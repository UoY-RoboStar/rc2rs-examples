	}
	clock C
}

operation clone_normal_Movement_Turning_entry_j_2_2_t_2_2_op_j_2_2_f ( ) {
	requires I_req_normal_Movement_Turning_entry_j_2_2_t_2_2 initial i
	final f
	transition t {
		from i
		to f
		action turned = false
	}
}

