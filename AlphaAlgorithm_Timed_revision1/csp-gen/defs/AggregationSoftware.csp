								 [[MovementAndAvoidance::interrupt <- x__ | x__ <- {|interrupt,internal__.NID_MovementAndAvoidance|}]]
								 [[Turning::interrupt <- x__ | x__ <- {|interrupt,internal__.NID_Turning|}]]
								 [[i1::interrupt <- x__ | x__ <- {|internal__.NID_i1|}]]
								 )
								  [[ share__ <- x__ | x__ <- {| share__ |} ]] 
								  [[set_turned <- setL_turned]]
								 )
								 [| union(union(union(flowevts,transSync),{terminate}),{|share__
								 			,setL_turned
								|}) |]
								 ((i1::enter -> Transitions(id__,
								 		    const_Movement_lv,
								 		    const_Movement_av,
								 		    const_Movement_MB,
								 		    const_Movement_alpha))
								  [[ share__ <- x__ | x__ <- {| share__,setL_turned |} ]]
