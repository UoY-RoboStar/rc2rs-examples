				HEXT(id__,
						    const_CommunicationC_stm_ref0_id,
						    const_CommunicationC_stm_ref0_RC) = O__(id__,
						    const_CommunicationC_stm_ref0_id,
						    const_CommunicationC_stm_ref0_RC) [|shared_variable_events|] SKIP			
	
		endmodule
	
	-- declaring module memory
	Memory(id__) = SKIP
	
	D__(id__,
			    const_MovementC_stm_ref0_lv,
			    const_MovementC_stm_ref0_av,
			    const_MovementC_stm_ref0_MB,
			    const_MovementC_stm_ref0_alpha,
			    const_CommunicationC_stm_ref0_id,
			    const_CommunicationC_stm_ref0_RC) = let
		Buffer0(<v>) = 
			ctrl_ref1::robots.out?x -> Buffer0(<x>)
			[]
			ctrl_ref0::neighbours.in!v -> Buffer0(<>)
		Buffer0(<>) = ctrl_ref1::robots.out?x -> Buffer0(<x>)
		
	within
		(
			(
				(Buffer0(<>)
				)
					[|{|ctrl_ref0::neighbours,ctrl_ref1::robots|}|]
				(
					(
						(
							ctrl_ref0::D__(id__,
									    const_MovementC_stm_ref0_lv,
									    const_MovementC_stm_ref0_av,
									    const_MovementC_stm_ref0_MB,
									    const_MovementC_stm_ref0_alpha)[[
								ctrl_ref0::terminate <- terminate,
								ctrl_ref0::obstacle <- obstacle,
								ctrl_ref0::moveCall <- moveCall
							]]
						)
							[|{|terminate|}|]
						(
							ctrl_ref1::D__(id__,
									    const_CommunicationC_stm_ref0_id,
