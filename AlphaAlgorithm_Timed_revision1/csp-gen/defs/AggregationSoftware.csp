					dbisim(Memory(id__))
				)
				\ union(
					{|
					|},
					{|
					|}
				)
				[|{|terminate|}|>SKIP
				))
								
				-- VS_O version
				VS_O__(id__,
						    const_CommunicationC_stm_ref0_id,
						    const_CommunicationC_stm_ref0_RC) = sbisim(diamond(	((
						let
							const_Communication_id = const_CommunicationC_stm_ref0_id
							const_Communication_RC = const_CommunicationC_stm_ref0_RC
						within 
						stm_ref0::VS_O__(id__,
								    const_Communication_id,
								    const_Communication_RC)[[
							stm_ref0::terminate <- terminate,
							stm_ref0::robots <- robots,
							stm_ref0::receive <- receive,
