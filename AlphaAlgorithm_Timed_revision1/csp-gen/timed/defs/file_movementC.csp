								 						 		    const_Movement_av,
								 						 		    const_Movement_MB,
								 						 		    const_Movement_alpha))
								 						  [[ share__ <- x__ | x__ <- {| share__,clockResetL.CLID_MBC |} ]]
								 						  [[set_p <- setR_p]]
								 						 )
								 						)[[clockResetL.CLID_MBC <- clockReset.CLID_MBC]]
								 						 [[setR_p <- set_p]]
								 						)
								 					)
								 					 \ hideSet)
								 					[[
								 						obstacle__.x____ <- obstacle,
								 						neighbours__.x____ <- neighbours
								 						| x____ <- NIDS
								 					]]
								 				)
								 				[| {|get_CLID_Move,Move::entered,terminate|} |]
								 				dbisim(Clock_CLID_Move(id__,0,
								 						          const_Movement_lv,
								 						          const_Movement_av,
								 						          const_Movement_MB,
								 						          const_Movement_alpha))
								 			)\{|get_CLID_Move|}
								 		)
								 		[| {|get_CLID_Avoid,Avoid::entered,terminate|} |]
								 		dbisim(Clock_CLID_Avoid(id__,0,
								 				          const_Movement_lv,
								 				          const_Movement_av,
								 				          const_Movement_MB,
								 				          const_Movement_alpha))
								 	)\{|get_CLID_Avoid|}
								 )
								 ))
								  [[ share__ <- x__ | x__ <- {| share__,setR_p,setR_n,setR_turned,clockResetR.CLID_MBC |} ]] 
								  [[set_p <- setL_p,set_n <- setL_n,set_turned <- setL_turned,clockReset.CLID_MBC <- clockResetL.CLID_MBC]]
								 )
								 [| union(union(enteredSS,{| interrupt, terminate |}),{|share__
								 			,setL_p
								 			,setL_n
								 			,setL_turned
								 			,clockResetL.CLID_MBC
								 			,setR_p
								 			 			,setR_n
								 			 			,setR_turned
								 			 			,clockResetR.CLID_MBC
								 			|}) |]
								 ((During)
								  [[ share__ <- x__ | x__ <- {| share__,setL_p,setL_n,setL_turned,clockResetL.CLID_MBC |} ]]
								  [[set_p <- setR_p,set_n <- setR_n,set_turned <- setR_turned,clockReset.CLID_MBC <- clockResetR.CLID_MBC]]
								 )
								)[[setL_p <- set_p,setL_n <- set_n,setL_turned <- set_turned,clockResetL.CLID_MBC <- clockReset.CLID_MBC]]
								 [[setR_p <- set_p,setR_n <- set_n,setR_turned <- set_turned,clockResetR.CLID_MBC <- clockReset.CLID_MBC]]
								)\{terminate} 
							)
							During 		= share__choice(([] e__ : enteredSS @ e__ -> SKIP))
									 	  ; entered -> ((CRUN(enteredSS) ||| SKIP ; SStop) /\ interrupt -> share__choice(terminate -> SKIP))
						within
							Inactive [| {terminate} |> SKIP)
						
						Transitions(id__,
								    const_Movement_lv,
								    const_Movement_av,
								    const_Movement_MB,
								    const_Movement_alpha) = ((let
							Trans = share__choice(get_CLID_MBC?MBC -> TimeOut_1(
								 (share__ -> SKIP
								 [] dbisim((true)&(internal__!NID_i1 -> SKIP ;  ((SKIP ; Move::enter -> SKIP))))
								 [] dbisim((obstacle__!NID_Move.in?p:{p|p <- AggregationSoftware_Position, (MBC<(Minus(const_Movement_MB, Div(360, const_Movement_av, core_real), core_real)))} -> share__choice(set_p!p -> SKIP) ;  share__choice(exit -> SKIP) ; (share__choice(exited -> SKIP) ; SKIP ; Avoid::enter -> SKIP)))
								 [] dbisim((true)&(internal__!NID_Avoid -> SKIP ;  share__choice(exit -> SKIP) ; (share__choice(exited -> SKIP) ; SKIP ; Move::enter -> SKIP)))
								 []
								 (interrupt -> share__choice(exit -> SKIP) ; share__choice(exited -> terminate -> SKIP))
								 []
								 terminate -> SKIP
								 )
							,SKIP);Trans
							)
						within
							Trans [|{terminate}|> SKIP
						)
						)
						
						
						-- Clocks
						Clock_CLID_Avoid(id__,x__,
								          const_Movement_lv,
								          const_Movement_av,
								          const_Movement_MB,
								          const_Movement_alpha) = 
							TimeOut_1(
								Avoid::entered -> Clock_CLID_Avoid(id__,0,
										          const_Movement_lv,
										          const_Movement_av,
										          const_Movement_MB,
										          const_Movement_alpha)
								[]
								get_CLID_Avoid!x__ -> Clock_CLID_Avoid(id__,x__,
										          const_Movement_lv,
										          const_Movement_av,
										          const_Movement_MB,
										          const_Movement_alpha)
								[]
								terminate -> SKIP,Clock_CLID_Avoid(id__,clock_type_plus(x__,1,CLID_Avoid_clock_type(id__,
										          const_Movement_lv,
										          const_Movement_av,
										          const_Movement_MB,
										          const_Movement_alpha)),
										          const_Movement_lv,
										          const_Movement_av,
										          const_Movement_MB,
										          const_Movement_alpha))
						Clock_CLID_Move(id__,x__,
								          const_Movement_lv,
								          const_Movement_av,
								          const_Movement_MB,
								          const_Movement_alpha) = 
							TimeOut_1(
								Move::entered -> Clock_CLID_Move(id__,0,
										          const_Movement_lv,
										          const_Movement_av,
										          const_Movement_MB,
										          const_Movement_alpha)
								[]
								get_CLID_Move!x__ -> Clock_CLID_Move(id__,x__,
										          const_Movement_lv,
										          const_Movement_av,
										          const_Movement_MB,
										          const_Movement_alpha)
								[]
								terminate -> SKIP,Clock_CLID_Move(id__,clock_type_plus(x__,1,CLID_Move_clock_type(id__,
										          const_Movement_lv,
										          const_Movement_av,
										          const_Movement_MB,
										          const_Movement_alpha)),
										          const_Movement_lv,
										          const_Movement_av,
										          const_Movement_MB,
										          const_Movement_alpha))
						
						StateClocks(id__,
								          const_Movement_lv,
								          const_Movement_av,
								          const_Movement_MB,
								          const_Movement_alpha) = dbisim(Clock_CLID_Avoid(id__,0,
								          const_Movement_lv,
								          const_Movement_av,
								          const_Movement_MB,
								          const_Movement_alpha))
						[| { terminate } |] (
						dbisim(Clock_CLID_Move(id__,0,
								          const_Movement_lv,
								          const_Movement_av,
								          const_Movement_MB,
								          const_Movement_alpha))
						)
						
						stateClockSync = {|get_CLID_Avoid,Avoid::entered,get_CLID_Move,Move::entered|}
					}
				
				endmodule
				----------------------------------------------------------------------
				
				
				----------------------------------------------------------------------
				-- State: Turning
				module Turning
				
				enterSS = 
						{|			i1::enter,
							j1::enter,
							Turn180::enter,
							RandomTurn::enter,
							f1::enter
						|}
				enteredSS = 
						{|			Turn180::entered,
							RandomTurn::entered,
							f1::entered
						|}
				exports
				
					--  Declarations
					
					channel enter, entered, interrupt
					channel enteredL, enteredR
					
									
					-- declaring identifiers of transitions
					datatype NIDS = 
					              NID_i1|
					              NID_j1|
					              NID_Turn180|
					              NID_RandomTurn|
					              NID_f1
					
					channel internal__ : NIDS
					channel obstacle__: NIDS.InOut.AggregationSoftware_Position
					channel neighbours__: NIDS.InOut.core_nat
					
					channel get_CLID_RandomTurn : core_clock_type 
					channel get_CLID_Turn180 : core_clock_type 
					--channel increment__
					
					CLID_RandomTurn_clock_type(id__,
							          const_Movement_lv,
							          const_Movement_av,
							          const_Movement_MB,
							          const_Movement_alpha) = 
						let
							max = (clock_type_max(Union({
					{}
					}))+1)
						ctype = {0..max}
					within
						if member(max,core_clock_type) then ctype else error("core_clock_type is not wide enough")
					
					CLID_Turn180_clock_type(id__,
							          const_Movement_lv,
							          const_Movement_av,
							          const_Movement_MB,
							          const_Movement_alpha) = 
						let
							max = (clock_type_max(Union({
					{}
					}))+1)
						ctype = {0..max}
					within
						if member(max,core_clock_type) then ctype else error("core_clock_type is not wide enough")
					
					
					--	Nodes
					-- declaring all nodes
					
					----------------------------------------------------------------------
					-- Initial: i1
					module i1
					exports
					
						channel enter, interrupt
						
						Timed(OneStep) {
							D__(id__,
									    const_Movement_lv,
									    const_Movement_av,
									    const_Movement_MB,
									    const_Movement_alpha) = 
								dbisim(let
									Inactive 	= share__choice(enter -> SKIP [] terminate -> SKIP) ; Active
									
									Termination = terminate -> SKIP
									
									Active 		= share__choice(interrupt -> SKIP) ; Inactive
								within
									Inactive [| {terminate} |> SKIP)
							
							VS_O__(id__,
									    const_Movement_lv,
									    const_Movement_av,
									    const_Movement_MB,
									    const_Movement_alpha) = D__(id__,
									    const_Movement_lv,
									    const_Movement_av,
									    const_Movement_MB,
									    const_Movement_alpha)
						}
					
					endmodule
					----------------------------------------------------------------------
					
					
					----------------------------------------------------------------------
					-- Junction: j1
					module j1
					exports
					
						channel enter, interrupt
						
						Timed(OneStep) {
							D__(id__,
									    const_Movement_lv,
									    const_Movement_av,
									    const_Movement_MB,
									    const_Movement_alpha) = 
								dbisim(let
									Inactive 	= share__choice(enter -> SKIP [] terminate -> SKIP) ; Active
									
									Active 		= share__choice(interrupt -> SKIP) ; Inactive
								within
									Inactive [| {terminate} |> SKIP)
								
							VS_O__(id__,
									    const_Movement_lv,
									    const_Movement_av,
									    const_Movement_MB,
									    const_Movement_alpha) = D__(id__,
									    const_Movement_lv,
									    const_Movement_av,
									    const_Movement_MB,
									    const_Movement_alpha)
						}
					
					endmodule
					----------------------------------------------------------------------
					
					
					----------------------------------------------------------------------
					-- State: Turn180
					module Turn180
					
					enterSS = {}
					
					enteredSS = {}
					
					exports
					
						--  Declarations
						
						channel enter, entered, interrupt
						channel enteredL, enteredR
						
										
						
						--channel increment__
						
						
						--	Nodes
						-- declaring all nodes
						
						
						Timed(OneStep) {
							--	Rule: behaviours(Node)
							--  Note that FDR has problems with efficiently compiling the process below
							-- 	if using a different recursion pattern.
							D__(id__,
									    const_Movement_lv,
									    const_Movement_av,
									    const_Movement_MB,
									    const_Movement_alpha) = 
							dbisim(let
								-- IMPLEMENTATION NOTE: 
								-- The following should be defined as: Inactive = share__choice(Activation [] Termination),
								-- however FDR struggles with that form in certain cases. So we use the exception operator
								-- instead to 'terminate'.
								
								Inactive 	= share__choice(enter -> SKIP [] terminate -> SKIP) ; Active
								
								Termination = terminate -> SKIP
								
								Active 		= true&CALL__move(
											id__,
										    const_Movement_lv,
										    const_Movement_av,
										    const_Movement_MB,
										    const_Movement_alpha,
											0,
											const_Movement_av
										);SHARE_WAIT(Mathematics_floor(Div(180, no_zero_div(const_Movement_av), core_real))) ; 
										 	  Behaviour ; 
										 	  share__choice(exit -> SKIP) ; SKIP ; 
										 	  share__choice(exited -> SKIP) ; Inactive
							
								Behaviour 	= entered -> During
								During 		= ((SKIP ; SStop) /\ interrupt -> SKIP)
							within
								Inactive [| {terminate} |> SKIP)
								
							VS_O__(id__,
									    const_Movement_lv,
									    const_Movement_av,
									    const_Movement_MB,
									    const_Movement_alpha) = 
							dbisim(let
								Inactive 	= share__choice(enter -> SKIP [] terminate -> SKIP) ; Active
								
								Termination = terminate -> SKIP
								
								Active 		= true&CALL__move(
											id__,
										    const_Movement_lv,
										    const_Movement_av,
										    const_Movement_MB,
										    const_Movement_alpha,
											0,
											const_Movement_av
										);SHARE_WAIT(Mathematics_floor(Div(180, no_zero_div(const_Movement_av), core_real))) ; 
										 	  Behaviour ; 
										 	  share__choice(exit -> SKIP) ; SKIP ; 
										 	  share__choice(exited -> SKIP) ; Inactive
							
								Behaviour 	= entered -> During
								During 		= ((SKIP ; SStop) /\ interrupt -> SKIP)
							within
								Inactive [| {terminate} |> SKIP)
							
							
							-- Clocks
							
							StateClocks(id__,
									          const_Movement_lv,
									          const_Movement_av,
									          const_Movement_MB,
									          const_Movement_alpha) = terminate -> SKIP
							
							stateClockSync = {||}
						}
					
					endmodule
					----------------------------------------------------------------------
					
					
					----------------------------------------------------------------------
					-- State: RandomTurn
					module RandomTurn
					
					enterSS = {}
					
					enteredSS = {}
					
					exports
					
						--  Declarations
						
						channel enter, entered, interrupt
						channel enteredL, enteredR
						
										
						
						--channel increment__
						
						
						--	Nodes
						-- declaring all nodes
						
						
						Timed(OneStep) {
							--	Rule: behaviours(Node)
							--  Note that FDR has problems with efficiently compiling the process below
							-- 	if using a different recursion pattern.
							D__(id__,
									    const_Movement_lv,
									    const_Movement_av,
									    const_Movement_MB,
									    const_Movement_alpha) = 
							dbisim(let
								-- IMPLEMENTATION NOTE: 
								-- The following should be defined as: Inactive = share__choice(Activation [] Termination),
								-- however FDR struggles with that form in certain cases. So we use the exception operator
								-- instead to 'terminate'.
								
								Inactive 	= share__choice(enter -> SKIP [] terminate -> SKIP) ; Active
								
								Termination = terminate -> SKIP
								
								Active 		= true&CALL__move(
											id__,
										    const_Movement_lv,
										    const_Movement_av,
										    const_Movement_MB,
										    const_Movement_alpha,
											0,
											const_Movement_av
										);SHARE_WAIT(Mathematics_floor(Div(Mult(Mathematics_random(), 360, core_real), no_zero_div(const_Movement_av), core_real))) ; 
										 	  Behaviour ; 
										 	  share__choice(exit -> SKIP) ; SKIP ; 
										 	  share__choice(exited -> SKIP) ; Inactive
							
								Behaviour 	= entered -> During
								During 		= ((SKIP ; SStop) /\ interrupt -> SKIP)
							within
								Inactive [| {terminate} |> SKIP)
								
							VS_O__(id__,
									    const_Movement_lv,
									    const_Movement_av,
									    const_Movement_MB,
									    const_Movement_alpha) = 
							dbisim(let
								Inactive 	= share__choice(enter -> SKIP [] terminate -> SKIP) ; Active
								
								Termination = terminate -> SKIP
								
								Active 		= true&CALL__move(
											id__,
										    const_Movement_lv,
										    const_Movement_av,
										    const_Movement_MB,
										    const_Movement_alpha,
											0,
											const_Movement_av
										);SHARE_WAIT(Mathematics_floor(Div(Mult(Mathematics_random(), 360, core_real), no_zero_div(const_Movement_av), core_real))) ; 
										 	  Behaviour ; 
										 	  share__choice(exit -> SKIP) ; SKIP ; 
										 	  share__choice(exited -> SKIP) ; Inactive
							
								Behaviour 	= entered -> During
								During 		= ((SKIP ; SStop) /\ interrupt -> SKIP)
							within
								Inactive [| {terminate} |> SKIP)
							
							
							-- Clocks
							
							StateClocks(id__,
									          const_Movement_lv,
									          const_Movement_av,
									          const_Movement_MB,
									          const_Movement_alpha) = terminate -> SKIP
							
							stateClockSync = {||}
						}
					
					endmodule
					----------------------------------------------------------------------
					
					
					----------------------------------------------------------------------
					-- Final state: f1
					module f1
					
					exports
					
						channel enter, entered, interrupt
						channel enteredL, enteredR
						
						Timed(OneStep) {
							--	Rule: behaviours(Node)
							D__(id__,
									    const_Movement_lv,
									    const_Movement_av,
									    const_Movement_MB,
									    const_Movement_alpha) = 
								dbisim(let
									Inactive 	= share__choice(enter -> SKIP [] terminate -> SKIP) ; Entering
									
									Entering 	= entered -> SKIP ; Active
									Active		= share__choice(terminate -> SKIP [] interrupt -> SKIP) ; Interrupted
									Interrupted	= share__choice(exit -> exited -> Inactive)
								within
									Inactive [| {terminate} |> SKIP)
								
							VS_O__(id__,
									    const_Movement_lv,
									    const_Movement_av,
									    const_Movement_MB,
									    const_Movement_alpha) = D__(id__,
									    const_Movement_lv,
									    const_Movement_av,
									    const_Movement_MB,
									    const_Movement_alpha)
						}
					
					endmodule
					----------------------------------------------------------------------
					
					
					
					Timed(OneStep) {
						--	Rule: behaviours(Node)
						--  Note that FDR has problems with efficiently compiling the process below
						-- 	if using a different recursion pattern.
						D__(id__,
								    const_Movement_lv,
								    const_Movement_av,
								    const_Movement_MB,
								    const_Movement_alpha) = 
						dbisim(let
							-- IMPLEMENTATION NOTE: 
							-- The following should be defined as: Inactive = share__choice(Activation [] Termination),
							-- however FDR struggles with that form in certain cases. So we use the exception operator
							-- instead to 'terminate'.
							
							Inactive 	= share__choice(enter -> SKIP [] terminate -> SKIP) ; Active
							
							Termination = terminate -> SKIP
							
							Active 		= true&(share__choice(neighbours.in?n -> (SStop /\ set_n!n -> SKIP)));share__choice(true & (share__choice(set_turned!false -> SKIP))) ; 
									 	  Behaviour ; 
									 	  share__choice(exit -> SKIP) ; SKIP ; 
									 	  share__choice(exited -> SKIP) ; Inactive
						
						
							Behaviour 	= dbisim(
								((
								 (((dbisim(
								 	sbisim(
								 		dbisim(
								 			sbisim(
								 				(let
								 					-- IMPLEMENTATION NOTE:
								 					-- Here the 'enter' channel set is calculated explicitly because of the use of CSPM 
								 					-- modules for defining the semantics of each node.
								 					enterSS = {|
								 					i1::enter,
								 					j1::enter,
								 					Turn180::enter,
								 					RandomTurn::enter,
								 					f1::enter
								 					|}
								 					hideSet = union(enterSS,{|exit,exited,internal__|})
								 				within 
								 					((let
								 						-- IMPLEMENTATION NOTE: the channel set 'enter' is calculated explicitly
								 						-- because CSPM modules are used for the semantics of Node.
								 						flowevts = union(enterSS,{|exit,exited,interrupt|})
								 						transSync = {|internal__.NID_i1,internal__.NID_j1,internal__.NID_j1,internal__.NID_Turn180,internal__.NID_RandomTurn|}
								 					within
								 						((
								 						 (((-- RULE composeNodes(nc:NodeContainer)^nops : CSPProcess
								 						   i1::D__(id__,
								 						   		    const_Movement_lv,
								 						   		    const_Movement_av,
								 						   		    const_Movement_MB,
								 						   		    const_Movement_alpha)
								 						   [| { share__, terminate } |] (
								 						   j1::D__(id__,
								 						   		    const_Movement_lv,
								 						   		    const_Movement_av,
								 						   		    const_Movement_MB,
								 						   		    const_Movement_alpha)
								 						   [| { share__, terminate } |] (
								 						   Turn180::D__(id__,
								 						   		    const_Movement_lv,
								 						   		    const_Movement_av,
								 						   		    const_Movement_MB,
								 						   		    const_Movement_alpha)
								 						   [| { share__, terminate } |] (
								 						   RandomTurn::D__(id__,
								 						   		    const_Movement_lv,
								 						   		    const_Movement_av,
								 						   		    const_Movement_MB,
								 						   		    const_Movement_alpha)
								 						   [| { share__, terminate } |] (
								 						   f1::D__(id__,
								 						   		    const_Movement_lv,
								 						   		    const_Movement_av,
								 						   		    const_Movement_MB,
								 						   		    const_Movement_alpha)
								 						   )
								 						   )
								 						   )
								 						   )
								 						 )
								 						 [[Turn180::interrupt <- x__ | x__ <- {|interrupt,internal__.NID_Turn180|}]]
								 						 [[RandomTurn::interrupt <- x__ | x__ <- {|interrupt,internal__.NID_RandomTurn|}]]
								 						 [[f1::interrupt <- x__ | x__ <- {|interrupt|}]]
								 						 [[i1::interrupt <- x__ | x__ <- {|internal__.NID_i1|}]]
								 						 [[j1::interrupt <- x__ | x__ <- {|internal__.NID_j1,internal__.NID_j1|}]]
								 						 )
								 						  [[ share__ <- x__ | x__ <- {| share__ |} ]] 
								 						  [[set_n <- setL_n]]
								 						 )
								 						 [| union(union(union(flowevts,transSync),{terminate}),{|share__
								 						 			,setL_n
								 						|}) |]
								 						 ((i1::enter -> Transitions(id__,
								 						 		    const_Movement_lv,
								 						 		    const_Movement_av,
								 						 		    const_Movement_MB,
								 						 		    const_Movement_alpha))
								 						  [[ share__ <- x__ | x__ <- {| share__,setL_n |} ]]
								 						 )
								 						)[[setL_n <- set_n]]
								 						)
								 					)
								 					 \ hideSet)
								 					[[
								 						obstacle__.x____ <- obstacle,
								 						neighbours__.x____ <- neighbours
								 						| x____ <- NIDS
								 					]]
								 				)
								 				[| {|get_CLID_Turn180,Turn180::entered,terminate|} |]
								 				dbisim(Clock_CLID_Turn180(id__,0,
								 						          const_Movement_lv,
								 						          const_Movement_av,
								 						          const_Movement_MB,
								 						          const_Movement_alpha))
								 			)\{|get_CLID_Turn180|}
								 		)
								 		[| {|get_CLID_RandomTurn,RandomTurn::entered,terminate|} |]
								 		dbisim(Clock_CLID_RandomTurn(id__,0,
								 				          const_Movement_lv,
								 				          const_Movement_av,
								 				          const_Movement_MB,
								 				          const_Movement_alpha))
								 	)\{|get_CLID_RandomTurn|}
								 )
								 ))
								  [[ share__ <- x__ | x__ <- {| share__,setR_p,setR_n,setR_turned,clockResetR.CLID_MBC |} ]] 
								  [[set_p <- setL_p,set_n <- setL_n,set_turned <- setL_turned,clockReset.CLID_MBC <- clockResetL.CLID_MBC]]
								 )
								 [| union(union(enteredSS,{| interrupt, terminate |}),{|share__
								 			,setL_p
								 			,setL_n
								 			,setL_turned
								 			,clockResetL.CLID_MBC
								 			,setR_p
