								 			 			,setR_turned
								 			 			,clockResetR.CLID_MBC
								 			|}) |]
								 ((During)
								  [[ share__ <- x__ | x__ <- {| share__,setL_p,setL_n,setL_turned,clockResetL.CLID_MBC |} ]]
								  [[set_p <- setR_p,set_n <- setR_n,set_turned <- setR_turned,clockReset.CLID_MBC <- clockResetR.CLID_MBC]]
								 )
								)[[setL_p <- set_p,setL_n <- set_n,setL_turned <- set_turned,clockResetL.CLID_MBC <- clockReset.CLID_MBC]]
								 [[setR_p <- set_p,setR_n <- set_n,setR_turned <- set_turned,clockResetR.CLID_MBC <- clockReset.CLID_MBC]]
								)\union(enteredSS,{terminate}) 
