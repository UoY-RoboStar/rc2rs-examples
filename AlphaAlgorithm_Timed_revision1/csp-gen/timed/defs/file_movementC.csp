						 ; ((SKIP ; MovementAndAvoidance::enter -> SKIP))))
						 [] dbisim(((MBC>=const_Movement_MB))&(internal__!NID_MovementAndAvoidance -> SKIP ;  share__choice(exit -> SKIP) ; (share__choice(exited -> SKIP) ; share__choice(clockReset.CLID_MBC -> SKIP) ; Turning::enter -> SKIP)))
						 [] dbisim(((turned==true))&(internal__!NID_Turning -> SKIP ;  share__choice(exit -> SKIP) ; (share__choice(exited -> SKIP) ; SKIP ; MovementAndAvoidance::enter -> SKIP)))
