								)\{|get_p,set_p|}
							)
							[| {|get_n,set_n,terminate|} |]
							Memory_n(0)
						)\{|get_n,set_n|}
					)
					)
				
				-- Visible counterparts
				MachineBody_VS_O(id__,
						    const_Movement_lv,
						    const_Movement_av,
						    const_Movement_MB,
						    const_Movement_alpha) = 
					dbisim((
					let
						finalNodesEntered = {||}
					within
						(dbisim((dbisim((let
							-- IMPLEMENTATION NOTE:
							-- Here the 'enter' channel set is calculated explicitly because of the use of CSPM 
							-- modules for defining the semantics of each node.
							enterSS = {|
							i1::enter,
							MovementAndAvoidance::enter,
							Turning::enter
							|}
							hideSet = union(enterSS,{|exit,exited,internal__|})
						within 
							((let
								-- IMPLEMENTATION NOTE: the channel set 'enter' is calculated explicitly
								-- because CSPM modules are used for the semantics of Node.
								flowevts = union(enterSS,{|exit,exited,interrupt|})
								transSync = {|internal__.NID_i1,internal__.NID_MovementAndAvoidance,internal__.NID_Turning|}
							within
								((
								 (((-- RULE composeNodes(nc:NodeContainer)^nops : CSPProcess
								   i1::VS_O__(id__,
								   		    const_Movement_lv,
								   		    const_Movement_av,
								   		    const_Movement_MB,
								   		    const_Movement_alpha)
								   [| { share__, terminate } |] (
								   MovementAndAvoidance::VS_O__(id__,
								   		    const_Movement_lv,
								   		    const_Movement_av,
								   		    const_Movement_MB,
								   		    const_Movement_alpha)
								   [| { share__, terminate } |] (
								   Turning::VS_O__(id__,
								   		    const_Movement_lv,
								   		    const_Movement_av,
								   		    const_Movement_MB,
								   		    const_Movement_alpha)
								   )
								   )
								 )
								 [[MovementAndAvoidance::interrupt <- x__ | x__ <- {|interrupt,internal__.NID_MovementAndAvoidance|}]]
								 [[Turning::interrupt <- x__ | x__ <- {|interrupt,internal__.NID_Turning|}]]
								 [[i1::interrupt <- x__ | x__ <- {|internal__.NID_i1|}]]
								 )
								  [[ share__ <- x__ | x__ <- {| share__ |} ]] 
								  [[set_turned <- setL_turned,clockReset.CLID_MBC <- clockResetL.CLID_MBC]]
								 )
								 [| union(union(union(flowevts,transSync),{terminate}),{|share__
								 			,setL_turned
								 			,clockResetL.CLID_MBC
								|}) |]
								 ((i1::enter -> Transitions(id__,
								 		    const_Movement_lv,
								 		    const_Movement_av,
								 		    const_Movement_MB,
								 		    const_Movement_alpha))
								  [[ share__ <- x__ | x__ <- {| share__,setL_turned,clockResetL.CLID_MBC |} ]]
								 )
								)[[setL_turned <- set_turned,clockResetL.CLID_MBC <- clockReset.CLID_MBC]]
								)
							)
							 \ hideSet)
							[[
								obstacle__.x____ <- obstacle,
								neighbours__.x____ <- neighbours
								| x____ <- NIDS
							]]
						)
						)
						 [| union(stateClockSync,{terminate}) |]
						 StateClocks(id__,
						 		          const_Movement_lv,
						 		          const_Movement_av,
						 		          const_Movement_MB,
						 		          const_Movement_alpha)
						)\diff(stateClockSync,enteredSS))
						 [| {| interrupt |} |] SKIP)
					)
					)
				
				Behaviour_VS_O(id__,
						    const_Movement_lv,
						    const_Movement_av,
						    const_Movement_MB,
						    const_Movement_alpha) = 
					dbisim((let
						stateClockSync = {|get_CLID_MovementAndAvoidance,MovementAndAvoidance::entered,get_CLID_Turning,Turning::entered|}
					 within
						(MachineBody_VS_O(id__,
								    const_Movement_lv,
								    const_Movement_av,
								    const_Movement_MB,
								    const_Movement_alpha) [| union(stateClockSync,{terminate}) |] StateClocks(id__,
								          const_Movement_lv,
								          const_Movement_av,
								          const_Movement_MB,
								          const_Movement_alpha)) \ diff(union(stateClockSync,enteredSS),enteredSS)
					)
					)
				
				IteratedBehaviour_VS_O(id__,
						    const_Movement_lv,
						    const_Movement_av,
						    const_Movement_MB,
						    const_Movement_alpha) = 
					dbisim((let
						stateClockSync = {|get_CLID_MovementAndAvoidance,MovementAndAvoidance::entered,get_CLID_Turning,Turning::entered|}
					 within
						(dbisim(
							sbisim(
								dbisim(
									sbisim(
										MachineBody_VS_O(id__,
												    const_Movement_lv,
												    const_Movement_av,
												    const_Movement_MB,
												    const_Movement_alpha)
										[| {|get_CLID_Turning,Turning::entered,terminate|} |]
										dbisim(Clock_CLID_Turning(id__,0,
												          const_Movement_lv,
												          const_Movement_av,
												          const_Movement_MB,
												          const_Movement_alpha))
									)\{|get_CLID_Turning|}
								)
								[| {|get_CLID_MovementAndAvoidance,MovementAndAvoidance::entered,terminate|} |]
								dbisim(Clock_CLID_MovementAndAvoidance(id__,0,
										          const_Movement_lv,
										          const_Movement_av,
										          const_Movement_MB,
										          const_Movement_alpha))
							)\{|get_CLID_MovementAndAvoidance|}
						)
						) \ diff(union(stateClockSync,enteredSS),enteredSS)
					)
					)
				
				Stateful_VS_O(id__,
						    const_Movement_lv,
						    const_Movement_av,
						    const_Movement_MB,
						    const_Movement_alpha) = 
					dbisim((let
						getsetLocalChannels = {|get_n,set_n,
						get_p,set_p,
						get_turned,set_turned|}
						clockSync = {|get_CLID_MBC,clockReset.CLID_MBC|}
					within
						(Behaviour_VS_O(id__,
								    const_Movement_lv,
								    const_Movement_av,
								    const_Movement_MB,
								    const_Movement_alpha) 
						 [| union(union(getsetLocalChannels,clockSync),{terminate}) |] 
						 (varMemory(id__,
						 		    const_Movement_lv,
						 		    const_Movement_av,
						 		    const_Movement_MB,
						 		    const_Movement_alpha) [| {terminate} |] Clocks(id__,
						 		          const_Movement_lv,
						 		          const_Movement_av,
						 		          const_Movement_MB,
						 		          const_Movement_alpha))
					 	)\union(getsetLocalChannels,clockSync)
					)
					)
				
				IteratedStateful_VS_O(id__,
						    const_Movement_lv,
						    const_Movement_av,
						    const_Movement_MB,
						    const_Movement_alpha) =
					(dbisim(
						sbisim(
							dbisim(
								sbisim(
									dbisim(
										sbisim(
											dbisim(
												sbisim(
													IteratedBehaviour_VS_O(id__,
															    const_Movement_lv,
															    const_Movement_av,
															    const_Movement_MB,
															    const_Movement_alpha)
													[| {|get_CLID_MBC,clockReset.CLID_MBC,terminate|} |]
													dbisim(Clock_CLID_MBC(id__,0,
															          const_Movement_lv,
															          const_Movement_av,
															          const_Movement_MB,
															          const_Movement_alpha))
												)\{|get_CLID_MBC,clockReset.CLID_MBC|}
											)
											[| {|get_turned,set_turned,terminate|} |]
											Memory_turned(true)
										)\{|get_turned,set_turned|}
									)
									[| {|get_p,set_p,terminate|} |]
									Memory_p(AggregationSoftware_Position_left)
								)\{|get_p,set_p|}
							)
							[| {|get_n,set_n,terminate|} |]
							Memory_n(0)
						)\{|get_n,set_n|}
					)
					)
				
				-- END
				
				-- Memory
				-- Memory variables
				Memory_n(n) =
					get_n!n -> Memory_n(n)
					[]
					set_n?x__ -> Memory_n(x__)
					[]
					terminate -> SKIP
				Memory_p(p) =
					get_p!p -> Memory_p(p)
					[]
					set_p?x__ -> Memory_p(x__)
					[]
					terminate -> SKIP
				Memory_turned(turned) =
					get_turned!turned -> Memory_turned(turned)
					[]
					set_turned?x__ -> Memory_turned(x__)
					[]
					terminate -> SKIP
				
				-- varMemory process
				varMemory(id__,
						    const_Movement_lv,
						    const_Movement_av,
						    const_Movement_MB,
						    const_Movement_alpha) = Memory_n(0)
				[| { terminate } |] (
				Memory_p(AggregationSoftware_Position_left)
				[| { terminate } |] (
				Memory_turned(true)
				)
				)
				
				getsetLocalChannels = {|get_n,set_n,get_p,set_p,get_turned,set_turned|}
				
				-- Definition of the behaviour of state machines (default, optimised, visible, visible and optimised)
				FVS__(id__,
						    const_Movement_lv,
						    const_Movement_av,
						    const_Movement_MB,
						    const_Movement_alpha) = STM_VS_O(id__,
						    const_Movement_lv,
						    const_Movement_av,
						    const_Movement_MB,
						    const_Movement_alpha) \ localClockResets
				D__(id__,
						    const_Movement_lv,
						    const_Movement_av,
						    const_Movement_MB,
						    const_Movement_alpha) = timed_priority(STM(id__,
						    const_Movement_lv,
						    const_Movement_av,
						    const_Movement_MB,
						    const_Movement_alpha) \ union(internal_events,localClockResets))
				O__(id__,
						    const_Movement_lv,
						    const_Movement_av,
						    const_Movement_MB,
						    const_Movement_alpha) = dbisim(D__(id__,
						    const_Movement_lv,
						    const_Movement_av,
						    const_Movement_MB,
						    const_Movement_alpha))
				VS__(id__,
						    const_Movement_lv,
						    const_Movement_av,
						    const_Movement_MB,
						    const_Movement_alpha) = FVS__(id__,
						    const_Movement_lv,
						    const_Movement_av,
						    const_Movement_MB,
						    const_Movement_alpha)
				VS_O__(id__,
						    const_Movement_lv,
						    const_Movement_av,
						    const_Movement_MB,
						    const_Movement_alpha) = dbisim(FVS__(id__,
						    const_Movement_lv,
						    const_Movement_av,
						    const_Movement_MB,
						    const_Movement_alpha))
				HEXT__(id__,
						    const_Movement_lv,
						    const_Movement_av,
						    const_Movement_MB,
						    const_Movement_alpha) = O__(id__,
						    const_Movement_lv,
						    const_Movement_av,
						    const_Movement_MB,
						    const_Movement_alpha) [|shared_variable_events|] SKIP
				FVS_C__(id__,
						    const_Movement_lv,
						    const_Movement_av,
						    const_Movement_MB,
						    const_Movement_alpha) = dbisim(timed_priority(STM(id__,
						    const_Movement_lv,
						    const_Movement_av,
						    const_Movement_MB,
						    const_Movement_alpha) \ internal_events))
				HUP__(id__,
						    const_Movement_lv,
						    const_Movement_av,
						    const_Movement_MB,
						    const_Movement_alpha) = timed_priority(O__(id__,
						    const_Movement_lv,
						    const_Movement_av,
						    const_Movement_MB,
						    const_Movement_alpha) [|{share__}|] SKIP)
				
				-- Clocks
				Clock_CLID_MBC(id__,x__,
						          const_Movement_lv,
						          const_Movement_av,
						          const_Movement_MB,
						          const_Movement_alpha) = 
					TimeOut_1(
						clockReset.CLID_MBC -> Clock_CLID_MBC(id__,0,
								          const_Movement_lv,
								          const_Movement_av,
								          const_Movement_MB,
								          const_Movement_alpha)
						[]
						get_CLID_MBC!x__ -> Clock_CLID_MBC(id__,x__,
								          const_Movement_lv,
								          const_Movement_av,
								          const_Movement_MB,
								          const_Movement_alpha)
						[]
						terminate -> SKIP,Clock_CLID_MBC(id__,clock_type_plus(x__,1,CLID_MBC_clock_type(id__,
								          const_Movement_lv,
								          const_Movement_av,
								          const_Movement_MB,
								          const_Movement_alpha)),
								          const_Movement_lv,
								          const_Movement_av,
								          const_Movement_MB,
								          const_Movement_alpha))
				
				Clocks(id__,
						          const_Movement_lv,
						          const_Movement_av,
						          const_Movement_MB,
						          const_Movement_alpha) = dbisim(Clock_CLID_MBC(id__,0,
						          const_Movement_lv,
						          const_Movement_av,
						          const_Movement_MB,
						          const_Movement_alpha))
				
				clockSync = {|get_CLID_MBC,clockReset.CLID_MBC|}
				
				Clock_CLID_MovementAndAvoidance(id__,x__,
						          const_Movement_lv,
						          const_Movement_av,
						          const_Movement_MB,
						          const_Movement_alpha) = 
					TimeOut_1(
						MovementAndAvoidance::entered -> Clock_CLID_MovementAndAvoidance(id__,0,
								          const_Movement_lv,
								          const_Movement_av,
								          const_Movement_MB,
								          const_Movement_alpha)
						[]
						get_CLID_MovementAndAvoidance!x__ -> Clock_CLID_MovementAndAvoidance(id__,x__,
								          const_Movement_lv,
								          const_Movement_av,
								          const_Movement_MB,
								          const_Movement_alpha)
						[]
						terminate -> SKIP,Clock_CLID_MovementAndAvoidance(id__,clock_type_plus(x__,1,CLID_MovementAndAvoidance_clock_type(id__,
								          const_Movement_lv,
								          const_Movement_av,
								          const_Movement_MB,
								          const_Movement_alpha)),
								          const_Movement_lv,
								          const_Movement_av,
								          const_Movement_MB,
								          const_Movement_alpha))
				Clock_CLID_Turning(id__,x__,
						          const_Movement_lv,
						          const_Movement_av,
						          const_Movement_MB,
						          const_Movement_alpha) = 
					TimeOut_1(
						Turning::entered -> Clock_CLID_Turning(id__,0,
								          const_Movement_lv,
								          const_Movement_av,
								          const_Movement_MB,
								          const_Movement_alpha)
						[]
						get_CLID_Turning!x__ -> Clock_CLID_Turning(id__,x__,
								          const_Movement_lv,
								          const_Movement_av,
								          const_Movement_MB,
								          const_Movement_alpha)
						[]
						terminate -> SKIP,Clock_CLID_Turning(id__,clock_type_plus(x__,1,CLID_Turning_clock_type(id__,
								          const_Movement_lv,
								          const_Movement_av,
								          const_Movement_MB,
								          const_Movement_alpha)),
								          const_Movement_lv,
								          const_Movement_av,
								          const_Movement_MB,
								          const_Movement_alpha))
				
				StateClocks(id__,
						          const_Movement_lv,
						          const_Movement_av,
						          const_Movement_MB,
						          const_Movement_alpha) = dbisim(Clock_CLID_MovementAndAvoidance(id__,0,
						          const_Movement_lv,
						          const_Movement_av,
						          const_Movement_MB,
						          const_Movement_alpha))
				[| { terminate } |] (
				dbisim(Clock_CLID_Turning(id__,0,
						          const_Movement_lv,
						          const_Movement_av,
						          const_Movement_MB,
						          const_Movement_alpha))
				)
				
				stateClockSync = {|get_CLID_MovementAndAvoidance,MovementAndAvoidance::entered,get_CLID_Turning,Turning::entered|}
				
				-- Shared memory
				-- Shared memory variables
				
				-- sharedVarMemory process
				sharedVarMemory(id__,
						    const_Movement_lv,
						    const_Movement_av,
						    const_Movement_MB,
						    const_Movement_alpha) = terminate -> SKIP
				
				sharedVarSync = {||}
				
				sharedVarHide = {||}
				}
		endmodule
		
		Timed(OneStep) {
				-- undefined operations
				CALL__move(id__,
						    param_l,
						    param_a) 	= moveCall.param_l.param_a -> SKIP
				
				-- declaring controller memory
				Memory(id__) = SKIP
				
				D__(id__,
						    const_MovementC_stm_ref0_lv,
						    const_MovementC_stm_ref0_av,
						    const_MovementC_stm_ref0_MB,
						    const_MovementC_stm_ref0_alpha) = prioritise(	((
						let
							const_Movement_lv = const_MovementC_stm_ref0_lv
							const_Movement_av = const_MovementC_stm_ref0_av
							const_Movement_MB = const_MovementC_stm_ref0_MB
							const_Movement_alpha = const_MovementC_stm_ref0_alpha
						within 
						stm_ref0::D__(id__,
								    const_Movement_lv,
								    const_Movement_av,
								    const_Movement_MB,
								    const_Movement_alpha)[[
							stm_ref0::terminate <- terminate,
							stm_ref0::obstacle <- obstacle,
							stm_ref0::neighbours <- neighbours,
							stm_ref0::moveCall <- moveCall
						]]
					)
						[|
							union(
								{|
								|},
								{|
								|}
							)
						|]
					Memory(id__)
				)
				\ union(
					{|
					|},
					{|
					|}
				)
				[|{|terminate|}|>SKIP
				,<visibleMemoryEvents,{tock}>)
				
				-- VS version
				VS__(id__,
						    const_MovementC_stm_ref0_lv,
						    const_MovementC_stm_ref0_av,
						    const_MovementC_stm_ref0_MB,
						    const_MovementC_stm_ref0_alpha) = prioritise(	((
						let
							const_Movement_lv = const_MovementC_stm_ref0_lv
							const_Movement_av = const_MovementC_stm_ref0_av
							const_Movement_MB = const_MovementC_stm_ref0_MB
							const_Movement_alpha = const_MovementC_stm_ref0_alpha
						within 
						stm_ref0::VS__(id__,
								    const_Movement_lv,
								    const_Movement_av,
								    const_Movement_MB,
								    const_Movement_alpha)[[
							stm_ref0::terminate <- terminate,
							stm_ref0::obstacle <- obstacle,
							stm_ref0::neighbours <- neighbours,
							stm_ref0::moveCall <- moveCall
						]]
					)
						[|
							union(
								{|
								|},
								{|
								|}
							)
						|]
					Memory(id__)
				)
				\ union(
					{|
					|},
					{|
					|}
				)
				[|{|terminate|}|>SKIP
				,<visibleMemoryEvents,{tock}>)
			
				-- O version (optimised) THESE TWO PROCESSES SHOULD BE KEPT IN SYNC WITH THE ABOVE TWO
				O__(id__,
						    const_MovementC_stm_ref0_lv,
						    const_MovementC_stm_ref0_av,
						    const_MovementC_stm_ref0_MB,
						    const_MovementC_stm_ref0_alpha) = dbisim(prioritise(	((
						let
							const_Movement_lv = const_MovementC_stm_ref0_lv
							const_Movement_av = const_MovementC_stm_ref0_av
							const_Movement_MB = const_MovementC_stm_ref0_MB
							const_Movement_alpha = const_MovementC_stm_ref0_alpha
						within 
						stm_ref0::O__(id__,
								    const_Movement_lv,
								    const_Movement_av,
								    const_Movement_MB,
								    const_Movement_alpha)[[
							stm_ref0::terminate <- terminate,
							stm_ref0::obstacle <- obstacle,
							stm_ref0::neighbours <- neighbours,
							stm_ref0::moveCall <- moveCall
						]]
					)
						[|
							union(
								{|
								|},
								{|
								|}
							)
						|]
					dbisim(Memory(id__))
				)
				\ union(
					{|
					|},
					{|
					|}
				)
				[|{|terminate|}|>SKIP
				,<visibleMemoryEvents,{tock}>))
								
				-- VS_O version
				VS_O__(id__,
						    const_MovementC_stm_ref0_lv,
						    const_MovementC_stm_ref0_av,
						    const_MovementC_stm_ref0_MB,
						    const_MovementC_stm_ref0_alpha) = dbisim(prioritise(	((
						let
							const_Movement_lv = const_MovementC_stm_ref0_lv
							const_Movement_av = const_MovementC_stm_ref0_av
							const_Movement_MB = const_MovementC_stm_ref0_MB
							const_Movement_alpha = const_MovementC_stm_ref0_alpha
						within 
						stm_ref0::VS_O__(id__,
								    const_Movement_lv,
								    const_Movement_av,
								    const_Movement_MB,
								    const_Movement_alpha)[[
							stm_ref0::terminate <- terminate,
							stm_ref0::obstacle <- obstacle,
							stm_ref0::neighbours <- neighbours,
							stm_ref0::moveCall <- moveCall
						]]
					)
						[|
							union(
								{|
								|},
								{|
								|}
							)
						|]
					dbisim(Memory(id__))
				)
				\ union(
					{|
					|},
					{|
					|}
				)
				[|{|terminate|}|>SKIP
				,<visibleMemoryEvents,{tock}>))
			
				HEXT(id__,
						    const_MovementC_stm_ref0_lv,
						    const_MovementC_stm_ref0_av,
						    const_MovementC_stm_ref0_MB,
						    const_MovementC_stm_ref0_alpha) = O__(id__,
						    const_MovementC_stm_ref0_lv,
						    const_MovementC_stm_ref0_av,
						    const_MovementC_stm_ref0_MB,
						    const_MovementC_stm_ref0_alpha) [|shared_variable_events|] SKIP			
		}

	endmodule



