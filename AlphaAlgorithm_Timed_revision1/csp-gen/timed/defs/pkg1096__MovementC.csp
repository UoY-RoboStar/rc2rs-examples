				----------------------------------------------------------------------
				
				
				----------------------------------------------------------------------
				-- State: Turning
				module Turning
				
				enterSS = 
						{|			i1::enter,
							j1::enter,
							Turn180::enter,
							RandomTurn::enter,
							EmptyCycle::enter
						|}
				enteredSS = 
