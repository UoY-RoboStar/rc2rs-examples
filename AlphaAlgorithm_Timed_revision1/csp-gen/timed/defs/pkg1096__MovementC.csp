								  [[ share__ <- x__ | x__ <- {| share__,setR_turned,setR_p,clockResetR.CLID_MBC,setR_n |} ]] 
								  [[set_turned <- setL_turned,set_p <- setL_p,clockReset.CLID_MBC <- clockResetL.CLID_MBC,set_n <- setL_n]]
								 )
								 [| union(union(enteredSS,{| interrupt, terminate |}),{|share__
								 			,setL_turned
								 			,setL_p
								 			,clockResetL.CLID_MBC
								 			,setL_n
