								)[[setL_turned <- set_turned,setL_p <- set_p,clockResetL.CLID_MBC <- clockReset.CLID_MBC,setL_n <- set_n]]
								 [[setR_turned <- set_turned,setR_p <- set_p,clockResetR.CLID_MBC <- clockReset.CLID_MBC,setR_n <- set_n]]
								)\{terminate} 
