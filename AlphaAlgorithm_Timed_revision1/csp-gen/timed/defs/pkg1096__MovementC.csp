								 						   		    const_pkg1096__Movement_lv,
								 						   		    const_pkg1096__Movement_av,
								 						   		    const_pkg1096__Movement_MB,
								 						   		    const_pkg1096__Movement_alpha)
								 						   )
								 						   )
								 						 )
								 						 [[Move::interrupt <- x__ | x__ <- {|interrupt,obstacle__.NID_Move.in|}]]
								 						 [[Avoid::interrupt <- x__ | x__ <- {|interrupt,internal__.NID_Avoid|}]]
								 						 [[i1::interrupt <- x__ | x__ <- {|internal__.NID_i1|}]]
								 						 )
								 						  [[ share__ <- x__ | x__ <- {| share__,setR_p |} ]] 
								 						  [[clockReset.CLID_MBC <- clockResetL.CLID_MBC]]
								 						 )
								 						 [| union(union(union(flowevts,transSync),{terminate}),{|share__
								 						 			,clockResetL.CLID_MBC
								 						 			,setR_p
								 						 			|}) |]
								 						 ((i1::enter -> Transitions(id__,
								 						 		    const_pkg1096__Movement_lv,
								 						 		    const_pkg1096__Movement_av,
								 						 		    const_pkg1096__Movement_MB,
								 						 		    const_pkg1096__Movement_alpha))
								 						  [[ share__ <- x__ | x__ <- {| share__,clockResetL.CLID_MBC |} ]]
								 						  [[set_p <- setR_p]]
								 						 )
								 						)[[clockResetL.CLID_MBC <- clockReset.CLID_MBC]]
								 						 [[setR_p <- set_p]]
								 						)
								 					)
								 					 \ hideSet)
								 					[[
								 						obstacle__.x____ <- obstacle,
								 						neighbours__.x____ <- neighbours
								 						| x____ <- NIDS
								 					]]
								 				)
								 				[| {|get_CLID_Avoid,Avoid::entered,terminate|} |]
								 				dbisim(Clock_CLID_Avoid(id__,0,
								 						          const_pkg1096__Movement_lv,
								 						          const_pkg1096__Movement_av,
