								 						-- IMPLEMENTATION NOTE: the channel set 'enter' is calculated explicitly
								 						-- because CSPM modules are used for the semantics of Node.
								 						flowevts = union(enterSS,{|exit,exited,interrupt|})
								 						transSync = {|internal__.NID_i1,obstacle__.NID_Move.in,internal__.NID_Avoid|}
								 					within
								 						((
								 						 (((-- RULE composeNodes(nc:NodeContainer)^nops : CSPProcess
								 						   i1::D__(id__,
								 						   		    const_pkg1096__Movement_lv,
								 						   		    const_pkg1096__Movement_av,
								 						   		    const_pkg1096__Movement_MB,
								 						   		    const_pkg1096__Movement_alpha)
								 						   [| { share__, terminate } |] (
								 						   Move::D__(id__,
								 						   		    const_pkg1096__Movement_lv,
								 						   		    const_pkg1096__Movement_av,
								 						   		    const_pkg1096__Movement_MB,
								 						   		    const_pkg1096__Movement_alpha)
								 						   [| { share__, terminate } |] (
								 						   Avoid::D__(id__,
								 						   		    const_pkg1096__Movement_lv,
								 						   		    const_pkg1096__Movement_av,
								 						   		    const_pkg1096__Movement_MB,
								 						   		    const_pkg1096__Movement_alpha)
								 						   )
								 						   )
								 						 )
								 						 [[Move::interrupt <- x__ | x__ <- {|interrupt,obstacle__.NID_Move.in|}]]
								 						 [[Avoid::interrupt <- x__ | x__ <- {|interrupt,internal__.NID_Avoid|}]]
								 						 [[i1::interrupt <- x__ | x__ <- {|internal__.NID_i1|}]]
								 						 )
								 						  [[ share__ <- x__ | x__ <- {| share__,setR_p |} ]] 
								 						  [[clockReset.CLID_MBC <- clockResetL.CLID_MBC]]
								 						 )
								 						 [| union(union(union(flowevts,transSync),{terminate}),{|share__
								 						 			,clockResetL.CLID_MBC
								 						 			,setR_p
								 						 			|}) |]
								 						 ((i1::enter -> Transitions(id__,
								 						 		    const_pkg1096__Movement_lv,
								 						 		    const_pkg1096__Movement_av,
								 						 		    const_pkg1096__Movement_MB,
								 						 		    const_pkg1096__Movement_alpha))
								 						  [[ share__ <- x__ | x__ <- {| share__,clockResetL.CLID_MBC |} ]]
								 						  [[set_p <- setR_p]]
								 						 )
								 						)[[clockResetL.CLID_MBC <- clockReset.CLID_MBC]]
								 						 [[setR_p <- set_p]]
								 						)
								 					)
								 					 \ hideSet)
								 					[[
								 						obstacle__.x____ <- obstacle,
								 						neighbours__.x____ <- neighbours
								 						| x____ <- NIDS
								 					]]
								 				)
								 				[| {|get_CLID_Avoid,Avoid::entered,terminate|} |]
								 				dbisim(Clock_CLID_Avoid(id__,0,
								 						          const_pkg1096__Movement_lv,
								 						          const_pkg1096__Movement_av,
								 						          const_pkg1096__Movement_MB,
								 						          const_pkg1096__Movement_alpha))
								 			)\{|get_CLID_Avoid|}
								 		)
								 		[| {|get_CLID_Move,Move::entered,terminate|} |]
								 		dbisim(Clock_CLID_Move(id__,0,
								 				          const_pkg1096__Movement_lv,
								 				          const_pkg1096__Movement_av,
								 				          const_pkg1096__Movement_MB,
								 				          const_pkg1096__Movement_alpha))
								 	)\{|get_CLID_Move|}
								 )
								 ))
								  [[ share__ <- x__ | x__ <- {| share__,setR_turned,setR_p,clockResetR.CLID_MBC,setR_n |} ]] 
								  [[set_turned <- setL_turned,set_p <- setL_p,clockReset.CLID_MBC <- clockResetL.CLID_MBC,set_n <- setL_n]]
								 )
								 [| union(union(enteredSS,{| interrupt, terminate |}),{|share__
								 			,setL_turned
								 			,setL_p
								 			,clockResetL.CLID_MBC
								 			,setL_n
								 			,setR_turned
								 			 			,setR_p
								 			 			,clockResetR.CLID_MBC
								 			 			,setR_n
								 			|}) |]
								 ((During)
								  [[ share__ <- x__ | x__ <- {| share__,setL_turned,setL_p,clockResetL.CLID_MBC,setL_n |} ]]
								  [[set_turned <- setR_turned,set_p <- setR_p,clockReset.CLID_MBC <- clockResetR.CLID_MBC,set_n <- setR_n]]
								 )
								)[[setL_turned <- set_turned,setL_p <- set_p,clockResetL.CLID_MBC <- clockReset.CLID_MBC,setL_n <- set_n]]
								 [[setR_turned <- set_turned,setR_p <- set_p,clockResetR.CLID_MBC <- clockReset.CLID_MBC,setR_n <- set_n]]
								)\union(enteredSS,{terminate}) 
							)
							During 		= share__choice(([] e__ : enteredSS @ e__ -> SKIP))
									 	  ; entered -> ((CRUN(enteredSS) ||| SKIP ; SStop) /\ interrupt -> share__choice(terminate -> SKIP))
						within
							Inactive [| {terminate} |> SKIP)
							
						VS_O__(id__,
								    const_pkg1096__Movement_lv,
								    const_pkg1096__Movement_av,
								    const_pkg1096__Movement_MB,
								    const_pkg1096__Movement_alpha) = 
						dbisim(let
							Inactive 	= share__choice(enter -> SKIP [] terminate -> SKIP) ; Active
							
							Termination = terminate -> SKIP
							
							Active 		= SKIP ; 
									 	  Behaviour ; 
									 	  share__choice(exit -> SKIP) ; SKIP ; 
									 	  share__choice(exited -> SKIP) ; Inactive
						
						
							Behaviour 	= dbisim(
								((
								 (((dbisim(
								 	sbisim(
								 		dbisim(
								 			sbisim(
								 				(let
								 					-- IMPLEMENTATION NOTE:
								 					-- Here the 'enter' channel set is calculated explicitly because of the use of CSPM 
								 					-- modules for defining the semantics of each node.
								 					enterSS = {|
								 					i1::enter,
								 					Move::enter,
								 					Avoid::enter
								 					|}
								 					hideSet = union(enterSS,{|exit,exited,internal__|})
								 				within 
								 					((let
								 						-- IMPLEMENTATION NOTE: the channel set 'enter' is calculated explicitly
								 						-- because CSPM modules are used for the semantics of Node.
								 						flowevts = union(enterSS,{|exit,exited,interrupt|})
								 						transSync = {|internal__.NID_i1,obstacle__.NID_Move.in,internal__.NID_Avoid|}
								 					within
								 						((
								 						 (((-- RULE composeNodes(nc:NodeContainer)^nops : CSPProcess
								 						   i1::VS_O__(id__,
								 						   		    const_pkg1096__Movement_lv,
								 						   		    const_pkg1096__Movement_av,
								 						   		    const_pkg1096__Movement_MB,
								 						   		    const_pkg1096__Movement_alpha)
								 						   [| { share__, terminate } |] (
								 						   Move::VS_O__(id__,
								 						   		    const_pkg1096__Movement_lv,
								 						   		    const_pkg1096__Movement_av,
								 						   		    const_pkg1096__Movement_MB,
								 						   		    const_pkg1096__Movement_alpha)
