stm Communication {
	uses CommHw uses Internal requires I_clone_normal_Communication_Receive_t3_op requires I_clone_normal_Communication_Broadcast_t4_op requires I_clone_normal_Communication_Broadcast_entry requires I_clone_normal_Communication_Receive_t5_op requires I_clone_normal_Communication_Receive_t2_op const id : AggregationSoftware::ID
	var x : AggregationSoftware::ID * AggregationSoftware::ID , y : AggregationSoftware::ID
	var neighs : Set( AggregationSoftware::ID )
	const RC : nat
	initial i1
	state Broadcast {
		initial i
		state EmptyCycle {
		}
		transition tBroadcast {
			from i
			to EmptyCycle
		}
		entry clone_normal_Communication_Broadcast_entry ( )
	}
	state Receive {
		initial i
		state EmptyCycle {
		}
		transition tReceive {
			from i
			to EmptyCycle
		}
	}
	transition t1 {
		from i1
		to Broadcast
	}
	transition t2 {
		from Receive
		to Receive
		trigger receive ? x
		condition  (x [ 1 ] == id ) /\ ( since ( RCC ) < RC )
		action clone_normal_Communication_Receive_t2_op ( )
	}
	transition t3 {
		from Receive
		to Receive
		trigger broadcast ? y
		condition since ( RCC ) < RC
		action clone_normal_Communication_Receive_t3_op ( )
	}
	transition t4 {
		from Broadcast
		to Receive
		# RCC
		action clone_normal_Communication_Broadcast_t4_op ( )
	}
	transition t5 {
		from Receive
		to Broadcast
		condition since ( RCC ) >= RC
		action clone_normal_Communication_Receive_t5_op ( )
	}
	clock RCC
}

