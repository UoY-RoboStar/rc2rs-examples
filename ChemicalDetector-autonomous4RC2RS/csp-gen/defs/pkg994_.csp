				 	]]
				 )
				 )
				  [[ share__ <- x__ | x__ <- {| share__,setR_d0,setR_a,setR_d1,setR_l |} ]] 
				  [[set_d0 <- setL_d0,set_a <- setL_a,set_d1 <- setL_d1,set_l <- setL_l]]
				 )
				 [| union(union(enteredSS,{| interrupt, terminate |}),{|share__
				 			,setL_d0
				 			,setL_a
				 			,setL_d1
				 			,setL_l
				 			,setR_d0
				 			 			,setR_a
				 			 			,setR_d1
				 			 			,setR_l
				 			|}) |]
				 ((During)
				  [[ share__ <- x__ | x__ <- {| share__,setL_d0,setL_a,setL_d1,setL_l |} ]]
				  [[set_d0 <- setR_d0,set_a <- setR_a,set_d1 <- setR_d1,set_l <- setR_l]]
				 )
				)[[setL_d0 <- set_d0,setL_a <- set_a,setL_d1 <- set_d1,setL_l <- set_l]]
				 [[setR_d0 <- set_d0,setR_a <- set_a,setR_d1 <- set_d1,setR_l <- set_l]]
				)\union(enteredSS,{terminate}) 
			)
			During 		= share__choice(([] e__ : enteredSS @ e__ -> SKIP))
					 	  ; entered -> ((CRUN(enteredSS) ||| SKIP ; SStop) /\ interrupt -> share__choice(terminate -> SKIP))
		within
			Inactive [| {terminate} |> SKIP)
			
