				 		 		    const_pkg994__Movement_stuckPeriod,
				 		 		    const_pkg994__Movement_stuckDist,
				 		 		    const_pkg994__Movement_outPeriod))
				 		  [[ share__ <- x__ | x__ <- {| share__ |} ]]
				 		 )
				 		)
				 		)
				 	)
				 	 \ hideSet)
				 	[[
				 		obstacle__.x____ <- obstacle,
				 		odometer__.x____ <- odometer,
				 		resume__.x____ <- resume,
				 		turn__.x____ <- turn,
				 		stop__.x____ <- stop,
				 		flag__.x____ <- flag
				 		| x____ <- NIDS
				 	]]
				 )
				 )
				  [[ share__ <- x__ | x__ <- {| share__,setR_d0,setR_a,setR_d1,setR_l |} ]] 
				  [[set_d0 <- setL_d0,set_a <- setL_a,set_d1 <- setL_d1,set_l <- setL_l]]
