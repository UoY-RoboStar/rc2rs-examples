		)
	
	-- END
	
	-- Memory
	-- Memory variables
	Memory_gs(gs) =
		get_gs!gs -> Memory_gs(gs)
		[]
		set_gs?x__ -> Memory_gs(x__)
		[]
		terminate -> SKIP
	
	-- varMemory process
	varMemory(id__,
			    const_pkg994__GasAnalysis_thr) = Memory_gs(<>)
	
	getsetLocalChannels = {|get_gs,set_gs|}
	
	-- Definition of the behaviour of state machines (default, optimised, visible, visible and optimised)
	FVS__(id__,
			    const_pkg994__GasAnalysis_thr) = STM_VS_O(id__,
			    const_pkg994__GasAnalysis_thr)
	
	D__(id__,
			    const_pkg994__GasAnalysis_thr) = STM(id__,
			    const_pkg994__GasAnalysis_thr) \ internal_events
	O__(id__,
			    const_pkg994__GasAnalysis_thr) = sbisim(diamond(D__(id__,
			    const_pkg994__GasAnalysis_thr)))
	VS__(id__,
			    const_pkg994__GasAnalysis_thr) = FVS__(id__,
			    const_pkg994__GasAnalysis_thr)
	VS_O__(id__,
			    const_pkg994__GasAnalysis_thr) = sbisim(diamond(FVS__(id__,
			    const_pkg994__GasAnalysis_thr)))
	HEXT__(id__,
			    const_pkg994__GasAnalysis_thr) = O__(id__,
			    const_pkg994__GasAnalysis_thr) [|shared_variable_events|] SKIP
	HUP__(id__,
			    const_pkg994__GasAnalysis_thr) = O__(id__,
			    const_pkg994__GasAnalysis_thr) [|{share__}|] SKIP
	
	-- Shared memory
	-- Shared memory variables
	
	-- sharedVarMemory process
	sharedVarMemory(id__,
			    const_pkg994__GasAnalysis_thr) = terminate -> SKIP
	
	sharedVarSync = {||}
	
	sharedVarHide = {||}
endmodule
