			 ) ; Trans)
			 []
			 (interrupt -> share__choice(exit -> SKIP) ; share__choice(exited -> terminate -> SKIP))
			 []
			 terminate -> SKIP
		)
		)
	within
		Trans
	)
	)
	
	-- Stateful
	-- RULE: Stateful(stm:StateMachineBody) : CSPProcess
	
	-- Named process definitions
	MachineBody(id__,
			    const_pkg994__GasAnalysis_thr) = 
		dbisim((
		let
			finalNodesEntered = {|j1::entered|}
		within
			((let
				-- IMPLEMENTATION NOTE:
				-- Here the 'enter' channel set is calculated explicitly because of the use of CSPM 
				-- modules for defining the semantics of each node.
				enterSS = {|
				i1::enter,
				NoGas::enter,
				Analysis::enter,
				GasDetected::enter,
				j1::enter,
				Reading::enter
				|}
				hideSet = union(enterSS,{|exit,exited,internal__|})
			within 
				((let
					-- IMPLEMENTATION NOTE: the channel set 'enter' is calculated explicitly
					-- because CSPM modules are used for the semantics of Node.
					flowevts = union(enterSS,{|exit,exited,interrupt|})
					transSync = {|internal__.NID_i1,gas__.NID_NoGas.in,internal__.NID_Analysis,internal__.NID_Analysis,internal__.NID_GasDetected,internal__.NID_GasDetected,gas__.NID_Reading.in|}
				within
					((
					 (((-- RULE composeNodes(nc:NodeContainer)^nops : CSPProcess
					   i1::D__(id__,
					   		    const_pkg994__GasAnalysis_thr)
					   [| { share__, terminate } |] (
					   NoGas::D__(id__,
					   		    const_pkg994__GasAnalysis_thr)
					   [| { share__, terminate } |] (
					   Analysis::D__(id__,
					   		    const_pkg994__GasAnalysis_thr)
					   [| { share__, terminate } |] (
					   GasDetected::D__(id__,
					   		    const_pkg994__GasAnalysis_thr)
					   [| { share__, terminate } |] (
					   j1::D__(id__,
					   		    const_pkg994__GasAnalysis_thr)
					   [| { share__, terminate } |] (
					   Reading::D__(id__,
					   		    const_pkg994__GasAnalysis_thr)
					   )
					   )
					   )
					   )
					   )
					 )
					 [[NoGas::interrupt <- x__ | x__ <- {|interrupt,gas__.NID_NoGas.in|}]]
					 [[Analysis::interrupt <- x__ | x__ <- {|interrupt,internal__.NID_Analysis,internal__.NID_Analysis|}]]
					 [[GasDetected::interrupt <- x__ | x__ <- {|interrupt,internal__.NID_GasDetected,internal__.NID_GasDetected|}]]
					 [[j1::interrupt <- x__ | x__ <- {|interrupt|}]]
					 [[Reading::interrupt <- x__ | x__ <- {|interrupt,gas__.NID_Reading.in|}]]
					 [[i1::interrupt <- x__ | x__ <- {|internal__.NID_i1|}]]
					 )
					  [[ share__ <- x__ | x__ <- {| share__,setR_gs |} ]] 
					  [[set_gs <- setL_gs]]
					 )
					 [| union(union(union(flowevts,transSync),{terminate}),{|share__
					 			,setL_gs
					 			,setR_gs
					 			|}) |]
					 ((i1::enter -> Transitions(id__,
					 		    const_pkg994__GasAnalysis_thr))
					  [[ share__ <- x__ | x__ <- {| share__,setL_gs |} ]]
					  [[set_gs <- setR_gs]]
					 )
					)[[setL_gs <- set_gs]]
					 [[setR_gs <- set_gs]]
					)
				)
				 \ hideSet)
				[[
					gas__.x____ <- gas,
					resume__.x____ <- resume,
					turn__.x____ <- turn,
					stop__.x____ <- stop
					| x____ <- NIDS
				]]
			)
			 [| {| interrupt |} |] SKIP)
		)
		)
	
	Behaviour(id__,
			    const_pkg994__GasAnalysis_thr) = 
		dbisim((MachineBody(id__,
				    const_pkg994__GasAnalysis_thr)\ enteredSS)
		)
	
	IteratedBehaviour(id__,
			    const_pkg994__GasAnalysis_thr) = 
		dbisim((MachineBody(id__,
				    const_pkg994__GasAnalysis_thr)\ enteredSS)
		)
	
	Stateful(id__,
			    const_pkg994__GasAnalysis_thr) = 
		((
			(Behaviour(id__,
					    const_pkg994__GasAnalysis_thr) [| union(getsetLocalChannels,{terminate}) |] varMemory(id__,
					    const_pkg994__GasAnalysis_thr))
		 	\getsetLocalChannels
		)
		)
	
	IteratedStateful(id__,
			    const_pkg994__GasAnalysis_thr) =
		(dbisim(
			sbisim(
				Behaviour(id__,
						    const_pkg994__GasAnalysis_thr)
				[| {|get_gs,set_gs,terminate|} |]
				Memory_gs(<>)
			)\{|get_gs,set_gs|}
		)
		)
	
	-- Visible counterparts
	MachineBody_VS_O(id__,
			    const_pkg994__GasAnalysis_thr) = 
		dbisim((
		let
			finalNodesEntered = {|j1::entered|}
		within
			((let
				-- IMPLEMENTATION NOTE:
				-- Here the 'enter' channel set is calculated explicitly because of the use of CSPM 
				-- modules for defining the semantics of each node.
				enterSS = {|
				i1::enter,
				NoGas::enter,
				Analysis::enter,
				GasDetected::enter,
				j1::enter,
				Reading::enter
				|}
				hideSet = union(enterSS,{|exit,exited,internal__|})
			within 
				((let
					-- IMPLEMENTATION NOTE: the channel set 'enter' is calculated explicitly
					-- because CSPM modules are used for the semantics of Node.
					flowevts = union(enterSS,{|exit,exited,interrupt|})
					transSync = {|internal__.NID_i1,gas__.NID_NoGas.in,internal__.NID_Analysis,internal__.NID_Analysis,internal__.NID_GasDetected,internal__.NID_GasDetected,gas__.NID_Reading.in|}
				within
					((
					 (((-- RULE composeNodes(nc:NodeContainer)^nops : CSPProcess
					   i1::VS_O__(id__,
					   		    const_pkg994__GasAnalysis_thr)
					   [| { share__, terminate } |] (
					   NoGas::VS_O__(id__,
					   		    const_pkg994__GasAnalysis_thr)
					   [| { share__, terminate } |] (
					   Analysis::VS_O__(id__,
					   		    const_pkg994__GasAnalysis_thr)
					   [| { share__, terminate } |] (
					   GasDetected::VS_O__(id__,
					   		    const_pkg994__GasAnalysis_thr)
					   [| { share__, terminate } |] (
					   j1::VS_O__(id__,
					   		    const_pkg994__GasAnalysis_thr)
					   [| { share__, terminate } |] (
					   Reading::VS_O__(id__,
					   		    const_pkg994__GasAnalysis_thr)
					   )
					   )
					   )
					   )
					   )
					 )
					 [[NoGas::interrupt <- x__ | x__ <- {|interrupt,gas__.NID_NoGas.in|}]]
					 [[Analysis::interrupt <- x__ | x__ <- {|interrupt,internal__.NID_Analysis,internal__.NID_Analysis|}]]
					 [[GasDetected::interrupt <- x__ | x__ <- {|interrupt,internal__.NID_GasDetected,internal__.NID_GasDetected|}]]
					 [[j1::interrupt <- x__ | x__ <- {|interrupt|}]]
					 [[Reading::interrupt <- x__ | x__ <- {|interrupt,gas__.NID_Reading.in|}]]
					 [[i1::interrupt <- x__ | x__ <- {|internal__.NID_i1|}]]
					 )
					  [[ share__ <- x__ | x__ <- {| share__,setR_gs |} ]] 
					  [[set_gs <- setL_gs]]
					 )
					 [| union(union(union(flowevts,transSync),{terminate}),{|share__
					 			,setL_gs
					 			,setR_gs
					 			|}) |]
					 ((i1::enter -> Transitions(id__,
					 		    const_pkg994__GasAnalysis_thr))
					  [[ share__ <- x__ | x__ <- {| share__,setL_gs |} ]]
					  [[set_gs <- setR_gs]]
					 )
					)[[setL_gs <- set_gs]]
					 [[setR_gs <- set_gs]]
					)
				)
				 \ hideSet)
				[[
					gas__.x____ <- gas,
					resume__.x____ <- resume,
					turn__.x____ <- turn,
					stop__.x____ <- stop
					| x____ <- NIDS
				]]
			)
			 [| {| interrupt |} |] SKIP)
		)
		)
	
	Behaviour_VS_O(id__,
			    const_pkg994__GasAnalysis_thr) = 
		dbisim((MachineBody_VS_O(id__,
				    const_pkg994__GasAnalysis_thr))
		)
	
	IteratedBehaviour_VS_O(id__,
			    const_pkg994__GasAnalysis_thr) = 
		dbisim((MachineBody_VS_O(id__,
				    const_pkg994__GasAnalysis_thr))
