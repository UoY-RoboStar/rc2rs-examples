							 [] dbisim(((not (false)))&(internal__!NID_EmptyCycle -> SKIP ;  share__choice(exit -> SKIP) ; ((let 
							 	X = share__choice(exited -> SKIP [] endexec -> Y)
							 	Y = share__choice(exited -> SKIP [] startexec -> X)
							  within
							  	X) ; ((endexec -> startexec -> SKIP;share__choice(true & (share__choice(set_resumeF!true -> SKIP)));share__choice(true & (share__choice(set_turnF!true -> SKIP)));share__choice(true & (share__choice(set_stopF!true -> SKIP)));share__choice(true & (share__choice(set_obstacleF!true -> SKIP))))[[ endexec <- endexec_action, startexec <- startexec_action ]]) ; EmptyCycle::enter -> SKIP)))
							 []
							 (exit -> SKIP ; share__choice(exited -> terminate -> SKIP))
							 []
							 terminate -> SKIP
							 []
							 (endexec -> SKIP ; share__choice(startexec -> SKIP))
							 )
						,SKIP);Trans
					within
						Trans [|{terminate}|> SKIP
					)
					)
					
					
					-- Clocks
					Clock_CLID_EmptyCycle(id__,x__,
