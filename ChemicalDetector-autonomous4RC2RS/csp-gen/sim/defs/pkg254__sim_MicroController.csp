							 				 		    const_pkg254__sim_Movement_stuckDist,
							 				 		    const_pkg254__sim_Movement_outPeriod))
							 				  [[ share__ <- x__ | x__ <- {| share__ |} ]]
							 				 )
							 				)
							 				)
							 			)
