			endmodule
			----------------------------------------------------------------------
			
			
			----------------------------------------------------------------------
			-- State: Going
			module Going
			
			enterSS = 
					{|			i::enter,
						EmptyCycle::enter
					|}
			enteredSS = 
					{|			EmptyCycle::entered
					|}
			exports
			
				--  Declarations
				channel endexec__ : NIDS
				
				
				channel enter, entered, interrupt
				channel enteredL, enteredR
				
								
				-- declaring identifiers of transitions
				datatype NIDS = 
				              NID_i|
				              NID_EmptyCycle
				
				channel internal__ : NIDS
				
				channel get_CLID_EmptyCycle : core_clock_type 
				--channel increment__
				
				CLID_EmptyCycle_clock_type(id__,
						          const_pkg254__sim_Movement_lv,
						          const_pkg254__sim_Movement_evadeTime,
						          const_pkg254__sim_Movement_stuckPeriod,
						          const_pkg254__sim_Movement_stuckDist,
						          const_pkg254__sim_Movement_outPeriod) = 
					let
						max = (clock_type_max(Union({
				{}
				}))+1)
					ctype = {0..max}
				within
					if member(max,core_clock_type) then ctype else error("core_clock_type is not wide enough")
				
				
				--	Nodes
				-- declaring all nodes
				
				----------------------------------------------------------------------
				-- Initial: i
				module i
				exports
				
					channel enter, interrupt
					
					Timed(OneStep) {
						D__(id__,cycle_pkg254__sim_Movement_Movement,
								    const_pkg254__sim_Movement_lv,
								    const_pkg254__sim_Movement_evadeTime,
								    const_pkg254__sim_Movement_stuckPeriod,
								    const_pkg254__sim_Movement_stuckDist,
								    const_pkg254__sim_Movement_outPeriod) = 
