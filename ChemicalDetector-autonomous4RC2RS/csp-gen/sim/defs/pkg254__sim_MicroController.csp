							    const_pkg254__sim_Movement_stuckPeriod,
							    const_pkg254__sim_Movement_stuckDist,
							    const_pkg254__sim_Movement_outPeriod) = ((let
						Trans = TimeOut_1(
							 (share__ -> SKIP
							 [] dbisim((true)&(internal__!NID_i -> SKIP ;  ((((SKIP)[[ endexec <- endexec_action, startexec <- startexec_action ]]) ; EmptyCycle::enter -> SKIP))))
							 []
							 (exit -> SKIP ; share__choice(exited -> terminate -> SKIP))
							 []
							 terminate -> SKIP
							 []
							 (endexec -> SKIP ; share__choice(startexec -> SKIP))
							 )
						,SKIP);Trans
					within
						Trans [|{terminate}|> SKIP
					)
					)
					
					
					-- Clocks
					Clock_CLID_EmptyCycle(id__,x__,
							          const_pkg254__sim_Movement_lv,
							          const_pkg254__sim_Movement_evadeTime,
							          const_pkg254__sim_Movement_stuckPeriod,
							          const_pkg254__sim_Movement_stuckDist,
							          const_pkg254__sim_Movement_outPeriod) = 
