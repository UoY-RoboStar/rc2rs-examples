							 			,setL_d1
							 			,setL_turnF
							 			,setL_obstacleF
							 			,setL_odometerF
							 			,setL_resumeF
							 			,setL_d0
							 			,setL_l
							 			,setL_stopF
							 			,clockResetR.CLID_T
							 			 			,setR_a
							 			 			,setR_d1
							 			 			,setR_turnF
							 			 			,setR_obstacleF
							 			 			,setR_odometerF
							 			 			,setR_resumeF
							 			 			,setR_d0
							 			 			,setR_l
							 			 			,setR_stopF
							 			|}) |]
							 ((During)
							  [[ share__ <- x__ | x__ <- {| share__,clockResetL.CLID_T,setL_a,setL_d1,setL_turnF,setL_obstacleF,setL_odometerF,setL_resumeF,setL_d0,setL_l,setL_stopF |} ]]
							  [[clockReset.CLID_T <- clockResetR.CLID_T,set_a <- setR_a,set_d1 <- setR_d1,set_turnF <- setR_turnF,set_obstacleF <- setR_obstacleF,set_odometerF <- setR_odometerF,set_resumeF <- setR_resumeF,set_d0 <- setR_d0,set_l <- setR_l,set_stopF <- setR_stopF]]
							 )
							)[[clockResetL.CLID_T <- clockReset.CLID_T,setL_a <- set_a,setL_d1 <- set_d1,setL_turnF <- set_turnF,setL_obstacleF <- set_obstacleF,setL_odometerF <- set_odometerF,setL_resumeF <- set_resumeF,setL_d0 <- set_d0,setL_l <- set_l,setL_stopF <- set_stopF]]
							 [[clockResetR.CLID_T <- clockReset.CLID_T,setR_a <- set_a,setR_d1 <- set_d1,setR_turnF <- set_turnF,setR_obstacleF <- set_obstacleF,setR_odometerF <- set_odometerF,setR_resumeF <- set_resumeF,setR_d0 <- set_d0,setR_l <- set_l,setR_stopF <- set_stopF]]
							)\union(enteredSS,{terminate}) 
						)
						During 		= share__choice(([] e__ : enteredSS @ e__ -> SKIP))
								 	  ; entered -> ((CRUN(enteredSS) ||| true&CALL__randomWalk(
								 	  			id__,
								 	  		    const_pkg254__sim_Movement_lv,
								 	  		    const_pkg254__sim_Movement_evadeTime,
								 	  		    const_pkg254__sim_Movement_stuckPeriod,
								 	  		    const_pkg254__sim_Movement_stuckDist,
								 	  		    const_pkg254__sim_Movement_outPeriod
								 	  		) ; SStop) /\ interrupt -> share__choice(terminate -> SKIP))
					within
						Inactive [| {terminate} |> SKIP)
						
					VS_O__(id__,cycle_pkg254__sim_Movement_Movement,
							    const_pkg254__sim_Movement_lv,
							    const_pkg254__sim_Movement_evadeTime,
							    const_pkg254__sim_Movement_stuckPeriod,
							    const_pkg254__sim_Movement_stuckDist,
							    const_pkg254__sim_Movement_outPeriod) = 
					dbisim(let
						Inactive 	= share__choice(enter -> SKIP [] terminate -> SKIP) ; Active
						
						Termination = terminate -> SKIP
						
						Active 		= SKIP ; 
								 	  Behaviour ; 
								 	  share__choice(exit -> SKIP) ; SKIP ; 
								 	  share__choice(exited -> SKIP) ; Inactive
					
					
						Behaviour 	= dbisim(
							((
							 (((dbisim(
							 	sbisim(
							 		(let
							 			-- IMPLEMENTATION NOTE:
							 			-- Here the 'enter' channel set is calculated explicitly because of the use of CSPM 
							 			-- modules for defining the semantics of each node.
							 			enterSS = {|
							 			i::enter,
							 			EmptyCycle::enter
							 			|}
							 			hideSet = union(enterSS,{|exit,exited,internal__|})
							 		within 
							 			((let
							 				-- IMPLEMENTATION NOTE: the channel set 'enter' is calculated explicitly
							 				-- because CSPM modules are used for the semantics of Node.
							 				flowevts = union(enterSS,{|exit,exited|})
							 				transSync = {|internal__.NID_i|}
							 			within
							 				((
							 				 (((-- RULE composeNodes(nc:NodeContainer)^nops : CSPProcess
							 				   i::VS_O__(id__,cycle_pkg254__sim_Movement_Movement,
							 				   		    const_pkg254__sim_Movement_lv,
							 				   		    const_pkg254__sim_Movement_evadeTime,
							 				   		    const_pkg254__sim_Movement_stuckPeriod,
							 				   		    const_pkg254__sim_Movement_stuckDist,
							 				   		    const_pkg254__sim_Movement_outPeriod)
							 				   [| { share__, terminate } |] (
							 				   EmptyCycle::VS_O__(id__,cycle_pkg254__sim_Movement_Movement,
							 				   		    const_pkg254__sim_Movement_lv,
							 				   		    const_pkg254__sim_Movement_evadeTime,
							 				   		    const_pkg254__sim_Movement_stuckPeriod,
							 				   		    const_pkg254__sim_Movement_stuckDist,
							 				   		    const_pkg254__sim_Movement_outPeriod)
							 				   )
							 				 )
							 				 [[EmptyCycle::interrupt <- x__ | x__ <- {|interrupt|}]]
							 				 [[i::interrupt <- x__ | x__ <- {|internal__.NID_i|}]]
							 				 )
							 				  [[ share__ <- x__ | x__ <- {| share__ |} ]] 
							 				 )
							 				 [| union(union(union(flowevts,transSync),{|terminate,endexec,startexec|}),{|share__
							 				|}) |]
							 				 ((i::enter -> Transitions(id__,cycle_pkg254__sim_Movement_Movement,
							 				 		    const_pkg254__sim_Movement_lv,
							 				 		    const_pkg254__sim_Movement_evadeTime,
							 				 		    const_pkg254__sim_Movement_stuckPeriod,
							 				 		    const_pkg254__sim_Movement_stuckDist,
							 				 		    const_pkg254__sim_Movement_outPeriod))
							 				  [[ share__ <- x__ | x__ <- {| share__ |} ]]
							 				 )
							 				)
							 				)
							 			)
							 			 \ hideSet)
							 			[[ endexec__.x____  <- endexec | x____ <- NIDS ]]
							 			[[ endexec_action <- endexec ]]
							 			[[ startexec_action <- startexec ]]
							 		)
							 		[| {|get_CLID_EmptyCycle,EmptyCycle::entered,terminate|} |]
							 		dbisim(Clock_CLID_EmptyCycle(id__,0,
							 				          const_pkg254__sim_Movement_lv,
							 				          const_pkg254__sim_Movement_evadeTime,
							 				          const_pkg254__sim_Movement_stuckPeriod,
							 				          const_pkg254__sim_Movement_stuckDist,
							 				          const_pkg254__sim_Movement_outPeriod))
							 	)\{|get_CLID_EmptyCycle|}
							 )
							 ))
							  [[ share__ <- x__ | x__ <- {| share__,clockResetR.CLID_T,setR_a,setR_d1,setR_turnF,setR_obstacleF,setR_odometerF,setR_resumeF,setR_d0,setR_l,setR_stopF |} ]] 
							  [[clockReset.CLID_T <- clockResetL.CLID_T,set_a <- setL_a,set_d1 <- setL_d1,set_turnF <- setL_turnF,set_obstacleF <- setL_obstacleF,set_odometerF <- setL_odometerF,set_resumeF <- setL_resumeF,set_d0 <- setL_d0,set_l <- setL_l,set_stopF <- setL_stopF]]
							 )
