							)
						)
						 \ hideSet)
						[[ endexec__.x____  <- endexec | x____ <- NIDS ]]
						[[ endexec_action <- endexec ]]
						[[ startexec_action <- startexec ]]
					)
					)
					 [| union(stateClockSync,{terminate}) |]
					 StateClocks(id__)
					)\diff(stateClockSync,enteredSS))
					 [| {| interrupt |} |] SKIP)
				)
				)
			
			Behaviour_VS_O(id__) = 
				dbisim((let
					stateClockSync = {||}
				 within
					(MachineBody_VS_O(id__) [| union(stateClockSync,{terminate}) |] StateClocks(id__)) \ diff(union(stateClockSync,enteredSS),enteredSS)
				)
				)
			
			
			Stateful_VS_O(id__) = 
				dbisim((let
					getsetLocalChannels = {||}
					clockSync = {||}
				within
					(Behaviour_VS_O(id__) 
					 [| union(union(getsetLocalChannels,clockSync),{terminate}) |] 
					 (varMemory(id__) [| {terminate} |] Clocks(id__))
				 	)\union(getsetLocalChannels,clockSync)
				)
				)
			
			
			-- END
			
			-- Memory
			-- Memory variables
			
			-- varMemory process
			varMemory(id__) = terminate -> SKIP
			
			getsetLocalChannels = {||}
			
			-- Definition of the behaviour of state machines (default, optimised, visible, visible and optimised)
			FVS__(id__) = STM_VS_O(id__) \ localClockResets
			D__(id__) = timed_priority(STM(id__) \ union(internal_events,localClockResets))
			O__(id__) = dbisim(D__(id__))
			VS__(id__) = FVS__(id__)
			VS_O__(id__) = dbisim(FVS__(id__))
			HEXT__(id__) = O__(id__) [|shared_variable_events|] SKIP
			FVS_C__(id__) = dbisim(timed_priority(STM(id__) \ internal_events))
			HUP__(id__) = timed_priority(O__(id__) [|{share__}|] SKIP)
			
			-- Clocks
			
			Clocks(id__) = terminate -> SKIP
			
			clockSync = {||}
			
			
			StateClocks(id__) = terminate -> SKIP
			
			stateClockSync = {||}
			
			}
				endmodule
	
	Timed(OneStep) {
	-- (Rule 8) cycleController(...) : CSPProcess
	datatype SOutputEvents = SOutput_randomWalk
		| SOutput_shortRandomWalk
		| SOutput_move
		| SOutput_flag
	
	DVarsEvents = {}
	
	EVarsEvents = {}
	
	cycleController(id__,cycle_pkg254__sim_MicroController_MicroController,
			    const_pkg254__sim_MicroController_stm_ref0_lv,
			    const_pkg254__sim_MicroController_stm_ref0_evadeTime,
			    const_pkg254__sim_MicroController_stm_ref0_stuckPeriod,
			    const_pkg254__sim_MicroController_stm_ref0_stuckDist,
			    const_pkg254__sim_MicroController_stm_ref0_outPeriod) =
	let
				
		project_stm_ref0(stm_ref0::o_randomWalk) = SOutput_randomWalk
		project_stm_ref0(stm_ref0::o_shortRandomWalk) = SOutput_shortRandomWalk
		project_stm_ref0(stm_ref0::o_move.x__) = SOutput_move
		project_stm_ref0(stm_ref0::o_flag) = SOutput_flag
	
		connected_stm_ref0(stm_ref0::o_randomWalk) = true
		connected_stm_ref0(stm_ref0::o_shortRandomWalk) = true
		connected_stm_ref0(stm_ref0::o_move.x__) = true
		connected_stm_ref0(stm_ref0::o_flag) = true
		connected_stm_ref0(_) = false
	
		lift_stm_ref0(stm_ref0::o_randomWalk) = o_randomWalk
		lift_stm_ref0(stm_ref0::o_shortRandomWalk) = o_shortRandomWalk
		lift_stm_ref0(stm_ref0::o_move.x__) = o_move.x__
		lift_stm_ref0(stm_ref0::o_flag) = o_flag
		
		CycleController =
			Deadline(
			-- read inputs from the controller and pass to state machines
			(
			((registerRead.i_turn?x__ ->
				((stm_ref0::registerRead.stm_ref0::i_turn!x__ -> SKIP)))
				|||
			(registerRead.i_stop?x__ ->
				((stm_ref0::registerRead.stm_ref0::i_stop!x__ -> SKIP)))
				|||
			(registerRead.i_odometer?x__ ->
				((stm_ref0::registerRead.stm_ref0::i_odometer!x__ -> SKIP)))
				|||
			(registerRead.i_resume?x__ ->
				((stm_ref0::registerRead.stm_ref0::i_resume!x__ -> SKIP)))
				|||
			(registerRead.i_obstacle?x__ ->
				((stm_ref0::registerRead.stm_ref0::i_obstacle!x__ -> SKIP))))
			-- ensure state machines read the values being communicated via evars
					);
			-- synchronize on events related to evars to erase memory
			-- collect outputs, and monitor termination of the cycle, by all controllers
			(CollectOutputs(SOutputEvents) [| {endexec} |] Monitor),0);
			-- wait for the cycleDef period
			TimeOut_1(terminate -> SKIP,WAIT(cycle_pkg254__sim_MicroController_MicroController-1));
			-- recurse
			CycleController
			
									
		CollectOutputs(sout) =
			(stm_ref0::registerWrite?outp:{ outp | outc <- diff(sout,union(EVarsEvents,DVarsEvents)), outp <- stm_ref0::RegisterDataOutput, connected_stm_ref0(outp), project_stm_ref0(outp) == outc}
					-> registerWrite!lift_stm_ref0(outp)
						-> CollectOutputs(diff(sout,{project_stm_ref0(outp)}))
			[]
			endexec -> SKIP
			)
	
		Monitor = 
			(	 (stm_ref0::endexec -> SKIP)); endexec -> SKIP
	within
		CycleController
	
	-- (Rule 5) memoryComp(...) : CSPProcess
	memoryComp(id__,
			    const_pkg254__sim_MicroController_stm_ref0_lv,
			    const_pkg254__sim_MicroController_stm_ref0_evadeTime,
			    const_pkg254__sim_MicroController_stm_ref0_stuckPeriod,
			    const_pkg254__sim_MicroController_stm_ref0_stuckDist,
			    const_pkg254__sim_MicroController_stm_ref0_outPeriod) = (
		STOP)
	
	
	-- (Rule 7) [[ c : Controller ]]_C : CSPProcess
	D__(id__,cycle_pkg254__sim_MicroController_MicroController,
			    const_pkg254__sim_MicroController_stm_ref0_lv,
			    const_pkg254__sim_MicroController_stm_ref0_evadeTime,
			    const_pkg254__sim_MicroController_stm_ref0_stuckPeriod,
			    const_pkg254__sim_MicroController_stm_ref0_stuckDist,
			    const_pkg254__sim_MicroController_stm_ref0_outPeriod) =
	timed_priority(
		(
			(
				(
					(
					dbisim(cycleController(id__,cycle_pkg254__sim_MicroController_MicroController,
							    const_pkg254__sim_MicroController_stm_ref0_lv,
							    const_pkg254__sim_MicroController_stm_ref0_evadeTime,
							    const_pkg254__sim_MicroController_stm_ref0_stuckPeriod,
							    const_pkg254__sim_MicroController_stm_ref0_stuckDist,
							    const_pkg254__sim_MicroController_stm_ref0_outPeriod))
				 	 [| Union({{||},
				 	 		  {||},
				 	 		  {||},
				 	 		  {||}}) |]
				 	memoryComp(id__,
				 			    const_pkg254__sim_MicroController_stm_ref0_lv,
				 			    const_pkg254__sim_MicroController_stm_ref0_evadeTime,
				 			    const_pkg254__sim_MicroController_stm_ref0_stuckPeriod,
				 			    const_pkg254__sim_MicroController_stm_ref0_stuckDist,
				 			    const_pkg254__sim_MicroController_stm_ref0_outPeriod)
				 	)\{||}
					[| {| 	terminate,tock,
							stm_ref0::endexec,stm_ref0::registerRead,stm_ref0::registerWrite|} |]
					-- (Rule 9) composeMachines(...) : CSPProcess
				 	((let
				 		const_pkg254__sim_Movement_lv = const_pkg254__sim_MicroController_stm_ref0_lv
				 		const_pkg254__sim_Movement_evadeTime = const_pkg254__sim_MicroController_stm_ref0_evadeTime
				 		const_pkg254__sim_Movement_stuckPeriod = const_pkg254__sim_MicroController_stm_ref0_stuckPeriod
				 		const_pkg254__sim_Movement_stuckDist = const_pkg254__sim_MicroController_stm_ref0_stuckDist
				 		const_pkg254__sim_Movement_outPeriod = const_pkg254__sim_MicroController_stm_ref0_outPeriod
				 		cycle_pkg254__sim_Movement_Movement = cycle_pkg254__sim_MicroController_MicroController
				 	within
				 		(stm_ref0::D__(id__,cycle_pkg254__sim_Movement_Movement,
				 				    const_pkg254__sim_Movement_lv,
				 				    const_pkg254__sim_Movement_evadeTime,
				 				    const_pkg254__sim_Movement_stuckPeriod,
				 				    const_pkg254__sim_Movement_stuckDist,
				 				    const_pkg254__sim_Movement_outPeriod)
				 		\{| |})
				 		[[stm_ref0::terminate <- terminate]]
				 	)
				 	)
				) \ {|	stm_ref0::endexec,stm_ref0::registerRead,stm_ref0::registerWrite |}
			) [| {terminate} |> SKIP
		)
	)
	
	O__(id__,cycle_pkg254__sim_MicroController_MicroController,
			    const_pkg254__sim_MicroController_stm_ref0_lv,
			    const_pkg254__sim_MicroController_stm_ref0_evadeTime,
			    const_pkg254__sim_MicroController_stm_ref0_stuckPeriod,
			    const_pkg254__sim_MicroController_stm_ref0_stuckDist,
			    const_pkg254__sim_MicroController_stm_ref0_outPeriod) = 
	timed_priority(
		dbisim(
			(
				(
					(
					dbisim(cycleController(id__,cycle_pkg254__sim_MicroController_MicroController,
							    const_pkg254__sim_MicroController_stm_ref0_lv,
							    const_pkg254__sim_MicroController_stm_ref0_evadeTime,
							    const_pkg254__sim_MicroController_stm_ref0_stuckPeriod,
							    const_pkg254__sim_MicroController_stm_ref0_stuckDist,
							    const_pkg254__sim_MicroController_stm_ref0_outPeriod))
				 	 [| Union({{||},
				 	 		  {||},
				 	 		  {||},
				 	 		  {||}}) |]
				 	memoryComp(id__,
				 			    const_pkg254__sim_MicroController_stm_ref0_lv,
				 			    const_pkg254__sim_MicroController_stm_ref0_evadeTime,
				 			    const_pkg254__sim_MicroController_stm_ref0_stuckPeriod,
				 			    const_pkg254__sim_MicroController_stm_ref0_stuckDist,
				 			    const_pkg254__sim_MicroController_stm_ref0_outPeriod)
				 	)\{||}
					[| {| 	terminate,tock,
							stm_ref0::endexec,stm_ref0::registerRead,stm_ref0::registerWrite|} |]
					-- (Rule 9) composeMachines(...) : CSPProcess
				 	((let
				 		const_pkg254__sim_Movement_lv = const_pkg254__sim_MicroController_stm_ref0_lv
				 		const_pkg254__sim_Movement_evadeTime = const_pkg254__sim_MicroController_stm_ref0_evadeTime
				 		const_pkg254__sim_Movement_stuckPeriod = const_pkg254__sim_MicroController_stm_ref0_stuckPeriod
				 		const_pkg254__sim_Movement_stuckDist = const_pkg254__sim_MicroController_stm_ref0_stuckDist
				 		const_pkg254__sim_Movement_outPeriod = const_pkg254__sim_MicroController_stm_ref0_outPeriod
				 		cycle_pkg254__sim_Movement_Movement = cycle_pkg254__sim_MicroController_MicroController
				 	within
				 		(stm_ref0::O__(id__,cycle_pkg254__sim_Movement_Movement,
				 				    const_pkg254__sim_Movement_lv,
				 				    const_pkg254__sim_Movement_evadeTime,
				 				    const_pkg254__sim_Movement_stuckPeriod,
				 				    const_pkg254__sim_Movement_stuckDist,
				 				    const_pkg254__sim_Movement_outPeriod)
				 		\{| |})
				 		[[stm_ref0::terminate <- terminate]]
				 	)
				 	)
				) \ {|	stm_ref0::endexec,stm_ref0::registerRead,stm_ref0::registerWrite |}
			) [| {terminate} |> SKIP
		)
	)
	}
endmodule
