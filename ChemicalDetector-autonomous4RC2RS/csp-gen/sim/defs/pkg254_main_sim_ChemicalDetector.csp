						--channel increment__
						
						
						--	Nodes
						-- declaring all nodes
						
						
						Timed(OneStep) {
							--	Rule: behaviours(Node)
							--  Note that FDR has problems with efficiently compiling the process below
							-- 	if using a different recursion pattern.
							D__(id__,cycle_pkg254__sim_GasAnalysis_GasAnalysis,
									    const_pkg254__sim_GasAnalysis_thr) = 
							dbisim(let
								-- IMPLEMENTATION NOTE: 
								-- The following should be defined as: Inactive = share__choice(Activation [] Termination),
								-- however FDR struggles with that form in certain cases. So we use the exception operator
								-- instead to 'terminate'.
								
								Inactive 	= share__choice(enter -> SKIP [] terminate -> SKIP) ; Active
								
								Termination = terminate -> SKIP
								
								Active 		= SKIP ; 
										 	  Behaviour ; 
										 	  share__choice(exit -> SKIP) ; SKIP ; 
										 	  share__choice(exited -> SKIP) ; Inactive
							
								Behaviour 	= entered -> During
								During 		= ((SKIP ; SStop) /\ interrupt -> SKIP)
							within
								Inactive [| {terminate} |> SKIP)
								
							VS_O__(id__,cycle_pkg254__sim_GasAnalysis_GasAnalysis,
									    const_pkg254__sim_GasAnalysis_thr) = 
							dbisim(let
								Inactive 	= share__choice(enter -> SKIP [] terminate -> SKIP) ; Active
								
								Termination = terminate -> SKIP
								
								Active 		= SKIP ; 
										 	  Behaviour ; 
										 	  share__choice(exit -> SKIP) ; SKIP ; 
										 	  share__choice(exited -> SKIP) ; Inactive
							
								Behaviour 	= entered -> During
								During 		= ((SKIP ; SStop) /\ interrupt -> SKIP)
							within
								Inactive [| {terminate} |> SKIP)
							
							
							-- Clocks
							
							StateClocks(id__,
									          const_pkg254__sim_GasAnalysis_thr) = terminate -> SKIP
							
							stateClockSync = {||}
						}
					
					endmodule
					----------------------------------------------------------------------
					
					
					
					Timed(OneStep) {
						--	Rule: behaviours(Node)
						--  Note that FDR has problems with efficiently compiling the process below
						-- 	if using a different recursion pattern.
						D__(id__,cycle_pkg254__sim_GasAnalysis_GasAnalysis,
								    const_pkg254__sim_GasAnalysis_thr) = 
						dbisim(let
							-- IMPLEMENTATION NOTE: 
							-- The following should be defined as: Inactive = share__choice(Activation [] Termination),
							-- however FDR struggles with that form in certain cases. So we use the exception operator
							-- instead to 'terminate'.
							
							Inactive 	= share__choice(enter -> SKIP [] terminate -> SKIP) ; Active
							
							Termination = terminate -> SKIP
							
							Active 		= SKIP ; 
									 	  Behaviour ; 
									 	  share__choice(exit -> SKIP) ; SKIP ; 
									 	  share__choice(exited -> SKIP) ; Inactive
						
						
							Behaviour 	= dbisim(
								((
								 (((dbisim(
								 	sbisim(
								 		(let
								 			-- IMPLEMENTATION NOTE:
								 			-- Here the 'enter' channel set is calculated explicitly because of the use of CSPM 
								 			-- modules for defining the semantics of each node.
								 			enterSS = {|
								 			i::enter,
								 			EmptyCycle::enter
								 			|}
								 			hideSet = union(enterSS,{|exit,exited,internal__|})
								 		within 
								 			((let
								 				-- IMPLEMENTATION NOTE: the channel set 'enter' is calculated explicitly
								 				-- because CSPM modules are used for the semantics of Node.
								 				flowevts = union(enterSS,{|exit,exited|})
								 				transSync = {|internal__.NID_i,internal__.NID_EmptyCycle|}
								 			within
								 				((
								 				 (((-- RULE composeNodes(nc:NodeContainer)^nops : CSPProcess
								 				   i::D__(id__,cycle_pkg254__sim_GasAnalysis_GasAnalysis,
								 				   		    const_pkg254__sim_GasAnalysis_thr)
								 				   [| { share__, terminate } |] (
								 				   EmptyCycle::D__(id__,cycle_pkg254__sim_GasAnalysis_GasAnalysis,
								 				   		    const_pkg254__sim_GasAnalysis_thr)
								 				   )
								 				 )
								 				 [[EmptyCycle::interrupt <- x__ | x__ <- {|interrupt,internal__.NID_EmptyCycle|}]]
								 				 [[i::interrupt <- x__ | x__ <- {|internal__.NID_i|}]]
								 				 )
								 				  [[ share__ <- x__ | x__ <- {| share__ |} ]] 
								 				  [[set_gasF <- setL_gasF]]
								 				 )
								 				 [| union(union(union(flowevts,transSync),{|terminate,endexec,startexec|}),{|share__
								 				 			,setL_gasF
								 				|}) |]
								 				 ((i::enter -> Transitions(id__,cycle_pkg254__sim_GasAnalysis_GasAnalysis,
								 				 		    const_pkg254__sim_GasAnalysis_thr))
								 				  [[ share__ <- x__ | x__ <- {| share__,setL_gasF |} ]]
								 				 )
								 				)[[setL_gasF <- set_gasF]]
								 				)
								 			)
								 			 \ hideSet)
								 			[[ endexec__.x____  <- endexec | x____ <- NIDS ]]
								 			[[ endexec_action <- endexec ]]
								 			[[ startexec_action <- startexec ]]
								 		)
								 		[| {|get_CLID_EmptyCycle,EmptyCycle::entered,terminate|} |]
								 		dbisim(Clock_CLID_EmptyCycle(id__,0,
								 				          const_pkg254__sim_GasAnalysis_thr))
								 	)\{|get_CLID_EmptyCycle|}
								 )
								 ))
								  [[ share__ <- x__ | x__ <- {| share__,setR_gasF,setR_gs |} ]] 
								  [[set_gasF <- setL_gasF,set_gs <- setL_gs]]
								 )
								 [| union(union(enteredSS,{| interrupt, terminate |}),{|share__
								 			,setL_gasF
								 			,setL_gs
								 			,setR_gasF
								 			 			,setR_gs
								 			|}) |]
								 ((During)
								  [[ share__ <- x__ | x__ <- {| share__,setL_gasF,setL_gs |} ]]
								  [[set_gasF <- setR_gasF,set_gs <- setR_gs]]
								 )
								)[[setL_gasF <- set_gasF,setL_gs <- set_gs]]
								 [[setR_gasF <- set_gasF,setR_gs <- set_gs]]
