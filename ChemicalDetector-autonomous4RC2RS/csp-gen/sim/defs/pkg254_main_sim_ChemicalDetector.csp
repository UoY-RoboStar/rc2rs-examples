					 	 		  {||}}) |]
					 	memoryComp(id__,
					 			    const_pkg254__sim_MainController_stm_ref0_thr)
					 	)\{||}
						[| {| 	terminate,tock,
								stm_ref0::endexec,stm_ref0::registerRead,stm_ref0::registerWrite|} |]
						-- (Rule 9) composeMachines(...) : CSPProcess
					 	((let
					 		const_pkg254__sim_GasAnalysis_thr = const_pkg254__sim_MainController_stm_ref0_thr
					 		cycle_pkg254__sim_GasAnalysis_GasAnalysis = cycle_pkg254__sim_MainController_MainController
					 	within
					 		(stm_ref0::D__(id__,cycle_pkg254__sim_GasAnalysis_GasAnalysis,
					 				    const_pkg254__sim_GasAnalysis_thr)
					 		\{| |})
					 		[[stm_ref0::terminate <- terminate]]
					 	)
					 	)
					) \ {|	stm_ref0::endexec,stm_ref0::registerRead,stm_ref0::registerWrite |}
				) [| {terminate} |> SKIP
			)
		)
		
		O__(id__,cycle_pkg254__sim_MainController_MainController,
				    const_pkg254__sim_MainController_stm_ref0_thr) = 
		timed_priority(
			dbisim(
				(
					(
						(
						dbisim(cycleController(id__,cycle_pkg254__sim_MainController_MainController,
								    const_pkg254__sim_MainController_stm_ref0_thr))
					 	 [| Union({{||},
					 	 		  {||},
					 	 		  {||},
					 	 		  {||}}) |]
					 	memoryComp(id__,
					 			    const_pkg254__sim_MainController_stm_ref0_thr)
					 	)\{||}
						[| {| 	terminate,tock,
								stm_ref0::endexec,stm_ref0::registerRead,stm_ref0::registerWrite|} |]
						-- (Rule 9) composeMachines(...) : CSPProcess
					 	((let
					 		const_pkg254__sim_GasAnalysis_thr = const_pkg254__sim_MainController_stm_ref0_thr
					 		cycle_pkg254__sim_GasAnalysis_GasAnalysis = cycle_pkg254__sim_MainController_MainController
					 	within
					 		(stm_ref0::O__(id__,cycle_pkg254__sim_GasAnalysis_GasAnalysis,
					 				    const_pkg254__sim_GasAnalysis_thr)
					 		\{| |})
					 		[[stm_ref0::terminate <- terminate]]
					 	)
					 	)
					) \ {|	stm_ref0::endexec,stm_ref0::registerRead,stm_ref0::registerWrite |}
				) [| {terminate} |> SKIP
			)
		)
		}
	endmodule
	
	-- declaring inputs and outputs of the module
	
	Timed(OneStep) {
	-- (Rule 3) cycleModule(...) : CSPProcess
	
	datatype COutputEvents = COutput_turn
		| COutput_randomWalk
		| COutput_resume
		| COutput_shortRandomWalk
		| COutput_flag
		| COutput_stop
		| COutput_move
	
	nametype EVarsEvents = {|COutput_turn
		, COutput_resume
		, COutput_stop|}	
	
	
	cycleModule(id__,cycle_pkg254_main_sim_ChemicalDetector_ChemicalDetector) =
	let 
					
		project_ctrl_ref1(ctrl_ref1::o_turn.x__) = COutput_turn
		project_ctrl_ref1(ctrl_ref1::o_resume) = COutput_resume
		project_ctrl_ref1(ctrl_ref1::o_stop) = COutput_stop
		project_ctrl_ref0(ctrl_ref0::o_randomWalk) = COutput_randomWalk
		project_ctrl_ref0(ctrl_ref0::o_shortRandomWalk) = COutput_shortRandomWalk
		project_ctrl_ref0(ctrl_ref0::o_flag) = COutput_flag
		project_ctrl_ref0(ctrl_ref0::o_move.x__) = COutput_move
		
		connected_ctrl_ref1(ctrl_ref1::o_turn.x__) = true
		connected_ctrl_ref1(ctrl_ref1::o_resume) = true
		connected_ctrl_ref1(ctrl_ref1::o_stop) = true
		connected_ctrl_ref1(_) = false
		connected_ctrl_ref0(ctrl_ref0::o_randomWalk) = true
		connected_ctrl_ref0(ctrl_ref0::o_shortRandomWalk) = true
		connected_ctrl_ref0(ctrl_ref0::o_flag) = true
		connected_ctrl_ref0(ctrl_ref0::o_move.x__) = true
		connected_ctrl_ref0(_) = false
	
		lift_ctrl_ref0(ctrl_ref0::o_randomWalk) = o_randomWalk
		lift_ctrl_ref0(ctrl_ref0::o_shortRandomWalk) = o_shortRandomWalk
		lift_ctrl_ref0(ctrl_ref0::o_flag) = o_flag
		lift_ctrl_ref0(ctrl_ref0::o_move.x__) = o_move.x__
	
		CycleModule =
			Deadline(
			-- read inputs from the platform and pass to controllers
			(
			((registerRead.i_obstacle?x__ ->
				ctrl_ref0::registerRead.ctrl_ref0::i_obstacle!x__ -> SKIP)
				|||
			(registerRead.i_gas?x__ ->
				ctrl_ref1::registerRead.ctrl_ref1::i_gas!x__ -> SKIP)
				|||
			(registerRead.i_odometer?x__ ->
				ctrl_ref0::registerRead.ctrl_ref0::i_odometer!x__ -> SKIP))
			||| ((ctrl_ref0::registerRead.ctrl_ref0::i_turn?x__ -> SKIP)
				|||
			
	(ctrl_ref0::registerRead.ctrl_ref0::i_resume?x__ -> SKIP)
				|||
			
	(ctrl_ref0::registerRead.ctrl_ref0::i_stop?x__ -> SKIP)
	)		);
			-- synchronize on events related to evars
			((registerWriteE.e_turn -> SKIP)
				|||
			(registerWriteE.e_resume -> SKIP)
				|||
			(registerWriteE.e_stop -> SKIP));
			-- collect outputs, and monitor termination of the cycle, by all controllers
			(CollectOutputs(COutputEvents) [| {endexec} |] Monitor),0);
			-- wait for the cycleDef period
			TimeOut_1(terminate -> SKIP,WAIT(cycle_pkg254_main_sim_ChemicalDetector_ChemicalDetector-1));
			-- recurse
			CycleModule
								
		CollectOutputs(sout) =
			(
			ctrl_ref0::registerWrite?outp:{ outp | outc <- diff(sout,EVarsEvents), outp <- ctrl_ref0::RegisterDataOutput, connected_ctrl_ref0(outp), project_ctrl_ref0(outp) == outc}
			 	-> registerWrite!lift_ctrl_ref0(outp)
			 		-> CollectOutputs(diff(sout,{project_ctrl_ref0(outp)}))
			[]
			ctrl_ref1::registerWrite?outp:{ outp | outc <- inter(sout,EVarsEvents), outp <- ctrl_ref1::RegisterDataOutput, connected_ctrl_ref1(outp), project_ctrl_ref1(outp) == outc}
				-> CollectOutputs(diff(sout,{project_ctrl_ref1(outp)}))
			[]
			endexec -> SKIP
			)
			
		Monitor = 
			(	 (ctrl_ref0::endexec -> SKIP)
			|||	 (ctrl_ref1::endexec -> SKIP)); endexec -> SKIP
		
	within
		CycleModule 
	
	-- (Rule 5) memoryComp(...) : CSPProcess
	memoryComp(id__) = (
		Memory_turn(false.Chemical_Angle_Left)
		||| Memory_resume(false)
		||| Memory_stop(false)
		)
	
	Memory_turn(x__) = (
		registerWriteE.e_turn -> Memory_turn(false.Chemical_Angle_Left)
		[]
		ctrl_ref1::registerWrite.ctrl_ref1::o_turn?x__ -> Memory_turn(true.x__)
		[]
		ctrl_ref0::registerRead.ctrl_ref0::i_turn!x__ -> Memory_turn(x__)
	)
	Memory_resume(x__) = (
		registerWriteE.e_resume -> Memory_resume(false)
		[]
		ctrl_ref1::registerWrite.ctrl_ref1::o_resume -> Memory_resume(true)
		[]
		ctrl_ref0::registerRead.ctrl_ref0::i_resume!x__ -> Memory_resume(x__)
	)
	Memory_stop(x__) = (
		registerWriteE.e_stop -> Memory_stop(false)
		[]
		ctrl_ref1::registerWrite.ctrl_ref1::o_stop -> Memory_stop(true)
		[]
		ctrl_ref0::registerRead.ctrl_ref0::i_stop!x__ -> Memory_stop(x__)
	)
	
	-- (Rule 1) [[ M : SimModule ]]_M : CSPProcess
	D__(id__,cycle_pkg254_main_sim_ChemicalDetector_ChemicalDetector,
			    const_pkg254__sim_MicroController_stm_ref0_lv,
			    const_pkg254__sim_MicroController_stm_ref0_evadeTime,
			    const_pkg254__sim_MicroController_stm_ref0_stuckPeriod,
			    const_pkg254__sim_MicroController_stm_ref0_stuckDist,
			    const_pkg254__sim_MicroController_stm_ref0_outPeriod,
			    const_pkg254__sim_MainController_stm_ref0_thr) =
	timed_priority(
		(
			(
				(
					(
						dbisim(cycleModule(id__,cycle_pkg254_main_sim_ChemicalDetector_ChemicalDetector))
								[| Union({{||},
										  {|registerWriteE|},
										  {|ctrl_ref0::registerRead.ctrl_ref0::i_turn,
										  	ctrl_ref0::registerRead.ctrl_ref0::i_resume,
										  	ctrl_ref0::registerRead.ctrl_ref0::i_stop|},
										  {|ctrl_ref1::registerWrite.ctrl_ref1::o_turn,
										  	ctrl_ref1::registerWrite.ctrl_ref1::o_resume,
										  	ctrl_ref1::registerWrite.ctrl_ref1::o_stop|}}) |]
									memoryComp(id__)
						)\{|registerWriteE|}
					[| {| 	terminate,tock,
							ctrl_ref0::endexec,ctrl_ref0::registerRead,ctrl_ref0::registerWrite,
							ctrl_ref1::endexec,ctrl_ref1::registerRead,ctrl_ref1::registerWrite	|} |]
					-- (Rule 6) composeControllers(...) : CSPProcess
						((
							(let
									cycle_pkg254__sim_MicroController_MicroController = cycle_pkg254_main_sim_ChemicalDetector_ChemicalDetector
								within
									(ctrl_ref0::D__(id__,cycle_pkg254__sim_MicroController_MicroController,
											    const_pkg254__sim_MicroController_stm_ref0_lv,
											    const_pkg254__sim_MicroController_stm_ref0_evadeTime,
											    const_pkg254__sim_MicroController_stm_ref0_stuckPeriod,
											    const_pkg254__sim_MicroController_stm_ref0_stuckDist,
											    const_pkg254__sim_MicroController_stm_ref0_outPeriod)
									\{| |})
										[[ctrl_ref0::terminate <- terminate]]
								)
							[|{tock,terminate}|]
							(let
									cycle_pkg254__sim_MainController_MainController = cycle_pkg254_main_sim_ChemicalDetector_ChemicalDetector
								within
									(ctrl_ref1::D__(id__,cycle_pkg254__sim_MainController_MainController,
											    const_pkg254__sim_MainController_stm_ref0_thr)
									\{| |})
										[[ctrl_ref1::terminate <- terminate]]
								)
						)
						)
				) \ {|	endexec,
						ctrl_ref0::endexec,ctrl_ref0::registerRead,ctrl_ref0::registerWrite,
						ctrl_ref1::endexec,ctrl_ref1::registerRead,ctrl_ref1::registerWrite |}
			) [| {terminate} |> SKIP
		) \ {terminate}
	)
	
	
	
	O__(id__,cycle_pkg254_main_sim_ChemicalDetector_ChemicalDetector,
			    const_pkg254__sim_MicroController_stm_ref0_lv,
			    const_pkg254__sim_MicroController_stm_ref0_evadeTime,
			    const_pkg254__sim_MicroController_stm_ref0_stuckPeriod,
			    const_pkg254__sim_MicroController_stm_ref0_stuckDist,
			    const_pkg254__sim_MicroController_stm_ref0_outPeriod,
			    const_pkg254__sim_MainController_stm_ref0_thr) =
	timed_priority(
		(
			(
				(
					(
						dbisim(cycleModule(id__,cycle_pkg254_main_sim_ChemicalDetector_ChemicalDetector))
								[| Union({{||},
										  {|registerWriteE|},
										  {|ctrl_ref0::registerRead.ctrl_ref0::i_turn,
										  	ctrl_ref0::registerRead.ctrl_ref0::i_resume,
										  	ctrl_ref0::registerRead.ctrl_ref0::i_stop|},
										  {|ctrl_ref1::registerWrite.ctrl_ref1::o_turn,
										  	ctrl_ref1::registerWrite.ctrl_ref1::o_resume,
										  	ctrl_ref1::registerWrite.ctrl_ref1::o_stop|}}) |]
									memoryComp(id__)
						)\{|registerWriteE|}
					[| {| 	terminate,tock,
							ctrl_ref0::endexec,ctrl_ref0::registerRead,ctrl_ref0::registerWrite,
							ctrl_ref1::endexec,ctrl_ref1::registerRead,ctrl_ref1::registerWrite	|} |]
					-- (Rule 6) composeControllers(...) : CSPProcess
						((
							(let
									cycle_pkg254__sim_MicroController_MicroController = cycle_pkg254_main_sim_ChemicalDetector_ChemicalDetector
								within
									(ctrl_ref0::O__(id__,cycle_pkg254__sim_MicroController_MicroController,
											    const_pkg254__sim_MicroController_stm_ref0_lv,
											    const_pkg254__sim_MicroController_stm_ref0_evadeTime,
											    const_pkg254__sim_MicroController_stm_ref0_stuckPeriod,
											    const_pkg254__sim_MicroController_stm_ref0_stuckDist,
											    const_pkg254__sim_MicroController_stm_ref0_outPeriod)
									\{| |})
										[[ctrl_ref0::terminate <- terminate]]
								)
							[|{tock,terminate}|]
							(let
									cycle_pkg254__sim_MainController_MainController = cycle_pkg254_main_sim_ChemicalDetector_ChemicalDetector
								within
									(ctrl_ref1::O__(id__,cycle_pkg254__sim_MainController_MainController,
											    const_pkg254__sim_MainController_stm_ref0_thr)
									\{| |})
										[[ctrl_ref1::terminate <- terminate]]
								)
						)
						)
				) \ {|	endexec,
						ctrl_ref0::endexec,ctrl_ref0::registerRead,ctrl_ref0::registerWrite,
						ctrl_ref1::endexec,ctrl_ref1::registerRead,ctrl_ref1::registerWrite |}
			) [| {terminate} |> SKIP
		) \ {terminate}
	)
	}
endmodule
