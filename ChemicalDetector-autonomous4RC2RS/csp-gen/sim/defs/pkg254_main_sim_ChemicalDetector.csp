			connected_stm_ref0(stm_ref0::o_move.x__) = true
			connected_stm_ref0(stm_ref0::o_randomWalk) = true
			connected_stm_ref0(stm_ref0::o_flag) = true
			connected_stm_ref0(_) = false
		
			lift_stm_ref0(stm_ref0::o_shortRandomWalk) = o_shortRandomWalk
			lift_stm_ref0(stm_ref0::o_move.x__) = o_move.x__
			lift_stm_ref0(stm_ref0::o_randomWalk) = o_randomWalk
			lift_stm_ref0(stm_ref0::o_flag) = o_flag
			
			CycleController =
				Deadline(
				-- read inputs from the controller and pass to state machines
				(
				((registerRead.i_odometer?x__ ->
					((stm_ref0::registerRead.stm_ref0::i_odometer!x__ -> SKIP)))
					|||
				(registerRead.i_turn?x__ ->
					((stm_ref0::registerRead.stm_ref0::i_turn!x__ -> SKIP)))
					|||
				(registerRead.i_obstacle?x__ ->
					((stm_ref0::registerRead.stm_ref0::i_obstacle!x__ -> SKIP)))
					|||
				(registerRead.i_stop?x__ ->
					((stm_ref0::registerRead.stm_ref0::i_stop!x__ -> SKIP)))
					|||
				(registerRead.i_resume?x__ ->
					((stm_ref0::registerRead.stm_ref0::i_resume!x__ -> SKIP))))
				-- ensure state machines read the values being communicated via evars
						);
				-- synchronize on events related to evars to erase memory
				-- collect outputs, and monitor termination of the cycle, by all controllers
				(CollectOutputs(SOutputEvents) [| {endexec} |] Monitor),0);
				-- wait for the cycleDef period
				TimeOut_1(terminate -> SKIP,WAIT(cycle_pkg254__sim_MicroController_MicroController-1));
				-- recurse
				CycleController
				
										
			CollectOutputs(sout) =
				(stm_ref0::registerWrite?outp:{ outp | outc <- diff(sout,union(EVarsEvents,DVarsEvents)), outp <- stm_ref0::RegisterDataOutput, connected_stm_ref0(outp), project_stm_ref0(outp) == outc}
						-> registerWrite!lift_stm_ref0(outp)
							-> CollectOutputs(diff(sout,{project_stm_ref0(outp)}))
				[]
				endexec -> SKIP
				)
		
			Monitor = 
				(	 (stm_ref0::endexec -> SKIP)); endexec -> SKIP
		within
			CycleController
		
		-- (Rule 5) memoryComp(...) : CSPProcess
		memoryComp(id__,
				    const_pkg254__sim_MicroController_stm_ref0_lv,
				    const_pkg254__sim_MicroController_stm_ref0_evadeTime,
				    const_pkg254__sim_MicroController_stm_ref0_stuckPeriod,
				    const_pkg254__sim_MicroController_stm_ref0_stuckDist,
				    const_pkg254__sim_MicroController_stm_ref0_outPeriod) = (
			STOP)
		
		
		-- (Rule 7) [[ c : Controller ]]_C : CSPProcess
		D__(id__,cycle_pkg254__sim_MicroController_MicroController,
				    const_pkg254__sim_MicroController_stm_ref0_lv,
				    const_pkg254__sim_MicroController_stm_ref0_evadeTime,
				    const_pkg254__sim_MicroController_stm_ref0_stuckPeriod,
				    const_pkg254__sim_MicroController_stm_ref0_stuckDist,
				    const_pkg254__sim_MicroController_stm_ref0_outPeriod) =
		timed_priority(
			(
				(
					(
						(
						dbisim(cycleController(id__,cycle_pkg254__sim_MicroController_MicroController,
								    const_pkg254__sim_MicroController_stm_ref0_lv,
								    const_pkg254__sim_MicroController_stm_ref0_evadeTime,
								    const_pkg254__sim_MicroController_stm_ref0_stuckPeriod,
								    const_pkg254__sim_MicroController_stm_ref0_stuckDist,
								    const_pkg254__sim_MicroController_stm_ref0_outPeriod))
					 	 [| Union({{||},
					 	 		  {||},
					 	 		  {||},
					 	 		  {||}}) |]
					 	memoryComp(id__,
					 			    const_pkg254__sim_MicroController_stm_ref0_lv,
