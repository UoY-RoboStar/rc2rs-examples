					 			    const_pkg254__sim_MicroController_stm_ref0_stuckPeriod,
					 			    const_pkg254__sim_MicroController_stm_ref0_stuckDist,
					 			    const_pkg254__sim_MicroController_stm_ref0_outPeriod)
					 	)\{||}
						[| {| 	terminate,tock,
								stm_ref0::endexec,stm_ref0::registerRead,stm_ref0::registerWrite|} |]
						-- (Rule 9) composeMachines(...) : CSPProcess
					 	((let
					 		const_pkg254__sim_Movement_lv = const_pkg254__sim_MicroController_stm_ref0_lv
					 		const_pkg254__sim_Movement_evadeTime = const_pkg254__sim_MicroController_stm_ref0_evadeTime
					 		const_pkg254__sim_Movement_stuckPeriod = const_pkg254__sim_MicroController_stm_ref0_stuckPeriod
					 		const_pkg254__sim_Movement_stuckDist = const_pkg254__sim_MicroController_stm_ref0_stuckDist
					 		const_pkg254__sim_Movement_outPeriod = const_pkg254__sim_MicroController_stm_ref0_outPeriod
					 		cycle_pkg254__sim_Movement_Movement = cycle_pkg254__sim_MicroController_MicroController
					 	within
					 		(stm_ref0::D__(id__,cycle_pkg254__sim_Movement_Movement,
					 				    const_pkg254__sim_Movement_lv,
					 				    const_pkg254__sim_Movement_evadeTime,
					 				    const_pkg254__sim_Movement_stuckPeriod,
					 				    const_pkg254__sim_Movement_stuckDist,
					 				    const_pkg254__sim_Movement_outPeriod)
					 		\{| |})
					 		[[stm_ref0::terminate <- terminate]]
					 	)
					 	)
					) \ {|	stm_ref0::endexec,stm_ref0::registerRead,stm_ref0::registerWrite |}
				) [| {terminate} |> SKIP
			)
		)
		
		O__(id__,cycle_pkg254__sim_MicroController_MicroController,
				    const_pkg254__sim_MicroController_stm_ref0_lv,
				    const_pkg254__sim_MicroController_stm_ref0_evadeTime,
				    const_pkg254__sim_MicroController_stm_ref0_stuckPeriod,
				    const_pkg254__sim_MicroController_stm_ref0_stuckDist,
				    const_pkg254__sim_MicroController_stm_ref0_outPeriod) = 
		timed_priority(
			dbisim(
				(
					(
						(
						dbisim(cycleController(id__,cycle_pkg254__sim_MicroController_MicroController,
								    const_pkg254__sim_MicroController_stm_ref0_lv,
								    const_pkg254__sim_MicroController_stm_ref0_evadeTime,
								    const_pkg254__sim_MicroController_stm_ref0_stuckPeriod,
								    const_pkg254__sim_MicroController_stm_ref0_stuckDist,
