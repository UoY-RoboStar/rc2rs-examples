						 				          const_pkg254__Movement_stuckDist,
						 				          const_pkg254__Movement_outPeriod))
						 	)\{|get_CLID_EmptyCycle|}
						 )
						 ))
						  [[ share__ <- x__ | x__ <- {| share__,clockResetR.CLID_T,setR_l,setR_d0,setR_d1,setR_a |} ]] 
						  [[clockReset.CLID_T <- clockResetL.CLID_T,set_l <- setL_l,set_d0 <- setL_d0,set_d1 <- setL_d1,set_a <- setL_a]]
