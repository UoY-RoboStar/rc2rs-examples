									 (((-- RULE composeNodes(nc:NodeContainer)^nops : CSPProcess
									   Waiting::D__(id__,
									   			param_i)
									   [| { share__, terminate } |] (
									   i0::D__(id__,
									   			param_i)
									   [| { share__, terminate } |] (
