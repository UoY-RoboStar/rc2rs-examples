					getsetLocalChannels = {||}
					
					-- Definition of the behaviour of state machines (default, optimised, visible, visible and optimised)
					FVS__(id__,
								param_d) = STM_VS_O(id__,
								param_d) \ localClockResets
					D__(id__,
								param_d) = timed_priority(STM(id__,
