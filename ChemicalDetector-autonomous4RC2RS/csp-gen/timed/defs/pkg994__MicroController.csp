						)
						
						
						-- Clocks
						Clock_CLID_EmptyCycle(id__,x__) = 
							TimeOut_1(
								EmptyCycle::entered -> Clock_CLID_EmptyCycle(id__,0)
								[]
								get_CLID_EmptyCycle!x__ -> Clock_CLID_EmptyCycle(id__,x__)
								[]
								terminate -> SKIP,Clock_CLID_EmptyCycle(id__,clock_type_plus(x__,1,CLID_EmptyCycle_clock_type(id__))))
						
						StateClocks(id__) = dbisim(Clock_CLID_EmptyCycle(id__,0))
						
						stateClockSync = {|get_CLID_EmptyCycle,EmptyCycle::entered|}
					}
				
				endmodule
				----------------------------------------------------------------------
				
