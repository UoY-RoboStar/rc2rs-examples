								 		dbisim(Clock_CLID_EmptyCycle(id__,0,
								 				          const_pkg994__Movement_lv,
								 				          const_pkg994__Movement_evadeTime,
								 				          const_pkg994__Movement_stuckPeriod,
								 				          const_pkg994__Movement_stuckDist,
								 				          const_pkg994__Movement_outPeriod))
								 	)\{|get_CLID_EmptyCycle|}
								 )
								 ))
								  [[ share__ <- x__ | x__ <- {| share__,setR_d0,setR_a,clockResetR.CLID_T,setR_d1,setR_l |} ]] 
								  [[set_d0 <- setL_d0,set_a <- setL_a,clockReset.CLID_T <- clockResetL.CLID_T,set_d1 <- setL_d1,set_l <- setL_l]]
								 )
								 [| union(union(enteredSS,{| interrupt, terminate |}),{|share__
								 			,setL_d0
								 			,setL_a
								 			,clockResetL.CLID_T
								 			,setL_d1
								 			,setL_l
								 			,setR_d0
								 			 			,setR_a
								 			 			,clockResetR.CLID_T
								 			 			,setR_d1
								 			 			,setR_l
								 			|}) |]
								 ((During)
								  [[ share__ <- x__ | x__ <- {| share__,setL_d0,setL_a,clockResetL.CLID_T,setL_d1,setL_l |} ]]
								  [[set_d0 <- setR_d0,set_a <- setR_a,clockReset.CLID_T <- clockResetR.CLID_T,set_d1 <- setR_d1,set_l <- setR_l]]
								 )
								)[[setL_d0 <- set_d0,setL_a <- set_a,clockResetL.CLID_T <- clockReset.CLID_T,setL_d1 <- set_d1,setL_l <- set_l]]
								 [[setR_d0 <- set_d0,setR_a <- set_a,clockResetR.CLID_T <- clockReset.CLID_T,setR_d1 <- set_d1,setR_l <- set_l]]
								)\union(enteredSS,{terminate}) 
							)
							During 		= share__choice(([] e__ : enteredSS @ e__ -> SKIP))
