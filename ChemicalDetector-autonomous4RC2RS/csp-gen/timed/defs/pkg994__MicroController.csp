					--channel increment__
					
					CLID_EmptyCycle_clock_type(id__,
							          const_pkg994__Movement_lv,
							          const_pkg994__Movement_evadeTime,
							          const_pkg994__Movement_stuckPeriod,
							          const_pkg994__Movement_stuckDist,
							          const_pkg994__Movement_outPeriod) = 
						let
							max = (clock_type_max(Union({
					}))+1)
						ctype = {0..max}
					within
						if member(max,core_clock_type) then ctype else error("core_clock_type is not wide enough")
					
					
					--	Nodes
					-- declaring all nodes
					
					----------------------------------------------------------------------
					-- Initial: i
					module i
					exports
					
