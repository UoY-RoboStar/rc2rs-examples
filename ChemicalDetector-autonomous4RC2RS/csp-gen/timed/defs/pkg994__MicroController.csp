									 	  share__choice(exited -> SKIP) ; Inactive
						
						
							Behaviour 	= dbisim(
								((
								 (((dbisim(
								 	sbisim(
								 		(let
								 			-- IMPLEMENTATION NOTE:
								 			-- Here the 'enter' channel set is calculated explicitly because of the use of CSPM 
								 			-- modules for defining the semantics of each node.
								 			enterSS = {|
								 			i::enter,
