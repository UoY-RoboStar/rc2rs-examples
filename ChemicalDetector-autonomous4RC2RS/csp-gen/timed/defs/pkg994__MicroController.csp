					channel obstacle__: NIDS.InOut.Location_Loc
					channel odometer__: NIDS.InOut.core_real
					channel resume__: NIDS.InOut
					channel turn__: NIDS.InOut.Chemical_Angle
					channel stop__: NIDS.InOut
