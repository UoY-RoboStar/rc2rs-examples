operation clone_normal_GasAnalysis_GasDetected_t9a_op ( ) {
	uses I_events_normal_GasAnalysis_GasDetected_t9a_op requires req_normal_GasAnalysis_GasDetected_t9a_op initial i
	final f
	transition t {
		from i
		to f
		action turn ! location ( gs )
	}
