package pkg994_ import Chemical::analysis import Chemical::Angle import Chemical::goreq import Chemical::intensity import Chemical::location import Chemical::Status import Location::Loc interface I_events_normal_GasAnalysis_Analysis_t3_op {
	event resume
}

