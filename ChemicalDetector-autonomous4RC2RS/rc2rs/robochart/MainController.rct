package pkg994_ import Chemical::Angle import Chemical::Status import Location::Loc controller MainController {
	event turn : Angle 
	event stop
	event gas : Seq( Chemical::GasSensor )
	event resume
	opref MainController_ref_normal_GasAnalysis_Analysis_t3_op = pkg994_::normal_GasAnalysis_Analysis_t3_op
	opref MainController_ref_normal_GasAnalysis_GasDetected_t8_op = pkg994_::normal_GasAnalysis_GasDetected_t8_op
	opref MainController_ref_normal_GasAnalysis_GasDetected_t9a_op = pkg994_::normal_GasAnalysis_GasDetected_t9a_op
	opref MainController_ref_tStop = pkg994_ChemicalDetector::tStop
	opref MainController_ref_deadlineCheck = pkg994_ChemicalDetector::deadlineCheck
	opref MainController_ref_waitOp = pkg994_ChemicalDetector::waitOp
	opref MainController_ref_waitInterval = pkg994_ChemicalDetector::waitInterval
	opref MainController_ref_clone_normal_GasAnalysis_GasDetected_t8_op = pkg994_::clone_normal_GasAnalysis_GasDetected_t8_op
	opref MainController_ref_clone_normal_GasAnalysis_Analysis_t3_op = pkg994_::clone_normal_GasAnalysis_Analysis_t3_op
	opref MainController_ref_clone_normal_GasAnalysis_GasDetected_t9a_op = pkg994_::clone_normal_GasAnalysis_GasDetected_t9a_op
	sref stm_ref0 = pkg994_::GasAnalysis
	connection MainController on gas to stm_ref0 on gas
	connection stm_ref0 on turn to MainController on turn
	connection stm_ref0 on stop to MainController on stop
	connection stm_ref0 on resume to MainController on resume
}

