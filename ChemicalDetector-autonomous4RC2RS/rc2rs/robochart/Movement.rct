operation clone_normal_Movement_GettingOut_entry_clone_waitOp_j_2_4_f ( i : nat
) {
	state Waiting {
		state EmptyCycle {
		}
		initial i
		transition t {
			from i
			to EmptyCycle
		}
	}
	initial i0
	final f
	transition t2 {
		from Waiting
		to f
		condition since ( C ) == i
	}
	transition t {
		from i0
		to Waiting
		action # C
	}
	clock C
}

