stm Movement {
	requires pkg254_main::Operations requires I_clone_normal_Movement_TryingAgain_t11_op requires I_clone_normal_Movement_GettingOut_entry requires I_clone_normal_Movement_Avoiding_entry requires I_clone_normal_Movement_Found_entry const lv : real , evadeTime : nat , stuckPeriod : nat , stuckDist : real , outPeriod : nat
	var a : Angle , d0 : real , d1 : real
	var l : Location::Loc
	event obstacle : Location::Loc
	event odometer : real
	event resume
	event turn : Angle
	event stop
	event flag
	initial i1
	state Waiting {
		initial i
		state EmptyCycle {
		}
		transition tWaiting {
			from i
			to EmptyCycle
		}
		during randomWalk ( )
	}
	state Going {
		state EmptyCycle {
		}
		initial i
		transition tGoing {
			from i
			to EmptyCycle
		}
		entry move ( lv , a )
	}
	state Found {
		state EmptyCycle {
		}
		initial i
		transition tFound {
			from i
			to EmptyCycle
		}
		entry clone_normal_Movement_Found_entry ( )
	}
	final j1
	state Avoiding {
		initial i
		state EmptyCycle {
		}
		transition tAvoiding {
			from i
			to EmptyCycle
		}
		entry clone_normal_Movement_Avoiding_entry ( )
	}
	state TryingAgain {
		initial i
		state EmptyCycle {
		}
		transition tTryingAgain {
			from i
			to EmptyCycle
		}
		entry move ( lv , a )
	}
	state AvoidingAgain {
		state EmptyCycle {
		}
		initial i
		transition tAvoidingAgain {
			from i
			to EmptyCycle
		}
	}
	state GettingOut {
		state EmptyCycle {
		}
		initial i
		transition tGettingOut {
			from i
			to EmptyCycle
		}
		entry clone_normal_Movement_GettingOut_entry ( )
	}
	transition t1 {
		from i1
		to Waiting
	}
	transition t2 {
		from Waiting
		to Going
		trigger turn ? a
	}
	transition t3 {
		from Going
		to Going
		trigger turn ? a
	}
	transition t4 {
		from Going
		to Found
		trigger stop
	}
	transition t5 {
		from Found
		to j1
	}
	transition t6 {
		from Going
		to Avoiding
		trigger obstacle ? l
		# T
	}
	transition t7 {
		from Avoiding
		to TryingAgain
		trigger turn ? a
	}
	transition t8 {
		from TryingAgain
		to TryingAgain
		trigger turn ? a
	}
	transition t9 {
		from TryingAgain
		to Found
		trigger stop
	}
	transition t10 {
		from TryingAgain
		to Waiting
		trigger resume
	}
	transition t11 {
		from TryingAgain
		to AvoidingAgain
		trigger obstacle ? l
		action clone_normal_Movement_TryingAgain_t11_op ( )
	}
	transition t12 {
		from AvoidingAgain
		to Avoiding
		# T
		condition since ( T ) < stuckPeriod \/ d1 - d0 > stuckDist
	}
	transition t13 {
		from AvoidingAgain
		to GettingOut
		condition since ( T ) >= stuckPeriod /\ d1 - d0 <= stuckDist
	}
	transition t14 {
		from GettingOut
		to Going
		trigger turn ? a
	}
	transition t0 {
		from Waiting
		to Waiting
		trigger resume
	}
	transition t15 {
		from Waiting
		to Found
		trigger stop
	}
	transition t16 {
		from GettingOut
		to Found
		trigger stop
	}
	transition t17 {
		from AvoidingAgain
		to Found
		trigger stop
	}
	transition t18 {
		from Avoiding
		to Found
		trigger stop
	}
	transition t19 {
		from Avoiding
		to Waiting
		trigger resume
	}
	transition t20 {
		from GettingOut
		to Waiting
		trigger resume
	}
	transition t21 {
		from Avoiding
		to Going
		trigger resume
	}
	transition t22 {
		from AvoidingAgain
		to Waiting
		trigger resume
	}
	clock T
}

operation normal_Movement_Avoiding_entry ( ) {
	uses I_events_normal_Movement_Avoiding_entry requires req_normal_Movement_Avoiding_entry requires pkg254_main::I_waitOp requires I_normal_Movement_Avoiding_entry_j_3_3_t_3_3_op requires I_normal_Movement_Avoiding_entry_i_t_op initial i
	final f
	junction j_3_3
	junction j_2_5
	transition t {
		from i
		to j_3_3
		action normal_Movement_Avoiding_entry_i_t_op ( )
	}
	transition t_3_3 {
		from j_3_3
		to j_2_5
		action normal_Movement_Avoiding_entry_j_3_3_t_3_3_op ( )
	}
	transition t_2_5 {
		from j_2_5
		to f
		action waitOp ( evadeTime )
	}
}

