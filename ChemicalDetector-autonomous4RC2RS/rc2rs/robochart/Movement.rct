operation clone_normal_Movement_Avoiding_entry ( ) {
	uses I_events_normal_Movement_Avoiding_entry requires req_normal_Movement_Avoiding_entry requires pkg254_main::I_waitOp requires I_normal_Movement_Avoiding_entry_j_3_3_t_3_3_op requires I_normal_Movement_Avoiding_entry_i_t_op requires I_clone_normal_Movement_Avoiding_entry_j_3_3_t_3_3_op_j_3_3_j_2_5 requires I_clone_normal_Movement_Avoiding_entry_i_t_op_i_j_3_3 requires I_clone_normal_Movement_Avoiding_entry_clone_waitOp_j_2_5_f initial i
