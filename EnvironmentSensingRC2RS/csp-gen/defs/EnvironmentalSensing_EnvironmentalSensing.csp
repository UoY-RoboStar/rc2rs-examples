						dbisim(let
							Inactive 	= share__choice(enter -> SKIP [] terminate -> SKIP) ; Entering
							
							Entering 	= entered -> SKIP ; Active
							Active		= share__choice(terminate -> SKIP [] interrupt -> SKIP) ; Interrupted
							Interrupted	= share__choice(exit -> exited -> Inactive)
						within
							Inactive [| {terminate} |> SKIP)
						
					VS_O__(id__,
							    const_SourceAnalysis_thr) = D__(id__,
							    const_SourceAnalysis_thr)
				
				endmodule
				----------------------------------------------------------------------
				
				
				----------------------------------------------------------------------
				-- State: Reading
				module Reading
				
				enterSS = {}
				
				enteredSS = {}
				
				exports
				
					--  Declarations
					
					channel enter, entered, interrupt
					channel enteredL, enteredR
					
									
					
					--	Nodes
					-- declaring all nodes
					
					
					--	Rule: behaviours(Node)
					--  Note that FDR has problems with efficiently compiling the process below
					-- 	if using a different recursion pattern.
					D__(id__,
							    const_SourceAnalysis_thr) = 
					dbisim(let
						-- IMPLEMENTATION NOTE: 
						-- The following should be defined as: Inactive = share__choice(Activation [] Termination),
						-- however FDR struggles with that form in certain cases. So we use the exception operator
						-- instead to 'terminate'.
						
						Inactive 	= share__choice(enter -> SKIP [] terminate -> SKIP) ; Active
						
						Termination = terminate -> SKIP
						
						Active 		= SKIP ; 
								 	  Behaviour ; 
								 	  share__choice(exit -> SKIP) ; SKIP ; 
								 	  share__choice(exited -> SKIP) ; Inactive
					
						Behaviour 	= entered -> During
						During 		= ((SKIP ; SStop) /\ interrupt -> SKIP)
					within
						Inactive [| {terminate} |> SKIP)
						
					VS_O__(id__,
							    const_SourceAnalysis_thr) = 
					dbisim(let
						Inactive 	= share__choice(enter -> SKIP [] terminate -> SKIP) ; Active
						
						Termination = terminate -> SKIP
						
						Active 		= SKIP ; 
								 	  Behaviour ; 
								 	  share__choice(exit -> SKIP) ; SKIP ; 
								 	  share__choice(exited -> SKIP) ; Inactive
					
						Behaviour 	= entered -> During
						During 		= ((SKIP ; SStop) /\ interrupt -> SKIP)
					within
						Inactive [| {terminate} |> SKIP)
					
				
				endmodule
				----------------------------------------------------------------------
				
				-- END of Nodes --
				
				-- Operation calls --
				-- Only the undefined operations are declared here.
				-- If the state machine is in isolation, all required operations will be undefined.
				-- If it is in the context of a controller, the required operations not provided by the
				-- controller will be declared here, and the defined operations will be defined in the
				-- context of the Controller module, and therefore within scope of the state machine module.
				
				-- END of Operation calls --
				
				-- STM processes
				STM(id__,
						    const_SourceAnalysis_thr) = -- RULE: [[stm:StateMachineDef]]_STM^nops : CSPProcess
				( 
					(
						(
							(IteratedStateful(id__,
									    const_SourceAnalysis_thr) \ {terminate} ; share__choice(terminate -> SKIP))
						 	[[ share__ <- x__ | x__ <- {||} ]]
						)
					[| {share__} |]
					SKIP
					)
					[| union(sharedVarSync,{terminate}) |]
					dbisim(sharedVarMemory(id__,
							    const_SourceAnalysis_thr))
				)\sharedVarHide
				
				STM_VS_O(id__,
						    const_SourceAnalysis_thr) = -- RULE: [[stm:StateMachineDef]]_STM^nops : CSPProcess
				( 
					(
						(
							(IteratedStateful_VS_O(id__,
									    const_SourceAnalysis_thr) \ {terminate} ; share__choice(terminate -> SKIP))
						 	[[ share__ <- x__ | x__ <- {||} ]]
						)
					[| {share__} |]
					SKIP
					)
					[| union(sharedVarSync,{terminate}) |]
					dbisim(sharedVarMemory(id__,
							    const_SourceAnalysis_thr))
				)\sharedVarHide
				
				-- Transitions
				Transitions(id__,
						    const_SourceAnalysis_thr) = ((let
					Trans = share__choice(get_gs?gs -> (
						((share__ -> SKIP
						 [] dbisim((true)&(internal__!NID_i1 -> SKIP ;  ((SKIP ; NoSource::enter -> SKIP))))
						 	 [] dbisim((true)&(s__!NID_NoSource.in?gs:{gs|gs <- LSeq(core_real,2), true} -> share__choice(set_gs!gs -> SKIP) ;  share__choice(exit -> SKIP) ; (share__choice(exited -> SKIP) ; SKIP ; Analysis::enter -> SKIP)))
						 	 [] dbisim(((analysis(gs)==Status_noSource))&(internal__!NID_Analysis -> SKIP ;  share__choice(exit -> SKIP) ; (share__choice(exited -> SKIP) ; true&(share__choice(resume.out -> SKIP)) ; NoSource::enter -> SKIP)))
						 	 [] dbisim(((analysis(gs)==Status_sourceD))&(internal__!NID_Analysis -> SKIP ;  share__choice(exit -> SKIP) ; (share__choice(exited -> SKIP) ; SKIP ; SourceDetected::enter -> SKIP)))
						 	 [] dbisim((gt(intensity(gs),const_SourceAnalysis_thr))&(internal__!NID_SourceDetected -> SKIP ;  share__choice(exit -> SKIP) ; (share__choice(exited -> SKIP) ; true&(share__choice(stop.out -> SKIP)) ; j1::enter -> SKIP)))
						 	 [] dbisim(((not (gt(intensity(gs),const_SourceAnalysis_thr))))&(internal__!NID_SourceDetected -> SKIP ;  share__choice(exit -> SKIP) ; (share__choice(exited -> SKIP) ; share__choice(get_gs?gs -> true&(share__choice(turn.out!location(gs) -> SKIP))) ; Reading::enter -> SKIP)))
						 	 [] dbisim((true)&(s__!NID_Reading.in?gs:{gs|gs <- LSeq(core_real,2), true} -> share__choice(set_gs!gs -> SKIP) ;  share__choice(exit -> SKIP) ; (share__choice(exited -> SKIP) ; SKIP ; Analysis::enter -> SKIP)))
						 ) ; Trans)
						 []
						 (interrupt -> share__choice(exit -> SKIP) ; share__choice(exited -> terminate -> SKIP))
						 []
						 terminate -> SKIP
					)
					)
				within
					Trans
				)
				)
				
				-- Stateful
				-- RULE: Stateful(stm:StateMachineBody) : CSPProcess
				
				-- Named process definitions
				MachineBody(id__,
						    const_SourceAnalysis_thr) = 
					dbisim((
					let
						finalNodesEntered = {|j1::entered|}
					within
						((let
							-- IMPLEMENTATION NOTE:
							-- Here the 'enter' channel set is calculated explicitly because of the use of CSPM 
							-- modules for defining the semantics of each node.
							enterSS = {|
							i1::enter,
							NoSource::enter,
							Analysis::enter,
							SourceDetected::enter,
							j1::enter,
							Reading::enter
							|}
							hideSet = union(enterSS,{|exit,exited,internal__|})
						within 
							((let
								-- IMPLEMENTATION NOTE: the channel set 'enter' is calculated explicitly
								-- because CSPM modules are used for the semantics of Node.
								flowevts = union(enterSS,{|exit,exited,interrupt|})
								transSync = {|internal__.NID_i1,s__.NID_NoSource.in,internal__.NID_Analysis,internal__.NID_Analysis,internal__.NID_SourceDetected,internal__.NID_SourceDetected,s__.NID_Reading.in|}
							within
								((
								 (((-- RULE composeNodes(nc:NodeContainer)^nops : CSPProcess
								   i1::D__(id__,
								   		    const_SourceAnalysis_thr)
								   [| { share__, terminate } |] (
								   NoSource::D__(id__,
								   		    const_SourceAnalysis_thr)
								   [| { share__, terminate } |] (
								   Analysis::D__(id__,
								   		    const_SourceAnalysis_thr)
								   [| { share__, terminate } |] (
								   SourceDetected::D__(id__,
								   		    const_SourceAnalysis_thr)
								   [| { share__, terminate } |] (
								   j1::D__(id__,
								   		    const_SourceAnalysis_thr)
								   [| { share__, terminate } |] (
								   Reading::D__(id__,
								   		    const_SourceAnalysis_thr)
								   )
								   )
								   )
								   )
								   )
								 )
								 [[NoSource::interrupt <- x__ | x__ <- {|interrupt,s__.NID_NoSource.in|}]]
								 [[Analysis::interrupt <- x__ | x__ <- {|interrupt,internal__.NID_Analysis,internal__.NID_Analysis|}]]
								 [[SourceDetected::interrupt <- x__ | x__ <- {|interrupt,internal__.NID_SourceDetected,internal__.NID_SourceDetected|}]]
								 [[j1::interrupt <- x__ | x__ <- {|interrupt|}]]
								 [[Reading::interrupt <- x__ | x__ <- {|interrupt,s__.NID_Reading.in|}]]
								 [[i1::interrupt <- x__ | x__ <- {|internal__.NID_i1|}]]
								 )
								  [[ share__ <- x__ | x__ <- {| share__,setR_gs |} ]] 
								  [[set_gs <- setL_gs]]
								 )
								 [| union(union(union(flowevts,transSync),{terminate}),{|share__
								 			,setL_gs
								 			,setR_gs
								 			|}) |]
								 ((i1::enter -> Transitions(id__,
								 		    const_SourceAnalysis_thr))
								  [[ share__ <- x__ | x__ <- {| share__,setL_gs |} ]]
								  [[set_gs <- setR_gs]]
								 )
								)[[setL_gs <- set_gs]]
								 [[setR_gs <- set_gs]]
								)
							)
							 \ hideSet)
							[[
								s__.x____ <- s,
								resume__.x____ <- resume,
								turn__.x____ <- turn,
								stop__.x____ <- stop
								| x____ <- NIDS
							]]
						)
						 [| {| interrupt |} |] SKIP)
					)
					)
				
				Behaviour(id__,
						    const_SourceAnalysis_thr) = 
					dbisim((MachineBody(id__,
							    const_SourceAnalysis_thr)\ enteredSS)
					)
				
				IteratedBehaviour(id__,
						    const_SourceAnalysis_thr) = 
					dbisim((MachineBody(id__,
							    const_SourceAnalysis_thr)\ enteredSS)
					)
				
				Stateful(id__,
						    const_SourceAnalysis_thr) = 
					((
						(Behaviour(id__,
								    const_SourceAnalysis_thr) [| union(getsetLocalChannels,{terminate}) |] varMemory(id__,
								    const_SourceAnalysis_thr))
					 	\getsetLocalChannels
					)
					)
				
				IteratedStateful(id__,
						    const_SourceAnalysis_thr) =
					(dbisim(
						sbisim(
							Behaviour(id__,
									    const_SourceAnalysis_thr)
							[| {|get_gs,set_gs,terminate|} |]
							Memory_gs(<>)
						)\{|get_gs,set_gs|}
					)
					)
				
				-- Visible counterparts
				MachineBody_VS_O(id__,
						    const_SourceAnalysis_thr) = 
					dbisim((
					let
						finalNodesEntered = {|j1::entered|}
					within
						((let
							-- IMPLEMENTATION NOTE:
							-- Here the 'enter' channel set is calculated explicitly because of the use of CSPM 
							-- modules for defining the semantics of each node.
							enterSS = {|
							i1::enter,
							NoSource::enter,
							Analysis::enter,
							SourceDetected::enter,
							j1::enter,
							Reading::enter
							|}
							hideSet = union(enterSS,{|exit,exited,internal__|})
						within 
							((let
								-- IMPLEMENTATION NOTE: the channel set 'enter' is calculated explicitly
								-- because CSPM modules are used for the semantics of Node.
								flowevts = union(enterSS,{|exit,exited,interrupt|})
								transSync = {|internal__.NID_i1,s__.NID_NoSource.in,internal__.NID_Analysis,internal__.NID_Analysis,internal__.NID_SourceDetected,internal__.NID_SourceDetected,s__.NID_Reading.in|}
							within
								((
								 (((-- RULE composeNodes(nc:NodeContainer)^nops : CSPProcess
								   i1::VS_O__(id__,
								   		    const_SourceAnalysis_thr)
								   [| { share__, terminate } |] (
								   NoSource::VS_O__(id__,
								   		    const_SourceAnalysis_thr)
								   [| { share__, terminate } |] (
								   Analysis::VS_O__(id__,
								   		    const_SourceAnalysis_thr)
								   [| { share__, terminate } |] (
								   SourceDetected::VS_O__(id__,
								   		    const_SourceAnalysis_thr)
								   [| { share__, terminate } |] (
								   j1::VS_O__(id__,
								   		    const_SourceAnalysis_thr)
								   [| { share__, terminate } |] (
								   Reading::VS_O__(id__,
								   		    const_SourceAnalysis_thr)
								   )
								   )
								   )
								   )
								   )
								 )
								 [[NoSource::interrupt <- x__ | x__ <- {|interrupt,s__.NID_NoSource.in|}]]
								 [[Analysis::interrupt <- x__ | x__ <- {|interrupt,internal__.NID_Analysis,internal__.NID_Analysis|}]]
								 [[SourceDetected::interrupt <- x__ | x__ <- {|interrupt,internal__.NID_SourceDetected,internal__.NID_SourceDetected|}]]
								 [[j1::interrupt <- x__ | x__ <- {|interrupt|}]]
								 [[Reading::interrupt <- x__ | x__ <- {|interrupt,s__.NID_Reading.in|}]]
								 [[i1::interrupt <- x__ | x__ <- {|internal__.NID_i1|}]]
								 )
								  [[ share__ <- x__ | x__ <- {| share__,setR_gs |} ]] 
								  [[set_gs <- setL_gs]]
								 )
								 [| union(union(union(flowevts,transSync),{terminate}),{|share__
								 			,setL_gs
								 			,setR_gs
								 			|}) |]
								 ((i1::enter -> Transitions(id__,
								 		    const_SourceAnalysis_thr))
								  [[ share__ <- x__ | x__ <- {| share__,setL_gs |} ]]
								  [[set_gs <- setR_gs]]
								 )
								)[[setL_gs <- set_gs]]
								 [[setR_gs <- set_gs]]
								)
							)
							 \ hideSet)
							[[
								s__.x____ <- s,
								resume__.x____ <- resume,
								turn__.x____ <- turn,
								stop__.x____ <- stop
								| x____ <- NIDS
							]]
						)
						 [| {| interrupt |} |] SKIP)
					)
					)
				
				Behaviour_VS_O(id__,
						    const_SourceAnalysis_thr) = 
					dbisim((MachineBody_VS_O(id__,
							    const_SourceAnalysis_thr))
					)
				
				IteratedBehaviour_VS_O(id__,
						    const_SourceAnalysis_thr) = 
					dbisim((MachineBody_VS_O(id__,
							    const_SourceAnalysis_thr))
					)
				
				Stateful_VS_O(id__,
						    const_SourceAnalysis_thr) = 
					dbisim((
						(Behaviour_VS_O(id__,
								    const_SourceAnalysis_thr) [| union(getsetLocalChannels,{terminate}) |] varMemory(id__,
								    const_SourceAnalysis_thr))
					 	\getsetLocalChannels
					)
					)
				
				IteratedStateful_VS_O(id__,
						    const_SourceAnalysis_thr) =
					(dbisim(
						sbisim(
							Behaviour_VS_O(id__,
									    const_SourceAnalysis_thr)
							[| {|get_gs,set_gs,terminate|} |]
							Memory_gs(<>)
						)\{|get_gs,set_gs|}
					)
					)
				
				-- END
				
				-- Memory
				-- Memory variables
				Memory_gs(gs) =
					get_gs!gs -> Memory_gs(gs)
					[]
					set_gs?x__ -> Memory_gs(x__)
					[]
					terminate -> SKIP
				
				-- varMemory process
				varMemory(id__,
						    const_SourceAnalysis_thr) = Memory_gs(<>)
				
				getsetLocalChannels = {|get_gs,set_gs|}
				
				-- Definition of the behaviour of state machines (default, optimised, visible, visible and optimised)
				FVS__(id__,
						    const_SourceAnalysis_thr) = STM_VS_O(id__,
						    const_SourceAnalysis_thr)
				
				D__(id__,
						    const_SourceAnalysis_thr) = STM(id__,
						    const_SourceAnalysis_thr) \ internal_events
				O__(id__,
						    const_SourceAnalysis_thr) = sbisim(diamond(D__(id__,
						    const_SourceAnalysis_thr)))
				VS__(id__,
						    const_SourceAnalysis_thr) = FVS__(id__,
						    const_SourceAnalysis_thr)
				VS_O__(id__,
						    const_SourceAnalysis_thr) = sbisim(diamond(FVS__(id__,
						    const_SourceAnalysis_thr)))
				HEXT__(id__,
						    const_SourceAnalysis_thr) = O__(id__,
						    const_SourceAnalysis_thr) [|shared_variable_events|] SKIP
				HUP__(id__,
						    const_SourceAnalysis_thr) = O__(id__,
						    const_SourceAnalysis_thr) [|{share__}|] SKIP
				
				-- Shared memory
				-- Shared memory variables
				
				-- sharedVarMemory process
				sharedVarMemory(id__,
						    const_SourceAnalysis_thr) = terminate -> SKIP
				
				sharedVarSync = {||}
				
				sharedVarHide = {||}
			endmodule
			
				-- undefined operations
				
				-- declaring controller memory
				Memory(id__) = SKIP
				
				D__(id__,
						    const_MainController_stm_ref0_thr) = 	((
						let
							const_SourceAnalysis_thr = const_MainController_stm_ref0_thr
						within 
						stm_ref0::D__(id__,
								    const_SourceAnalysis_thr)[[
							stm_ref0::terminate <- terminate,
							stm_ref0::s <- s,
							stm_ref0::turn <- turn,
							stm_ref0::stop <- stop,
							stm_ref0::resume <- resume
						]]
					)
						[|
							union(
								{|
								|},
								{|
								|}
							)
						|]
					Memory(id__)
				)
				\ union(
					{|
					|},
					{|
					|}
				)
				[|{|terminate|}|>SKIP
				
				-- VS version
				VS__(id__,
						    const_MainController_stm_ref0_thr) = 	((
						let
							const_SourceAnalysis_thr = const_MainController_stm_ref0_thr
						within 
						stm_ref0::VS__(id__,
								    const_SourceAnalysis_thr)[[
							stm_ref0::terminate <- terminate,
							stm_ref0::s <- s,
							stm_ref0::turn <- turn,
							stm_ref0::stop <- stop,
							stm_ref0::resume <- resume
						]]
					)
						[|
							union(
								{|
								|},
								{|
								|}
							)
						|]
					Memory(id__)
				)
				\ union(
					{|
					|},
					{|
					|}
				)
				[|{|terminate|}|>SKIP
			
				-- O version (optimised) THESE TWO PROCESSES SHOULD BE KEPT IN SYNC WITH THE ABOVE TWO
				O__(id__,
						    const_MainController_stm_ref0_thr) = sbisim(diamond(	((
						let
							const_SourceAnalysis_thr = const_MainController_stm_ref0_thr
						within 
						stm_ref0::O__(id__,
								    const_SourceAnalysis_thr)[[
							stm_ref0::terminate <- terminate,
							stm_ref0::s <- s,
							stm_ref0::turn <- turn,
							stm_ref0::stop <- stop,
							stm_ref0::resume <- resume
						]]
					)
						[|
							union(
								{|
								|},
								{|
								|}
							)
						|]
					dbisim(Memory(id__))
				)
				\ union(
					{|
					|},
					{|
					|}
				)
				[|{|terminate|}|>SKIP
				))
								
				-- VS_O version
				VS_O__(id__,
						    const_MainController_stm_ref0_thr) = sbisim(diamond(	((
						let
							const_SourceAnalysis_thr = const_MainController_stm_ref0_thr
						within 
						stm_ref0::VS_O__(id__,
								    const_SourceAnalysis_thr)[[
							stm_ref0::terminate <- terminate,
							stm_ref0::s <- s,
							stm_ref0::turn <- turn,
							stm_ref0::stop <- stop,
							stm_ref0::resume <- resume
						]]
					)
						[|
							union(
								{|
								|},
								{|
								|}
							)
						|]
					dbisim(Memory(id__))
				)
				\ union(
					{|
					|},
					{|
					|}
				)
				[|{|terminate|}|>SKIP
				))
			
				HEXT(id__,
						    const_MainController_stm_ref0_thr) = O__(id__,
						    const_MainController_stm_ref0_thr) [|shared_variable_events|] SKIP			
	
		endmodule
	
	-- declaring module memory
	Memory(id__) = SKIP
	
	D__(id__,
			    const_MicroController_stm_ref0_lv,
			    const_MicroController_stm_ref0_evadeTime,
			    const_MicroController_stm_ref0_stuckDist,
			    const_MicroController_stm_ref0_outPeriod,
			    const_MainController_stm_ref0_thr) = 	(
			(
				(SKIP)
					[|{||}|]
				(
					(
						(
							ctrl_ref0::D__(id__,
									    const_MicroController_stm_ref0_lv,
									    const_MicroController_stm_ref0_evadeTime,
									    const_MicroController_stm_ref0_stuckDist,
									    const_MicroController_stm_ref0_outPeriod)[[
								ctrl_ref0::terminate <- terminate,
								ctrl_ref0::stop.in <- ctrl_ref1::stop.out,
								ctrl_ref0::stop.out <- ctrl_ref1::stop.in,
								ctrl_ref0::obstacle <- obstacle,
								ctrl_ref0::flag <- flag,
								ctrl_ref0::resume.in <- ctrl_ref1::resume.out,
								ctrl_ref0::resume.out <- ctrl_ref1::resume.in,
								ctrl_ref0::odometer <- odometer,
								ctrl_ref0::turn.in <- ctrl_ref1::turn.out,
								ctrl_ref0::turn.out <- ctrl_ref1::turn.in,
								ctrl_ref0::stopCall <- stopCall,
								ctrl_ref0::reverseCall <- reverseCall,
								ctrl_ref0::moveForwardCall <- moveForwardCall,
								ctrl_ref0::moveTowardsCall <- moveTowardsCall,
								ctrl_ref0::changeDirectionCall <- changeDirectionCall
							]]
						)
							[|{|terminate, ctrl_ref1::stop, ctrl_ref1::resume, ctrl_ref1::turn|}|]
						(
							ctrl_ref1::D__(id__,
									    const_MainController_stm_ref0_thr)[[
								ctrl_ref1::terminate <- terminate,
								ctrl_ref1::s <- s
							]]
						)
					)
					\
					diff(
						{|terminate, ctrl_ref1::stop, ctrl_ref1::resume, ctrl_ref1::turn|},
						{|terminate|}
					)
						[|
							union(
								{|
								|},
								{|
								|}
							)
						|]
					Memory(id__)
				)
			)
			\ Union({
				{|
				|},
				{|
				|},
				{|
				|}
			})
			[|{|terminate|}|>SKIP
		)
		\{|terminate|}
	
	-- visible state equivalent
	
	VS__(id__,
			    const_MicroController_stm_ref0_lv,
			    const_MicroController_stm_ref0_evadeTime,
			    const_MicroController_stm_ref0_stuckDist,
			    const_MicroController_stm_ref0_outPeriod,
			    const_MainController_stm_ref0_thr) = 	(
			(
				(SKIP)
					[|{||}|]
				(
					(
						(
							ctrl_ref0::VS__(id__,
									    const_MicroController_stm_ref0_lv,
									    const_MicroController_stm_ref0_evadeTime,
									    const_MicroController_stm_ref0_stuckDist,
									    const_MicroController_stm_ref0_outPeriod)[[
								ctrl_ref0::terminate <- terminate,
								ctrl_ref0::stop.in <- ctrl_ref1::stop.out,
								ctrl_ref0::stop.out <- ctrl_ref1::stop.in,
								ctrl_ref0::obstacle <- obstacle,
								ctrl_ref0::flag <- flag,
								ctrl_ref0::resume.in <- ctrl_ref1::resume.out,
								ctrl_ref0::resume.out <- ctrl_ref1::resume.in,
								ctrl_ref0::odometer <- odometer,
								ctrl_ref0::turn.in <- ctrl_ref1::turn.out,
								ctrl_ref0::turn.out <- ctrl_ref1::turn.in,
