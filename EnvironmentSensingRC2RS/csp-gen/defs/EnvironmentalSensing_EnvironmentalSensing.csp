						    const_Movement_stuckDist,
						    const_Movement_outPeriod) \ internal_events
				O__(id__,
						    const_Movement_lv,
						    const_Movement_evadeTime,
						    const_Movement_stuckDist,
						    const_Movement_outPeriod) = sbisim(diamond(D__(id__,
						    const_Movement_lv,
						    const_Movement_evadeTime,
						    const_Movement_stuckDist,
						    const_Movement_outPeriod)))
				VS__(id__,
						    const_Movement_lv,
						    const_Movement_evadeTime,
						    const_Movement_stuckDist,
						    const_Movement_outPeriod) = FVS__(id__,
						    const_Movement_lv,
						    const_Movement_evadeTime,
						    const_Movement_stuckDist,
						    const_Movement_outPeriod)
				VS_O__(id__,
						    const_Movement_lv,
						    const_Movement_evadeTime,
						    const_Movement_stuckDist,
						    const_Movement_outPeriod) = sbisim(diamond(FVS__(id__,
						    const_Movement_lv,
						    const_Movement_evadeTime,
						    const_Movement_stuckDist,
						    const_Movement_outPeriod)))
				HEXT__(id__,
						    const_Movement_lv,
						    const_Movement_evadeTime,
						    const_Movement_stuckDist,
						    const_Movement_outPeriod) = O__(id__,
						    const_Movement_lv,
						    const_Movement_evadeTime,
						    const_Movement_stuckDist,
						    const_Movement_outPeriod) [|shared_variable_events|] SKIP
				HUP__(id__,
						    const_Movement_lv,
						    const_Movement_evadeTime,
						    const_Movement_stuckDist,
						    const_Movement_outPeriod) = O__(id__,
						    const_Movement_lv,
						    const_Movement_evadeTime,
						    const_Movement_stuckDist,
						    const_Movement_outPeriod) [|{share__}|] SKIP
				
				-- Shared memory
				-- Shared memory variables
				
				-- sharedVarMemory process
				sharedVarMemory(id__,
						    const_Movement_lv,
						    const_Movement_evadeTime,
						    const_Movement_stuckDist,
						    const_Movement_outPeriod) = terminate -> SKIP
				
				sharedVarSync = {||}
				
				sharedVarHide = {||}
			endmodule
			
				-- undefined operations
				CALL__stop(id__) 	= stopCall -> SKIP
				CALL__reverse(id__) 	= reverseCall -> SKIP
				CALL__moveForward(id__) 	= moveForwardCall -> SKIP
				CALL__moveTowards(id__,
