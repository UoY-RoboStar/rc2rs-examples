						    const_Movement_outPeriod)
				
				D__(id__,
						    const_Movement_lv,
						    const_Movement_evadeTime,
						    const_Movement_stuckDist,
						    const_Movement_outPeriod) = STM(id__,
						    const_Movement_lv,
