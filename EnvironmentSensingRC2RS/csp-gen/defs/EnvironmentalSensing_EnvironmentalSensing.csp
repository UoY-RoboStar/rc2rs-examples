			channel turn: InOut.core_real
			channel stop: InOut
			channel s: InOut.LSeq(core_real,2)
			channel resume: InOut
			
			
			
			-- declaring call and ret events for undefined operations
			
			-- declaring controller termination channel
			channel terminate
			
			-- channel set with all visible events
			sem__events = {|
				terminate
			,	turn,
				stop,
				s,
				resume
			|}
	
			-- defined operations
		
			-- declaring machines
			module stm_ref0
			exports
				transparent diamond
				transparent sbisim
				transparent dbisim
				transparent chase
			
				-- Transition identifiers
				-- declaring identifiers of transitions
				datatype NIDS = 
				              NID_i1|
				              NID_NoSource|
				              NID_Analysis|
				              NID_SourceDetected|
				              NID_j1|
				              NID_Reading
				
				channel internal__ : NIDS
				
				-- Flow channels		
				channel interrupt
				channel exited
				channel exit
				channel terminate
				
				-- Variable channels
				channel get_gs, set_gs, setL_gs, setR_gs: LSeq(core_real,2)
				
				-- Shared variable channels
				
				-- Local variable channels for defined operations that are required by the state machine
				
				-- Declaring state machine events
				channel s__: NIDS.InOut.LSeq(core_real,2)
				channel s: InOut.LSeq(core_real,2)
				channel resume__: NIDS.InOut
				channel resume: InOut
				channel turn__: NIDS.InOut.core_real
				channel turn: InOut.core_real
				channel stop__: NIDS.InOut
				channel stop: InOut
				
				-- Declaring call and ret events for undefined operations
				
				enterSS = {|
				i1::enter,
				NoSource::enter,
				Analysis::enter,
				SourceDetected::enter,
				j1::enter,
				Reading::enter
				|}
				
				enteredSS = 	{|
				NoSource::entered,
				Analysis::entered,
				SourceDetected::entered,
				j1::entered,
				Reading::entered
				|}
				
				internal_events = union(enteredSS,union(enterSS,{|interrupt,exited|}))
				
				shared_variable_events = {|
				|}
				
				-- channel set with all visible events
				sem__events = {|
					terminate
				,	s,
					resume,
					turn,
					stop
					|}
			
				-- Nodes --
				-- declaring all nodes
				
				----------------------------------------------------------------------
				-- Initial: i1
				module i1
				exports
				
					channel enter, interrupt
					
					D__(id__,
							    const_SourceAnalysis_thr) = 
						dbisim(let
							Inactive 	= share__choice(enter -> SKIP [] terminate -> SKIP) ; Active
							
							Termination = terminate -> SKIP
							
							Active 		= share__choice(interrupt -> SKIP) ; Inactive
						within
							Inactive [| {terminate} |> SKIP)
					
					VS_O__(id__,
							    const_SourceAnalysis_thr) = D__(id__,
							    const_SourceAnalysis_thr)
				
				endmodule
				----------------------------------------------------------------------
				
				
				----------------------------------------------------------------------
				-- State: NoSource
				module NoSource
				
				enterSS = {}
				
				enteredSS = {}
				
				exports
				
					--  Declarations
					
					channel enter, entered, interrupt
					channel enteredL, enteredR
					
									
					
					--	Nodes
					-- declaring all nodes
					
					
					--	Rule: behaviours(Node)
					--  Note that FDR has problems with efficiently compiling the process below
					-- 	if using a different recursion pattern.
					D__(id__,
							    const_SourceAnalysis_thr) = 
					dbisim(let
						-- IMPLEMENTATION NOTE: 
						-- The following should be defined as: Inactive = share__choice(Activation [] Termination),
						-- however FDR struggles with that form in certain cases. So we use the exception operator
						-- instead to 'terminate'.
						
						Inactive 	= share__choice(enter -> SKIP [] terminate -> SKIP) ; Active
						
						Termination = terminate -> SKIP
						
						Active 		= SKIP ; 
								 	  Behaviour ; 
								 	  share__choice(exit -> SKIP) ; SKIP ; 
								 	  share__choice(exited -> SKIP) ; Inactive
					
						Behaviour 	= entered -> During
						During 		= ((SKIP ; SStop) /\ interrupt -> SKIP)
					within
						Inactive [| {terminate} |> SKIP)
						
					VS_O__(id__,
							    const_SourceAnalysis_thr) = 
					dbisim(let
						Inactive 	= share__choice(enter -> SKIP [] terminate -> SKIP) ; Active
						
