						 	 [] dbisim((true)&(turn__!NID_Going.in?a:{a|a <- core_real, true} -> share__choice(set_a!a -> SKIP) ;  share__choice(exit -> SKIP) ; (share__choice(exited -> SKIP) ; SKIP ; Going::enter -> SKIP)))
