							    const_Movement_lv,
							    const_Movement_evadeTime,
							    const_Movement_stuckDist,
							    const_Movement_outPeriod))
					)
				
				Stateful_VS_O(id__,
						    const_Movement_lv,
						    const_Movement_evadeTime,
						    const_Movement_stuckDist,
						    const_Movement_outPeriod) = 
					dbisim((
						(Behaviour_VS_O(id__,
								    const_Movement_lv,
								    const_Movement_evadeTime,
								    const_Movement_stuckDist,
								    const_Movement_outPeriod) [| union(getsetLocalChannels,{terminate}) |] varMemory(id__,
								    const_Movement_lv,
								    const_Movement_evadeTime,
								    const_Movement_stuckDist,
								    const_Movement_outPeriod))
					 	\getsetLocalChannels
					)
					)
				
				IteratedStateful_VS_O(id__,
						    const_Movement_lv,
