-- data definitions used by platform:/resource/EnvironmentSensing/Chemical.rct
datatype Status = noSource | sourceD

Status_is(noSource,noSource) = true
Status_is(_,noSource) = false
Status_is(sourceD,sourceD) = true
Status_is(_,sourceD) = false

datatype Loc = left | right | front

Loc_is(left,left) = true
Loc_is(_,left) = false
Loc_is(right,right) = true
Loc_is(_,right) = false
Loc_is(front,front) = true
Loc_is(_,front) = false



