channel Movement_internal__: Movement_TIDS

ShowEvents_Movement(P,E) = P[[ Movement_entered.x.y <- Movement_enteredV.y | Movement_entered.x.y <- E]]
							 [[	Movement_enter.x.y <- Movement_enterV.y | Movement_enter.x.y <- E]]
							 [[ Movement_exit.x.y <- Movement_exitV.y | Movement_exit.x.y <- E]]
							 [[ Movement_exited.x.y <- Movement_exitedV.y | Movement_exited.x.y <- E ]]
							 
ShowEnteredV_Movement(P) = P[[ Movement_entered.x.y <- Movement_enteredV.y | x <- Movement_SIDS, y <- Movement_SIDS ]]
ShowEnterV_Movement(P) = P[[ Movement_enter.x.y <- Movement_enterV.y | x <- Movement_SIDS, y <- Movement_SIDS ]]
ShowExitV_Movement(P) = P[[ Movement_exit.x.y <- Movement_exitV.y | x <- Movement_SIDS, y <- Movement_SIDS ]]
ShowExitedV_Movement(P) = P[[ Movement_exited.x.y <- Movement_exitedV.y | x <- Movement_SIDS, y <- Movement_SIDS ]]
ShowV_Movement(P) = P[[ Movement_entered.x.y <- Movement_enteredV.y | x <- Movement_SIDS, y <- Movement_SIDS]]
							 [[	Movement_enter.x.y <- Movement_enterV.y | x <- Movement_SIDS, y <- Movement_SIDS ]]
							 [[ Movement_exit.x.y <- Movement_exitV.y | x <- Movement_SIDS, y <- Movement_SIDS]]
							 [[ Movement_exited.x.y <- Movement_exitedV.y | x <- Movement_SIDS, y <- Movement_SIDS ]]

channel Movement_enteredV, Movement_enterV, Movement_exitV, Movement_exitedV : Movement_SIDS
channel Movement_enter, Movement_entered: Movement_SIDS.Movement_SIDS
channel Movement_exit,Movement_exited: Movement_SIDS.Movement_SIDS

channel get_Movement_a, set_Movement_a: real
channel get_Movement_d0, set_Movement_d0: real
channel get_Movement_d1, set_Movement_d1: real
channel get_Movement_l, set_Movement_l: Loc


-- declaring identifiers of state and final states
Movement_SIDS = {
	"Movement",
	"Movement_Exploring",
	"Movement_Going",
	"Movement_Found",
	"Movement_j1",
	"Movement_Avoiding",
	"Movement_TryingAgain",
	"Movement_AvoidingAgain",
	"Movement_GettingOut"
}

-- declaring identifiers of transitions
Movement_TIDS = {
	"__NULLTRANSITION__",
	"Movement_t1",
	"Movement_t2",
	"Movement_t3",
	"Movement_t4",
	"Movement_t5",
	"Movement_t6",
	"Movement_t7",
	"Movement_t8",
	"Movement_t9",
	"Movement_t10",
	"Movement_t11",
	"Movement_t12",
	"Movement_t13",
	"Movement_t14",
	"Movement_t0",
	"Movement_t15",
	"Movement_t16",
	"Movement_t17",
	"Movement_t18",
	"Movement_t19",
	"Movement_t20",
	"Movement_t22",
	"Movement_t21"
}

-- declaring state machine events
channel Movement_obstacle__:Movement_TIDS.InOut.Loc

channel Movement_obstacle: InOut.Loc
channel Movement_odometer__:Movement_TIDS.InOut.real

channel Movement_odometer: InOut.real
channel Movement_resume__:Movement_TIDS.InOut

channel Movement_resume: InOut
channel Movement_turn__:Movement_TIDS.InOut.real

channel Movement_turn: InOut.real
channel Movement_stop__:Movement_TIDS.InOut

channel Movement_stop: InOut
channel Movement_flag__:Movement_TIDS.InOut

channel Movement_flag: InOut

channel Movement_terminate

-- declaring all states
CS_Movement_Exploring_sync = {|
	Movement_enter.y.x, 
	Movement_entered.y.x, 
	Movement_exit.y.x, 
	Movement_exited.y.x,
	Movement_enter.x.y, 
	Movement_entered.x.y, 
	Movement_exit.x.y, 
	Movement_exited.x.y |
	x <- {"Movement_Exploring","Movement_Going","Movement_Found","Movement_j1","Movement_Avoiding","Movement_TryingAgain","Movement_AvoidingAgain","Movement_GettingOut"},
	y <- {"Movement_Exploring"}
|}



Movement_Exploring_triggers = {|
	Movement_turn__."Movement_t8",
	Movement_obstacle__."Movement_t11",
	Movement_stop__."Movement_t15",
	Movement_turn__."Movement_t14",
	Movement_resume__."Movement_t0",
	Movement_turn__."Movement_t3",
	Movement_internal__."Movement_t5",
	Movement_stop__."Movement_t18",
	Movement_turn__."Movement_t7",
	Movement_stop__."Movement_t4",
	Movement_resume__."Movement_t20",
	Movement_turn__."Movement_t2",
	Movement_resume__."Movement_t19",
	Movement_stop__."Movement_t9",
	Movement_obstacle__."Movement_t6",
	Movement_obstacle__."Movement_t21",
	Movement_stop__."Movement_t16",
	Movement_internal__."Movement_t12",
	Movement_internal__."Movement_t13",
	Movement_resume__."Movement_t22",
	Movement_resume__."Movement_t10",
	Movement_stop__."Movement_t17"
|}
		   
S_Movement_Exploring(id) = let
	T_Movement_t2(id)	= Movement_turn__!"Movement_t2".in?a -> set_Movement_a!a ->  (Movement_exit!"Movement_Exploring"!"Movement_Exploring" -> SKIP;
						SKIP;Movement_exited!"Movement_Exploring"!"Movement_Exploring" -> SKIP;
						Movement_enter!"Movement_Exploring"!"Movement_Going" -> Movement_entered!"Movement_Exploring"!"Movement_Going" ->
						S_Movement_Exploring(id)
	)
	T_Movement_t0(id)	= Movement_resume__!"Movement_t0".in ->  (Movement_exit!"Movement_Exploring"!"Movement_Exploring" -> SKIP;
						SKIP;Movement_exited!"Movement_Exploring"!"Movement_Exploring" -> SKIP;
						Movement_enter!"Movement_Exploring"!"Movement_Exploring" -> S_Movement_Exploring_execute(id,"Movement_Exploring")
	)
	T_Movement_t15(id)	= Movement_stop__!"Movement_t15".in ->  (Movement_exit!"Movement_Exploring"!"Movement_Exploring" -> SKIP;
						SKIP;Movement_exited!"Movement_Exploring"!"Movement_Exploring" -> SKIP;
						Movement_enter!"Movement_Exploring"!"Movement_Found" -> Movement_entered!"Movement_Exploring"!"Movement_Found" ->
						S_Movement_Exploring(id)
	)
	T_Movement_t21(id)	= Movement_obstacle__!"Movement_t21".in?l -> set_Movement_l!l ->  (Movement_exit!"Movement_Exploring"!"Movement_Exploring" -> SKIP;
						SKIP;Movement_exited!"Movement_Exploring"!"Movement_Exploring" -> SKIP;
						SKIP;Movement_enter!"Movement_Exploring"!"Movement_Avoiding" -> Movement_entered!"Movement_Exploring"!"Movement_Avoiding" ->
						S_Movement_Exploring(id)
	)

	S_Movement_Exploring_execute(id,o__) = 
	(moveForwardCall -> moveForward(id); moveForwardRet -> SKIP); 
	Movement_entered!o__!"Movement_Exploring" ->
	   (SKIP
	   													; STOP /\ (
	   														    T_Movement_t2(id)[]
	   														    T_Movement_t0(id)[]
	   														    T_Movement_t15(id)[]
	   														    T_Movement_t21(id)
	   														    []
	   														    Movement_internal__?x:diff(Movement_TIDS,{"__NULLTRANSITION__","Movement_t8","Movement_t11","Movement_t15","Movement_t14","Movement_t0","Movement_t3","Movement_t5","Movement_t18","Movement_t7","Movement_t4","Movement_t20","Movement_t2","Movement_t19","Movement_t9","Movement_t6","Movement_t21","Movement_t16","Movement_t12","Movement_t13","Movement_t22","Movement_t10","Movement_t17"}) ->
	   														      Movement_exit?y:diff(Movement_SIDS,{"Movement_Exploring"})!"Movement_Exploring" -> (
	   														      	SKIP;
	   														      	Movement_exited!y!"Movement_Exploring" -> SKIP);
	   														      	S_Movement_Exploring(id)
	   														    [] Movement_obstacle__?x:diff(Movement_TIDS,{"__NULLTRANSITION__","Movement_t8","Movement_t11","Movement_t15","Movement_t14","Movement_t0","Movement_t3","Movement_t5","Movement_t18","Movement_t7","Movement_t4","Movement_t20","Movement_t2","Movement_t19","Movement_t9","Movement_t6","Movement_t21","Movement_t16","Movement_t12","Movement_t13","Movement_t22","Movement_t10","Movement_t17"})?d__?x__ ->
	   														      Movement_exit?y:diff(Movement_SIDS,{"Movement_Exploring"})!"Movement_Exploring" -> (
	   														      	SKIP;
	   														      	Movement_exited!y!"Movement_Exploring" -> SKIP);
	   														      	S_Movement_Exploring(id)
	   														    [] Movement_odometer__?x:diff(Movement_TIDS,{"__NULLTRANSITION__","Movement_t8","Movement_t11","Movement_t15","Movement_t14","Movement_t0","Movement_t3","Movement_t5","Movement_t18","Movement_t7","Movement_t4","Movement_t20","Movement_t2","Movement_t19","Movement_t9","Movement_t6","Movement_t21","Movement_t16","Movement_t12","Movement_t13","Movement_t22","Movement_t10","Movement_t17"})?d__?x__ ->
	   														      Movement_exit?y:diff(Movement_SIDS,{"Movement_Exploring"})!"Movement_Exploring" -> (
	   														      	SKIP;
	   														      	Movement_exited!y!"Movement_Exploring" -> SKIP);
	   														      	S_Movement_Exploring(id)
	   														    [] Movement_resume__?x:diff(Movement_TIDS,{"__NULLTRANSITION__","Movement_t8","Movement_t11","Movement_t15","Movement_t14","Movement_t0","Movement_t3","Movement_t5","Movement_t18","Movement_t7","Movement_t4","Movement_t20","Movement_t2","Movement_t19","Movement_t9","Movement_t6","Movement_t21","Movement_t16","Movement_t12","Movement_t13","Movement_t22","Movement_t10","Movement_t17"})?d__ ->
	   														      Movement_exit?y:diff(Movement_SIDS,{"Movement_Exploring"})!"Movement_Exploring" -> (
	   														      	SKIP;
	   														      	Movement_exited!y!"Movement_Exploring" -> SKIP);
	   														      	S_Movement_Exploring(id)
	   														    [] Movement_turn__?x:diff(Movement_TIDS,{"__NULLTRANSITION__","Movement_t8","Movement_t11","Movement_t15","Movement_t14","Movement_t0","Movement_t3","Movement_t5","Movement_t18","Movement_t7","Movement_t4","Movement_t20","Movement_t2","Movement_t19","Movement_t9","Movement_t6","Movement_t21","Movement_t16","Movement_t12","Movement_t13","Movement_t22","Movement_t10","Movement_t17"})?d__?x__ ->
	   														      Movement_exit?y:diff(Movement_SIDS,{"Movement_Exploring"})!"Movement_Exploring" -> (
	   														      	SKIP;
	   														      	Movement_exited!y!"Movement_Exploring" -> SKIP);
	   														      	S_Movement_Exploring(id)
	   														    [] Movement_stop__?x:diff(Movement_TIDS,{"__NULLTRANSITION__","Movement_t8","Movement_t11","Movement_t15","Movement_t14","Movement_t0","Movement_t3","Movement_t5","Movement_t18","Movement_t7","Movement_t4","Movement_t20","Movement_t2","Movement_t19","Movement_t9","Movement_t6","Movement_t21","Movement_t16","Movement_t12","Movement_t13","Movement_t22","Movement_t10","Movement_t17"})?d__ ->
	   														      Movement_exit?y:diff(Movement_SIDS,{"Movement_Exploring"})!"Movement_Exploring" -> (
	   														      	SKIP;
	   														      	Movement_exited!y!"Movement_Exploring" -> SKIP);
	   														      	S_Movement_Exploring(id)
	   														    [] Movement_flag__?x:diff(Movement_TIDS,{"__NULLTRANSITION__","Movement_t8","Movement_t11","Movement_t15","Movement_t14","Movement_t0","Movement_t3","Movement_t5","Movement_t18","Movement_t7","Movement_t4","Movement_t20","Movement_t2","Movement_t19","Movement_t9","Movement_t6","Movement_t21","Movement_t16","Movement_t12","Movement_t13","Movement_t22","Movement_t10","Movement_t17"})?d__ ->
	   														      Movement_exit?y:diff(Movement_SIDS,{"Movement_Exploring"})!"Movement_Exploring" -> (
	   														      	SKIP;
	   														      	Movement_exited!y!"Movement_Exploring" -> SKIP);
	   														      	S_Movement_Exploring(id)
	   														    )
	   													)
within
Movement_enter?x:diff(Movement_SIDS,{"Movement_Exploring"})!"Movement_Exploring" -> ( 
	S_Movement_Exploring_execute(id,x)) 
CS_Movement_Going_sync = {|
	Movement_enter.y.x, 
	Movement_entered.y.x, 
	Movement_exit.y.x, 
	Movement_exited.y.x,
