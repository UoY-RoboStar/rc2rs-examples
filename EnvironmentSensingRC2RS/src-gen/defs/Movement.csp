	x <- {"Movement_Exploring","Movement_Going","Movement_Found","Movement_j1","Movement_Avoiding","Movement_TryingAgain","Movement_AvoidingAgain","Movement_GettingOut"},
	y <- {"Movement_Going"}
|}



Movement_Going_triggers = {|
	Movement_turn__."Movement_t8",
	Movement_obstacle__."Movement_t11",
	Movement_stop__."Movement_t15",
	Movement_turn__."Movement_t14",
	Movement_resume__."Movement_t0",
	Movement_turn__."Movement_t3",
	Movement_internal__."Movement_t5",
	Movement_stop__."Movement_t18",
	Movement_turn__."Movement_t7",
	Movement_stop__."Movement_t4",
	Movement_resume__."Movement_t20",
	Movement_turn__."Movement_t2",
	Movement_resume__."Movement_t19",
	Movement_stop__."Movement_t9",
	Movement_obstacle__."Movement_t6",
	Movement_obstacle__."Movement_t21",
	Movement_stop__."Movement_t16",
	Movement_internal__."Movement_t12",
	Movement_internal__."Movement_t13",
	Movement_resume__."Movement_t22",
	Movement_resume__."Movement_t10",
	Movement_stop__."Movement_t17"
|}
		   
S_Movement_Going(id) = let
	T_Movement_t3(id)	= Movement_turn__!"Movement_t3".in?a -> set_Movement_a!a ->  (Movement_exit!"Movement_Going"!"Movement_Going" -> SKIP;
						SKIP;Movement_exited!"Movement_Going"!"Movement_Going" -> SKIP;
						Movement_enter!"Movement_Going"!"Movement_Going" -> S_Movement_Going_execute(id,"Movement_Going")
	)
	T_Movement_t4(id)	= Movement_stop__!"Movement_t4".in ->  (Movement_exit!"Movement_Going"!"Movement_Going" -> SKIP;
						SKIP;Movement_exited!"Movement_Going"!"Movement_Going" -> SKIP;
						Movement_enter!"Movement_Going"!"Movement_Found" -> Movement_entered!"Movement_Going"!"Movement_Found" ->
						S_Movement_Going(id)
	)
	T_Movement_t6(id)	= Movement_obstacle__!"Movement_t6".in?l -> set_Movement_l!l ->  (Movement_exit!"Movement_Going"!"Movement_Going" -> SKIP;
						SKIP;Movement_exited!"Movement_Going"!"Movement_Going" -> SKIP;
						SKIP;Movement_enter!"Movement_Going"!"Movement_Avoiding" -> Movement_entered!"Movement_Going"!"Movement_Avoiding" ->
						S_Movement_Going(id)
	)

	S_Movement_Going_execute(id,o__) = 
	get_Movement_a?a -> (moveTowardsCall -> moveTowards(id, a); moveTowardsRet -> SKIP); 
	Movement_entered!o__!"Movement_Going" ->
	   (SKIP
	   													; STOP /\ (
	   														    T_Movement_t3(id)[]
	   														    T_Movement_t4(id)[]
	   														    T_Movement_t6(id)
	   														    []
	   														    Movement_internal__?x:diff(Movement_TIDS,{"__NULLTRANSITION__","Movement_t8","Movement_t11","Movement_t15","Movement_t14","Movement_t0","Movement_t3","Movement_t5","Movement_t18","Movement_t7","Movement_t4","Movement_t20","Movement_t2","Movement_t19","Movement_t9","Movement_t6","Movement_t21","Movement_t16","Movement_t12","Movement_t13","Movement_t22","Movement_t10","Movement_t17"}) ->
	   														      Movement_exit?y:diff(Movement_SIDS,{"Movement_Going"})!"Movement_Going" -> (
	   														      	SKIP;
	   														      	Movement_exited!y!"Movement_Going" -> SKIP);
	   														      	S_Movement_Going(id)
	   														    [] Movement_obstacle__?x:diff(Movement_TIDS,{"__NULLTRANSITION__","Movement_t8","Movement_t11","Movement_t15","Movement_t14","Movement_t0","Movement_t3","Movement_t5","Movement_t18","Movement_t7","Movement_t4","Movement_t20","Movement_t2","Movement_t19","Movement_t9","Movement_t6","Movement_t21","Movement_t16","Movement_t12","Movement_t13","Movement_t22","Movement_t10","Movement_t17"})?d__?x__ ->
	   														      Movement_exit?y:diff(Movement_SIDS,{"Movement_Going"})!"Movement_Going" -> (
	   														      	SKIP;
	   														      	Movement_exited!y!"Movement_Going" -> SKIP);
	   														      	S_Movement_Going(id)
	   														    [] Movement_odometer__?x:diff(Movement_TIDS,{"__NULLTRANSITION__","Movement_t8","Movement_t11","Movement_t15","Movement_t14","Movement_t0","Movement_t3","Movement_t5","Movement_t18","Movement_t7","Movement_t4","Movement_t20","Movement_t2","Movement_t19","Movement_t9","Movement_t6","Movement_t21","Movement_t16","Movement_t12","Movement_t13","Movement_t22","Movement_t10","Movement_t17"})?d__?x__ ->
	   														      Movement_exit?y:diff(Movement_SIDS,{"Movement_Going"})!"Movement_Going" -> (
	   														      	SKIP;
	   														      	Movement_exited!y!"Movement_Going" -> SKIP);
	   														      	S_Movement_Going(id)
	   														    [] Movement_resume__?x:diff(Movement_TIDS,{"__NULLTRANSITION__","Movement_t8","Movement_t11","Movement_t15","Movement_t14","Movement_t0","Movement_t3","Movement_t5","Movement_t18","Movement_t7","Movement_t4","Movement_t20","Movement_t2","Movement_t19","Movement_t9","Movement_t6","Movement_t21","Movement_t16","Movement_t12","Movement_t13","Movement_t22","Movement_t10","Movement_t17"})?d__ ->
	   														      Movement_exit?y:diff(Movement_SIDS,{"Movement_Going"})!"Movement_Going" -> (
	   														      	SKIP;
	   														      	Movement_exited!y!"Movement_Going" -> SKIP);
	   														      	S_Movement_Going(id)
	   														    [] Movement_turn__?x:diff(Movement_TIDS,{"__NULLTRANSITION__","Movement_t8","Movement_t11","Movement_t15","Movement_t14","Movement_t0","Movement_t3","Movement_t5","Movement_t18","Movement_t7","Movement_t4","Movement_t20","Movement_t2","Movement_t19","Movement_t9","Movement_t6","Movement_t21","Movement_t16","Movement_t12","Movement_t13","Movement_t22","Movement_t10","Movement_t17"})?d__?x__ ->
	   														      Movement_exit?y:diff(Movement_SIDS,{"Movement_Going"})!"Movement_Going" -> (
	   														      	SKIP;
	   														      	Movement_exited!y!"Movement_Going" -> SKIP);
	   														      	S_Movement_Going(id)
	   														    [] Movement_stop__?x:diff(Movement_TIDS,{"__NULLTRANSITION__","Movement_t8","Movement_t11","Movement_t15","Movement_t14","Movement_t0","Movement_t3","Movement_t5","Movement_t18","Movement_t7","Movement_t4","Movement_t20","Movement_t2","Movement_t19","Movement_t9","Movement_t6","Movement_t21","Movement_t16","Movement_t12","Movement_t13","Movement_t22","Movement_t10","Movement_t17"})?d__ ->
	   														      Movement_exit?y:diff(Movement_SIDS,{"Movement_Going"})!"Movement_Going" -> (
	   														      	SKIP;
	   														      	Movement_exited!y!"Movement_Going" -> SKIP);
	   														      	S_Movement_Going(id)
	   														    [] Movement_flag__?x:diff(Movement_TIDS,{"__NULLTRANSITION__","Movement_t8","Movement_t11","Movement_t15","Movement_t14","Movement_t0","Movement_t3","Movement_t5","Movement_t18","Movement_t7","Movement_t4","Movement_t20","Movement_t2","Movement_t19","Movement_t9","Movement_t6","Movement_t21","Movement_t16","Movement_t12","Movement_t13","Movement_t22","Movement_t10","Movement_t17"})?d__ ->
	   														      Movement_exit?y:diff(Movement_SIDS,{"Movement_Going"})!"Movement_Going" -> (
	   														      	SKIP;
	   														      	Movement_exited!y!"Movement_Going" -> SKIP);
	   														      	S_Movement_Going(id)
	   														    )
	   													)
within
Movement_enter?x:diff(Movement_SIDS,{"Movement_Going"})!"Movement_Going" -> ( 
	S_Movement_Going_execute(id,x)) 
CS_Movement_Found_sync = {|
	Movement_enter.y.x, 
	Movement_entered.y.x, 
	Movement_exit.y.x, 
	Movement_exited.y.x,
	Movement_enter.x.y, 
	Movement_entered.x.y, 
	Movement_exit.x.y, 
	Movement_exited.x.y |
	x <- {"Movement_Exploring","Movement_Going","Movement_Found","Movement_j1","Movement_Avoiding","Movement_TryingAgain","Movement_AvoidingAgain","Movement_GettingOut"},
	y <- {"Movement_Found"}
|}



Movement_Found_triggers = {|
	Movement_internal__."Movement_t5"
|}
		   
S_Movement_Found(id) = let
	T_Movement_t5(id)	= Movement_internal__!"Movement_t5" ->  Movement_exit!"Movement_Found"!"Movement_Found" -> SKIP;
						SKIP;Movement_exited!"Movement_Found"!"Movement_Found" -> SKIP;
						Movement_enter!"Movement_Found"!"Movement_j1" -> Movement_entered!"Movement_Found"!"Movement_j1" ->
						S_Movement_Found(id)

	S_Movement_Found_execute(id,o__) = 
	(stopCall -> stop(id); stopRet -> SKIP);Movement_flag.out -> SKIP; 
	Movement_entered!o__!"Movement_Found" ->
	   (SKIP
	   													; STOP /\ (
	   														    T_Movement_t5(id)
	   														    []
	   														    Movement_internal__?x:diff(Movement_TIDS,{"__NULLTRANSITION__","Movement_t5"}) ->
	   														      Movement_exit?y:diff(Movement_SIDS,{"Movement_Found"})!"Movement_Found" -> (
	   														      	SKIP;
	   														      	Movement_exited!y!"Movement_Found" -> SKIP);
	   														      	S_Movement_Found(id)
	   														    [] Movement_obstacle__?x:diff(Movement_TIDS,{"__NULLTRANSITION__","Movement_t5"})?d__?x__ ->
	   														      Movement_exit?y:diff(Movement_SIDS,{"Movement_Found"})!"Movement_Found" -> (
	   														      	SKIP;
	   														      	Movement_exited!y!"Movement_Found" -> SKIP);
	   														      	S_Movement_Found(id)
	   														    [] Movement_odometer__?x:diff(Movement_TIDS,{"__NULLTRANSITION__","Movement_t5"})?d__?x__ ->
