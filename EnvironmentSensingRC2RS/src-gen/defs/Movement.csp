T_Movement_t1(id)	= Movement_internal__!"Movement_t1" -> Movement_enter!"Movement"!"Movement_Exploring" -> Movement_entered!"Movement"!"Movement_Exploring" ->
SKIP

S_Movement_Exploring_R(id) = S_Movement_Exploring(id)
 		[|diff(Movement_int_int,Movement_Exploring_triggers)|]
 		SKIP
 		
S_Movement_Going_R(id) = S_Movement_Going(id)
 		[|diff(Movement_int_int,Movement_Going_triggers)|]
 		SKIP
 		
S_Movement_Found_R(id) = S_Movement_Found(id)
 		[|diff(Movement_int_int,Movement_Found_triggers)|]
 		SKIP
 		
S_Movement_j1_R(id) = S_Movement_j1(id)
 		[|diff(Movement_int_int,Movement_j1_triggers)|]
 		SKIP
 		
S_Movement_Avoiding_R(id) = S_Movement_Avoiding(id)
 		[|diff(Movement_int_int,Movement_Avoiding_triggers)|]
 		SKIP
 		
S_Movement_TryingAgain_R(id) = S_Movement_TryingAgain(id)
 		[|diff(Movement_int_int,Movement_TryingAgain_triggers)|]
 		SKIP
 		
S_Movement_AvoidingAgain_R(id) = S_Movement_AvoidingAgain(id)
 		[|diff(Movement_int_int,Movement_AvoidingAgain_triggers)|]
 		SKIP
 		
S_Movement_GettingOut_R(id) = S_Movement_GettingOut(id)
 		[|diff(Movement_int_int,Movement_GettingOut_triggers)|]
 		SKIP
 		
STM_Movement(id) = (I_Movement_i1(id)
[|{|Movement_enter.x.y,
		Movement_entered.x.y,
		Movement_exit.x.y,
		Movement_exited.x.y |
		x <- diff(Movement_SIDS,{"Movement_Exploring","Movement_Going","Movement_Found","Movement_j1","Movement_Avoiding","Movement_TryingAgain","Movement_AvoidingAgain","Movement_GettingOut"}),
		y <- {"Movement_Exploring","Movement_Going","Movement_Found","Movement_j1","Movement_Avoiding","Movement_TryingAgain","Movement_AvoidingAgain","Movement_GettingOut"}
|}|]
(S_Movement_Exploring_R(id)
  [|inter(CS_Movement_Exploring_sync,union(union(union(union(union(union(CS_Movement_Going_sync,CS_Movement_Found_sync),CS_Movement_j1_sync),CS_Movement_Avoiding_sync),CS_Movement_TryingAgain_sync),CS_Movement_AvoidingAgain_sync),CS_Movement_GettingOut_sync))|]
 (S_Movement_Going_R(id)
   [|inter(CS_Movement_Going_sync,union(union(union(union(union(CS_Movement_Found_sync,CS_Movement_j1_sync),CS_Movement_Avoiding_sync),CS_Movement_TryingAgain_sync),CS_Movement_AvoidingAgain_sync),CS_Movement_GettingOut_sync))|]
  (S_Movement_Found_R(id)
    [|inter(CS_Movement_Found_sync,union(union(union(union(CS_Movement_j1_sync,CS_Movement_Avoiding_sync),CS_Movement_TryingAgain_sync),CS_Movement_AvoidingAgain_sync),CS_Movement_GettingOut_sync))|]
   (S_Movement_j1_R(id)
     [|inter(CS_Movement_j1_sync,union(union(union(CS_Movement_Avoiding_sync,CS_Movement_TryingAgain_sync),CS_Movement_AvoidingAgain_sync),CS_Movement_GettingOut_sync))|]
    (S_Movement_Avoiding_R(id)
      [|inter(CS_Movement_Avoiding_sync,union(union(CS_Movement_TryingAgain_sync,CS_Movement_AvoidingAgain_sync),CS_Movement_GettingOut_sync))|]
     (S_Movement_TryingAgain_R(id)
       [|inter(CS_Movement_TryingAgain_sync,union(CS_Movement_AvoidingAgain_sync,CS_Movement_GettingOut_sync))|]
      (S_Movement_AvoidingAgain_R(id)
        [|inter(CS_Movement_AvoidingAgain_sync,CS_Movement_GettingOut_sync)|]
       S_Movement_GettingOut_R(id))
      )
     )
    )
   )
  )
 )
 	)
-- memory process
Memory_Movement(id, a, d0, d1, l) = (
  get_Movement_a!a -> Memory_Movement(id,a,d0,d1,l)
  []
  set_Movement_a?x__ -> Memory_Movement(id,x__,d0,d1,l)
  []
  get_Movement_d0!d0 -> Memory_Movement(id,a,d0,d1,l)
  []
  set_Movement_d0?x__ -> Memory_Movement(id,a,x__,d1,l)
  []
  get_Movement_d1!d1 -> Memory_Movement(id,a,d0,d1,l)
  []
  set_Movement_d1?x__ -> Memory_Movement(id,a,d0,x__,l)
  []
  get_Movement_l!l -> Memory_Movement(id,a,d0,d1,l)
  []
  set_Movement_l?x__ -> Memory_Movement(id,a,d0,d1,x__)
	  []
	Movement_internal__!"Movement_t1" -> Memory_Movement(id, a, d0, d1, l)
	  []
	Movement_turn__!"Movement_t2".in?a -> Memory_Movement(id, a, d0, d1, l)
	  []
	Movement_turn__!"Movement_t3".in?a -> Memory_Movement(id, a, d0, d1, l)
	  []
	Movement_stop__!"Movement_t4".in -> Memory_Movement(id, a, d0, d1, l)
	  []
	Movement_internal__!"Movement_t5" -> Memory_Movement(id, a, d0, d1, l)
	  []
	Movement_obstacle__!"Movement_t6".in?l -> Memory_Movement(id, a, d0, d1, l)
	  []
	(Movement_turn__!"Movement_t7".in?a:{a|a <- real, true} -> Memory_Movement(id, a, d0, d1, l) |~| STOP)
	  []
	Movement_turn__!"Movement_t8".in?a -> Memory_Movement(id, a, d0, d1, l)
	  []
	Movement_stop__!"Movement_t9".in -> Memory_Movement(id, a, d0, d1, l)
	  []
	Movement_resume__!"Movement_t10".in -> Memory_Movement(id, a, d0, d1, l)
	  []
	Movement_obstacle__!"Movement_t11".in?l -> Memory_Movement(id, a, d0, d1, l)
	  []
	((Minus(d1, d0, real)>Movement_stuckDist))&(Movement_internal__!"Movement_t12" -> Memory_Movement(id, a, d0, d1, l))
	  []
	((Minus(d1, d0, real)<=Movement_stuckDist))&(Movement_internal__!"Movement_t13" -> Memory_Movement(id, a, d0, d1, l))
	  []
	(Movement_turn__!"Movement_t14".in?a:{a|a <- real, true} -> Memory_Movement(id, a, d0, d1, l) |~| STOP)
	  []
	Movement_resume__!"Movement_t0".in -> Memory_Movement(id, a, d0, d1, l)
	  []
	Movement_stop__!"Movement_t15".in -> Memory_Movement(id, a, d0, d1, l)
	  []
	((true)&(Movement_stop__!"Movement_t16".in -> Memory_Movement(id, a, d0, d1, l)) |~| STOP)
	  []
	Movement_stop__!"Movement_t17".in -> Memory_Movement(id, a, d0, d1, l)
	  []
	((true)&(Movement_stop__!"Movement_t18".in -> Memory_Movement(id, a, d0, d1, l)) |~| STOP)
	  []
	((true)&(Movement_resume__!"Movement_t19".in -> Memory_Movement(id, a, d0, d1, l)) |~| STOP)
	  []
	((true)&(Movement_resume__!"Movement_t20".in -> Memory_Movement(id, a, d0, d1, l)) |~| STOP)
	  []
	Movement_resume__!"Movement_t22".in -> Memory_Movement(id, a, d0, d1, l)
	  []
	Movement_obstacle__!"Movement_t21".in?l -> Memory_Movement(id, a, d0, d1, l)
	)
-- main process
Movement_aux(id) = ((STM_Movement(id)
	[|union(
		{|get_Movement_a,set_Movement_a,
		get_Movement_d0,set_Movement_d0,
		get_Movement_d1,set_Movement_d1,
		get_Movement_l,set_Movement_l|},
		{|Movement_internal__."Movement_t1",
		Movement_turn__."Movement_t2",
		Movement_turn__."Movement_t3",
		Movement_stop__."Movement_t4",
		Movement_internal__."Movement_t5",
		Movement_obstacle__."Movement_t6",
		Movement_turn__."Movement_t7",
		Movement_turn__."Movement_t8",
		Movement_stop__."Movement_t9",
		Movement_resume__."Movement_t10",
		Movement_obstacle__."Movement_t11",
		Movement_internal__."Movement_t12",
		Movement_internal__."Movement_t13",
		Movement_turn__."Movement_t14",
		Movement_resume__."Movement_t0",
		Movement_stop__."Movement_t15",
		Movement_stop__."Movement_t16",
		Movement_stop__."Movement_t17",
		Movement_stop__."Movement_t18",
		Movement_resume__."Movement_t19",
		Movement_resume__."Movement_t20",
		Movement_resume__."Movement_t22",
		Movement_obstacle__."Movement_t21"|}
	)|]
	Memory_Movement(id, 0, 0, 0, left)
)[[Movement_obstacle__.x <- Movement_obstacle, Movement_odometer__.x <- Movement_odometer, Movement_resume__.x <- Movement_resume, Movement_turn__.x <- Movement_turn, Movement_stop__.x <- Movement_stop, Movement_flag__.x <- Movement_flag| x<-Movement_TIDS]]
\union({|get_Movement_a,set_Movement_a,
get_Movement_d0,set_Movement_d0,
get_Movement_d1,set_Movement_d1,
get_Movement_l,set_Movement_l|},
{||}))
[|{|Movement_terminate|}|>SKIP\{|Movement_internal__|}

Movement(id) = Movement_aux(id) \ Movement_internal_events
Movement_FVS(id) = Movement_aux(id)
Movement_VS(id) = ShowV_Movement(Movement_FVS(id))
Movement_O(id) = sbisim(diamond(Movement(id)))
Movement_VS_O(id) = sbisim(diamond(Movement_VS(id)))
