	SourceAnalysis_enter.y.x, 
	SourceAnalysis_entered.y.x, 
	SourceAnalysis_exit.y.x, 
	SourceAnalysis_exited.y.x,
	SourceAnalysis_enter.x.y, 
	SourceAnalysis_entered.x.y, 
	SourceAnalysis_exit.x.y, 
	SourceAnalysis_exited.x.y |
	x <- {"SourceAnalysis_NoSource","SourceAnalysis_Analysis","SourceAnalysis_SourceDetected","SourceAnalysis_j1","SourceAnalysis_Reading"},
	y <- {"SourceAnalysis_NoSource"}
|}



