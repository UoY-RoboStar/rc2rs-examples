 		SKIP
 		
S_SourceAnalysis_Reading_R(id) = S_SourceAnalysis_Reading(id)
 		[|diff(SourceAnalysis_int_int,SourceAnalysis_Reading_triggers)|]
 		SKIP
 		
STM_SourceAnalysis(id) = (I_SourceAnalysis_i1(id)
[|{|SourceAnalysis_enter.x.y,
		SourceAnalysis_entered.x.y,
		SourceAnalysis_exit.x.y,
		SourceAnalysis_exited.x.y |
		x <- diff(SourceAnalysis_SIDS,{"SourceAnalysis_NoSource","SourceAnalysis_Analysis","SourceAnalysis_SourceDetected","SourceAnalysis_j1","SourceAnalysis_Reading"}),
		y <- {"SourceAnalysis_NoSource","SourceAnalysis_Analysis","SourceAnalysis_SourceDetected","SourceAnalysis_j1","SourceAnalysis_Reading"}
|}|]
(S_SourceAnalysis_NoSource_R(id)
  [|inter(CS_SourceAnalysis_NoSource_sync,union(union(union(CS_SourceAnalysis_Analysis_sync,CS_SourceAnalysis_SourceDetected_sync),CS_SourceAnalysis_j1_sync),CS_SourceAnalysis_Reading_sync))|]
 (S_SourceAnalysis_Analysis_R(id)
   [|inter(CS_SourceAnalysis_Analysis_sync,union(union(CS_SourceAnalysis_SourceDetected_sync,CS_SourceAnalysis_j1_sync),CS_SourceAnalysis_Reading_sync))|]
  (S_SourceAnalysis_SourceDetected_R(id)
    [|inter(CS_SourceAnalysis_SourceDetected_sync,union(CS_SourceAnalysis_j1_sync,CS_SourceAnalysis_Reading_sync))|]
   (S_SourceAnalysis_j1_R(id)
     [|inter(CS_SourceAnalysis_j1_sync,CS_SourceAnalysis_Reading_sync)|]
    S_SourceAnalysis_Reading_R(id))
   )
  )
 )
 	)
-- memory process
Memory_SourceAnalysis(id, gs) = (
  get_SourceAnalysis_gs!gs -> Memory_SourceAnalysis(id,gs)
  []
  set_SourceAnalysis_gs?x__ -> Memory_SourceAnalysis(id,x__)
	  []
	SourceAnalysis_internal__!"SourceAnalysis_t1" -> Memory_SourceAnalysis(id, gs)
	  []
	SourceAnalysis_s__!"SourceAnalysis_t2".in?gs -> Memory_SourceAnalysis(id, gs)
	  []
	((analysis(gs)==noSource))&(SourceAnalysis_internal__!"SourceAnalysis_t3" -> Memory_SourceAnalysis(id, gs))
	  []
	((analysis(gs)==sourceD))&(SourceAnalysis_internal__!"SourceAnalysis_t4" -> Memory_SourceAnalysis(id, gs))
	  []
	(gt(intensity(gs),SourceAnalysis_thr))&(SourceAnalysis_internal__!"SourceAnalysis_t8" -> Memory_SourceAnalysis(id, gs))
	  []
	((not (gt(intensity(gs),SourceAnalysis_thr))))&(SourceAnalysis_internal__!"SourceAnalysis_t9a" -> Memory_SourceAnalysis(id, gs))
	  []
	SourceAnalysis_s__!"SourceAnalysis_t0".in?gs -> Memory_SourceAnalysis(id, gs)
	)
-- main process
SourceAnalysis_aux(id) = ((STM_SourceAnalysis(id)
	[|union(
		{|get_SourceAnalysis_gs,set_SourceAnalysis_gs|},
		{|SourceAnalysis_internal__."SourceAnalysis_t1",
		SourceAnalysis_s__."SourceAnalysis_t2",
		SourceAnalysis_internal__."SourceAnalysis_t3",
		SourceAnalysis_internal__."SourceAnalysis_t4",
		SourceAnalysis_internal__."SourceAnalysis_t8",
		SourceAnalysis_internal__."SourceAnalysis_t9a",
		SourceAnalysis_s__."SourceAnalysis_t0"|}
	)|]
	Memory_SourceAnalysis(id, <>)
)[[SourceAnalysis_s__.x <- SourceAnalysis_s, SourceAnalysis_resume__.x <- SourceAnalysis_resume, SourceAnalysis_turn__.x <- SourceAnalysis_turn, SourceAnalysis_stop__.x <- SourceAnalysis_stop| x<-SourceAnalysis_TIDS]]
\union({|get_SourceAnalysis_gs,set_SourceAnalysis_gs|},
{||}))
[|{|SourceAnalysis_terminate|}|>SKIP\{|SourceAnalysis_internal__|}

SourceAnalysis(id) = SourceAnalysis_aux(id) \ SourceAnalysis_internal_events
SourceAnalysis_FVS(id) = SourceAnalysis_aux(id)
SourceAnalysis_VS(id) = ShowV_SourceAnalysis(SourceAnalysis_FVS(id))
SourceAnalysis_O(id) = sbisim(diamond(SourceAnalysis(id)))
SourceAnalysis_VS_O(id) = sbisim(diamond(SourceAnalysis_VS(id)))
