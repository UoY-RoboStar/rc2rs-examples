S_SourceAnalysis_NoSource(id) = let
	T_SourceAnalysis_t2(id)	= SourceAnalysis_s__!"SourceAnalysis_t2".in?gs -> set_SourceAnalysis_gs!gs ->  (SourceAnalysis_exit!"SourceAnalysis_NoSource"!"SourceAnalysis_NoSource" -> SKIP;
						SKIP;SourceAnalysis_exited!"SourceAnalysis_NoSource"!"SourceAnalysis_NoSource" -> SKIP;
						SourceAnalysis_enter!"SourceAnalysis_NoSource"!"SourceAnalysis_Analysis" -> SourceAnalysis_entered!"SourceAnalysis_NoSource"!"SourceAnalysis_Analysis" ->
						S_SourceAnalysis_NoSource(id)
	)

	S_SourceAnalysis_NoSource_execute(id,o__) = 
	SKIP; 
	SourceAnalysis_entered!o__!"SourceAnalysis_NoSource" ->
	   (SKIP
	   													; STOP /\ (
	   														    T_SourceAnalysis_t2(id)
	   														    []
	   														    SourceAnalysis_internal__?x:diff(SourceAnalysis_TIDS,{"__NULLTRANSITION__","SourceAnalysis_t3","SourceAnalysis_t8","SourceAnalysis_t4","SourceAnalysis_t9a","SourceAnalysis_t2","SourceAnalysis_t0"}) ->
	   														      SourceAnalysis_exit?y:diff(SourceAnalysis_SIDS,{"SourceAnalysis_NoSource"})!"SourceAnalysis_NoSource" -> (
	   														      	SKIP;
	   														      	SourceAnalysis_exited!y!"SourceAnalysis_NoSource" -> SKIP);
	   														      	S_SourceAnalysis_NoSource(id)
	   														    [] SourceAnalysis_s__?x:diff(SourceAnalysis_TIDS,{"__NULLTRANSITION__","SourceAnalysis_t3","SourceAnalysis_t8","SourceAnalysis_t4","SourceAnalysis_t9a","SourceAnalysis_t2","SourceAnalysis_t0"})?d__?x__ ->
	   														      SourceAnalysis_exit?y:diff(SourceAnalysis_SIDS,{"SourceAnalysis_NoSource"})!"SourceAnalysis_NoSource" -> (
	   														      	SKIP;
	   														      	SourceAnalysis_exited!y!"SourceAnalysis_NoSource" -> SKIP);
	   														      	S_SourceAnalysis_NoSource(id)
	   														    [] SourceAnalysis_resume__?x:diff(SourceAnalysis_TIDS,{"__NULLTRANSITION__","SourceAnalysis_t3","SourceAnalysis_t8","SourceAnalysis_t4","SourceAnalysis_t9a","SourceAnalysis_t2","SourceAnalysis_t0"})?d__ ->
	   														      SourceAnalysis_exit?y:diff(SourceAnalysis_SIDS,{"SourceAnalysis_NoSource"})!"SourceAnalysis_NoSource" -> (
	   														      	SKIP;
	   														      	SourceAnalysis_exited!y!"SourceAnalysis_NoSource" -> SKIP);
	   														      	S_SourceAnalysis_NoSource(id)
	   														    [] SourceAnalysis_turn__?x:diff(SourceAnalysis_TIDS,{"__NULLTRANSITION__","SourceAnalysis_t3","SourceAnalysis_t8","SourceAnalysis_t4","SourceAnalysis_t9a","SourceAnalysis_t2","SourceAnalysis_t0"})?d__?x__ ->
	   														      SourceAnalysis_exit?y:diff(SourceAnalysis_SIDS,{"SourceAnalysis_NoSource"})!"SourceAnalysis_NoSource" -> (
	   														      	SKIP;
	   														      	SourceAnalysis_exited!y!"SourceAnalysis_NoSource" -> SKIP);
	   														      	S_SourceAnalysis_NoSource(id)
	   														    [] SourceAnalysis_stop__?x:diff(SourceAnalysis_TIDS,{"__NULLTRANSITION__","SourceAnalysis_t3","SourceAnalysis_t8","SourceAnalysis_t4","SourceAnalysis_t9a","SourceAnalysis_t2","SourceAnalysis_t0"})?d__ ->
