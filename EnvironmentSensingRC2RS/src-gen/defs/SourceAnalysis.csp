channel SourceAnalysis_internal__: SourceAnalysis_TIDS

ShowEvents_SourceAnalysis(P,E) = P[[ SourceAnalysis_entered.x.y <- SourceAnalysis_enteredV.y | SourceAnalysis_entered.x.y <- E]]
							 [[	SourceAnalysis_enter.x.y <- SourceAnalysis_enterV.y | SourceAnalysis_enter.x.y <- E]]
							 [[ SourceAnalysis_exit.x.y <- SourceAnalysis_exitV.y | SourceAnalysis_exit.x.y <- E]]
							 [[ SourceAnalysis_exited.x.y <- SourceAnalysis_exitedV.y | SourceAnalysis_exited.x.y <- E ]]
							 
ShowEnteredV_SourceAnalysis(P) = P[[ SourceAnalysis_entered.x.y <- SourceAnalysis_enteredV.y | x <- SourceAnalysis_SIDS, y <- SourceAnalysis_SIDS ]]
ShowEnterV_SourceAnalysis(P) = P[[ SourceAnalysis_enter.x.y <- SourceAnalysis_enterV.y | x <- SourceAnalysis_SIDS, y <- SourceAnalysis_SIDS ]]
ShowExitV_SourceAnalysis(P) = P[[ SourceAnalysis_exit.x.y <- SourceAnalysis_exitV.y | x <- SourceAnalysis_SIDS, y <- SourceAnalysis_SIDS ]]
ShowExitedV_SourceAnalysis(P) = P[[ SourceAnalysis_exited.x.y <- SourceAnalysis_exitedV.y | x <- SourceAnalysis_SIDS, y <- SourceAnalysis_SIDS ]]
ShowV_SourceAnalysis(P) = P[[ SourceAnalysis_entered.x.y <- SourceAnalysis_enteredV.y | x <- SourceAnalysis_SIDS, y <- SourceAnalysis_SIDS]]
							 [[	SourceAnalysis_enter.x.y <- SourceAnalysis_enterV.y | x <- SourceAnalysis_SIDS, y <- SourceAnalysis_SIDS ]]
							 [[ SourceAnalysis_exit.x.y <- SourceAnalysis_exitV.y | x <- SourceAnalysis_SIDS, y <- SourceAnalysis_SIDS]]
							 [[ SourceAnalysis_exited.x.y <- SourceAnalysis_exitedV.y | x <- SourceAnalysis_SIDS, y <- SourceAnalysis_SIDS ]]

channel SourceAnalysis_enteredV, SourceAnalysis_enterV, SourceAnalysis_exitV, SourceAnalysis_exitedV : SourceAnalysis_SIDS
channel SourceAnalysis_enter, SourceAnalysis_entered: SourceAnalysis_SIDS.SourceAnalysis_SIDS
channel SourceAnalysis_exit,SourceAnalysis_exited: SourceAnalysis_SIDS.SourceAnalysis_SIDS

channel get_SourceAnalysis_gs, set_SourceAnalysis_gs: LSeq(real,2)


-- declaring identifiers of state and final states
SourceAnalysis_SIDS = {
	"SourceAnalysis",
	"SourceAnalysis_NoSource",
	"SourceAnalysis_Analysis",
	"SourceAnalysis_SourceDetected",
	"SourceAnalysis_j1",
	"SourceAnalysis_Reading"
}

-- declaring identifiers of transitions
SourceAnalysis_TIDS = {
	"__NULLTRANSITION__",
	"SourceAnalysis_t1",
	"SourceAnalysis_t2",
	"SourceAnalysis_t3",
	"SourceAnalysis_t4",
	"SourceAnalysis_t8",
	"SourceAnalysis_t9a",
	"SourceAnalysis_t0"
}

-- declaring state machine events
channel SourceAnalysis_s__:SourceAnalysis_TIDS.InOut.LSeq(real,2)

channel SourceAnalysis_s: InOut.LSeq(real,2)
channel SourceAnalysis_resume__:SourceAnalysis_TIDS.InOut

channel SourceAnalysis_resume: InOut
channel SourceAnalysis_turn__:SourceAnalysis_TIDS.InOut.real

channel SourceAnalysis_turn: InOut.real
channel SourceAnalysis_stop__:SourceAnalysis_TIDS.InOut

channel SourceAnalysis_stop: InOut

channel SourceAnalysis_terminate

-- declaring all states
