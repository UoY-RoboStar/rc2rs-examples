Memory_Movement_WC_Movement_t7_0(WC_Movement_t7_0) = (
getWC_Movement."WC_Movement_t7_0"!WC_Movement_t7_0 -> Memory_Movement_WC_Movement_t7_0(WC_Movement_t7_0)
[]
Movement_WC."WC_Movement_t7_0"?x__ -> Memory_Movement_WC_Movement_t7_0(x__)
)

Memory_Movement_WC_Movement_t14_0(WC_Movement_t14_0) = (
getWC_Movement."WC_Movement_t14_0"!WC_Movement_t14_0 -> Memory_Movement_WC_Movement_t14_0(WC_Movement_t14_0)
[]
Movement_WC."WC_Movement_t14_0"?x__ -> Memory_Movement_WC_Movement_t14_0(x__)
)

MemoryTransitions_Movement(id) = (getV_Movement_a?a ->
getV_Movement_d0?d0 ->
getV_Movement_d1?d1 ->
getV_Movement_l?l ->
getWC_Movement."WC_Movement_t7_0"?WC_Movement_t7_0 ->
getWC_Movement."WC_Movement_t14_0"?WC_Movement_t14_0 ->
(Movement_internal__!"Movement_t1" -> MemoryTransitions_Movement(id)
[]
Movement_turn__!"Movement_t2".in?a -> MemoryTransitions_Movement(id)
[]
Movement_turn__!"Movement_t3".in?a -> MemoryTransitions_Movement(id)
[]
Movement_stop__!"Movement_t4".in -> MemoryTransitions_Movement(id)
[]
Movement_internal__!"Movement_t5" -> MemoryTransitions_Movement(id)
[]
Movement_obstacle__!"Movement_t6".in?l -> MemoryTransitions_Movement(id)
[]
Movement_turn__!"Movement_t7".in?a:{a|a <- real, WC_Movement_t7_0} -> MemoryTransitions_Movement(id)
[]
Movement_turn__!"Movement_t8".in?a -> MemoryTransitions_Movement(id)
[]
Movement_stop__!"Movement_t9".in -> MemoryTransitions_Movement(id)
[]
Movement_resume__!"Movement_t10".in -> MemoryTransitions_Movement(id)
[]
Movement_obstacle__!"Movement_t11".in?l -> MemoryTransitions_Movement(id)
[]
((Minus(d1, d0, real)>Movement_stuckDist))&(Movement_internal__!"Movement_t12" -> MemoryTransitions_Movement(id))
[]
((Minus(d1, d0, real)<=Movement_stuckDist))&(Movement_internal__!"Movement_t13" -> MemoryTransitions_Movement(id))
[]
Movement_turn__!"Movement_t14".in?a:{a|a <- real, WC_Movement_t14_0} -> MemoryTransitions_Movement(id)
[]
Movement_resume__!"Movement_t0".in -> MemoryTransitions_Movement(id)
[]
Movement_stop__!"Movement_t15".in -> MemoryTransitions_Movement(id)
[]
(WC_Movement_t14_0)&(Movement_stop__!"Movement_t16".in -> MemoryTransitions_Movement(id))
[]
Movement_stop__!"Movement_t17".in -> MemoryTransitions_Movement(id)
[]
(WC_Movement_t7_0)&(Movement_stop__!"Movement_t18".in -> MemoryTransitions_Movement(id))
[]
(WC_Movement_t7_0)&(Movement_resume__!"Movement_t19".in -> MemoryTransitions_Movement(id))
[]
(WC_Movement_t14_0)&(Movement_resume__!"Movement_t20".in -> MemoryTransitions_Movement(id))
[]
Movement_resume__!"Movement_t22".in -> MemoryTransitions_Movement(id)
[]
Movement_obstacle__!"Movement_t21".in?l -> MemoryTransitions_Movement(id)
[]
set_Movement_a?x__ -> MemoryTransitions_Movement(id)
[]
set_Movement_d0?x__ -> MemoryTransitions_Movement(id)
[]
set_Movement_d1?x__ -> MemoryTransitions_Movement(id)
[]
set_Movement_l?x__ -> MemoryTransitions_Movement(id)
[]
Movement_WC."WC_Movement_t7_0"?x__ -> MemoryTransitions_Movement(id)
[]
Movement_WC."WC_Movement_t14_0"?x__ -> MemoryTransitions_Movement(id)))


MemoryVariablesProcesses_Movement = {(Memory_Movement_a(0),{|Movement_turn__."Movement_t7",Movement_turn__."Movement_t3",Movement_turn__."Movement_t2",set_Movement_a,getV_Movement_a,Movement_turn__."Movement_t14",get_Movement_a,Movement_turn__."Movement_t8"|}),
(Memory_Movement_d0(0),{|getV_Movement_d0,set_Movement_d0,get_Movement_d0|}),
(Memory_Movement_d1(0),{|set_Movement_d1,getV_Movement_d1,get_Movement_d1|}),
(Memory_Movement_l(left),{|getV_Movement_l,Movement_obstacle__."Movement_t11",get_Movement_l,Movement_obstacle__."Movement_t21",Movement_obstacle__."Movement_t6",set_Movement_l|}),
(Memory_Movement_WC_Movement_t7_0(false),{|getWC_Movement."WC_Movement_t7_0",Movement_WC."WC_Movement_t7_0"|}),
(Memory_Movement_WC_Movement_t14_0(false),{|getWC_Movement."WC_Movement_t14_0",Movement_WC."WC_Movement_t14_0"|})}

MemoryVariables_Movement = ||| (P, alpha) : MemoryVariablesProcesses_Movement @ P
MemoryVariablesSyncSet_Movement = {|Movement_WC."WC_Movement_t7_0",
getV_Movement_l,
Movement_WC."WC_Movement_t14_0",
getV_Movement_d0,
set_Movement_d1,
getWC_Movement."WC_Movement_t14_0",
getV_Movement_d1,
getV_Movement_a,
Movement_turn__."Movement_t8",
