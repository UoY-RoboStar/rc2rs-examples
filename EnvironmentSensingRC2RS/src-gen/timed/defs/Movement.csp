Movement_obstacle__."Movement_t11",
Movement_obstacle__."Movement_t21",
Movement_turn__."Movement_t3",
Movement_turn__."Movement_t2",
set_Movement_a,
Movement_turn__."Movement_t14",
set_Movement_d0,
Movement_obstacle__."Movement_t6",
getWC_Movement."WC_Movement_t7_0"|}
MemoryVariablesHideSet_Movement = {|getV_Movement_l,
getWC_Movement,
getV_Movement_d0,
getV_Movement_d1,
getV_Movement_a|}

MemoryN_Movement(id) = (wbisim(MemoryVariables_Movement) [| MemoryVariablesSyncSet_Movement |] wbisim(MemoryTransitions_Movement(id))) \ MemoryVariablesHideSet_Movement

Memory_Movement(id, a, d0, d1, l, WC_Movement_t7_0, WC_Movement_t14_0) = (
get_Movement_a!a -> Memory_Movement(id, a, d0, d1, l, WC_Movement_t7_0, WC_Movement_t14_0)
[]
set_Movement_a?x__ -> Memory_Movement(id, x__, d0, d1, l, WC_Movement_t7_0, WC_Movement_t14_0)
[]
get_Movement_d0!d0 -> Memory_Movement(id, a, d0, d1, l, WC_Movement_t7_0, WC_Movement_t14_0)
[]
set_Movement_d0?x__ -> Memory_Movement(id, a, x__, d1, l, WC_Movement_t7_0, WC_Movement_t14_0)
[]
get_Movement_d1!d1 -> Memory_Movement(id, a, d0, d1, l, WC_Movement_t7_0, WC_Movement_t14_0)
[]
set_Movement_d1?x__ -> Memory_Movement(id, a, d0, x__, l, WC_Movement_t7_0, WC_Movement_t14_0)
[]
get_Movement_l!l -> Memory_Movement(id, a, d0, d1, l, WC_Movement_t7_0, WC_Movement_t14_0)
[]
set_Movement_l?x__ -> Memory_Movement(id, a, d0, d1, x__, WC_Movement_t7_0, WC_Movement_t14_0)
[]
Movement_WC."WC_Movement_t7_0"?x__ -> Memory_Movement(id, a, d0, d1, l, x__, WC_Movement_t14_0)[]
Movement_WC."WC_Movement_t14_0"?x__ -> Memory_Movement(id, a, d0, d1, l, WC_Movement_t7_0, x__)[]
Movement_internal__!"Movement_t1" -> Memory_Movement(id, a, d0, d1, l, WC_Movement_t7_0, WC_Movement_t14_0)[]
Movement_turn__!"Movement_t2".in?a -> Memory_Movement(id, a, d0, d1, l, WC_Movement_t7_0, WC_Movement_t14_0)[]
Movement_turn__!"Movement_t3".in?a -> Memory_Movement(id, a, d0, d1, l, WC_Movement_t7_0, WC_Movement_t14_0)[]
Movement_stop__!"Movement_t4".in -> Memory_Movement(id, a, d0, d1, l, WC_Movement_t7_0, WC_Movement_t14_0)[]
Movement_internal__!"Movement_t5" -> Memory_Movement(id, a, d0, d1, l, WC_Movement_t7_0, WC_Movement_t14_0)[]
Movement_obstacle__!"Movement_t6".in?l -> Memory_Movement(id, a, d0, d1, l, WC_Movement_t7_0, WC_Movement_t14_0)[]
Movement_turn__!"Movement_t7".in?a:{a|a <- real, WC_Movement_t7_0} -> Memory_Movement(id, a, d0, d1, l, WC_Movement_t7_0, WC_Movement_t14_0)[]
Movement_turn__!"Movement_t8".in?a -> Memory_Movement(id, a, d0, d1, l, WC_Movement_t7_0, WC_Movement_t14_0)[]
Movement_stop__!"Movement_t9".in -> Memory_Movement(id, a, d0, d1, l, WC_Movement_t7_0, WC_Movement_t14_0)[]
Movement_resume__!"Movement_t10".in -> Memory_Movement(id, a, d0, d1, l, WC_Movement_t7_0, WC_Movement_t14_0)[]
Movement_obstacle__!"Movement_t11".in?l -> Memory_Movement(id, a, d0, d1, l, WC_Movement_t7_0, WC_Movement_t14_0)[]
((Minus(d1, d0, real)>Movement_stuckDist))&(Movement_internal__!"Movement_t12" -> Memory_Movement(id, a, d0, d1, l, WC_Movement_t7_0, WC_Movement_t14_0))[]
((Minus(d1, d0, real)<=Movement_stuckDist))&(Movement_internal__!"Movement_t13" -> Memory_Movement(id, a, d0, d1, l, WC_Movement_t7_0, WC_Movement_t14_0))[]
Movement_turn__!"Movement_t14".in?a:{a|a <- real, WC_Movement_t14_0} -> Memory_Movement(id, a, d0, d1, l, WC_Movement_t7_0, WC_Movement_t14_0)[]
Movement_resume__!"Movement_t0".in -> Memory_Movement(id, a, d0, d1, l, WC_Movement_t7_0, WC_Movement_t14_0)[]
Movement_stop__!"Movement_t15".in -> Memory_Movement(id, a, d0, d1, l, WC_Movement_t7_0, WC_Movement_t14_0)[]
(WC_Movement_t14_0)&(Movement_stop__!"Movement_t16".in -> Memory_Movement(id, a, d0, d1, l, WC_Movement_t7_0, WC_Movement_t14_0))[]
Movement_stop__!"Movement_t17".in -> Memory_Movement(id, a, d0, d1, l, WC_Movement_t7_0, WC_Movement_t14_0)[]
(WC_Movement_t7_0)&(Movement_stop__!"Movement_t18".in -> Memory_Movement(id, a, d0, d1, l, WC_Movement_t7_0, WC_Movement_t14_0))[]
(WC_Movement_t7_0)&(Movement_resume__!"Movement_t19".in -> Memory_Movement(id, a, d0, d1, l, WC_Movement_t7_0, WC_Movement_t14_0))[]
(WC_Movement_t14_0)&(Movement_resume__!"Movement_t20".in -> Memory_Movement(id, a, d0, d1, l, WC_Movement_t7_0, WC_Movement_t14_0))[]
Movement_resume__!"Movement_t22".in -> Memory_Movement(id, a, d0, d1, l, WC_Movement_t7_0, WC_Movement_t14_0)[]
Movement_obstacle__!"Movement_t21".in?l -> Memory_Movement(id, a, d0, d1, l, WC_Movement_t7_0, WC_Movement_t14_0)
)

MemoryO_Movement(id) = Memory_Movement(id, 0, 0, 0, left, false, false)

-- main process
Movement_aux(id) = prioritise(timed_priority(((wbisim(STM_Movement(id))
	[|Union({
		{|get_Movement_a,set_Movement_a,
		get_Movement_d0,set_Movement_d0,
		get_Movement_d1,set_Movement_d1,
		get_Movement_l,set_Movement_l|},
		{|Movement_internal__."Movement_t1",
		Movement_turn__."Movement_t2",
		Movement_turn__."Movement_t3",
		Movement_stop__."Movement_t4",
		Movement_internal__."Movement_t5",
		Movement_obstacle__."Movement_t6",
		Movement_turn__."Movement_t7",
		Movement_turn__."Movement_t8",
		Movement_stop__."Movement_t9",
		Movement_resume__."Movement_t10",
		Movement_obstacle__."Movement_t11",
		Movement_internal__."Movement_t12",
		Movement_internal__."Movement_t13",
		Movement_turn__."Movement_t14",
		Movement_resume__."Movement_t0",
		Movement_stop__."Movement_t15",
		Movement_stop__."Movement_t16",
		Movement_stop__."Movement_t17",
		Movement_stop__."Movement_t18",
		Movement_resume__."Movement_t19",
		Movement_resume__."Movement_t20",
		Movement_resume__."Movement_t22",
		Movement_obstacle__."Movement_t21"|}
		,
		{|Movement_deadline|},
		Movement_WCresets
	})|]
	(wbisim(MemoryN_Movement(id)) [| union({|Movement_WC|},Movement_WCsync) |] Movement_WaitingConditions)\{|Movement_WC|}
)[[Movement_obstacle__.x <- Movement_obstacle, Movement_odometer__.x <- Movement_odometer, Movement_resume__.x <- Movement_resume, Movement_turn__.x <- Movement_turn, Movement_stop__.x <- Movement_stop, Movement_flag__.x <- Movement_flag| x<-Movement_TIDS]]\union(union({|get_Movement_a,set_Movement_a,
get_Movement_d0,set_Movement_d0,
get_Movement_d1,set_Movement_d1,
get_Movement_l,set_Movement_l|},
{||}),{|Movement_deadline|}))
[|{|Movement_terminate|}|>SKIP\{|Movement_internal__|}),<union(Movement_internal_events,{|Movement_clockReset|}),{Movement_terminate},{tock}>)

Movement_internal_(id) = prioritise(timed_priority(((wbisim(STM_Movement(id))
	[|Union({
	{|get_Movement_a,set_Movement_a,
	get_Movement_d0,set_Movement_d0,
	get_Movement_d1,set_Movement_d1,
	get_Movement_l,set_Movement_l|},
	{|Movement_internal__."Movement_t1",
	Movement_turn__."Movement_t2",
	Movement_turn__."Movement_t3",
	Movement_stop__."Movement_t4",
	Movement_internal__."Movement_t5",
	Movement_obstacle__."Movement_t6",
	Movement_turn__."Movement_t7",
	Movement_turn__."Movement_t8",
	Movement_stop__."Movement_t9",
	Movement_resume__."Movement_t10",
	Movement_obstacle__."Movement_t11",
	Movement_internal__."Movement_t12",
	Movement_internal__."Movement_t13",
	Movement_turn__."Movement_t14",
	Movement_resume__."Movement_t0",
	Movement_stop__."Movement_t15",
	Movement_stop__."Movement_t16",
	Movement_stop__."Movement_t17",
	Movement_stop__."Movement_t18",
	Movement_resume__."Movement_t19",
	Movement_resume__."Movement_t20",
	Movement_resume__."Movement_t22",
	Movement_obstacle__."Movement_t21"|}
	,
	{|Movement_deadline|},
	Movement_WCresets
	})|]
	(wbisim(MemoryN_Movement(id)) [| union({|Movement_WC|},Movement_WCsync) |] Movement_WaitingConditions)\{|Movement_WC|}
)\union(union({|get_Movement_a,set_Movement_a,
get_Movement_d0,set_Movement_d0,
get_Movement_d1,set_Movement_d1,
get_Movement_l,set_Movement_l|},
{||}),{|Movement_deadline|}))
[|{|Movement_terminate|}|>SKIP),<union(Movement_internal_events,{|Movement_internal__,Movement_clockReset|}),{Movement_terminate},{tock}>)

-- With no internal events visible
Movement(id) = timed_priority(Movement_aux(id) \ union(Movement_internal_events,{|Movement_clockReset|}))
-- With enter/entered/exit/exited events visible
Movement_FVS(id) = timed_priority(Movement_aux(id) \ {|Movement_clockReset|})
-- With enterV/enteredV/exitV/exitedV events visible
Movement_VS(id) = ShowV_Movement(timed_priority(Movement_aux(id) \ {|Movement_clockReset|}))
-- With clock resets visible
Movement_FVS_C(id) = Movement_aux(id)
}

