-- r1 - deadlock free
assert timed::EnvironmentalSensing(0) :[deadlock free]

-- r2 - terminating
assert not timed::EnvironmentalSensing(0) :[deadlock free]
assert timed::EnvironmentalSensing(0); RUN({r__}) :[deadlock free]

-- r3 - refinement
assert Spec2 [FD= timed::Movement(0)


