//timed assertion EnvironmentalSensing is deadlock-free (r1)
//timed assertion EnvironmentalSensing terminates (r2)

untimed csp Common csp-begin
include "defs/Chemical_defs.csp"
csp-end

timed csp Spec2 csp-begin
include "../defs/Chemical_defs.csp"
Spec2 = let
Init = moveForwardCall -> moveForwardRet -> SKIP |~| moveForwardCall -> SKIP |~| SKIP
Reaction = |~|e:{|moveForwardCall, moveForwardRet, moveTowardsCall, moveTowardsRet, Movement_flag, Movement_obstacle, Movement_odometer|} @ e->(Reaction|~|SKIP)
T = (Reaction |~| SKIP |~| (|~|e:{|Movement_resume, Movement_turn,Movement_stop|} @ e->SKIP); Reaction; T)
Clock = (tock -> SKIP |~| SKIP); Clock
within
Init ||| T ||| Clock
csp-end

//timed assertion Movement refines Spec2 (r3)

csp Instantiations csp-begin
moveForward_BOUND = 2
Movement_evadeTime = 1
nametype string = LSeq(Char,2)
Movement_lv = 1
Movement_stuckDist = 1
SourceAnalysis_thr = 1
Plus(e1,e2,T) = if member(e1+e2,T) then e1+e2 else e1
nametype nat = {0..2}
stop_BOUND = 2
Movement_outPeriod = 1
nametype real = {0..2}
reverse_BOUND = 2
gt(i1,i2) = i1 > i2
nametype int = { -2..2}
Div(e1,e2,T) = if member(e1/e2,T) then e1/e2 else e1
Neg(e1,T) = if member(-e1,T) then -e1 else e1
nametype boolean = Bool
Mult(e1,e2,T) = if member(e1*e2,T) then e1*e2 else e1
Modulus(e1,e2,T) = if member(e1%e2,T) then e1%e2 else e1
moveTowards_BOUND = 2
changeDirection_BOUND = 2
Minus(e1,e2,T) = if member(e1-e2,T) then e1-e2 else e1

intensity(<>) = 0
intensity(<(i)>^xs) = let
n = intensity(xs)
within if (n > i) then n else i

location(gs) = 0

-- let
--	find(<>,_) = 0
--	find(<(i)>^xs,n) = if (i == intensity(gs)) then n else find(xs,n+1)
-- within
--	if (length(gs) > 0) then (360/length(gs))*find(gs,0) else 0

analysis(gs) = if (intensity(gs) > 0) then sourceD else noSource
csp-end