							 	  Behaviour ; 
							 	  share__choice(exit -> SKIP) ; share__choice(share__choice(get_apples?apples -> share__choice(get_apple?apple -> true & (share__choice(set_apples!set_toolkit_diff(apples,{apple}) -> SKIP))))) ; 
