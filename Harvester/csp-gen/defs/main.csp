					Inactive 	= share__choice(enter -> SKIP [] terminate -> SKIP) ; Active
					
					Termination = terminate -> SKIP
					
					Active 		= true&CALL__goHome(
								id__,
							    const_main_GoHome_goHTime
							);SKIP ; 
							 	  Behaviour ; 
							 	  share__choice(exit -> SKIP) ; SKIP ; 
							 	  share__choice(exited -> SKIP) ; Inactive
				
					Behaviour 	= entered -> During
					During 		= ((SKIP ; SStop) /\ interrupt -> SKIP)
				within
					Inactive [| {terminate} |> SKIP)
				
			
			endmodule
			----------------------------------------------------------------------
			
			-- END of Nodes --
			
			-- Operation calls --
			-- Only the undefined operations are declared here.
			-- If the state machine is in isolation, all required operations will be undefined.
			-- If it is in the context of a controller, the required operations not provided by the
			-- controller will be declared here, and the defined operations will be defined in the
			-- context of the Controller module, and therefore within scope of the state machine module.
			CALL__hideArm(id__,
					    const_main_GoHome_goHTime) 	= hideArmCall -> SKIP
			CALL__move(id__,
					    const_main_GoHome_goHTime,
						param_jp) 	= moveCall.param_jp -> SKIP
			CALL__grasp(id__,
					    const_main_GoHome_goHTime,
						param_jp) 	= graspCall.param_jp -> SKIP
			CALL__goHome(id__,
					    const_main_GoHome_goHTime) 	= goHomeCall -> SKIP
			CALL__pick(id__,
					    const_main_GoHome_goHTime) 	= pickCall -> SKIP
			CALL__drop(id__,
					    const_main_GoHome_goHTime,
						param_jp) 	= dropCall.param_jp -> SKIP
			
			-- END of Operation calls --
			
			-- STM processes
			STM(id__,
					    const_main_GoHome_goHTime) = -- RULE: [[stm:StateMachineDef]]_STM^nops : CSPProcess
			( 
				(
					(
						(IteratedStateful(id__,
								    const_main_GoHome_goHTime) \ {terminate} ; share__choice(terminate -> SKIP))
					 	[[ share__ <- x__ | x__ <- {||} ]]
					)
				[| {share__} |]
				SKIP
				)
				[| union(sharedVarSync,{terminate}) |]
				dbisim(sharedVarMemory(id__,
						    const_main_GoHome_goHTime))
