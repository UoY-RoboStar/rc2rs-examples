	module ControlArm
		shared_variable_events = {|
		|}
		
	exports
		transparent diamond
		transparent sbisim
		transparent dbisim
		transparent chase

		-- declaring controller events
		channel takePic: InOut.main_Image
		
		
		
		-- declaring call and ret events for undefined operations
		channel hideArmCall
		channel moveCall: main_JointsPos
		channel graspCall: main_JointsPos
		channel goHomeCall
		channel pickCall
		channel dropCall: main_JointsPos
		
		-- declaring controller termination channel
		channel terminate
		
		-- channel set with all visible events
		sem__events = {|
			terminate
		,	takePic
		,	hideArmCall,
			moveCall,
			graspCall,
			goHomeCall,
			pickCall,
			dropCall
		|}

		-- defined operations
		module OP_CHTBA
		exports
			datatype TIDS = NULLTRANSITION__
			-- These definitions are needed to make the structure of an incompletely defined operation compatible with that of fully defined operations.
			MemoryTransitions(id__) = STOP -- this is STOP because MemoryTransitions is put in a choice with the state machine's MemoryTransitions. if it were SKIP, a divergence would be introduced.
					MemoryVariablesSyncSet = {}
					MemoryVariablesHideSet = {}
					MachineMemorySyncSet = {}
					MachineMemoryHidingSet = {}
					channel internal__
			D__(id__,
						param_img) = let
				AUX = SKIP 
					  |~|
					  STOP 
					  		  within 
				AUX
			
			O__(id__,
						param_img) = D__(id__,
						param_img)
			HUP__(id__,
						param_img) = D__(id__,
						param_img)
		endmodule
		module OP_NearestNeighbour
		exports
			datatype TIDS = NULLTRANSITION__
			-- These definitions are needed to make the structure of an incompletely defined operation compatible with that of fully defined operations.
			MemoryTransitions(id__) = STOP -- this is STOP because MemoryTransitions is put in a choice with the state machine's MemoryTransitions. if it were SKIP, a divergence would be introduced.
					MemoryVariablesSyncSet = {}
					MemoryVariablesHideSet = {}
					MachineMemorySyncSet = {}
					MachineMemoryHidingSet = {}
					channel internal__
			D__(id__) = let
				AUX = SKIP 
					  |~|
					  STOP 
					  		  within 
				AUX
			
			O__(id__) = D__(id__)
			HUP__(id__) = D__(id__)
		endmodule
	
		-- declaring machines
		module stm_ref0
		exports
			transparent diamond
			transparent sbisim
			transparent dbisim
			transparent chase
		
			-- Transition identifiers
			-- declaring identifiers of transitions
			datatype NIDS = 
			              NID_i0|
			              NID_Prepare|
			              NID_LocalizeFruit|
			              NID_Next|
			              NID_GetApple|
			              NID_j0|
			              NID_GoingHome
			
			channel internal__ : NIDS
			
			-- Flow channels		
			channel interrupt
			channel exited
			channel exit
			channel terminate
			
			-- Variable channels
			channel get_img, set_img, setL_img, setR_img: main_Image
			channel get_localized, set_localized, setL_localized, setR_localized: core_boolean
			channel get_apples, set_apples, setL_apples, setR_apples: Set(setoperations_Coord3D)
			channel get_positions, set_positions, setL_positions, setR_positions: Function(setoperations_Coord3D, {(x0__,x1__,x2__) | x0__ <- main_JointsPos,x1__ <- main_JointsPos,x2__ <- main_JointsPos})
			channel get_nextApple, set_nextApple, setL_nextApple, setR_nextApple: setoperations_Coord3D
			
			-- Shared variable channels
			
			-- Local variable channels for defined operations that are required by the state machine
			
			-- Declaring state machine events
			channel takePic__: NIDS.InOut.main_Image
			channel takePic: InOut.main_Image
			channel startIKSolver__: NIDS.InOut.Set(setoperations_Coord3D)
			channel startIKSolver: InOut.Set(setoperations_Coord3D)
