			Clocks(id__) = terminate -> SKIP
			
			clockSync = {||}
			
			Clock_CLID_S1(id__,x__) = 
				TimeOut_1(
					S1::entered -> Clock_CLID_S1(id__,0)
					[]
					get_CLID_S1!x__ -> Clock_CLID_S1(id__,x__)
					[]
					terminate -> SKIP,Clock_CLID_S1(id__,clock_type_plus(x__,1,CLID_S1_clock_type(id__))))
			
			StateClocks(id__) = dbisim(Clock_CLID_S1(id__,0))
			
			stateClockSync = {|get_CLID_S1,S1::entered|}
			
			}
				endmodule
	
	Timed(OneStep) {
	-- (Rule 8) cycleController(...) : CSPProcess
	datatype SOutputEvents = SOutput_grasp
		| SOutput_endIKSolver
		| SOutput_endGoHome
		| SOutput_startIKSolver
		| SOutput_goHome
		| SOutput_move
		| SOutput_drop
		| SOutput_hideArm
		| SOutput_pick
		| SOutput_startGoHome
	
	DVarsEvents = {}
	
	nametype EVarsEvents = {|SOutput_endIKSolver
		, SOutput_endGoHome
		, SOutput_startIKSolver
		, SOutput_startGoHome|}	
	
	cycleController(id__,cycle_pkg727_main_sim_ControlArm_ControlArm,
			    const_pkg727_main_sim_ControlArm_stm_ref0_hideTime,
			    const_pkg727_main_sim_ControlArm_stm_ref0_approachTime,
			    const_pkg727_main_sim_ControlArm_stm_ref0_graspTime,
			    const_pkg727_main_sim_ControlArm_stm_ref0_dropTime,
			    const_pkg727_main_sim_ControlArm_stm_ref0_pickTime,
			    const_pkg727_main_sim_ControlArm_stm_ref0_pickDeadl,
			    const_pkg727_main_sim_ControlArm_stm_ref0_homePos,
			    const_pkg727_main_sim_ControlArm_stm_ref0_storagePos,
			    const_pkg727_main_sim_ControlArm_stm_ref2_goHTime) =
	let
				
		project_stm_ref0(stm_ref0::o_grasp.x__) = SOutput_grasp
		project_stm_ref0(stm_ref0::o_startIKSolver.x__) = SOutput_startIKSolver
		project_stm_ref0(stm_ref0::o_goHome) = SOutput_goHome
		project_stm_ref0(stm_ref0::o_move.x__) = SOutput_move
		project_stm_ref0(stm_ref0::o_drop.x__) = SOutput_drop
		project_stm_ref0(stm_ref0::o_hideArm) = SOutput_hideArm
		project_stm_ref0(stm_ref0::o_pick) = SOutput_pick
		project_stm_ref0(stm_ref0::o_startGoHome) = SOutput_startGoHome
		project_stm_ref1(stm_ref1::o_endIKSolver.x__) = SOutput_endIKSolver
		project_stm_ref2(stm_ref2::o_endGoHome) = SOutput_endGoHome
		project_stm_ref2(stm_ref2::o_drop.x__) = SOutput_drop
		project_stm_ref2(stm_ref2::o_move.x__) = SOutput_move
		project_stm_ref2(stm_ref2::o_grasp.x__) = SOutput_grasp
		project_stm_ref2(stm_ref2::o_hideArm) = SOutput_hideArm
		project_stm_ref2(stm_ref2::o_pick) = SOutput_pick
		project_stm_ref2(stm_ref2::o_goHome) = SOutput_goHome
	
		connected_stm_ref0(stm_ref0::o_grasp.x__) = true
		connected_stm_ref0(stm_ref0::o_startIKSolver.x__) = true
		connected_stm_ref0(stm_ref0::o_goHome) = true
		connected_stm_ref0(stm_ref0::o_move.x__) = true
		connected_stm_ref0(stm_ref0::o_drop.x__) = true
		connected_stm_ref0(stm_ref0::o_hideArm) = true
		connected_stm_ref0(stm_ref0::o_pick) = true
		connected_stm_ref0(stm_ref0::o_startGoHome) = true
		connected_stm_ref0(_) = false
		connected_stm_ref1(stm_ref1::o_endIKSolver.x__) = true
		connected_stm_ref1(_) = false
		connected_stm_ref2(stm_ref2::o_endGoHome) = true
		connected_stm_ref2(stm_ref2::o_drop.x__) = true
		connected_stm_ref2(stm_ref2::o_move.x__) = true
		connected_stm_ref2(stm_ref2::o_grasp.x__) = true
		connected_stm_ref2(stm_ref2::o_hideArm) = true
		connected_stm_ref2(stm_ref2::o_pick) = true
		connected_stm_ref2(stm_ref2::o_goHome) = true
		connected_stm_ref2(_) = false
	
		lift_stm_ref0(stm_ref0::o_goHome) = o_goHome
		lift_stm_ref0(stm_ref0::o_move.x__) = o_move.x__
		lift_stm_ref0(stm_ref0::o_grasp.x__) = o_grasp.x__
		lift_stm_ref0(stm_ref0::o_drop.x__) = o_drop.x__
		lift_stm_ref0(stm_ref0::o_hideArm) = o_hideArm
		lift_stm_ref0(stm_ref0::o_pick) = o_pick
		lift_stm_ref2(stm_ref2::o_drop.x__) = o_drop.x__
		lift_stm_ref2(stm_ref2::o_move.x__) = o_move.x__
		lift_stm_ref2(stm_ref2::o_grasp.x__) = o_grasp.x__
		lift_stm_ref2(stm_ref2::o_hideArm) = o_hideArm
		lift_stm_ref2(stm_ref2::o_pick) = o_pick
		lift_stm_ref2(stm_ref2::o_goHome) = o_goHome
		
		CycleController =
			Deadline(
			-- read inputs from the controller and pass to state machines
			(
			((registerRead.i_takePic?x__ ->
				((stm_ref0::registerRead.stm_ref0::i_takePic!x__ -> SKIP))))
			-- ensure state machines read the values being communicated via evars
			||| ((stm_ref0::registerRead.stm_ref0::i_endIKSolver?x__ -> SKIP)
				|||
			
	(stm_ref0::registerRead.stm_ref0::i_endGoHome?x__ -> SKIP)
				|||
			
	(stm_ref1::registerRead.stm_ref1::i_startIKSolver?x__ -> SKIP)
				|||
			
	(stm_ref2::registerRead.stm_ref2::i_startGoHome?x__ -> SKIP)
	)		);
			-- synchronize on events related to evars to erase memory
			((registerWriteE.e_endIKSolver -> SKIP)
				|||
			(registerWriteE.e_endGoHome -> SKIP)
				|||
			(registerWriteE.e_startIKSolver -> SKIP)
				|||
			(registerWriteE.e_startGoHome -> SKIP));
			-- collect outputs, and monitor termination of the cycle, by all controllers
			(CollectOutputs(SOutputEvents) [| {endexec} |] Monitor),0);
			-- wait for the cycleDef period
			TimeOut_1(terminate -> SKIP,WAIT(cycle_pkg727_main_sim_ControlArm_ControlArm-1));
			-- recurse
			CycleController
			
									
		CollectOutputs(sout) =
			(stm_ref0::registerWrite?outp:{ outp | outc <- diff(sout,union(EVarsEvents,DVarsEvents)), outp <- stm_ref0::RegisterDataOutput, connected_stm_ref0(outp), project_stm_ref0(outp) == outc}
					-> registerWrite!lift_stm_ref0(outp)
						-> CollectOutputs(diff(sout,{project_stm_ref0(outp)}))
			[]
			stm_ref2::registerWrite?outp:{ outp | outc <- diff(sout,union(EVarsEvents,DVarsEvents)), outp <- stm_ref2::RegisterDataOutput, connected_stm_ref2(outp), project_stm_ref2(outp) == outc}
					-> registerWrite!lift_stm_ref2(outp)
						-> CollectOutputs(diff(sout,{project_stm_ref2(outp)}))
			[]
			stm_ref1::registerWrite?outp:{ outp | outc <- inter(sout,EVarsEvents), outp <- stm_ref1::RegisterDataOutput, connected_stm_ref1(outp), project_stm_ref1(outp) == outc}
					-> CollectOutputs(diff(sout,{project_stm_ref1(outp)}))
			[]
			stm_ref2::registerWrite?outp:{ outp | outc <- inter(sout,EVarsEvents), outp <- stm_ref2::RegisterDataOutput, connected_stm_ref2(outp), project_stm_ref2(outp) == outc}
					-> CollectOutputs(diff(sout,{project_stm_ref2(outp)}))
			[]
			stm_ref0::registerWrite?outp:{ outp | outc <- inter(sout,EVarsEvents), outp <- stm_ref0::RegisterDataOutput, connected_stm_ref0(outp), project_stm_ref0(outp) == outc}
					-> CollectOutputs(diff(sout,{project_stm_ref0(outp)}))
			[]
			endexec -> SKIP
			)
	
		Monitor = 
			(	 (stm_ref0::endexec -> SKIP)
			|||	 (stm_ref1::endexec -> SKIP)
			|||	 (stm_ref2::endexec -> SKIP)); endexec -> SKIP
	within
		CycleController
	
	-- (Rule 5) memoryComp(...) : CSPProcess
	memoryComp(id__,
			    const_pkg727_main_sim_ControlArm_stm_ref0_hideTime,
			    const_pkg727_main_sim_ControlArm_stm_ref0_approachTime,
			    const_pkg727_main_sim_ControlArm_stm_ref0_graspTime,
			    const_pkg727_main_sim_ControlArm_stm_ref0_dropTime,
			    const_pkg727_main_sim_ControlArm_stm_ref0_pickTime,
			    const_pkg727_main_sim_ControlArm_stm_ref0_pickDeadl,
			    const_pkg727_main_sim_ControlArm_stm_ref0_homePos,
			    const_pkg727_main_sim_ControlArm_stm_ref0_storagePos,
			    const_pkg727_main_sim_ControlArm_stm_ref2_goHTime) = (
		Memory_endIKSolver(false.0)
		||| Memory_endGoHome(false)
		||| Memory_startIKSolver(false.{})
		||| Memory_startGoHome(false)
		)
	
	Memory_endIKSolver(x__) = (
		registerWriteE.e_endIKSolver -> Memory_endIKSolver(false.0)
		[]
		stm_ref1::registerWrite.stm_ref1::o_endIKSolver?x__ -> Memory_endIKSolver(true.x__)
		[]
		stm_ref0::registerRead.stm_ref0::i_endIKSolver!x__ -> Memory_endIKSolver(x__)
	)
	Memory_endGoHome(x__) = (
		registerWriteE.e_endGoHome -> Memory_endGoHome(false)
		[]
		stm_ref2::registerWrite.stm_ref2::o_endGoHome -> Memory_endGoHome(true)
		[]
		stm_ref0::registerRead.stm_ref0::i_endGoHome!x__ -> Memory_endGoHome(x__)
	)
	Memory_startIKSolver(x__) = (
		registerWriteE.e_startIKSolver -> Memory_startIKSolver(false.{})
		[]
		stm_ref0::registerWrite.stm_ref0::o_startIKSolver?x__ -> Memory_startIKSolver(true.x__)
		[]
		stm_ref1::registerRead.stm_ref1::i_startIKSolver!x__ -> Memory_startIKSolver(x__)
	)
	Memory_startGoHome(x__) = (
		registerWriteE.e_startGoHome -> Memory_startGoHome(false)
		[]
		stm_ref0::registerWrite.stm_ref0::o_startGoHome -> Memory_startGoHome(true)
		[]
		stm_ref2::registerRead.stm_ref2::i_startGoHome!x__ -> Memory_startGoHome(x__)
	)
	
	-- (Rule 7) [[ c : Controller ]]_C : CSPProcess
	D__(id__,cycle_pkg727_main_sim_ControlArm_ControlArm,
