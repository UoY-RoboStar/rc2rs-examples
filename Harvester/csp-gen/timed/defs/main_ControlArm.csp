					get_positions!positions -> Memory_positions(positions)
					[]
					set_positions?x__ -> Memory_positions(x__)
					[]
					terminate -> SKIP
				Memory_apple(apple) =
					get_apple!apple -> Memory_apple(apple)
					[]
					set_apple?x__ -> Memory_apple(x__)
					[]
					terminate -> SKIP
				Memory_p1(p1) =
					get_p1!p1 -> Memory_p1(p1)
					[]
					set_p1?x__ -> Memory_p1(x__)
					[]
					terminate -> SKIP
				Memory_p2(p2) =
					get_p2!p2 -> Memory_p2(p2)
					[]
					set_p2?x__ -> Memory_p2(x__)
					[]
					terminate -> SKIP
				Memory_p3(p3) =
					get_p3!p3 -> Memory_p3(p3)
					[]
					set_p3?x__ -> Memory_p3(x__)
					[]
					terminate -> SKIP
				
				-- varMemory process
				varMemory(id__) = Memory_apples({})
				[| { terminate } |] (
				Memory_positions(funcToSet(\ x_ @ (0,0,0), setoperations_Coord3D))
				[| { terminate } |] (
				Memory_apple(0)
				[| { terminate } |] (
				Memory_p1(0)
				[| { terminate } |] (
				Memory_p2(0)
				[| { terminate } |] (
				Memory_p3(0)
				)
				)
				)
				)
				)
				
				getsetLocalChannels = {|get_apples,set_apples,get_positions,set_positions,get_apple,set_apple,get_p1,set_p1,get_p2,set_p2,get_p3,set_p3|}
				
				-- Definition of the behaviour of state machines (default, optimised, visible, visible and optimised)
				FVS__(id__) = STM_VS_O(id__) \ localClockResets
				D__(id__) = timed_priority(STM(id__) \ union(internal_events,localClockResets))
				O__(id__) = dbisim(D__(id__))
				VS__(id__) = FVS__(id__)
				VS_O__(id__) = dbisim(FVS__(id__))
				HEXT__(id__) = O__(id__) [|shared_variable_events|] SKIP
				FVS_C__(id__) = dbisim(timed_priority(STM(id__) \ internal_events))
				HUP__(id__) = timed_priority(O__(id__) [|{share__}|] SKIP)
				
				-- Clocks
				
				Clocks(id__) = terminate -> SKIP
				
				clockSync = {||}
				
				Clock_CLID_Ready(id__,x__) = 
					TimeOut_1(
						Ready::entered -> Clock_CLID_Ready(id__,0)
						[]
						get_CLID_Ready!x__ -> Clock_CLID_Ready(id__,x__)
						[]
						terminate -> SKIP,Clock_CLID_Ready(id__,clock_type_plus(x__,1,CLID_Ready_clock_type(id__))))
				Clock_CLID_Solve(id__,x__) = 
					TimeOut_1(
						Solve::entered -> Clock_CLID_Solve(id__,0)
						[]
						get_CLID_Solve!x__ -> Clock_CLID_Solve(id__,x__)
						[]
						terminate -> SKIP,Clock_CLID_Solve(id__,clock_type_plus(x__,1,CLID_Solve_clock_type(id__))))
				Clock_CLID_Loop(id__,x__) = 
					TimeOut_1(
						Loop::entered -> Clock_CLID_Loop(id__,0)
						[]
						get_CLID_Loop!x__ -> Clock_CLID_Loop(id__,x__)
						[]
						terminate -> SKIP,Clock_CLID_Loop(id__,clock_type_plus(x__,1,CLID_Loop_clock_type(id__))))
				
				StateClocks(id__) = dbisim(Clock_CLID_Ready(id__,0))
				[| { terminate } |] (
				dbisim(Clock_CLID_Solve(id__,0))
				[| { terminate } |] (
				dbisim(Clock_CLID_Loop(id__,0))
				)
				)
				
				stateClockSync = {|get_CLID_Ready,Ready::entered,get_CLID_Solve,Solve::entered,get_CLID_Loop,Loop::entered|}
				
				-- Shared memory
				-- Shared memory variables
				
				-- sharedVarMemory process
				sharedVarMemory(id__) = terminate -> SKIP
				
				sharedVarSync = {||}
				
				sharedVarHide = {||}
				}
		endmodule
		module stm_ref2
		exports
			transparent diamond
			transparent sbisim
			transparent dbisim
			transparent chase
		
			-- Transition identifiers
			-- declaring identifiers of transitions
			datatype NIDS = 
			              NID_i0|
			              NID_Ready|
			              NID_Going
			
			channel internal__ : NIDS
			
			-- Flow channels		
			channel interrupt
			channel exited
			channel exit
			channel terminate
			
			-- Variable channels
			
			-- Shared variable channels
			
			-- Local variable channels for defined operations that are required by the state machine
			
			-- Declaring state machine events
			channel startGoHome__: NIDS.InOut
			channel startGoHome: InOut
			channel endGoHome__: NIDS.InOut
			channel endGoHome: InOut
			
			-- Declaring call and ret events for undefined operations
			channel hideArmCall
			channel moveCall: main_JointsPos
			channel graspCall: main_JointsPos
			channel goHomeCall
			channel pickCall
			channel dropCall: main_JointsPos
			
			enterSS = {|
			i0::enter,
			Ready::enter,
			Going::enter
			|}
			
			enteredSS = 	{|
			Ready::entered,
			Going::entered
			|}
			
			internal_events = union(enteredSS,union(enterSS,{|interrupt,exited|}))
			
			shared_variable_events = {|
			|}
			
			-- channel set with all visible events
			sem__events = {|
				terminate
			,	startGoHome,
				endGoHome
			,	hideArmCall,
				moveCall,
				graspCall,
				goHomeCall,
				pickCall,
				dropCall
				|}
			
			channel clockReset, clockResetL, clockResetR 
			
			localClockResets = {||}
			
			
			channel get_CLID_Going : core_clock_type 
			channel get_CLID_Ready : core_clock_type 
			--channel increment__
			
			CLID_Going_clock_type(id__,
					          const_main_GoHome_goHTime) = 
				let
					max = (clock_type_max(Union({
			}))+1)
				ctype = {0..max}
			within
				if member(max,core_clock_type) then ctype else error("core_clock_type is not wide enough")
			
			CLID_Ready_clock_type(id__,
					          const_main_GoHome_goHTime) = 
				let
					max = (clock_type_max(Union({
			}))+1)
				ctype = {0..max}
			within
				if member(max,core_clock_type) then ctype else error("core_clock_type is not wide enough")
			
			
		
				-- Nodes --
				-- declaring all nodes
				
				----------------------------------------------------------------------
				-- Initial: i0
				module i0
				exports
				
					channel enter, interrupt
					
					Timed(OneStep) {
						D__(id__,
								    const_main_GoHome_goHTime) = 
							dbisim(let
								Inactive 	= share__choice(enter -> SKIP [] terminate -> SKIP) ; Active
								
								Termination = terminate -> SKIP
								
								Active 		= share__choice(interrupt -> SKIP) ; Inactive
							within
								Inactive [| {terminate} |> SKIP)
						
						VS_O__(id__,
								    const_main_GoHome_goHTime) = D__(id__,
								    const_main_GoHome_goHTime)
					}
				
				endmodule
				----------------------------------------------------------------------
				
				
				----------------------------------------------------------------------
				-- State: Ready
				module Ready
				
				enterSS = {}
				
				enteredSS = {}
				
				exports
				
					--  Declarations
					
					channel enter, entered, interrupt
					channel enteredL, enteredR
					
									
					
					--channel increment__
					
					
					--	Nodes
					-- declaring all nodes
					
					
					Timed(OneStep) {
						--	Rule: behaviours(Node)
						--  Note that FDR has problems with efficiently compiling the process below
						-- 	if using a different recursion pattern.
						D__(id__,
								    const_main_GoHome_goHTime) = 
						dbisim(let
							-- IMPLEMENTATION NOTE: 
							-- The following should be defined as: Inactive = share__choice(Activation [] Termination),
							-- however FDR struggles with that form in certain cases. So we use the exception operator
							-- instead to 'terminate'.
							
							Inactive 	= share__choice(enter -> SKIP [] terminate -> SKIP) ; Active
							
							Termination = terminate -> SKIP
							
							Active 		= SKIP ; 
									 	  Behaviour ; 
									 	  share__choice(exit -> SKIP) ; SKIP ; 
									 	  share__choice(exited -> SKIP) ; Inactive
						
							Behaviour 	= entered -> During
							During 		= ((SKIP ; SStop) /\ interrupt -> SKIP)
						within
							Inactive [| {terminate} |> SKIP)
							
						VS_O__(id__,
								    const_main_GoHome_goHTime) = 
						dbisim(let
							Inactive 	= share__choice(enter -> SKIP [] terminate -> SKIP) ; Active
							
							Termination = terminate -> SKIP
							
							Active 		= SKIP ; 
									 	  Behaviour ; 
									 	  share__choice(exit -> SKIP) ; SKIP ; 
									 	  share__choice(exited -> SKIP) ; Inactive
						
							Behaviour 	= entered -> During
							During 		= ((SKIP ; SStop) /\ interrupt -> SKIP)
						within
							Inactive [| {terminate} |> SKIP)
						
						
						-- Clocks
						
						StateClocks(id__,
								          const_main_GoHome_goHTime) = terminate -> SKIP
						
						stateClockSync = {||}
					}
				
				endmodule
				----------------------------------------------------------------------
				
				
				----------------------------------------------------------------------
				-- State: Going
				module Going
				
				enterSS = {}
				
				enteredSS = {}
				
				exports
				
					--  Declarations
					
					channel enter, entered, interrupt
					channel enteredL, enteredR
					
									
					
					--channel increment__
					
					
					--	Nodes
					-- declaring all nodes
					
					
					Timed(OneStep) {
						--	Rule: behaviours(Node)
						--  Note that FDR has problems with efficiently compiling the process below
						-- 	if using a different recursion pattern.
						D__(id__,
								    const_main_GoHome_goHTime) = 
						dbisim(let
							-- IMPLEMENTATION NOTE: 
							-- The following should be defined as: Inactive = share__choice(Activation [] Termination),
							-- however FDR struggles with that form in certain cases. So we use the exception operator
							-- instead to 'terminate'.
							
							Inactive 	= share__choice(enter -> SKIP [] terminate -> SKIP) ; Active
							
							Termination = terminate -> SKIP
							
							Active 		= true&CALL__goHome(
										id__,
									    const_main_GoHome_goHTime
									);SHARE_WAIT(const_main_GoHome_goHTime) ; 
									 	  Behaviour ; 
									 	  share__choice(exit -> SKIP) ; SKIP ; 
									 	  share__choice(exited -> SKIP) ; Inactive
						
							Behaviour 	= entered -> During
							During 		= ((SKIP ; SStop) /\ interrupt -> SKIP)
						within
							Inactive [| {terminate} |> SKIP)
							
						VS_O__(id__,
								    const_main_GoHome_goHTime) = 
						dbisim(let
							Inactive 	= share__choice(enter -> SKIP [] terminate -> SKIP) ; Active
							
							Termination = terminate -> SKIP
							
							Active 		= true&CALL__goHome(
										id__,
									    const_main_GoHome_goHTime
									);SHARE_WAIT(const_main_GoHome_goHTime) ; 
									 	  Behaviour ; 
									 	  share__choice(exit -> SKIP) ; SKIP ; 
									 	  share__choice(exited -> SKIP) ; Inactive
						
							Behaviour 	= entered -> During
							During 		= ((SKIP ; SStop) /\ interrupt -> SKIP)
						within
							Inactive [| {terminate} |> SKIP)
						
						
						-- Clocks
						
						StateClocks(id__,
								          const_main_GoHome_goHTime) = terminate -> SKIP
						
						stateClockSync = {||}
					}
				
				endmodule
				----------------------------------------------------------------------
				
				-- END of Nodes --
				
				Timed(OneStep) {
				-- Operation calls --
				-- Only the undefined operations are declared here.
				-- If the state machine is in isolation, all required operations will be undefined.
				-- If it is in the context of a controller, the required operations not provided by the
				-- controller will be declared here, and the defined operations will be defined in the
				-- context of the Controller module, and therefore within scope of the state machine module.
				CALL__hideArm(id__,
						    const_main_GoHome_goHTime) = EDeadline(hideArmCall,0)
				CALL__move(id__,
						    const_main_GoHome_goHTime,
							param_jp) = EDeadline(moveCall.param_jp,0)
				CALL__grasp(id__,
						    const_main_GoHome_goHTime,
							param_jp) = EDeadline(graspCall.param_jp,0)
				CALL__goHome(id__,
						    const_main_GoHome_goHTime) = EDeadline(goHomeCall,0)
				CALL__pick(id__,
						    const_main_GoHome_goHTime) = EDeadline(pickCall,0)
				CALL__drop(id__,
						    const_main_GoHome_goHTime,
							param_jp) = EDeadline(dropCall.param_jp,0)
				
				-- END of Operation calls --
			
				-- STM processes
				STM(id__,
						    const_main_GoHome_goHTime) = -- RULE: [[stm:StateMachineDef]]_STM^nops : CSPProcess
				( 
					(
						(
							(IteratedStateful(id__,
									    const_main_GoHome_goHTime) \ {terminate} ; share__choice(terminate -> SKIP))
						 	[[ share__ <- x__ | x__ <- {||} ]]
						)
					[| {share__} |]
					SKIP
					)
					[| union(sharedVarSync,{terminate}) |]
					dbisim(sharedVarMemory(id__,
							    const_main_GoHome_goHTime))
				)\sharedVarHide
				
				STM_VS_O(id__,
						    const_main_GoHome_goHTime) = -- RULE: [[stm:StateMachineDef]]_STM^nops : CSPProcess
				( 
					(
						(
							(IteratedStateful_VS_O(id__,
									    const_main_GoHome_goHTime) \ {terminate} ; share__choice(terminate -> SKIP))
						 	[[ share__ <- x__ | x__ <- {||} ]]
						)
					[| {share__} |]
					SKIP
					)
					[| union(sharedVarSync,{terminate}) |]
					dbisim(sharedVarMemory(id__,
							    const_main_GoHome_goHTime))
				)\sharedVarHide
				
				-- Transitions
				Transitions(id__,
						    const_main_GoHome_goHTime) = ((let
					Trans = TimeOut_1(
						 (share__ -> SKIP
						 [] dbisim((true)&(internal__!NID_i0 -> SKIP ;  ((SKIP ; Ready::enter -> SKIP))))
						 [] dbisim((true)&(startGoHome__!NID_Ready.in -> SKIP ;  share__choice(exit -> SKIP) ; (share__choice(exited -> SKIP) ; SKIP ; Going::enter -> SKIP)))
						 [] dbisim((true)&(internal__!NID_Going -> SKIP ;  share__choice(exit -> SKIP) ; (share__choice(exited -> SKIP) ; true&(share__choice(endGoHome.out -> SKIP)) ; Ready::enter -> SKIP)))
						 []
						 (interrupt -> share__choice(exit -> SKIP) ; share__choice(exited -> terminate -> SKIP))
						 []
						 terminate -> SKIP
						 )
					,SKIP);Trans
				within
					Trans [|{terminate}|> SKIP
				)
				)
				
				-- Stateful
				-- RULE: Stateful(stm:StateMachineBody) : CSPProcess
				
				-- Named process definitions
				MachineBody(id__,
						    const_main_GoHome_goHTime) = 
					dbisim((
					let
						finalNodesEntered = {||}
					within
						(dbisim((dbisim((let
							-- IMPLEMENTATION NOTE:
							-- Here the 'enter' channel set is calculated explicitly because of the use of CSPM 
							-- modules for defining the semantics of each node.
							enterSS = {|
							i0::enter,
							Ready::enter,
							Going::enter
							|}
							hideSet = union(enterSS,{|exit,exited,internal__|})
						within 
							((let
								-- IMPLEMENTATION NOTE: the channel set 'enter' is calculated explicitly
								-- because CSPM modules are used for the semantics of Node.
								flowevts = union(enterSS,{|exit,exited,interrupt|})
								transSync = {|internal__.NID_i0,startGoHome__.NID_Ready.in,internal__.NID_Going|}
							within
								((
								 (((-- RULE composeNodes(nc:NodeContainer)^nops : CSPProcess
								   i0::D__(id__,
								   		    const_main_GoHome_goHTime)
								   [| { share__, terminate } |] (
								   Ready::D__(id__,
								   		    const_main_GoHome_goHTime)
								   [| { share__, terminate } |] (
								   Going::D__(id__,
								   		    const_main_GoHome_goHTime)
								   )
								   )
								 )
								 [[Ready::interrupt <- x__ | x__ <- {|interrupt,startGoHome__.NID_Ready.in|}]]
								 [[Going::interrupt <- x__ | x__ <- {|interrupt,internal__.NID_Going|}]]
								 [[i0::interrupt <- x__ | x__ <- {|internal__.NID_i0|}]]
								 )
								  [[ share__ <- x__ | x__ <- {| share__ |} ]] 
								 )
								 [| union(union(union(flowevts,transSync),{terminate}),{|share__
								|}) |]
								 ((i0::enter -> Transitions(id__,
								 		    const_main_GoHome_goHTime))
								  [[ share__ <- x__ | x__ <- {| share__ |} ]]
								 )
								)
								)
							)
							 \ hideSet)
							[[
								startGoHome__.x____ <- startGoHome,
								endGoHome__.x____ <- endGoHome
								| x____ <- NIDS
							]]
						)
						)
						 [| union(stateClockSync,{terminate}) |]
						 StateClocks(id__,
						 		          const_main_GoHome_goHTime)
						)\diff(stateClockSync,enteredSS))
						 [| {| interrupt |} |] SKIP)
					)
					)
				
				Behaviour(id__,
						    const_main_GoHome_goHTime) = 
					dbisim((let
						stateClockSync = {|get_CLID_Going,Going::entered,get_CLID_Ready,Ready::entered|}
					 within
						(MachineBody(id__,
								    const_main_GoHome_goHTime) [| union(stateClockSync,{terminate}) |] StateClocks(id__,
								          const_main_GoHome_goHTime)) \ union(stateClockSync,enteredSS)
					)
					)
				
				IteratedBehaviour(id__,
						    const_main_GoHome_goHTime) = 
					dbisim((let
						stateClockSync = {|get_CLID_Going,Going::entered,get_CLID_Ready,Ready::entered|}
					 within
						(dbisim(
							sbisim(
								dbisim(
									sbisim(
										MachineBody(id__,
												    const_main_GoHome_goHTime)
										[| {|get_CLID_Ready,Ready::entered,terminate|} |]
										dbisim(Clock_CLID_Ready(id__,0,
												          const_main_GoHome_goHTime))
