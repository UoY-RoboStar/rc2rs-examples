							    const_pkg727_main_AppleHarvestControl_graspTime,
							    const_pkg727_main_AppleHarvestControl_dropTime,
							    const_pkg727_main_AppleHarvestControl_pickTime,
							    const_pkg727_main_AppleHarvestControl_pickDeadl,
							    const_pkg727_main_AppleHarvestControl_homePos,
							    const_pkg727_main_AppleHarvestControl_storagePos) = ((let
						Trans = TimeOut_1(
							 (share__ -> SKIP
							 [] dbisim((true)&(internal__!NID_i -> SKIP ;  ((SKIP ; EmptyCycle::enter -> SKIP))))
							 []
							 (interrupt -> share__choice(exit -> SKIP) ; share__choice(exited -> terminate -> SKIP))
							 []
							 terminate -> SKIP
							 )
						,SKIP);Trans
					within
						Trans [|{terminate}|> SKIP
					)
					)
					
					
					-- Clocks
					Clock_CLID_EmptyCycle(id__,x__,
							          const_pkg727_main_AppleHarvestControl_hideTime,
							          const_pkg727_main_AppleHarvestControl_approachTime,
							          const_pkg727_main_AppleHarvestControl_graspTime,
							          const_pkg727_main_AppleHarvestControl_dropTime,
							          const_pkg727_main_AppleHarvestControl_pickTime,
							          const_pkg727_main_AppleHarvestControl_pickDeadl,
							          const_pkg727_main_AppleHarvestControl_homePos,
							          const_pkg727_main_AppleHarvestControl_storagePos) = 
						TimeOut_1(
							EmptyCycle::entered -> Clock_CLID_EmptyCycle(id__,0,
									          const_pkg727_main_AppleHarvestControl_hideTime,
									          const_pkg727_main_AppleHarvestControl_approachTime,
									          const_pkg727_main_AppleHarvestControl_graspTime,
									          const_pkg727_main_AppleHarvestControl_dropTime,
									          const_pkg727_main_AppleHarvestControl_pickTime,
									          const_pkg727_main_AppleHarvestControl_pickDeadl,
									          const_pkg727_main_AppleHarvestControl_homePos,
									          const_pkg727_main_AppleHarvestControl_storagePos)
							[]
							get_CLID_EmptyCycle!x__ -> Clock_CLID_EmptyCycle(id__,x__,
									          const_pkg727_main_AppleHarvestControl_hideTime,
									          const_pkg727_main_AppleHarvestControl_approachTime,
									          const_pkg727_main_AppleHarvestControl_graspTime,
									          const_pkg727_main_AppleHarvestControl_dropTime,
									          const_pkg727_main_AppleHarvestControl_pickTime,
									          const_pkg727_main_AppleHarvestControl_pickDeadl,
									          const_pkg727_main_AppleHarvestControl_homePos,
									          const_pkg727_main_AppleHarvestControl_storagePos)
							[]
							terminate -> SKIP,Clock_CLID_EmptyCycle(id__,clock_type_plus(x__,1,CLID_EmptyCycle_clock_type(id__,
									          const_pkg727_main_AppleHarvestControl_hideTime,
									          const_pkg727_main_AppleHarvestControl_approachTime,
