			endmodule
			----------------------------------------------------------------------
			
			
			----------------------------------------------------------------------
			-- State: Solving
			module Solving
			
			enterSS = 
					{|			i::enter,
						EmptyCycle::enter
					|}
			enteredSS = 
					{|			EmptyCycle::entered
					|}
			exports
			
				--  Declarations
				
				channel enter, entered, interrupt
				channel enteredL, enteredR
				
								
				-- declaring identifiers of transitions
				datatype NIDS = 
				              NID_i|
				              NID_EmptyCycle
				
				channel internal__ : NIDS
				channel takePic__: NIDS.InOut.main_Image
				channel startIKSolver__: NIDS.InOut.Set(setoperations_Coord3D)
				channel endIKSolver__: NIDS.InOut.Function(setoperations_Coord3D, {(x0__,x1__,x2__) | x0__ <- main_JointsPos,x1__ <- main_JointsPos,x2__ <- main_JointsPos})
				channel startGoHome__: NIDS.InOut
				channel endGoHome__: NIDS.InOut
				
				channel get_CLID_EmptyCycle : core_clock_type 
				--channel increment__
				
				CLID_EmptyCycle_clock_type(id__,
						          const_pkg727_main_AppleHarvestControl_hideTime,
						          const_pkg727_main_AppleHarvestControl_approachTime,
						          const_pkg727_main_AppleHarvestControl_graspTime,
						          const_pkg727_main_AppleHarvestControl_dropTime,
						          const_pkg727_main_AppleHarvestControl_pickTime,
						          const_pkg727_main_AppleHarvestControl_pickDeadl,
						          const_pkg727_main_AppleHarvestControl_homePos,
						          const_pkg727_main_AppleHarvestControl_storagePos) = 
					let
						max = (clock_type_max(Union({
				}))+1)
					ctype = {0..max}
				within
					if member(max,core_clock_type) then ctype else error("core_clock_type is not wide enough")
				
				
				--	Nodes
				-- declaring all nodes
				
				----------------------------------------------------------------------
				-- Initial: i
				module i
				exports
				
					channel enter, interrupt
					
					Timed(OneStep) {
						D__(id__,
								    const_pkg727_main_AppleHarvestControl_hideTime,
								    const_pkg727_main_AppleHarvestControl_approachTime,
								    const_pkg727_main_AppleHarvestControl_graspTime,
								    const_pkg727_main_AppleHarvestControl_dropTime,
								    const_pkg727_main_AppleHarvestControl_pickTime,
								    const_pkg727_main_AppleHarvestControl_pickDeadl,
								    const_pkg727_main_AppleHarvestControl_homePos,
								    const_pkg727_main_AppleHarvestControl_storagePos) = 
							dbisim(let
								Inactive 	= share__choice(enter -> SKIP [] terminate -> SKIP) ; Active
								
								Termination = terminate -> SKIP
								
								Active 		= share__choice(interrupt -> SKIP) ; Inactive
							within
								Inactive [| {terminate} |> SKIP)
						
						VS_O__(id__,
								    const_pkg727_main_AppleHarvestControl_hideTime,
								    const_pkg727_main_AppleHarvestControl_approachTime,
								    const_pkg727_main_AppleHarvestControl_graspTime,
								    const_pkg727_main_AppleHarvestControl_dropTime,
								    const_pkg727_main_AppleHarvestControl_pickTime,
								    const_pkg727_main_AppleHarvestControl_pickDeadl,
								    const_pkg727_main_AppleHarvestControl_homePos,
								    const_pkg727_main_AppleHarvestControl_storagePos) = D__(id__,
								    const_pkg727_main_AppleHarvestControl_hideTime,
								    const_pkg727_main_AppleHarvestControl_approachTime,
								    const_pkg727_main_AppleHarvestControl_graspTime,
								    const_pkg727_main_AppleHarvestControl_dropTime,
								    const_pkg727_main_AppleHarvestControl_pickTime,
								    const_pkg727_main_AppleHarvestControl_pickDeadl,
								    const_pkg727_main_AppleHarvestControl_homePos,
								    const_pkg727_main_AppleHarvestControl_storagePos)
					}
				
				endmodule
				----------------------------------------------------------------------
				
				
				----------------------------------------------------------------------
				-- State: EmptyCycle
				module EmptyCycle
				
				enterSS = {}
				
				enteredSS = {}
				
				exports
				
					--  Declarations
					
					channel enter, entered, interrupt
					channel enteredL, enteredR
					
									
					
					--channel increment__
					
					
					--	Nodes
					-- declaring all nodes
					
					
					Timed(OneStep) {
						--	Rule: behaviours(Node)
						--  Note that FDR has problems with efficiently compiling the process below
						-- 	if using a different recursion pattern.
						D__(id__,
								    const_pkg727_main_AppleHarvestControl_hideTime,
								    const_pkg727_main_AppleHarvestControl_approachTime,
								    const_pkg727_main_AppleHarvestControl_graspTime,
								    const_pkg727_main_AppleHarvestControl_dropTime,
								    const_pkg727_main_AppleHarvestControl_pickTime,
								    const_pkg727_main_AppleHarvestControl_pickDeadl,
								    const_pkg727_main_AppleHarvestControl_homePos,
								    const_pkg727_main_AppleHarvestControl_storagePos) = 
						dbisim(let
							-- IMPLEMENTATION NOTE: 
							-- The following should be defined as: Inactive = share__choice(Activation [] Termination),
							-- however FDR struggles with that form in certain cases. So we use the exception operator
							-- instead to 'terminate'.
							
							Inactive 	= share__choice(enter -> SKIP [] terminate -> SKIP) ; Active
							
							Termination = terminate -> SKIP
							
							Active 		= SKIP ; 
									 	  Behaviour ; 
									 	  share__choice(exit -> SKIP) ; SKIP ; 
									 	  share__choice(exited -> SKIP) ; Inactive
						
							Behaviour 	= entered -> During
							During 		= ((SKIP ; SStop) /\ interrupt -> SKIP)
						within
							Inactive [| {terminate} |> SKIP)
							
						VS_O__(id__,
								    const_pkg727_main_AppleHarvestControl_hideTime,
								    const_pkg727_main_AppleHarvestControl_approachTime,
								    const_pkg727_main_AppleHarvestControl_graspTime,
								    const_pkg727_main_AppleHarvestControl_dropTime,
								    const_pkg727_main_AppleHarvestControl_pickTime,
