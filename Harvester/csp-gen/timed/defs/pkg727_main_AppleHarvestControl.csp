							 				   		    const_pkg727_main_AppleHarvestControl_storagePos)
							 				   )
							 				 )
							 				 [[EmptyCycle::interrupt <- x__ | x__ <- {|interrupt|}]]
							 				 [[i::interrupt <- x__ | x__ <- {|internal__.NID_i|}]]
							 				 )
							 				  [[ share__ <- x__ | x__ <- {| share__ |} ]] 
							 				 )
							 				 [| union(union(union(flowevts,transSync),{terminate}),{|share__
							 				|}) |]
							 				 ((i::enter -> Transitions(id__,
							 				 		    const_pkg727_main_AppleHarvestControl_hideTime,
							 				 		    const_pkg727_main_AppleHarvestControl_approachTime,
							 				 		    const_pkg727_main_AppleHarvestControl_graspTime,
							 				 		    const_pkg727_main_AppleHarvestControl_dropTime,
							 				 		    const_pkg727_main_AppleHarvestControl_pickTime,
							 				 		    const_pkg727_main_AppleHarvestControl_pickDeadl,
							 				 		    const_pkg727_main_AppleHarvestControl_homePos,
							 				 		    const_pkg727_main_AppleHarvestControl_storagePos))
							 				  [[ share__ <- x__ | x__ <- {| share__ |} ]]
							 				 )
							 				)
							 				)
							 			)
							 			 \ hideSet)
							 			[[
							 				takePic__.x____ <- takePic,
							 				startIKSolver__.x____ <- startIKSolver,
							 				endIKSolver__.x____ <- endIKSolver,
							 				startGoHome__.x____ <- startGoHome,
							 				endGoHome__.x____ <- endGoHome
							 				| x____ <- NIDS
							 			]]
							 		)
							 		[| {|get_CLID_EmptyCycle,EmptyCycle::entered,terminate|} |]
							 		dbisim(Clock_CLID_EmptyCycle(id__,0,
							 				          const_pkg727_main_AppleHarvestControl_hideTime,
							 				          const_pkg727_main_AppleHarvestControl_approachTime,
							 				          const_pkg727_main_AppleHarvestControl_graspTime,
							 				          const_pkg727_main_AppleHarvestControl_dropTime,
							 				          const_pkg727_main_AppleHarvestControl_pickTime,
							 				          const_pkg727_main_AppleHarvestControl_pickDeadl,
							 				          const_pkg727_main_AppleHarvestControl_homePos,
							 				          const_pkg727_main_AppleHarvestControl_storagePos))
							 	)\{|get_CLID_EmptyCycle|}
							 )
							 ))
							  [[ share__ <- x__ | x__ <- {| share__,setR_localized,setR_apples,setR_nextApple,setR_img,setR_positions |} ]] 
							  [[set_localized <- setL_localized,set_apples <- setL_apples,set_nextApple <- setL_nextApple,set_img <- setL_img,set_positions <- setL_positions]]
							 )
							 [| union(union(enteredSS,{| interrupt, terminate |}),{|share__
							 			,setL_localized
							 			,setL_apples
							 			,setL_nextApple
							 			,setL_img
							 			,setL_positions
							 			,setR_localized
							 			 			,setR_apples
							 			 			,setR_nextApple
							 			 			,setR_img
							 			 			,setR_positions
							 			|}) |]
							 ((During)
							  [[ share__ <- x__ | x__ <- {| share__,setL_localized,setL_apples,setL_nextApple,setL_img,setL_positions |} ]]
							  [[set_localized <- setR_localized,set_apples <- setR_apples,set_nextApple <- setR_nextApple,set_img <- setR_img,set_positions <- setR_positions]]
							 )
							)[[setL_localized <- set_localized,setL_apples <- set_apples,setL_nextApple <- set_nextApple,setL_img <- set_img,setL_positions <- set_positions]]
