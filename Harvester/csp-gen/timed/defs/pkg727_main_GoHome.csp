								          const_pkg727_main_GoHome_goHTime)),
								          const_pkg727_main_GoHome_goHTime))
				
				StateClocks(id__,
						          const_pkg727_main_GoHome_goHTime) = dbisim(Clock_CLID_EmptyCycle(id__,0,
						          const_pkg727_main_GoHome_goHTime))
				
				stateClockSync = {|get_CLID_EmptyCycle,EmptyCycle::entered|}
			}
		
		endmodule
