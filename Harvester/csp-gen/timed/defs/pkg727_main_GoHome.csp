				    const_pkg727_main_GoHome_goHTime,
					param_jp) = EDeadline(moveCall.param_jp,0)
		
		-- END of Operation calls --
	
		-- STM processes
		STM(id__,
				    const_pkg727_main_GoHome_goHTime) = -- RULE: [[stm:StateMachineDef]]_STM^nops : CSPProcess
		( 
			(
				(
					(IteratedStateful(id__,
							    const_pkg727_main_GoHome_goHTime) \ {terminate} ; share__choice(terminate -> SKIP))
				 	[[ share__ <- x__ | x__ <- {||} ]]
				)
			[| {share__} |]
			SKIP
			)
			[| union(sharedVarSync,{terminate}) |]
			dbisim(sharedVarMemory(id__,
					    const_pkg727_main_GoHome_goHTime))
		)\sharedVarHide
		
		STM_VS_O(id__,
				    const_pkg727_main_GoHome_goHTime) = -- RULE: [[stm:StateMachineDef]]_STM^nops : CSPProcess
		( 
			(
				(
					(IteratedStateful_VS_O(id__,
							    const_pkg727_main_GoHome_goHTime) \ {terminate} ; share__choice(terminate -> SKIP))
