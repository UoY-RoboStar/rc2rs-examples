		-- RULE: Stateful(stm:StateMachineBody) : CSPProcess
		
		-- Named process definitions
		MachineBody(id__,
				    const_pkg727_main_GoHome_goHTime) = 
			dbisim((
			let
				finalNodesEntered = {||}
