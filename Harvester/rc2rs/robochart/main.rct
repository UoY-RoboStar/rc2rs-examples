stm AppleHarvestControl {
	uses Camera uses SolverControl uses GoHomeControl uses TimeConstants uses Locations requires ArmOperations requires TravellingSalesman requires Vision requires I_clone_normal_AppleHarvestControl_j0_t7_op requires I_clone_normal_AppleHarvestControl_GetApple_entry requires I_clone_NearestNeighbour requires I_clone_normal_AppleHarvestControl_LocalizeFruit_Done_t7_op requires I_clone_normal_AppleHarvestControl_LocalizeFruit_Start_t1_op requires I_clone_normal_AppleHarvestControl_LocalizeFruit_entry requires I_clone_normal_AppleHarvestControl_LocalizeFruit_Solving_t2_op requires I_clone_normal_AppleHarvestControl_Prepare_entry requires I_clone_normal_AppleHarvestControl_Prepare_t1_dop requires I_clone_normal_AppleHarvestControl_GetApple_exit var img : main::Image
	var localized : boolean
	var apples : Set( setoperations::Coord3D )
	var positions : setoperations::Coord3D -> main::JointsPos * main::JointsPos * main::JointsPos
	var nextApple : setoperations::Coord3D
	initial i0
	state Prepare {
		initial i
		state EmptyCycle {
		}
		transition tPrepare {
			from i
			to EmptyCycle
		}
		entry clone_normal_AppleHarvestControl_Prepare_entry ( )
		during clone_normal_AppleHarvestControl_Prepare_t1_dop ( )
	}
	state LocalizeFruit {
		initial i0
		state Start {
			initial i
			state EmptyCycle {
			}
			transition tStart {
				from i
				to EmptyCycle
			}
		}
		state Solving {
			initial i
			state EmptyCycle {
			}
			transition tSolving {
				from i
				to EmptyCycle
			}
		}
		state SolvingAndMoving {
			state EmptyCycle {
			}
			initial i
			transition tSolvingAndMoving {
				from i
				to EmptyCycle
			}
		}
		state Solved {
			state EmptyCycle {
			}
			initial i
			transition tSolved {
				from i
				to EmptyCycle
			}
		}
		state Moved {
			initial i
			state EmptyCycle {
			}
			transition tMoved {
				from i
				to EmptyCycle
			}
		}
		state Done {
			state EmptyCycle {
			}
			initial i
			transition tDone {
				from i
				to EmptyCycle
			}
		}
		state EmptyCycle {
		}
		transition t0 {
			from i0
			to Start
		}
		transition t1 {
			from Start
			to Solving
			action clone_normal_AppleHarvestControl_LocalizeFruit_Start_t1_op ( )
		}
		transition t2 {
			from Solving
			to SolvingAndMoving
			action clone_normal_AppleHarvestControl_LocalizeFruit_Solving_t2_op ( )
		}
		transition t3 {
			from SolvingAndMoving
			to Solved
			trigger endIKSolver ? positions
		}
		transition t4 {
			from SolvingAndMoving
			to Moved
			trigger endGoHome
		}
		transition t5 {
			from Moved
			to Done
			trigger endIKSolver ? positions
		}
		transition t6 {
			from Solved
			to Done
			trigger endGoHome
		}
		transition t7 {
			from Done
			to EmptyCycle
			action clone_normal_AppleHarvestControl_LocalizeFruit_Done_t7_op ( )
		}
		entry clone_normal_AppleHarvestControl_LocalizeFruit_entry ( )
	}
	state Next {
		initial i
		state EmptyCycle {
		}
		transition tNext {
			from i
			to EmptyCycle
		}
		entry clone_NearestNeighbour ( )
	}
	state GetApple {
		initial i
		state EmptyCycle {
		}
		transition tGetApple {
			from i
			to EmptyCycle
		}
		entry clone_normal_AppleHarvestControl_GetApple_entry ( )
		exit clone_normal_AppleHarvestControl_GetApple_exit ( )
	}
	junction j0
	state GoingHome {
		initial i
		state EmptyCycle {
		}
		transition tGoingHome {
			from i
			to EmptyCycle
		}
	}
	transition t0 {
		from i0
		to Prepare
	}
	transition t1 {
		from Prepare
		to LocalizeFruit
		trigger takePic ? img
	}
	transition t2 {
		from LocalizeFruit
		to Next
		condition localized
	}
	transition t3 {
		from Next
		to Next
		condition not reachable ( nextApple )
	}
	transition t4 {
		from Next
		to GetApple
		condition reachable ( nextApple )
	}
	transition t5 {
		from GetApple
		to j0
	}
	transition t6 {
		from j0
		to Next
		condition not isEmpty ( positions )
	}
	transition t7 {
		from j0
		to GoingHome
		condition isEmpty ( positions )
		action clone_normal_AppleHarvestControl_j0_t7_op ( )
	}
	transition t8 {
		from GoingHome
		to Next
		trigger endGoHome
	}
}

stm IKSolver {
	uses SolverControl requires I_clone_normal_IKSolver_Solve_entry requires I_clone_normal_IKSolver_Solve_t3_op requires I_clone_normal_IKSolver_Loop_t4_op requires I_clone_normal_IKSolver_Loop_t2_op requires I_clone_normal_IKSolver_Solve_exit var apples : Set( setoperations::Coord3D )
	var positions : setoperations::Coord3D -> main::JointsPos * main::JointsPos * main::JointsPos
	var apple : setoperations::Coord3D
	var p1 : main::JointsPos , p2 : main::JointsPos , p3 : main::JointsPos
	initial i0
	state Ready {
		initial i
		state EmptyCycle {
		}
		transition tReady {
			from i
			to EmptyCycle
		}
	}
	state Loop {
		state EmptyCycle {
		}
		initial i
		transition tLoop {
			from i
			to EmptyCycle
		}
	}
	state Solve {
		initial i
		state EmptyCycle {
		}
		transition tSolve {
			from i
			to EmptyCycle
		}
		entry clone_normal_IKSolver_Solve_entry ( )
		exit clone_normal_IKSolver_Solve_exit ( )
	}
	transition t0 {
		from i0
		to Ready
	}
	transition t1 {
		from Ready
		to Loop
		trigger startIKSolver ? apples
	}
	transition t2 {
		from Loop
		to Solve
		condition apples != { }
		action clone_normal_IKSolver_Loop_t2_op ( )
	}
	transition t4 {
		from Loop
		to Ready
		condition apples == { }
		action clone_normal_IKSolver_Loop_t4_op ( )
	}
	transition t3 {
		from Solve
		to Loop
		action clone_normal_IKSolver_Solve_t3_op ( )
	}
}

stm GoHome {
	uses GoHomeControl requires ArmOperations requires I_clone_normal_GoHome_Going_t2_op requires I_clone_normal_GoHome_Going_entry const goHTime : nat
	initial i0
	state Ready {
		state EmptyCycle {
		}
		initial i
		transition tReady {
			from i
			to EmptyCycle
		}
	}
	state Going {
		initial i
		state EmptyCycle {
		}
		transition tGoing {
			from i
			to EmptyCycle
		}
		entry clone_normal_GoHome_Going_entry ( )
	}
	transition t0 {
		from i0
		to Ready
	}
	transition t1 {
		from Ready
		to Going
		trigger startGoHome
	}
	transition t2 {
		from Going
		to Ready
		action clone_normal_GoHome_Going_t2_op ( )
	}
}

operation CHTBA ( 
