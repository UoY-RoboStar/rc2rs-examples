		}
	}
	final f
	initial i0
	transition t2 {
		from Waiting
		to f
		condition since ( C ) == i
	}
	transition t {
		from i0
		to Waiting
		action # C
	}
	clock C
}

module Harvester {
	connection Arm on takePic to ctrl_ref0 on takePic ( _async )
	cref ctrl_ref0 = ControlArm
	robotic platform Arm {
		uses Camera provides ArmOperations }

}

