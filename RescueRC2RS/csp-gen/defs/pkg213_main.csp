								param_m,
								param_n)\ enteredSS)
					)
				
				
				Stateful(id__,
							param_m,
							param_n) = 
					((
						(Behaviour(id__,
									param_m,
									param_n) [| union(getsetLocalChannels,{terminate}) |] varMemory(id__,
