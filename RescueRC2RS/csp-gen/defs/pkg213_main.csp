								 (((-- RULE composeNodes(nc:NodeContainer)^nops : CSPProcess
								   i::D__(id__,
								   			param_m,
								   			param_n)
								   [| { share__, terminate } |] (
								   f::D__(id__,
								   			param_m,
								   			param_n)
								   [| { share__, terminate } |] (
								   j::D__(id__,
								   			param_m,
								   			param_n)
								   )
								   )
								 )
								 [[f::interrupt <- x__ | x__ <- {|interrupt|}]]
								 [[i::interrupt <- x__ | x__ <- {|internal__.NID_i|}]]
								 [[j::interrupt <- x__ | x__ <- {|internal__.NID_j,internal__.NID_j|}]]
								 )
								  [[ share__ <- x__ | x__ <- {| share__ |} ]] 
