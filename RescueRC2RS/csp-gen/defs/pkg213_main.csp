			 	 [] dbisim((true)&(internal__!NID_j -> SKIP ;  ((SKIP ; f::enter -> SKIP))))
			 	 [] dbisim((true)&(internal__!NID_i -> SKIP ;  ((SKIP ; j::enter -> SKIP))))
