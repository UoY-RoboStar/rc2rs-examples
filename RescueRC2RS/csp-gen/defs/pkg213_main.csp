				channel interrupt
				channel exited
				channel exit
				channel terminate
				
				-- Variable channels
				
				-- Shared variable channels
				
				-- Local variable channels for defined operations that are required by the state machine
				
				-- Declaring state machine events
				channel switchOn__: NIDS.InOut
				channel switchOn: InOut
				channel takeoff__: NIDS.InOut
				channel takeoff: InOut
				channel land__: NIDS.InOut
				channel land: InOut
				channel found__: NIDS.InOut
				channel found: InOut
				channel origin__: NIDS.InOut
				channel origin: InOut
				
