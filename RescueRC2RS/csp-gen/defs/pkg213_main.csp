	enterSS = {|
	i0::enter,
	Off::enter,
	Looking::enter,
	Delivering::enter,
	Returning::enter
	|}
	
	enteredSS = 	{|
	Off::entered,
	Looking::entered,
	Delivering::entered,
	Returning::entered
	|}
	
	internal_events = union(enteredSS,union(enterSS,{|interrupt,exited|}))
	
	shared_variable_events = {|
	|}
	
