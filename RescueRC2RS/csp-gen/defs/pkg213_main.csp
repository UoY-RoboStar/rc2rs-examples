	channel switchOn__: NIDS.InOut
	channel switchOn: InOut
	channel takeoff__: NIDS.InOut
	channel takeoff: InOut
	channel land__: NIDS.InOut
	channel land: InOut
	channel found__: NIDS.InOut
	channel found: InOut
	channel origin__: NIDS.InOut
