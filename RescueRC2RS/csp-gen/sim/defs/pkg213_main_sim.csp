								 			param_i))
								  [[ share__ <- x__ | x__ <- {| share__,clockResetL.CLID_C |} ]]
								 )
								)[[clockResetL.CLID_C <- clockReset.CLID_C]]
								)
							)
							 \ hideSet)
							[[ endexec__.x____  <- endexec | x____ <- NIDS ]]
							[[ endexec_action <- endexec ]]
							[[ startexec_action <- startexec ]]
						)
						)
						 [| union(stateClockSync,{terminate}) |]
						 StateClocks(id__)
						)\diff(stateClockSync,enteredSS))
						 [| {| interrupt |} |] SKIP)
					)
					)
				
				Behaviour(id__,
							param_i) = 
					dbisim((let
						stateClockSync = {|get_CLID_Waiting,Waiting::entered|}
					 within
						(MachineBody(id__,
									param_i) [| union(stateClockSync,{terminate}) |] StateClocks(id__)) \ union(stateClockSync,enteredSS)
					)
					)
				
				
				Stateful(id__,
							param_i) = 
					((let
						getsetLocalChannels = {||}
						clockSync = {|get_CLID_C,clockReset.CLID_C|}
					within
						(Behaviour(id__,
									param_i) 
						 [| union(union(getsetLocalChannels,clockSync),{terminate}) |] 
						 (varMemory(id__,
						 			param_i) [| {terminate} |] Clocks(id__))
					 	)\union(getsetLocalChannels,clockSync)
					)
					)
				
				
				-- Visible counterparts
				MachineBody_VS_O(id__,
							param_i) = 
					dbisim((
					let
						finalNodesEntered = {|f::entered|}
					within
						(dbisim((dbisim((let
							-- IMPLEMENTATION NOTE:
							-- Here the 'enter' channel set is calculated explicitly because of the use of CSPM 
							-- modules for defining the semantics of each node.
							enterSS = {|
							i0::enter,
							f::enter,
							Waiting::enter
							|}
							hideSet = union(enterSS,{|exit,exited,internal__|})
						within 
							((let
								-- IMPLEMENTATION NOTE: the channel set 'enter' is calculated explicitly
								-- because CSPM modules are used for the semantics of Node.
								flowevts = union(enterSS,{|exit,exited|})
								transSync = {|internal__.NID_Waiting,internal__.NID_i0|}
							within
								((
								 (((-- RULE composeNodes(nc:NodeContainer)^nops : CSPProcess
								   i0::VS_O__(id__,
								   			param_i)
								   [| { share__, terminate } |] (
								   f::VS_O__(id__,
								   			param_i)
								   [| { share__, terminate } |] (
								   Waiting::VS_O__(id__,
								   			param_i)
								   )
								   )
								 )
								 [[f::interrupt <- x__ | x__ <- {|interrupt|}]]
								 [[Waiting::interrupt <- x__ | x__ <- {|interrupt,internal__.NID_Waiting|}]]
								 [[i0::interrupt <- x__ | x__ <- {|internal__.NID_i0|}]]
								 )
								  [[ share__ <- x__ | x__ <- {| share__ |} ]] 
								  [[clockReset.CLID_C <- clockResetL.CLID_C]]
								 )
								 [| union(union(union(flowevts,transSync),{|terminate,endexec,startexec|}),{|share__
								 			,clockResetL.CLID_C
								|}) |]
								 ((i0::enter -> Transitions(id__,
								 			param_i))
								  [[ share__ <- x__ | x__ <- {| share__,clockResetL.CLID_C |} ]]
								 )
								)[[clockResetL.CLID_C <- clockReset.CLID_C]]
								)
							)
							 \ hideSet)
							[[ endexec__.x____  <- endexec | x____ <- NIDS ]]
							[[ endexec_action <- endexec ]]
							[[ startexec_action <- startexec ]]
						)
						)
						 [| union(stateClockSync,{terminate}) |]
						 StateClocks(id__)
						)\diff(stateClockSync,enteredSS))
						 [| {| interrupt |} |] SKIP)
					)
					)
				
				Behaviour_VS_O(id__,
							param_i) = 
					dbisim((let
						stateClockSync = {|get_CLID_Waiting,Waiting::entered|}
					 within
						(MachineBody_VS_O(id__,
									param_i) [| union(stateClockSync,{terminate}) |] StateClocks(id__)) \ diff(union(stateClockSync,enteredSS),enteredSS)
					)
					)
				
				
				Stateful_VS_O(id__,
							param_i) = 
					dbisim((let
						getsetLocalChannels = {||}
						clockSync = {|get_CLID_C,clockReset.CLID_C|}
					within
						(Behaviour_VS_O(id__,
									param_i) 
						 [| union(union(getsetLocalChannels,clockSync),{terminate}) |] 
						 (varMemory(id__,
						 			param_i) [| {terminate} |] Clocks(id__))
					 	)\union(getsetLocalChannels,clockSync)
					)
					)
				
				
				-- END
				
				-- Memory
				-- Memory variables
				
				-- varMemory process
				varMemory(id__,
							param_i) = terminate -> SKIP
				
				getsetLocalChannels = {||}
				
				-- Definition of the behaviour of state machines (default, optimised, visible, visible and optimised)
				FVS__(id__,
							param_i) = STM_VS_O(id__,
							param_i) \ localClockResets
				D__(id__,
							param_i) = timed_priority(STM(id__,
							param_i) \ union(internal_events,localClockResets))
				O__(id__,
							param_i) = dbisim(D__(id__,
							param_i))
				VS__(id__,
							param_i) = FVS__(id__,
							param_i)
				VS_O__(id__,
							param_i) = dbisim(FVS__(id__,
							param_i))
				HEXT__(id__,
							param_i) = O__(id__,
							param_i) [|shared_variable_events|] SKIP
				FVS_C__(id__,
							param_i) = dbisim(timed_priority(STM(id__,
							param_i) \ internal_events))
				HUP__(id__,
							param_i) = timed_priority(O__(id__,
							param_i) [|{share__}|] SKIP)
				
				-- Clocks
				Clock_CLID_C(id__,x__) = 
					TimeOut_1(
						clockReset.CLID_C -> Clock_CLID_C(id__,0)
						[]
						get_CLID_C!x__ -> Clock_CLID_C(id__,x__)
						[]
						terminate -> SKIP,Clock_CLID_C(id__,clock_type_plus(x__,1,CLID_C_clock_type(id__))))
				
				Clocks(id__) = dbisim(Clock_CLID_C(id__,0))
				
				clockSync = {|get_CLID_C,clockReset.CLID_C|}
				
				Clock_CLID_Waiting(id__,x__) = 
					TimeOut_1(
						Waiting::entered -> Clock_CLID_Waiting(id__,0)
						[]
						get_CLID_Waiting!x__ -> Clock_CLID_Waiting(id__,x__)
						[]
						terminate -> SKIP,Clock_CLID_Waiting(id__,clock_type_plus(x__,1,CLID_Waiting_clock_type(id__))))
				
				StateClocks(id__) = dbisim(Clock_CLID_Waiting(id__,0))
				
				stateClockSync = {|get_CLID_Waiting,Waiting::entered|}
				
				}
					endmodule
		
		Timed(OneStep) {
		-- (Rule 8) cycleController(...) : CSPProcess
		datatype SOutputEvents = SOutput_land
			| SOutput_takeoff
			| SOutput_move
			| SOutput_turnBack
		
		DVarsEvents = {}
		
		EVarsEvents = {}
		
		cycleController(id__,cycle_pkg213_main_sim_Rescue_Finder_Finder,
				    const_pkg213_main_sim_Rescue_Finder_stm_ref0_DELIVERY,
				    const_pkg213_main_sim_Rescue_Finder_stm_ref0_LV,
				    const_pkg213_main_sim_Rescue_Finder_stm_ref0_TOP) =
		let
					
			project_stm_ref0(stm_ref0::o_land) = SOutput_land
			project_stm_ref0(stm_ref0::o_takeoff) = SOutput_takeoff
			project_stm_ref0(stm_ref0::o_move.x__) = SOutput_move
			project_stm_ref0(stm_ref0::o_turnBack) = SOutput_turnBack
		
			connected_stm_ref0(stm_ref0::o_land) = true
			connected_stm_ref0(stm_ref0::o_takeoff) = true
			connected_stm_ref0(stm_ref0::o_move.x__) = true
			connected_stm_ref0(stm_ref0::o_turnBack) = true
			connected_stm_ref0(_) = false
		
			lift_stm_ref0(stm_ref0::o_land) = o_land
			lift_stm_ref0(stm_ref0::o_takeoff) = o_takeoff
			lift_stm_ref0(stm_ref0::o_move.x__) = o_move.x__
			lift_stm_ref0(stm_ref0::o_turnBack) = o_turnBack
			
			CycleController =
				Deadline(
				-- read inputs from the controller and pass to state machines
				(
				((registerRead.i_found?x__ ->
					((stm_ref0::registerRead.stm_ref0::i_found!x__ -> SKIP)))
					|||
				(registerRead.i_origin?x__ ->
					((stm_ref0::registerRead.stm_ref0::i_origin!x__ -> SKIP)))
					|||
				(registerRead.i_switchOn?x__ ->
					((stm_ref0::registerRead.stm_ref0::i_switchOn!x__ -> SKIP))))
				-- ensure state machines read the values being communicated via evars
						);
				-- synchronize on events related to evars to erase memory
				-- collect outputs, and monitor termination of the cycle, by all controllers
				(CollectOutputs(SOutputEvents) [| {endexec} |] Monitor),0);
				-- wait for the cycleDef period
				TimeOut_1(terminate -> SKIP,WAIT(cycle_pkg213_main_sim_Rescue_Finder_Finder-1));
				-- recurse
				CycleController
				
										
			CollectOutputs(sout) =
				(stm_ref0::registerWrite?outp:{ outp | outc <- diff(sout,union(EVarsEvents,DVarsEvents)), outp <- stm_ref0::RegisterDataOutput, connected_stm_ref0(outp), project_stm_ref0(outp) == outc}
						-> registerWrite!lift_stm_ref0(outp)
							-> CollectOutputs(diff(sout,{project_stm_ref0(outp)}))
				[]
				endexec -> SKIP
				)
		
			Monitor = 
				(	 (stm_ref0::endexec -> SKIP)); endexec -> SKIP
		within
			CycleController
		
		-- (Rule 5) memoryComp(...) : CSPProcess
		memoryComp(id__,
				    const_pkg213_main_sim_Rescue_Finder_stm_ref0_DELIVERY,
				    const_pkg213_main_sim_Rescue_Finder_stm_ref0_LV,
				    const_pkg213_main_sim_Rescue_Finder_stm_ref0_TOP) = (
			STOP)
		
		
		-- (Rule 7) [[ c : Controller ]]_C : CSPProcess
		D__(id__,cycle_pkg213_main_sim_Rescue_Finder_Finder,
				    const_pkg213_main_sim_Rescue_Finder_stm_ref0_DELIVERY,
				    const_pkg213_main_sim_Rescue_Finder_stm_ref0_LV,
				    const_pkg213_main_sim_Rescue_Finder_stm_ref0_TOP) =
		timed_priority(
			(
				(
					(
						(
						dbisim(cycleController(id__,cycle_pkg213_main_sim_Rescue_Finder_Finder,
								    const_pkg213_main_sim_Rescue_Finder_stm_ref0_DELIVERY,
								    const_pkg213_main_sim_Rescue_Finder_stm_ref0_LV,
								    const_pkg213_main_sim_Rescue_Finder_stm_ref0_TOP))
					 	 [| Union({{||},
					 	 		  {||},
					 	 		  {||},
					 	 		  {||}}) |]
					 	memoryComp(id__,
					 			    const_pkg213_main_sim_Rescue_Finder_stm_ref0_DELIVERY,
					 			    const_pkg213_main_sim_Rescue_Finder_stm_ref0_LV,
					 			    const_pkg213_main_sim_Rescue_Finder_stm_ref0_TOP)
					 	)\{||}
						[| {| 	terminate,tock,
								stm_ref0::endexec,stm_ref0::registerRead,stm_ref0::registerWrite|} |]
						-- (Rule 9) composeMachines(...) : CSPProcess
					 	((let
					 		const_pkg213_main_sim_FinderM_DELIVERY = 2
					 		const_pkg213_main_sim_FinderM_LV = const_pkg213_main_sim_Rescue_Finder_stm_ref0_LV
					 		const_pkg213_main_sim_FinderM_TOP = 1
					 		cycle_pkg213_main_sim_FinderM_FinderM = cycle_pkg213_main_sim_Rescue_Finder_Finder
					 	within
					 		(stm_ref0::D__(id__,cycle_pkg213_main_sim_FinderM_FinderM,
					 				    const_pkg213_main_sim_FinderM_DELIVERY,
					 				    const_pkg213_main_sim_FinderM_LV,
					 				    const_pkg213_main_sim_FinderM_TOP)
					 		\{| |})
					 		[[stm_ref0::terminate <- terminate]]
					 	)
					 	)
					) \ {|	stm_ref0::endexec,stm_ref0::registerRead,stm_ref0::registerWrite |}
				) [| {terminate} |> SKIP
			)
		)
		
		O__(id__,cycle_pkg213_main_sim_Rescue_Finder_Finder,
				    const_pkg213_main_sim_Rescue_Finder_stm_ref0_DELIVERY,
				    const_pkg213_main_sim_Rescue_Finder_stm_ref0_LV,
