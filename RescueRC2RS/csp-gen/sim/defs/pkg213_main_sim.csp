					 	memoryComp(id__,
					 			    const_pkg213_main_sim_Rescue_Finder_stm_ref0_DELIVERY,
					 			    const_pkg213_main_sim_Rescue_Finder_stm_ref0_LV,
					 			    const_pkg213_main_sim_Rescue_Finder_stm_ref0_TOP)
					 	)\{||}
						[| {| 	terminate,tock,
								stm_ref0::endexec,stm_ref0::registerRead,stm_ref0::registerWrite|} |]
						-- (Rule 9) composeMachines(...) : CSPProcess
					 	((let
					 		const_pkg213_main_sim_FinderM_DELIVERY = 2
					 		const_pkg213_main_sim_FinderM_LV = const_pkg213_main_sim_Rescue_Finder_stm_ref0_LV
					 		const_pkg213_main_sim_FinderM_TOP = 1
					 		cycle_pkg213_main_sim_FinderM_FinderM = cycle_pkg213_main_sim_Rescue_Finder_Finder
					 	within
					 		(stm_ref0::O__(id__,cycle_pkg213_main_sim_FinderM_FinderM,
					 				    const_pkg213_main_sim_FinderM_DELIVERY,
					 				    const_pkg213_main_sim_FinderM_LV,
					 				    const_pkg213_main_sim_FinderM_TOP)
					 		\{| |})
					 		[[stm_ref0::terminate <- terminate]]
					 	)
					 	)
					) \ {|	stm_ref0::endexec,stm_ref0::registerRead,stm_ref0::registerWrite |}
				) [| {terminate} |> SKIP
			)
		)
		}
	endmodule
	
	-- declaring inputs and outputs of the module
	
	Timed(OneStep) {
	-- (Rule 3) cycleModule(...) : CSPProcess
	
	datatype COutputEvents = COutput_turnBack
		| COutput_land
		| COutput_takeoff
		| COutput_move
	
	EVarsEvents = {}
	
	
	cycleModule(id__,cycle_pkg213_main_sim_Rescue_Rescue) =
	let 
					
		project_Finder(Finder::o_turnBack) = COutput_turnBack
		project_Finder(Finder::o_land) = COutput_land
		project_Finder(Finder::o_takeoff) = COutput_takeoff
		project_Finder(Finder::o_move.x__) = COutput_move
		
		connected_Finder(Finder::o_turnBack) = true
		connected_Finder(Finder::o_land) = true
		connected_Finder(Finder::o_takeoff) = true
		connected_Finder(Finder::o_move.x__) = true
		connected_Finder(_) = false
	
		lift_Finder(Finder::o_turnBack) = o_turnBack
		lift_Finder(Finder::o_land) = o_land
		lift_Finder(Finder::o_takeoff) = o_takeoff
		lift_Finder(Finder::o_move.x__) = o_move.x__
	
		CycleModule =
			Deadline(
			-- read inputs from the platform and pass to controllers
			(
			((registerRead.i_switchOn?x__ ->
				Finder::registerRead.Finder::i_switchOn!x__ -> SKIP)
				|||
			(registerRead.i_found?x__ ->
				Finder::registerRead.Finder::i_found!x__ -> SKIP)
				|||
			(registerRead.i_origin?x__ ->
				Finder::registerRead.Finder::i_origin!x__ -> SKIP))
					);
			-- synchronize on events related to evars
			-- collect outputs, and monitor termination of the cycle, by all controllers
			(CollectOutputs(COutputEvents) [| {endexec} |] Monitor),0);
			-- wait for the cycleDef period
			TimeOut_1(terminate -> SKIP,WAIT(cycle_pkg213_main_sim_Rescue_Rescue-1));
			-- recurse
			CycleModule
								
		CollectOutputs(sout) =
			(
			Finder::registerWrite?outp:{ outp | outc <- diff(sout,EVarsEvents), outp <- Finder::RegisterDataOutput, connected_Finder(outp), project_Finder(outp) == outc}
			 	-> registerWrite!lift_Finder(outp)
			 		-> CollectOutputs(diff(sout,{project_Finder(outp)}))
			[]
			endexec -> SKIP
			)
			
		Monitor = 
			(	 (Finder::endexec -> SKIP)); endexec -> SKIP
		
	within
		CycleModule 
	
	-- (Rule 5) memoryComp(...) : CSPProcess
	memoryComp(id__) = (
		STOP)
	
	
	-- (Rule 1) [[ M : SimModule ]]_M : CSPProcess
	D__(id__,cycle_pkg213_main_sim_Rescue_Rescue,
			    const_pkg213_main_sim_Rescue_Finder_stm_ref0_DELIVERY,
			    const_pkg213_main_sim_Rescue_Finder_stm_ref0_LV,
			    const_pkg213_main_sim_Rescue_Finder_stm_ref0_TOP) =
	timed_priority(
		(
			(
				(
					(
						dbisim(cycleModule(id__,cycle_pkg213_main_sim_Rescue_Rescue))
								[| Union({{||},
										  {||},
										  {||},
										  {||}}) |]
									memoryComp(id__)
						)\{||}
					[| {| 	terminate,tock,
							Finder::endexec,Finder::registerRead,Finder::registerWrite	|} |]
					-- (Rule 6) composeControllers(...) : CSPProcess
						((let
								cycle_pkg213_main_sim_Rescue_Finder_Finder = cycle_pkg213_main_sim_Rescue_Rescue
							within
								(Finder::D__(id__,cycle_pkg213_main_sim_Rescue_Finder_Finder,
										    const_pkg213_main_sim_Rescue_Finder_stm_ref0_DELIVERY,
										    const_pkg213_main_sim_Rescue_Finder_stm_ref0_LV,
										    const_pkg213_main_sim_Rescue_Finder_stm_ref0_TOP)
								\{| |})
									[[Finder::terminate <- terminate]]
							)
						)
				) \ {|	endexec,
						Finder::endexec,Finder::registerRead,Finder::registerWrite |}
			) [| {terminate} |> SKIP
		) \ {terminate}
	)
	
	
	
	O__(id__,cycle_pkg213_main_sim_Rescue_Rescue,
			    const_pkg213_main_sim_Rescue_Finder_stm_ref0_DELIVERY,
			    const_pkg213_main_sim_Rescue_Finder_stm_ref0_LV,
			    const_pkg213_main_sim_Rescue_Finder_stm_ref0_TOP) =
	timed_priority(
		(
			(
				(
					(
						dbisim(cycleModule(id__,cycle_pkg213_main_sim_Rescue_Rescue))
								[| Union({{||},
										  {||},
										  {||},
										  {||}}) |]
									memoryComp(id__)
						)\{||}
					[| {| 	terminate,tock,
							Finder::endexec,Finder::registerRead,Finder::registerWrite	|} |]
					-- (Rule 6) composeControllers(...) : CSPProcess
						((let
								cycle_pkg213_main_sim_Rescue_Finder_Finder = cycle_pkg213_main_sim_Rescue_Rescue
							within
								(Finder::O__(id__,cycle_pkg213_main_sim_Rescue_Finder_Finder,
										    const_pkg213_main_sim_Rescue_Finder_stm_ref0_DELIVERY,
										    const_pkg213_main_sim_Rescue_Finder_stm_ref0_LV,
										    const_pkg213_main_sim_Rescue_Finder_stm_ref0_TOP)
								\{| |})
									[[Finder::terminate <- terminate]]
							)
						)
				) \ {|	endexec,
						Finder::endexec,Finder::registerRead,Finder::registerWrite |}
			) [| {terminate} |> SKIP
		) \ {terminate}
	)
	}
endmodule


module FinderM
exports
	transparent diamond
	transparent sbisim
	transparent dbisim
	transparent chase

	-- Transition identifiers
	-- declaring identifiers of transitions
	datatype NIDS = 
	              NID_i0|
	              NID_Off|
	              NID_Looking|
	              NID_Delivering|
	              NID_Returning
	
	channel internal__ : NIDS
	
	-- Flow channels		
	channel interrupt
	channel exited
	channel exit
	channel terminate
	
	-- Variable channels
	channel get_originF, set_originF, setL_originF, setR_originF: core_boolean
	channel get_foundF, set_foundF, setL_foundF, setR_foundF: core_boolean
	channel get_switchOnF, set_switchOnF, setL_switchOnF, setR_switchOnF: core_boolean
	
	-- Shared variable channels
	
	-- Local variable channels for defined operations that are required by the state machine
	
	-- Declaring state machine events
	
	-- Declaring call and ret events for undefined operations
	channel clone_normal_FinderM_Off_t1_opCall
	channel clone_normal_FinderM_Delivering_t3_opCall
	channel clone_normal_FinderM_Returning_t4_opCall
	channel moveCall: core_nat
	channel turnBackCall
	channel clone_normal_FinderM_Delivering_entryCall
	channel clone_normal_FinderM_Looking_t2_opCall
	
	enterSS = {|
	i0::enter,
	Off::enter,
	Looking::enter,
	Delivering::enter,
	Returning::enter
	|}
	
	enteredSS = 	{|
	Off::entered,
	Looking::entered,
	Delivering::entered,
	Returning::entered
	|}
	
	internal_events = union(enteredSS,union(enterSS,{|interrupt,exited|}))
	
	shared_variable_events = {|
	|}
	
	
	channel clockReset, clockResetL, clockResetR 
	
	localClockResets = {||}
	
	
	channel get_CLID_Looking : core_clock_type 
	channel get_CLID_Off : core_clock_type 
	channel get_CLID_Returning : core_clock_type 
	channel get_CLID_Delivering : core_clock_type 
	--channel increment__
	
	CLID_Looking_clock_type(id__,
			          const_pkg213_main_sim_FinderM_DELIVERY,
			          const_pkg213_main_sim_FinderM_LV,
			          const_pkg213_main_sim_FinderM_TOP) = 
		let
			max = (clock_type_max(Union({
	{}
	}))+1)
		ctype = {0..max}
	within
		if member(max,core_clock_type) then ctype else error("core_clock_type is not wide enough")
	
	CLID_Off_clock_type(id__,
			          const_pkg213_main_sim_FinderM_DELIVERY,
			          const_pkg213_main_sim_FinderM_LV,
			          const_pkg213_main_sim_FinderM_TOP) = 
		let
			max = (clock_type_max(Union({
	{}
	}))+1)
		ctype = {0..max}
