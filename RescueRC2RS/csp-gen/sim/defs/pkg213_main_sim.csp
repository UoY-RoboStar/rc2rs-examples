module OP_clone_normal_FinderM_Delivering_t3_waitOp
exports
	transparent diamond
	transparent sbisim
	transparent dbisim
	transparent chase

	-- Transition identifiers
	-- declaring identifiers of transitions
	datatype NIDS = 
	              NID_i0|
	              NID_f|
	              NID_Waiting
	
	channel internal__ : NIDS
	
	-- Flow channels		
	channel interrupt
	channel exited
	channel exit
	channel terminate
	
	-- Variable channels
	channel get_originF, set_originF, setL_originF, setR_originF: core_boolean
	channel get_foundF, set_foundF, setL_foundF, setR_foundF: core_boolean
	channel get_switchOnF, set_switchOnF, setL_switchOnF, setR_switchOnF: core_boolean
	
	-- Shared variable channels
	channel set_EXT_switchOnF: core_boolean
	channel set_EXT_originF: core_boolean
	channel set_EXT_foundF: core_boolean
	
	-- Local variable channels for defined operations that are required by the state machine
	
	-- Declaring state machine events
	
	-- Declaring call and ret events for undefined operations
	
	enterSS = {|
	i0::enter,
	f::enter,
	Waiting::enter
	|}
	
	enteredSS = 	{|
	f::entered,
	Waiting::entered
	|}
	
	internal_events = union(enteredSS,union(enterSS,{|interrupt,exited|}))
	
	shared_variable_events = {|
		set_EXT_switchOnF,
		set_EXT_originF,
		set_EXT_foundF
	|}
	
	datatype ClockSet = 
		CLID_C
	
	channel clockReset, clockResetL, clockResetR : ClockSet
	
	localClockResets = {|clockReset.CLID_C|}
	
	
	channel get_CLID_C : core_clock_type 
	channel get_CLID_Waiting : core_clock_type 
	channel get_CLID_f : core_clock_type 
	--channel increment__
	
	CLID_C_clock_type(id__) = 
		let
			max = (clock_type_max(Union({
	({param_i|param_i <- core_nat}),
	({param_i|param_i <- core_nat})
	}))+1)
		ctype = {0..max}
	within
		if member(max,core_clock_type) then ctype else error("core_clock_type is not wide enough")
	
	CLID_Waiting_clock_type(id__) = 
		let
			max = (clock_type_max(Union({
	{}
	}))+1)
		ctype = {0..max}
	within
		if member(max,core_clock_type) then ctype else error("core_clock_type is not wide enough")
	
	CLID_f_clock_type(id__) = 
