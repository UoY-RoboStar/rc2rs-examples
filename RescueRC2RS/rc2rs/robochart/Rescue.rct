	waitOp ( i : nat )
}

interface I_waitInterval {
	waitInterval ( m : nat , n : nat )
}

interface I_events_normal_FinderM_Off_t1_op_i_t {
	event takeoff
}

interface I_normal_FinderM_Off_t1_op_i_t_op {
	normal_FinderM_Off_t1_op_i_t_op ( )
}

interface I_events_normal_FinderM_Delivering_t3_op_i_t {
	event takeoff
}

interface I_normal_FinderM_Delivering_t3_op_i_t_op {
	normal_FinderM_Delivering_t3_op_i_t_op ( )
}

interface I_clone_normal_FinderM_Delivering_t3_op_i_t_op {
	clone_normal_FinderM_Delivering_t3_op_i_t_op ( )
}

interface I_clone_normal_FinderM_Looking_t2_op {
	clone_normal_FinderM_Looking_t2_op ( )
}

interface I_clone_normal_FinderM_Delivering_entry {
	clone_normal_FinderM_Delivering_entry ( )
}

interface I_clone_normal_FinderM_Returning_t4_op {
	clone_normal_FinderM_Returning_t4_op ( )
}

interface I_clone_normal_FinderM_Off_t1_op {
	clone_normal_FinderM_Off_t1_op ( )
}

interface I_clone_normal_FinderM_Delivering_t3_op {
	clone_normal_FinderM_Delivering_t3_op ( )
}

stm FinderM {
	uses Flying uses Camera requires Moving 
	//requires I_normal_FinderM_Looking_t2_op requires I_normal_FinderM_Delivering_entry requires I_normal_FinderM_Off_t1_op 
	//requires I_normal_FinderM_Returning_t4_op requires I_normal_FinderM_Delivering_t3_op 
	requires I_clone_normal_FinderM_Looking_t2_op requires I_clone_normal_FinderM_Delivering_entry 
	requires I_clone_normal_FinderM_Returning_t4_op requires I_clone_normal_FinderM_Off_t1_op 
	requires I_clone_normal_FinderM_Delivering_t3_op const DELIVERY : nat = 2
	const LV : nat
	const TOP : nat = 1
	event switchOn
	initial i0
	state Off {
		initial i
		state EmptyCycle {
		}
		transition tOff {
			from i
			to EmptyCycle
		}
	}
	state Looking {
		state EmptyCycle {
		}
		initial i
		transition tLooking {
			from i
			to EmptyCycle
		}
		entry move ( LV )
	}
	state Delivering {
		initial i
		state EmptyCycle {
		}
		transition tDelivering {
			from i
			to EmptyCycle
		}
		entry clone_normal_FinderM_Delivering_entry ( )
	}
	state Returning {
		initial i
		state EmptyCycle {
		}
		transition tReturning {
			from i
			to EmptyCycle
		}
	}
	transition t1 {
		from Off
		to Looking
		trigger switchOn
		action clone_normal_FinderM_Off_t1_op ( )
	}
	transition t2 {
		from Looking
		to Delivering
		trigger found
		action clone_normal_FinderM_Looking_t2_op ( )
	}
	transition t3 {
		from Delivering
		to Returning
		action clone_normal_FinderM_Delivering_t3_op ( )
	}
	transition t0 {
		from i0
		to Off
	}
	transition t4 {
		from Returning
		to Off
		trigger origin
		action clone_normal_FinderM_Returning_t4_op ( )
	}
}

operation normal_FinderM_Looking_t2_op ( ) {
	uses I_events_normal_FinderM_Looking_t2_op final f
	initial i
	transition t {
		from i
		to f
		action land
	}
}

operation normal_FinderM_Delivering_entry ( ) {
	requires req_normal_FinderM_Delivering_entry requires I_waitOp initial i
	final f
	transition t {
		from i
		to f
		action waitOp ( DELIVERY )
	}
}

operation normal_FinderM_Off_t1_op ( ) {
	uses I_events_normal_FinderM_Off_t1_op requires req_normal_FinderM_Off_t1_op requires I_waitOp requires I_normal_FinderM_Off_t1_op_i_t_op final f
	initial i
	junction j_2_2
	transition t {
		from i
		to j_2_2
		action normal_FinderM_Off_t1_op_i_t_op ( )
	}
	transition t_2_2 {
		from j_2_2
		to f
		action waitOp ( TOP )
	}
}

operation normal_FinderM_Returning_t4_op ( ) {
	uses I_events_normal_FinderM_Returning_t4_op initial i
	final f
	transition t {
		from i
		to f
		action land
	}
}

operation normal_FinderM_Delivering_t3_op ( ) {
	uses I_events_normal_FinderM_Delivering_t3_op requires req_normal_FinderM_Delivering_t3_op requires I_waitOp 
	requires I_normal_FinderM_Delivering_t3_op_i_t_op initial i
	final f
	junction j_4_3
	junction j_3_4
	junction j_2_5
	transition t {
		from i
		to j_4_3
		action normal_FinderM_Delivering_t3_op_i_t_op ( )
	}
	transition t_4_3 {
		from j_4_3
		to j_3_4
		action waitOp ( TOP )
	}
	transition t_3_4 {
		from j_3_4
		to j_2_5
		action turnBack ( )
	}
	transition t_2_5 {
		from j_2_5
		to f
		action move ( LV )
	}
}

operation tStop ( ) {
	state sStop {
	}
	initial i
	transition t {
		from i
		to sStop
	}
}

operation deadlineCheck ( d : nat
) {
	requires ItStop initial i
	final f
	transition t {
		from i
		to f
		action tStop ( ) <{ d }
	}
}

operation waitOp ( i : nat
) {
	initial i0
	final f
	state Waiting {
		state EmptyCycle {
		}
		initial i
		transition t {
			from i
			to EmptyCycle
		}
	}
	transition t2 {
		from Waiting
		to f
		condition since ( C ) == i
	}
	transition t {
		from i0
		to Waiting
		action # C
	}
	clock C
}

operation waitInterval ( m : nat
, n : nat
) {
	requires I_waitOp initial i
	final f
	junction j
	transition trSelf {
		from j
		to j
		condition since ( C ) < n
		action waitOp ( 1 )
	}
	transition trF {
		from j
		to f
		condition since ( C ) >= m
	}
	transition trI {
		from i
		to j
		action # C
	}
	clock C
}

operation normal_FinderM_Off_t1_op_i_t_op ( ) {
	uses I_events_normal_FinderM_Off_t1_op_i_t initial i
	final f
	transition t {
		from i
		to f
		action takeoff
	}
}


operation clone_normal_FinderM_Off_t1_op_i_t_op ( ) {
	uses I_events_clone_normal_FinderM_Off_t1_op_i_t initial i
	final f
	transition t {
		from i
		to f
		action takeoff
	}
}

interface I_clone_normal_FinderM_Off_t1_op_i_t_op {
	clone_normal_FinderM_Off_t1_op_i_t_op ()
}

interface I_events_clone_normal_FinderM_Off_t1_op_i_t{
	event takeoff
}

operation normal_FinderM_Delivering_t3_op_i_t_op ( ) {
	uses I_events_normal_FinderM_Delivering_t3_op_i_t final f
	initial i
	transition t {
		from i
		to f
		action takeoff
	}
}

