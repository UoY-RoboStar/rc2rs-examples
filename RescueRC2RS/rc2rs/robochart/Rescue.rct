	move ( lv : nat )
	turnBack ( )
	const TOP : nat = 1 , LV : nat
}

interface I_events_normal_FinderM_Delivering_t3_op {
	event takeoff
}

interface I_normal_FinderM_Delivering_t3_op {
	normal_FinderM_Delivering_t3_op ( )
}

