package pkg213_main 
interface Moving {
	move ( lv : nat )
	turnBack ( )
}

interface Camera {
	event found
	event origin
}

interface Flying {
	event takeoff
	event land
}

interface I_events_normal_FinderM_Looking_t2_op {
	event land
}
 
interface I_normal_FinderM_Looking_t2_op {
	normal_FinderM_Looking_t2_op ( )
}

interface req_normal_FinderM_Delivering_entry {
	const DELIVERY : nat = 2
}

interface I_normal_FinderM_Delivering_entry {
	normal_FinderM_Delivering_entry ( )
}

interface req_normal_FinderM_Off_t1_op {
	const TOP : nat = 1
}

interface I_events_normal_FinderM_Off_t1_op {
