}

operation clone_normal_FinderM_Looking_t2_op ( ) {
	uses I_events_normal_FinderM_Looking_t2_op final f
	initial i
	transition t {
		from i
		to f
		action land
	}
}

operation clone_normal_FinderM_Delivering_entry ( ) {
	requires req_normal_FinderM_Delivering_entry 
	requires I_clone_normal_FinderM_Delivering_entry_waitOp 
	initial i
	final f
	transition t {
		from i
		to f
		action clone_normal_FinderM_Delivering_entry_waitOp ( DELIVERY )
	}
}

interface I_clone_normal_FinderM_Delivering_entry_waitOp{
	clone_normal_FinderM_Delivering_entry_waitOp (n : nat)
}

operation clone_normal_FinderM_Returning_t4_op ( ) {
	uses I_events_normal_FinderM_Returning_t4_op initial i
	final f
	transition t {
		from i
		to f
		action land
	}
}

operation clone_normal_FinderM_Off_t1_op ( ) {
	uses I_events_normal_FinderM_Off_t1_op 
	requires req_normal_FinderM_Off_t1_op 
	requires I_clone_normal_FinderM_Off_t1_waitOp
	requires I_clone_normal_FinderM_Off_t1_op_i_t_op final f
	initial i
	junction j_2_2
	transition t {
		from i
		to j_2_2
		action clone_normal_FinderM_Off_t1_op_i_t_op ( )
	}
	transition t_2_2 {
		from j_2_2
		to f
		action clone_normal_FinderM_Off_t1_waitOp ( TOP ) 
	}
}

interface I_clone_normal_FinderM_Off_t1_waitOp{
	clone_normal_FinderM_Off_t1_waitOp ( n: nat )
}

interface I_clone_normal_FinderM_Delivering_t3_waitOp{
	clone_normal_FinderM_Delivering_t3_waitOp (n : nat)
}

operation clone_normal_FinderM_Delivering_t3_op ( ) {
	uses I_events_normal_FinderM_Delivering_t3_op requires req_normal_FinderM_Delivering_t3_op 
	requires I_clone_normal_FinderM_Delivering_t3_waitOp 
	requires I_clone_normal_FinderM_Delivering_t3_op_i_t_op initial i
	final f
	junction j_4_3
	junction j_3_4
	junction j_2_5
	transition t {
		from i
		to j_4_3
		action clone_normal_FinderM_Delivering_t3_op_i_t_op ( )
	}
	transition t_4_3 {
		from j_4_3
		to j_3_4
		action clone_normal_FinderM_Delivering_t3_waitOp ( TOP )
	}
	transition t_3_4 {
		from j_3_4
		to j_2_5
		action turnBack ( )
	}
	transition t_2_5 {
		from j_2_5
		to f
		action move ( LV )
	}
}

operation clone_normal_FinderM_Delivering_entry_waitOp ( n : nat
) {
	initial i0
	final f
	state Waiting {
		state EmptyCycle {
		}
		initial i
		transition t {
			from i
			to EmptyCycle
		}

	}
	transition t2 {
		from Waiting
		to f
		condition since ( C ) == n
	}
	transition t {
		from i0
		to Waiting
		action # C
	}
	clock C
}

operation clone_normal_FinderM_Delivering_t3_waitOp ( n : nat) {
	initial i0
	final f
	state Waiting {
		state EmptyCycle {
		}
		initial i
		transition t {
			from i
			to EmptyCycle
		}

	}
	transition t2 {
		from Waiting
		to f
		condition since ( C ) == n
	}
	transition t {
		from i0
		to Waiting
		action # C
	}
	clock C
}

operation clone_normal_FinderM_Off_t1_waitOp ( n : nat
) {
	initial i0
	final f
	state Waiting {
		state EmptyCycle {
		}
		initial i
		transition t {
			from i
			to EmptyCycle
		}
	}
	transition t2 {
		from Waiting
		to f
		condition since ( C ) == n
	}
