					 [] dbisim((true)&(internal__!NID_i1 -> SKIP ;  ((((SKIP)[[ endexec <- endexec_action, startexec <- startexec_action ]]) ; SMoving::enter -> SKIP))))
					 [] dbisim((true)&(internal__!NID_SMoving -> SKIP ;  share__choice(exit -> SKIP) ; ((let 
					 	X = share__choice(exited -> SKIP [] endexec -> Y)
					 	Y = share__choice(exited -> SKIP [] startexec -> X)
					  within
