	-- Transition identifiers
	-- declaring identifiers of transitions
	datatype NIDS = 
	              NID_i1|
	              NID_SMoving|
	              NID_DMoving|
	              NID_J1|
	              NID_Waiting|
	              NID_STurning|
	              NID_DTurning|
	              NID_J2
	
