												          const_SimSMovement_av))
									)\{|get_CLID_STurning|}
								)
								[| {|get_CLID_SMoving,SMoving::entered,terminate|} |]
								dbisim(Clock_CLID_SMoving(id__,0,
										          const_SimSMovement_PI,
										          const_SimSMovement_lv,
										          const_SimSMovement_av))
							)\{|get_CLID_SMoving|}
						)
						[| {|get_CLID_Waiting,Waiting::entered,terminate|} |]
						dbisim(Clock_CLID_Waiting(id__,0,
								          const_SimSMovement_PI,
								          const_SimSMovement_lv,
								          const_SimSMovement_av))
					)\{|get_CLID_Waiting|}
				)
				) \ diff(union(stateClockSync,enteredSS),enteredSS)
			)
			)
		
		Stateful_VS_O(id__,cycle_SimSMovement_SimSMovement,
				    const_SimSMovement_PI,
				    const_SimSMovement_lv,
				    const_SimSMovement_av) = 
			dbisim((let
				getsetLocalChannels = {||}
				clockSync = {|get_CLID_MBC,clockReset.CLID_MBC|}
			within
				(Behaviour_VS_O(id__,cycle_SimSMovement_SimSMovement,
						    const_SimSMovement_PI,
						    const_SimSMovement_lv,
						    const_SimSMovement_av) 
				 [| union(union(getsetLocalChannels,clockSync),{terminate}) |] 
				 (varMemory(id__,cycle_SimSMovement_SimSMovement,
				 		    const_SimSMovement_PI,
				 		    const_SimSMovement_lv,
				 		    const_SimSMovement_av) [| {terminate} |] Clocks(id__,
				 		          const_SimSMovement_PI,
				 		          const_SimSMovement_lv,
				 		          const_SimSMovement_av))
			 	)\union(getsetLocalChannels,clockSync)
			)
			)
		
		IteratedStateful_VS_O(id__,cycle_SimSMovement_SimSMovement,
				    const_SimSMovement_PI,
				    const_SimSMovement_lv,
				    const_SimSMovement_av) =
			(dbisim(
				sbisim(
					IteratedBehaviour_VS_O(id__,cycle_SimSMovement_SimSMovement,
							    const_SimSMovement_PI,
							    const_SimSMovement_lv,
							    const_SimSMovement_av)
					[| {|get_CLID_MBC,clockReset.CLID_MBC,terminate|} |]
					dbisim(Clock_CLID_MBC(id__,0,
							          const_SimSMovement_PI,
							          const_SimSMovement_lv,
							          const_SimSMovement_av))
				)\{|get_CLID_MBC,clockReset.CLID_MBC|}
			)
			)
		
		-- END
		
		-- Memory
		-- Memory variables
		
		-- varMemory process
		varMemory(id__,cycle_SimSMovement_SimSMovement,
				    const_SimSMovement_PI,
				    const_SimSMovement_lv,
				    const_SimSMovement_av) = terminate -> SKIP
		
		getsetLocalChannels = {||}
		
		-- Definition of the behaviour of state machines (default, optimised, visible, visible and optimised)
		FVS__(id__,cycle_SimSMovement_SimSMovement,
				    const_SimSMovement_PI,
				    const_SimSMovement_lv,
				    const_SimSMovement_av) = STM_VS_O(id__,cycle_SimSMovement_SimSMovement,
				    const_SimSMovement_PI,
				    const_SimSMovement_lv,
				    const_SimSMovement_av) \ localClockResets
		D__(id__,cycle_SimSMovement_SimSMovement,
				    const_SimSMovement_PI,
				    const_SimSMovement_lv,
				    const_SimSMovement_av) = timed_priority(STM(id__,cycle_SimSMovement_SimSMovement,
				    const_SimSMovement_PI,
				    const_SimSMovement_lv,
				    const_SimSMovement_av) \ union(internal_events,localClockResets))
		O__(id__,cycle_SimSMovement_SimSMovement,
				    const_SimSMovement_PI,
				    const_SimSMovement_lv,
				    const_SimSMovement_av) = dbisim(D__(id__,cycle_SimSMovement_SimSMovement,
				    const_SimSMovement_PI,
				    const_SimSMovement_lv,
				    const_SimSMovement_av))
		VS__(id__,cycle_SimSMovement_SimSMovement,
				    const_SimSMovement_PI,
				    const_SimSMovement_lv,
				    const_SimSMovement_av) = FVS__(id__,cycle_SimSMovement_SimSMovement,
				    const_SimSMovement_PI,
				    const_SimSMovement_lv,
				    const_SimSMovement_av)
		VS_O__(id__,cycle_SimSMovement_SimSMovement,
				    const_SimSMovement_PI,
				    const_SimSMovement_lv,
				    const_SimSMovement_av) = dbisim(FVS__(id__,cycle_SimSMovement_SimSMovement,
				    const_SimSMovement_PI,
				    const_SimSMovement_lv,
				    const_SimSMovement_av))
		HEXT__(id__,cycle_SimSMovement_SimSMovement,
				    const_SimSMovement_PI,
				    const_SimSMovement_lv,
				    const_SimSMovement_av) = O__(id__,cycle_SimSMovement_SimSMovement,
				    const_SimSMovement_PI,
				    const_SimSMovement_lv,
				    const_SimSMovement_av) [|shared_variable_events|] SKIP
		FVS_C__(id__,cycle_SimSMovement_SimSMovement,
				    const_SimSMovement_PI,
				    const_SimSMovement_lv,
				    const_SimSMovement_av) = dbisim(timed_priority(STM(id__,cycle_SimSMovement_SimSMovement,
				    const_SimSMovement_PI,
				    const_SimSMovement_lv,
				    const_SimSMovement_av) \ internal_events))
		HUP__(id__,cycle_SimSMovement_SimSMovement,
				    const_SimSMovement_PI,
				    const_SimSMovement_lv,
				    const_SimSMovement_av) = timed_priority(O__(id__,cycle_SimSMovement_SimSMovement,
				    const_SimSMovement_PI,
				    const_SimSMovement_lv,
				    const_SimSMovement_av) [|{share__}|] SKIP)
		
		-- Clocks
		Clock_CLID_MBC(id__,x__,
				          const_SimSMovement_PI,
				          const_SimSMovement_lv,
				          const_SimSMovement_av) = 
			TimeOut_1(
				clockReset.CLID_MBC -> Clock_CLID_MBC(id__,0,
						          const_SimSMovement_PI,
						          const_SimSMovement_lv,
						          const_SimSMovement_av)
				[]
				get_CLID_MBC!x__ -> Clock_CLID_MBC(id__,x__,
						          const_SimSMovement_PI,
						          const_SimSMovement_lv,
						          const_SimSMovement_av)
				[]
				terminate -> SKIP,Clock_CLID_MBC(id__,clock_type_plus(x__,1,CLID_MBC_clock_type(id__,
						          const_SimSMovement_PI,
						          const_SimSMovement_lv,
						          const_SimSMovement_av)),
						          const_SimSMovement_PI,
						          const_SimSMovement_lv,
						          const_SimSMovement_av))
		
		Clocks(id__,
				          const_SimSMovement_PI,
				          const_SimSMovement_lv,
				          const_SimSMovement_av) = dbisim(Clock_CLID_MBC(id__,0,
				          const_SimSMovement_PI,
				          const_SimSMovement_lv,
				          const_SimSMovement_av))
		
		clockSync = {|get_CLID_MBC,clockReset.CLID_MBC|}
		
		Clock_CLID_Waiting(id__,x__,
				          const_SimSMovement_PI,
				          const_SimSMovement_lv,
				          const_SimSMovement_av) = 
			TimeOut_1(
				Waiting::entered -> Clock_CLID_Waiting(id__,0,
						          const_SimSMovement_PI,
						          const_SimSMovement_lv,
						          const_SimSMovement_av)
				[]
				get_CLID_Waiting!x__ -> Clock_CLID_Waiting(id__,x__,
						          const_SimSMovement_PI,
						          const_SimSMovement_lv,
						          const_SimSMovement_av)
				[]
				terminate -> SKIP,Clock_CLID_Waiting(id__,clock_type_plus(x__,1,CLID_Waiting_clock_type(id__,
						          const_SimSMovement_PI,
						          const_SimSMovement_lv,
						          const_SimSMovement_av)),
						          const_SimSMovement_PI,
						          const_SimSMovement_lv,
						          const_SimSMovement_av))
		Clock_CLID_SMoving(id__,x__,
				          const_SimSMovement_PI,
				          const_SimSMovement_lv,
				          const_SimSMovement_av) = 
			TimeOut_1(
				SMoving::entered -> Clock_CLID_SMoving(id__,0,
						          const_SimSMovement_PI,
						          const_SimSMovement_lv,
						          const_SimSMovement_av)
				[]
				get_CLID_SMoving!x__ -> Clock_CLID_SMoving(id__,x__,
						          const_SimSMovement_PI,
						          const_SimSMovement_lv,
						          const_SimSMovement_av)
				[]
				terminate -> SKIP,Clock_CLID_SMoving(id__,clock_type_plus(x__,1,CLID_SMoving_clock_type(id__,
						          const_SimSMovement_PI,
						          const_SimSMovement_lv,
						          const_SimSMovement_av)),
						          const_SimSMovement_PI,
						          const_SimSMovement_lv,
						          const_SimSMovement_av))
		Clock_CLID_STurning(id__,x__,
				          const_SimSMovement_PI,
				          const_SimSMovement_lv,
				          const_SimSMovement_av) = 
			TimeOut_1(
				STurning::entered -> Clock_CLID_STurning(id__,0,
						          const_SimSMovement_PI,
						          const_SimSMovement_lv,
						          const_SimSMovement_av)
				[]
				get_CLID_STurning!x__ -> Clock_CLID_STurning(id__,x__,
						          const_SimSMovement_PI,
						          const_SimSMovement_lv,
						          const_SimSMovement_av)
				[]
				terminate -> SKIP,Clock_CLID_STurning(id__,clock_type_plus(x__,1,CLID_STurning_clock_type(id__,
						          const_SimSMovement_PI,
						          const_SimSMovement_lv,
						          const_SimSMovement_av)),
						          const_SimSMovement_PI,
						          const_SimSMovement_lv,
						          const_SimSMovement_av))
		Clock_CLID_DMoving(id__,x__,
				          const_SimSMovement_PI,
				          const_SimSMovement_lv,
				          const_SimSMovement_av) = 
			TimeOut_1(
				DMoving::entered -> Clock_CLID_DMoving(id__,0,
						          const_SimSMovement_PI,
						          const_SimSMovement_lv,
						          const_SimSMovement_av)
				[]
				get_CLID_DMoving!x__ -> Clock_CLID_DMoving(id__,x__,
						          const_SimSMovement_PI,
						          const_SimSMovement_lv,
						          const_SimSMovement_av)
				[]
				terminate -> SKIP,Clock_CLID_DMoving(id__,clock_type_plus(x__,1,CLID_DMoving_clock_type(id__,
						          const_SimSMovement_PI,
						          const_SimSMovement_lv,
						          const_SimSMovement_av)),
						          const_SimSMovement_PI,
						          const_SimSMovement_lv,
						          const_SimSMovement_av))
		Clock_CLID_DTurning(id__,x__,
				          const_SimSMovement_PI,
				          const_SimSMovement_lv,
				          const_SimSMovement_av) = 
			TimeOut_1(
				DTurning::entered -> Clock_CLID_DTurning(id__,0,
						          const_SimSMovement_PI,
						          const_SimSMovement_lv,
						          const_SimSMovement_av)
				[]
				get_CLID_DTurning!x__ -> Clock_CLID_DTurning(id__,x__,
						          const_SimSMovement_PI,
						          const_SimSMovement_lv,
						          const_SimSMovement_av)
				[]
				terminate -> SKIP,Clock_CLID_DTurning(id__,clock_type_plus(x__,1,CLID_DTurning_clock_type(id__,
						          const_SimSMovement_PI,
						          const_SimSMovement_lv,
						          const_SimSMovement_av)),
						          const_SimSMovement_PI,
						          const_SimSMovement_lv,
						          const_SimSMovement_av))
		
		StateClocks(id__,
				          const_SimSMovement_PI,
				          const_SimSMovement_lv,
				          const_SimSMovement_av) = dbisim(Clock_CLID_Waiting(id__,0,
				          const_SimSMovement_PI,
				          const_SimSMovement_lv,
				          const_SimSMovement_av))
		[| { terminate } |] (
		dbisim(Clock_CLID_SMoving(id__,0,
				          const_SimSMovement_PI,
				          const_SimSMovement_lv,
				          const_SimSMovement_av))
		[| { terminate } |] (
		dbisim(Clock_CLID_STurning(id__,0,
				          const_SimSMovement_PI,
				          const_SimSMovement_lv,
				          const_SimSMovement_av))
		[| { terminate } |] (
		dbisim(Clock_CLID_DMoving(id__,0,
				          const_SimSMovement_PI,
				          const_SimSMovement_lv,
				          const_SimSMovement_av))
		[| { terminate } |] (
		dbisim(Clock_CLID_DTurning(id__,0,
				          const_SimSMovement_PI,
				          const_SimSMovement_lv,
				          const_SimSMovement_av))
		)
		)
		)
		)
		
		stateClockSync = {|get_CLID_Waiting,Waiting::entered,get_CLID_SMoving,SMoving::entered,get_CLID_STurning,STurning::entered,get_CLID_DMoving,DMoving::entered,get_CLID_DTurning,DTurning::entered|}
		
		
		-- Shared memory
		-- Shared memory variables
		
		Memory_obstacle(x__) = (
			get_obstacle!x__ -> Memory_obstacle(x__)
			[]
			registerRead.i_obstacle?x__ -> Memory_obstacle(x__)
			[]
			terminate -> SKIP
		)
		
		-- sharedVarMemory process
		sharedVarMemory(id__,cycle_SimSMovement_SimSMovement,
				    const_SimSMovement_PI,
				    const_SimSMovement_lv,
				    const_SimSMovement_av) = (
		 (terminate -> SKIP
		 )
		 [| { terminate } |]
		 (Memory_obstacle(false)
		 )
		)
		
		sharedVarSync = union({|get_obstacle|},
			  {||}
			 )
		
		sharedVarHide = union({|get_obstacle|},
			  {||}
			 )
		
		}
endmodule


