						    const_SimSMovement_PI,
						    const_SimSMovement_lv,
						    const_SimSMovement_av) = D__(id__,cycle_SimSMovement_SimSMovement,
						    const_SimSMovement_PI,
						    const_SimSMovement_lv,
						    const_SimSMovement_av)
			}
		
		endmodule
		----------------------------------------------------------------------
		
		-- END of Nodes --
		
		Timed(OneStep) {
		-- Operation calls --
		-- Only the undefined operations are declared here.
		-- If the state machine is in isolation, all required operations will be undefined.
		-- If it is in the context of a controller, the required operations not provided by the
		-- controller will be declared here, and the defined operations will be defined in the
		-- context of the Controller module, and therefore within scope of the state machine module.
		CALL__move(id__,
				    const_SimSMovement_PI,
				    const_SimSMovement_lv,
				    const_SimSMovement_av,
					param_lv,
					param_av) = EDeadline(registerWrite.o_move.param_lv.param_av,0)
		CALL__stop(id__,
				    const_SimSMovement_PI,
				    const_SimSMovement_lv,
				    const_SimSMovement_av) = EDeadline(registerWrite.o_stop,0)
		
		-- END of Operation calls --
	
		datatype SOutputEvents = SOutput_move
			| SOutput_stop
		
		cycle(cycle_SimSMovement_SimSMovement) =
			let
				project(o_move.x__) = SOutput_move
				project(o_stop) = SOutput_stop
		
				Cycle =
					Deadline(
						(registerRead.i_obstacle?x__ -> SKIP);
						startexec -> CollectOutputs(SOutputEvents),0);
					TimeOut_1(terminate -> SKIP,WAIT(cycle_SimSMovement_SimSMovement-1);Cycle)
				
				CollectOutputs(sout) =
					(registerWrite?outp:{ outp | outc <- inter(sout,SOutputEvents), outp <- RegisterDataOutput,project(outp) == outc} -> CollectOutputs(diff(sout,{project(outp)}))
						[]
					endexec -> SKIP
					)
			within
				Cycle
		
		-- STM processes
		STM(id__,cycle_SimSMovement_SimSMovement,
				    const_SimSMovement_PI,
				    const_SimSMovement_lv,
				    const_SimSMovement_av) = -- RULE: [[stm:StateMachineDef]]_STM^nops : CSPProcess
		(
			cycle(cycle_SimSMovement_SimSMovement)
			[| {| endexec,registerRead,registerWrite,startexec,terminate |} |]
			( 
				(
					(
						(startexec -> IteratedStateful(id__,cycle_SimSMovement_SimSMovement,
								    const_SimSMovement_PI,
								    const_SimSMovement_lv,
								    const_SimSMovement_av) \ {terminate}) 
						[| {share__} |]
						SKIP
					) ; 
					(let
						Ending = endexec -> (startexec -> Ending [] terminate -> SKIP)
					 within
					 	Ending
					)
				)
				[| union(sharedVarSync,{terminate}) |]
				dbisim(sharedVarMemory(id__,cycle_SimSMovement_SimSMovement,
						    const_SimSMovement_PI,
						    const_SimSMovement_lv,
						    const_SimSMovement_av))
