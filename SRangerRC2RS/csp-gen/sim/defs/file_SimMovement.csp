						[]
						terminate -> SKIP,Clock_CLID_DMoving(id__,clock_type_plus(x__,1,CLID_DMoving_clock_type(id__,
								          const_SimSMovement_PI,
								          const_SimSMovement_lv,
								          const_SimSMovement_av)),
								          const_SimSMovement_PI,
								          const_SimSMovement_lv,
								          const_SimSMovement_av))
				Clock_CLID_DTurning(id__,x__,
						          const_SimSMovement_PI,
						          const_SimSMovement_lv,
						          const_SimSMovement_av) = 
					TimeOut_1(
						DTurning::entered -> Clock_CLID_DTurning(id__,0,
