		enterSS = {|
		i1::enter,
		SMoving::enter,
		DMoving::enter,
		J1::enter,
		Waiting::enter,
		STurning::enter,
		DTurning::enter,
		J2::enter
		|}
		
		enteredSS = 	{|
		SMoving::entered,
		DMoving::entered,
		Waiting::entered,
		STurning::entered,
		DTurning::entered
		|}
		
		internal_events = union(enteredSS,union(enterSS,{|interrupt,exited|}))
		
		shared_variable_events = {|
		|}
		
		datatype ClockSet = 
			CLID_MBC
		
		channel clockReset, clockResetL, clockResetR : ClockSet
		
		localClockResets = {|clockReset.CLID_MBC|}
		
		
		channel get_CLID_Waiting : core_clock_type 
		channel get_CLID_MBC : core_clock_type 
		channel get_CLID_SMoving : core_clock_type 
		channel get_CLID_STurning : core_clock_type 
		channel get_CLID_DMoving : core_clock_type 
		channel get_CLID_DTurning : core_clock_type 
		--channel increment__
		
		CLID_Waiting_clock_type(id__,
				          const_SimSMovement_PI,
				          const_SimSMovement_lv,
				          const_SimSMovement_av) = 
			let
				max = (clock_type_max(Union({
		{}
		}))+1)
			ctype = {0..max}
		within
			if member(max,core_clock_type) then ctype else error("core_clock_type is not wide enough")
		
		CLID_MBC_clock_type(id__,
				          const_SimSMovement_PI,
				          const_SimSMovement_lv,
				          const_SimSMovement_av) = 
			let
				max = (clock_type_max(Union({
		{},
		({Div(const_SimSMovement_PI, no_zero_div(const_SimSMovement_av), core_real)|PI <- core_real,av <- core_real}),
		({Div(const_SimSMovement_PI, no_zero_div(const_SimSMovement_av), core_real)|PI <- core_real,av <- core_real})
		}))+1)
			ctype = {0..max}
		within
			if member(max,core_clock_type) then ctype else error("core_clock_type is not wide enough")
		
