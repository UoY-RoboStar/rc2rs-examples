						    const_SimSMovement_PI,
						    const_SimSMovement_lv,
						    const_SimSMovement_av) = terminate -> SKIP
				
				getsetLocalChannels = {||}
				
				-- Definition of the behaviour of state machines (default, optimised, visible, visible and optimised)
				FVS__(id__,cycle_SimSMovement_SimSMovement,
						    const_SimSMovement_PI,
						    const_SimSMovement_lv,
						    const_SimSMovement_av) = STM_VS_O(id__,cycle_SimSMovement_SimSMovement,
						    const_SimSMovement_PI,
						    const_SimSMovement_lv,
						    const_SimSMovement_av) \ localClockResets
				D__(id__,cycle_SimSMovement_SimSMovement,
						    const_SimSMovement_PI,
						    const_SimSMovement_lv,
						    const_SimSMovement_av) = timed_priority(STM(id__,cycle_SimSMovement_SimSMovement,
						    const_SimSMovement_PI,
						    const_SimSMovement_lv,
						    const_SimSMovement_av) \ union(internal_events,localClockResets))
				O__(id__,cycle_SimSMovement_SimSMovement,
						    const_SimSMovement_PI,
						    const_SimSMovement_lv,
						    const_SimSMovement_av) = dbisim(D__(id__,cycle_SimSMovement_SimSMovement,
						    const_SimSMovement_PI,
						    const_SimSMovement_lv,
						    const_SimSMovement_av))
				VS__(id__,cycle_SimSMovement_SimSMovement,
						    const_SimSMovement_PI,
						    const_SimSMovement_lv,
						    const_SimSMovement_av) = FVS__(id__,cycle_SimSMovement_SimSMovement,
						    const_SimSMovement_PI,
