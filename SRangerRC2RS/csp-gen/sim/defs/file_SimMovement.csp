				-- Clocks
				Clock_CLID_MBC(id__,x__,
						          const_SimSMovement_PI,
						          const_SimSMovement_lv,
						          const_SimSMovement_av) = 
					TimeOut_1(
						clockReset.CLID_MBC -> Clock_CLID_MBC(id__,0,
								          const_SimSMovement_PI,
								          const_SimSMovement_lv,
								          const_SimSMovement_av)
						[]
						get_CLID_MBC!x__ -> Clock_CLID_MBC(id__,x__,
								          const_SimSMovement_PI,
								          const_SimSMovement_lv,
								          const_SimSMovement_av)
						[]
						terminate -> SKIP,Clock_CLID_MBC(id__,clock_type_plus(x__,1,CLID_MBC_clock_type(id__,
								          const_SimSMovement_PI,
								          const_SimSMovement_lv,
								          const_SimSMovement_av)),
								          const_SimSMovement_PI,
								          const_SimSMovement_lv,
								          const_SimSMovement_av))
				
				Clocks(id__,
						          const_SimSMovement_PI,
						          const_SimSMovement_lv,
