	--channel increment__
	
	CLID_Waiting_clock_type(id__,
			          const_SimSMovement_PI,
			          const_SimSMovement_lv,
			          const_SimSMovement_av) = 
		let
			max = (clock_type_max(Union({
	{}
	}))+1)
		ctype = {0..max}
	within
		if member(max,core_clock_type) then ctype else error("core_clock_type is not wide enough")
	
	CLID_MBC_clock_type(id__,
			          const_SimSMovement_PI,
			          const_SimSMovement_lv,
			          const_SimSMovement_av) = 
		let
			max = (clock_type_max(Union({
	{},
	({Div(const_SimSMovement_PI, no_zero_div(const_SimSMovement_av), core_real)|PI <- core_real,av <- core_real}),
	({Div(const_SimSMovement_PI, no_zero_div(const_SimSMovement_av), core_real)|PI <- core_real,av <- core_real})
