	datatype RegisterDataOutput = o_stop
		| o_move.core_real.core_real
		| o_obstacle
	
	
	nametype RegisterOutputs = {|
	o_move,
	o_stop|}
		
	nametype RegisterInputs = {|
	i_obstacle|}
	
	channel registerRead 	: RegisterDataInput
	channel registerWrite 	: RegisterDataOutput
	
	channel endexec, terminate
	
	
	-- declaring call and ret events for undefined operations
	channel moveCall: core_real.core_real
	channel stopCall
	
	-- channel set with all visible events
	sem__events = {|endexec,terminate
	,registerRead
	,registerWrite
	|}
	
	module sm
	exports
		transparent diamond
		transparent sbisim
		transparent dbisim
		transparent chase
	
		-- Transition identifiers
		-- declaring identifiers of transitions
		datatype NIDS = 
		              NID_i1|
		              NID_SMoving|
		              NID_DMoving|
		              NID_J1|
		              NID_Waiting|
		              NID_STurning|
		              NID_DTurning|
		              NID_J2
		
		channel internal__ : NIDS
		
