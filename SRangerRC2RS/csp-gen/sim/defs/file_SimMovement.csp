								          const_SimSMovement_PI,
								          const_SimSMovement_lv,
								          const_SimSMovement_av)) \ diff(union(stateClockSync,enteredSS),enteredSS)
					)
					)
				
				IteratedBehaviour_VS_O(id__,cycle_SimSMovement_SimSMovement,
						    const_SimSMovement_PI,
						    const_SimSMovement_lv,
						    const_SimSMovement_av) = 
					dbisim((let
						stateClockSync = {|get_CLID_Waiting,Waiting::entered,get_CLID_SMoving,SMoving::entered,get_CLID_STurning,STurning::entered,get_CLID_DMoving,DMoving::entered,get_CLID_DTurning,DTurning::entered|}
					 within
						(dbisim(
							sbisim(
								dbisim(
									sbisim(
										dbisim(
											sbisim(
												dbisim(
													sbisim(
														dbisim(
															sbisim(
																MachineBody_VS_O(id__,cycle_SimSMovement_SimSMovement,
																		    const_SimSMovement_PI,
																		    const_SimSMovement_lv,
																		    const_SimSMovement_av)
																[| {|get_CLID_DTurning,DTurning::entered,terminate|} |]
																dbisim(Clock_CLID_DTurning(id__,0,
