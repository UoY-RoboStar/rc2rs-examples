				)
				
				sharedVarSync = union({|get_obstacle|},
					  {||}
					 )
				
				sharedVarHide = union({|get_obstacle|},
					  {||}
					 )
				
				}
		endmodule
		
		Timed(OneStep) {
		CALL__move(id__,
				    param_lv,
				    param_av) 	= moveCall.param_lv.param_av -> SKIP
		CALL__stop(id__) 	= stopCall -> SKIP
		}
		
		Timed(OneStep) {
		-- (Rule 8) cycleController(...) : CSPProcess
		datatype SOutputEvents = SOutput_move
			| SOutput_stop
		
		DVarsEvents = {}
		
		EVarsEvents = {}
		
		cycleController(id__,cycle_SimMovement_SimMovement,
				    const_SimMovement_sm_PI,
				    const_SimMovement_sm_lv,
				    const_SimMovement_sm_av) =
		let
					
			project_sm(sm::o_move.x__) = SOutput_move
			project_sm(sm::o_stop) = SOutput_stop
		
			connected_sm(sm::o_move.x__) = true
			connected_sm(sm::o_stop) = true
			connected_sm(_) = false
		
			lift_sm(sm::o_move.x__) = o_move.x__
			lift_sm(sm::o_stop) = o_stop
			
			CycleController =
				Deadline(
				-- read inputs from the controller and pass to state machines
				(
				((registerRead.i_obstacle?x__ ->
					((sm::registerRead.sm::i_obstacle!x__ -> SKIP))))
				-- ensure state machines read the values being communicated via evars
						);
				-- synchronize on events related to evars to erase memory
				-- collect outputs, and monitor termination of the cycle, by all controllers
				(CollectOutputs(SOutputEvents) [| {endexec} |] Monitor),0);
				-- wait for the cycleDef period
				TimeOut_1(terminate -> SKIP,WAIT(cycle_SimMovement_SimMovement-1));
				-- recurse
				CycleController
				
										
			CollectOutputs(sout) =
				(sm::registerWrite?outp:{ outp | outc <- diff(sout,union(EVarsEvents,DVarsEvents)), outp <- sm::RegisterDataOutput, connected_sm(outp), project_sm(outp) == outc}
						-> registerWrite!lift_sm(outp)
							-> CollectOutputs(diff(sout,{project_sm(outp)}))
				[]
				endexec -> SKIP
				)
		
			Monitor = 
				(	 (sm::endexec -> SKIP)); endexec -> SKIP
		within
			CycleController
		
		-- (Rule 5) memoryComp(...) : CSPProcess
		memoryComp(id__,
				    const_SimMovement_sm_PI,
				    const_SimMovement_sm_lv,
				    const_SimMovement_sm_av) = (
			STOP)
		
		
		-- (Rule 7) [[ c : Controller ]]_C : CSPProcess
		D__(id__,cycle_SimMovement_SimMovement,
				    const_SimMovement_sm_PI,
				    const_SimMovement_sm_lv,
				    const_SimMovement_sm_av) =
		timed_priority(
			(
				(
					(
						(
						dbisim(cycleController(id__,cycle_SimMovement_SimMovement,
								    const_SimMovement_sm_PI,
								    const_SimMovement_sm_lv,
								    const_SimMovement_sm_av))
					 	 [| Union({{||},
					 	 		  {||},
					 	 		  {||},
					 	 		  {||}}) |]
					 	memoryComp(id__,
					 			    const_SimMovement_sm_PI,
					 			    const_SimMovement_sm_lv,
					 			    const_SimMovement_sm_av)
					 	)\{||}
						[| {| 	terminate,tock,
								sm::endexec,sm::registerRead,sm::registerWrite|} |]
						-- (Rule 9) composeMachines(...) : CSPProcess
					 	((let
					 		const_SimSMovement_PI = const_SimMovement_sm_PI
					 		const_SimSMovement_lv = const_SimMovement_sm_lv
					 		const_SimSMovement_av = const_SimMovement_sm_av
					 		cycle_SimSMovement_SimSMovement = cycle_SimMovement_SimMovement
					 	within
					 		(sm::D__(id__,cycle_SimSMovement_SimSMovement,
					 				    const_SimSMovement_PI,
					 				    const_SimSMovement_lv,
					 				    const_SimSMovement_av)
					 		\{| |})
					 		[[sm::terminate <- terminate]]
					 	)
					 	)
					) \ {|	sm::endexec,sm::registerRead,sm::registerWrite |}
				) [| {terminate} |> SKIP
			)
		)
		
		O__(id__,cycle_SimMovement_SimMovement,
				    const_SimMovement_sm_PI,
				    const_SimMovement_sm_lv,
				    const_SimMovement_sm_av) = 
		timed_priority(
			dbisim(
				(
					(
						(
						dbisim(cycleController(id__,cycle_SimMovement_SimMovement,
								    const_SimMovement_sm_PI,
								    const_SimMovement_sm_lv,
								    const_SimMovement_sm_av))
					 	 [| Union({{||},
					 	 		  {||},
					 	 		  {||},
					 	 		  {||}}) |]
					 	memoryComp(id__,
					 			    const_SimMovement_sm_PI,
					 			    const_SimMovement_sm_lv,
					 			    const_SimMovement_sm_av)
					 	)\{||}
						[| {| 	terminate,tock,
								sm::endexec,sm::registerRead,sm::registerWrite|} |]
						-- (Rule 9) composeMachines(...) : CSPProcess
					 	((let
					 		const_SimSMovement_PI = const_SimMovement_sm_PI
					 		const_SimSMovement_lv = const_SimMovement_sm_lv
					 		const_SimSMovement_av = const_SimMovement_sm_av
					 		cycle_SimSMovement_SimSMovement = cycle_SimMovement_SimMovement
					 	within
					 		(sm::O__(id__,cycle_SimSMovement_SimSMovement,
					 				    const_SimSMovement_PI,
					 				    const_SimSMovement_lv,
					 				    const_SimSMovement_av)
					 		\{| |})
					 		[[sm::terminate <- terminate]]
					 	)
					 	)
					) \ {|	sm::endexec,sm::registerRead,sm::registerWrite |}
				) [| {terminate} |> SKIP
			)
		)
		}
	endmodule
	
	-- declaring inputs and outputs of the module
	
	Timed(OneStep) {
	-- (Rule 3) cycleModule(...) : CSPProcess
	
	datatype COutputEvents = COutput_move
		| COutput_stop
	
	EVarsEvents = {}
	
	
	cycleModule(id__,cycle_SimCMovement_SimCMovement) =
	let 
					
		project_cm(cm::o_move.x__) = COutput_move
		project_cm(cm::o_stop) = COutput_stop
		
		connected_cm(cm::o_move.x__) = true
		connected_cm(cm::o_stop) = true
		connected_cm(_) = false
	
		lift_cm(cm::o_move.x__) = o_move.x__
		lift_cm(cm::o_stop) = o_stop
	
		CycleModule =
			Deadline(
			-- read inputs from the platform and pass to controllers
			(
			((registerRead.i_obstacle?x__ ->
				cm::registerRead.cm::i_obstacle!x__ -> SKIP))
					);
			-- synchronize on events related to evars
			-- collect outputs, and monitor termination of the cycle, by all controllers
			(CollectOutputs(COutputEvents) [| {endexec} |] Monitor),0);
			-- wait for the cycleDef period
			TimeOut_1(terminate -> SKIP,WAIT(cycle_SimCMovement_SimCMovement-1));
			-- recurse
			CycleModule
								
		CollectOutputs(sout) =
			(
			cm::registerWrite?outp:{ outp | outc <- diff(sout,EVarsEvents), outp <- cm::RegisterDataOutput, connected_cm(outp), project_cm(outp) == outc}
			 	-> registerWrite!lift_cm(outp)
			 		-> CollectOutputs(diff(sout,{project_cm(outp)}))
			[]
			endexec -> SKIP
			)
			
		Monitor = 
			(	 (cm::endexec -> SKIP)); endexec -> SKIP
		
	within
		CycleModule 
	
	-- (Rule 5) memoryComp(...) : CSPProcess
	memoryComp(id__) = (
		STOP)
	
	
	-- (Rule 1) [[ M : SimModule ]]_M : CSPProcess
	D__(id__,cycle_SimCMovement_SimCMovement,
			    const_SimMovement_sm_PI,
			    const_SimMovement_sm_lv,
			    const_SimMovement_sm_av) =
	timed_priority(
		(
			(
				(
					(
						dbisim(cycleModule(id__,cycle_SimCMovement_SimCMovement))
								[| Union({{||},
										  {||},
										  {||},
										  {||}}) |]
									memoryComp(id__)
						)\{||}
					[| {| 	terminate,tock,
							cm::endexec,cm::registerRead,cm::registerWrite	|} |]
					-- (Rule 6) composeControllers(...) : CSPProcess
						((let
								cycle_SimMovement_SimMovement = cycle_SimCMovement_SimCMovement
							within
								(cm::D__(id__,cycle_SimMovement_SimMovement,
										    const_SimMovement_sm_PI,
										    const_SimMovement_sm_lv,
										    const_SimMovement_sm_av)
								\{| |})
									[[cm::terminate <- terminate]]
							)
						)
				) \ {|	endexec,
						cm::endexec,cm::registerRead,cm::registerWrite |}
			) [| {terminate} |> SKIP
		) \ {terminate}
	)
	
	
	
	O__(id__,cycle_SimCMovement_SimCMovement,
			    const_SimMovement_sm_PI,
			    const_SimMovement_sm_lv,
			    const_SimMovement_sm_av) =
	timed_priority(
		(
			(
				(
					(
						dbisim(cycleModule(id__,cycle_SimCMovement_SimCMovement))
								[| Union({{||},
										  {||},
										  {||},
										  {||}}) |]
									memoryComp(id__)
						)\{||}
					[| {| 	terminate,tock,
							cm::endexec,cm::registerRead,cm::registerWrite	|} |]
					-- (Rule 6) composeControllers(...) : CSPProcess
						((let
								cycle_SimMovement_SimMovement = cycle_SimCMovement_SimCMovement
							within
								(cm::O__(id__,cycle_SimMovement_SimMovement,
										    const_SimMovement_sm_PI,
										    const_SimMovement_sm_lv,
										    const_SimMovement_sm_av)
								\{| |})
									[[cm::terminate <- terminate]]
							)
						)
				) \ {|	endexec,
						cm::endexec,cm::registerRead,cm::registerWrite |}
			) [| {terminate} |> SKIP
		) \ {terminate}
	)
	}
endmodule

