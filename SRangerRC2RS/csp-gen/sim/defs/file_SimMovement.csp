										          const_SimSMovement_PI,
										          const_SimSMovement_lv,
										          const_SimSMovement_av))
							)\{|get_CLID_Waiting|}
						)
						) \ diff(union(stateClockSync,enteredSS),enteredSS)
					)
					)
				
				Stateful_VS_O(id__,cycle_SimSMovement_SimSMovement,
						    const_SimSMovement_PI,
						    const_SimSMovement_lv,
						    const_SimSMovement_av) = 
					dbisim((let
						getsetLocalChannels = {||}
						clockSync = {|get_CLID_MBC,clockReset.CLID_MBC|}
					within
						(Behaviour_VS_O(id__,cycle_SimSMovement_SimSMovement,
								    const_SimSMovement_PI,
