						terminate -> SKIP,Clock_CLID_sStop(id__,clock_type_plus(x__,1,CLID_sStop_clock_type(id__))))
				
				StateClocks(id__) = dbisim(Clock_CLID_sStop(id__,0))
				
				stateClockSync = {|get_CLID_sStop,sStop::entered|}
				}
					endmodule
