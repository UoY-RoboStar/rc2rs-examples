					D__(id__,
								param_i) = 
						dbisim(let
							Inactive 	= share__choice(enter -> SKIP [] terminate -> SKIP) ; Active
							
							Termination = terminate -> SKIP
							
							Active 		= share__choice(interrupt -> SKIP) ; Inactive
						within
							Inactive [| {terminate} |> SKIP)
					
					VS_O__(id__,
								param_i) = D__(id__,
								param_i)
				}
			
			endmodule
			----------------------------------------------------------------------
			
			
			----------------------------------------------------------------------
			-- State: EmptyCycle
			module EmptyCycle
			
			enterSS = {}
			
			enteredSS = {}
			
			exports
			
				--  Declarations
				channel endexec__ : NIDS
				
				
				channel enter, entered, interrupt
				channel enteredL, enteredR
				
								
				
				--channel increment__
				
				
				--	Nodes
				-- declaring all nodes
				
				
				Timed(OneStep) {
					--	Rule: behaviours(Node)
					--  Note that FDR has problems with efficiently compiling the process below
					-- 	if using a different recursion pattern.
					D__(id__,
								param_i) = 
					dbisim(let
						-- IMPLEMENTATION NOTE: 
						-- The following should be defined as: Inactive = share__choice(Activation [] Termination),
						-- however FDR struggles with that form in certain cases. So we use the exception operator
						-- instead to 'terminate'.
						
						Inactive 	= share__choice(enter -> SKIP [] terminate -> SKIP) ; Active
						
						Termination = terminate -> SKIP
						
						Active 		= SKIP ; 
								 	  Behaviour ; 
								 	  share__choice(exit -> SKIP) ; SKIP ; 
								 	  share__choice(exited -> SKIP) ; Inactive
					
						Behaviour 	= entered -> During
						During 		= ((SKIP ; SStop) /\ interrupt -> SKIP)
					within
						Inactive [| {terminate} |> SKIP)
						
					VS_O__(id__,
								param_i) = 
					dbisim(let
						Inactive 	= share__choice(enter -> SKIP [] terminate -> SKIP) ; Active
						
						Termination = terminate -> SKIP
						
						Active 		= SKIP ; 
								 	  Behaviour ; 
								 	  share__choice(exit -> SKIP) ; SKIP ; 
								 	  share__choice(exited -> SKIP) ; Inactive
					
						Behaviour 	= entered -> During
						During 		= ((SKIP ; SStop) /\ interrupt -> SKIP)
					within
						Inactive [| {terminate} |> SKIP)
					
					
					-- Clocks
					
					StateClocks(id__) = terminate -> SKIP
					
					stateClockSync = {||}
				}
			
			endmodule
			----------------------------------------------------------------------
			
			
			
			Timed(OneStep) {
				--	Rule: behaviours(Node)
				--  Note that FDR has problems with efficiently compiling the process below
				-- 	if using a different recursion pattern.
				D__(id__,
							param_i) = 
				dbisim(let
					-- IMPLEMENTATION NOTE: 
					-- The following should be defined as: Inactive = share__choice(Activation [] Termination),
					-- however FDR struggles with that form in certain cases. So we use the exception operator
					-- instead to 'terminate'.
					
					Inactive 	= share__choice(enter -> SKIP [] terminate -> SKIP) ; Active
					
					Termination = terminate -> SKIP
					
					Active 		= SKIP ; 
							 	  Behaviour ; 
							 	  share__choice(exit -> SKIP) ; SKIP ; 
							 	  share__choice(exited -> SKIP) ; Inactive
				
				
					Behaviour 	= dbisim(
						((
						 (((dbisim(
						 	sbisim(
						 		(let
						 			-- IMPLEMENTATION NOTE:
						 			-- Here the 'enter' channel set is calculated explicitly because of the use of CSPM 
						 			-- modules for defining the semantics of each node.
						 			enterSS = {|
						 			i::enter,
						 			EmptyCycle::enter
						 			|}
						 			hideSet = union(enterSS,{|exit,exited,internal__|})
						 		within 
						 			((let
						 				-- IMPLEMENTATION NOTE: the channel set 'enter' is calculated explicitly
						 				-- because CSPM modules are used for the semantics of Node.
						 				flowevts = union(enterSS,{|exit,exited|})
						 				transSync = {|internal__.NID_i,internal__.NID_EmptyCycle|}
						 			within
						 				((
						 				 (((-- RULE composeNodes(nc:NodeContainer)^nops : CSPProcess
						 				   i::D__(id__,
						 				   			param_i)
						 				   [| { share__, terminate } |] (
						 				   EmptyCycle::D__(id__,
						 				   			param_i)
						 				   )
						 				 )
						 				 [[EmptyCycle::interrupt <- x__ | x__ <- {|interrupt,internal__.NID_EmptyCycle|}]]
						 				 [[i::interrupt <- x__ | x__ <- {|internal__.NID_i|}]]
						 				 )
						 				  [[ share__ <- x__ | x__ <- {| share__ |} ]] 
						 				  [[clockReset.CLID_C <- clockResetL.CLID_C]]
						 				 )
						 				 [| union(union(union(flowevts,transSync),{|terminate,endexec,startexec|}),{|share__
						 				 			,clockResetL.CLID_C
						 				|}) |]
						 				 ((i::enter -> Transitions(id__,
						 				 			param_i))
						 				  [[ share__ <- x__ | x__ <- {| share__,clockResetL.CLID_C |} ]]
						 				 )
						 				)[[clockResetL.CLID_C <- clockReset.CLID_C]]
						 				)
						 			)
						 			 \ hideSet)
						 			[[ endexec__.x____  <- endexec | x____ <- NIDS ]]
						 			[[ endexec_action <- endexec ]]
						 			[[ startexec_action <- startexec ]]
						 		)
						 		[| {|get_CLID_EmptyCycle,EmptyCycle::entered,terminate|} |]
						 		dbisim(Clock_CLID_EmptyCycle(id__,0))
						 	)\{|get_CLID_EmptyCycle|}
						 )
						 ))
						  [[ share__ <- x__ | x__ <- {| share__,setR_gyroZF,setR_gyroXF,clockResetR.CLID_C,setR_leftMotorVelocityF,setR_rightMotorVelocityF,setR_angleF |} ]] 
						  [[set_gyroZF <- setL_gyroZF,set_gyroXF <- setL_gyroXF,clockReset.CLID_C <- clockResetL.CLID_C,set_leftMotorVelocityF <- setL_leftMotorVelocityF,set_rightMotorVelocityF <- setL_rightMotorVelocityF,set_angleF <- setL_angleF]]
						 )
						 [| union(union(enteredSS,{| interrupt, terminate |}),{|share__
						 			,setL_gyroZF
						 			,setL_gyroXF
						 			,clockResetL.CLID_C
						 			,setL_leftMotorVelocityF
						 			,setL_rightMotorVelocityF
						 			,setL_angleF
						 			,setR_gyroZF
						 			 			,setR_gyroXF
						 			 			,clockResetR.CLID_C
						 			 			,setR_leftMotorVelocityF
						 			 			,setR_rightMotorVelocityF
						 			 			,setR_angleF
						 			|}) |]
						 ((During)
						  [[ share__ <- x__ | x__ <- {| share__,setL_gyroZF,setL_gyroXF,clockResetL.CLID_C,setL_leftMotorVelocityF,setL_rightMotorVelocityF,setL_angleF |} ]]
						  [[set_gyroZF <- setR_gyroZF,set_gyroXF <- setR_gyroXF,clockReset.CLID_C <- clockResetR.CLID_C,set_leftMotorVelocityF <- setR_leftMotorVelocityF,set_rightMotorVelocityF <- setR_rightMotorVelocityF,set_angleF <- setR_angleF]]
						 )
						)[[setL_gyroZF <- set_gyroZF,setL_gyroXF <- set_gyroXF,clockResetL.CLID_C <- clockReset.CLID_C,setL_leftMotorVelocityF <- set_leftMotorVelocityF,setL_rightMotorVelocityF <- set_rightMotorVelocityF,setL_angleF <- set_angleF]]
						 [[setR_gyroZF <- set_gyroZF,setR_gyroXF <- set_gyroXF,clockResetR.CLID_C <- clockReset.CLID_C,setR_leftMotorVelocityF <- set_leftMotorVelocityF,setR_rightMotorVelocityF <- set_rightMotorVelocityF,setR_angleF <- set_angleF]]
						)\union(enteredSS,{terminate}) 
					)
					During 		= share__choice(([] e__ : enteredSS @ e__ -> SKIP))
							 	  ; entered -> ((CRUN(enteredSS) ||| SKIP ; SStop) /\ interrupt -> share__choice(terminate -> SKIP))
				within
					Inactive [| {terminate} |> SKIP)
					
				VS_O__(id__,
							param_i) = 
				dbisim(let
					Inactive 	= share__choice(enter -> SKIP [] terminate -> SKIP) ; Active
					
					Termination = terminate -> SKIP
					
					Active 		= SKIP ; 
							 	  Behaviour ; 
							 	  share__choice(exit -> SKIP) ; SKIP ; 
							 	  share__choice(exited -> SKIP) ; Inactive
				
				
					Behaviour 	= dbisim(
						((
						 (((dbisim(
						 	sbisim(
						 		(let
						 			-- IMPLEMENTATION NOTE:
						 			-- Here the 'enter' channel set is calculated explicitly because of the use of CSPM 
						 			-- modules for defining the semantics of each node.
						 			enterSS = {|
						 			i::enter,
						 			EmptyCycle::enter
						 			|}
						 			hideSet = union(enterSS,{|exit,exited,internal__|})
						 		within 
						 			((let
						 				-- IMPLEMENTATION NOTE: the channel set 'enter' is calculated explicitly
						 				-- because CSPM modules are used for the semantics of Node.
						 				flowevts = union(enterSS,{|exit,exited|})
						 				transSync = {|internal__.NID_i,internal__.NID_EmptyCycle|}
						 			within
						 				((
						 				 (((-- RULE composeNodes(nc:NodeContainer)^nops : CSPProcess
						 				   i::VS_O__(id__,
						 				   			param_i)
						 				   [| { share__, terminate } |] (
						 				   EmptyCycle::VS_O__(id__,
						 				   			param_i)
						 				   )
						 				 )
						 				 [[EmptyCycle::interrupt <- x__ | x__ <- {|interrupt,internal__.NID_EmptyCycle|}]]
						 				 [[i::interrupt <- x__ | x__ <- {|internal__.NID_i|}]]
						 				 )
						 				  [[ share__ <- x__ | x__ <- {| share__ |} ]] 
						 				  [[clockReset.CLID_C <- clockResetL.CLID_C]]
						 				 )
						 				 [| union(union(union(flowevts,transSync),{|terminate,endexec,startexec|}),{|share__
						 				 			,clockResetL.CLID_C
						 				|}) |]
						 				 ((i::enter -> Transitions(id__,
						 				 			param_i))
						 				  [[ share__ <- x__ | x__ <- {| share__,clockResetL.CLID_C |} ]]
						 				 )
						 				)[[clockResetL.CLID_C <- clockReset.CLID_C]]
						 				)
						 			)
						 			 \ hideSet)
						 			[[ endexec__.x____  <- endexec | x____ <- NIDS ]]
						 			[[ endexec_action <- endexec ]]
						 			[[ startexec_action <- startexec ]]
						 		)
						 		[| {|get_CLID_EmptyCycle,EmptyCycle::entered,terminate|} |]
						 		dbisim(Clock_CLID_EmptyCycle(id__,0))
						 	)\{|get_CLID_EmptyCycle|}
						 )
						 ))
						  [[ share__ <- x__ | x__ <- {| share__,setR_gyroZF,setR_gyroXF,clockResetR.CLID_C,setR_leftMotorVelocityF,setR_rightMotorVelocityF,setR_angleF |} ]] 
						  [[set_gyroZF <- setL_gyroZF,set_gyroXF <- setL_gyroXF,clockReset.CLID_C <- clockResetL.CLID_C,set_leftMotorVelocityF <- setL_leftMotorVelocityF,set_rightMotorVelocityF <- setL_rightMotorVelocityF,set_angleF <- setL_angleF]]
						 )
						 [| union(union(enteredSS,{| interrupt, terminate |}),{|share__
						 			,setL_gyroZF
						 			,setL_gyroXF
						 			,clockResetL.CLID_C
						 			,setL_leftMotorVelocityF
						 			,setL_rightMotorVelocityF
						 			,setL_angleF
						 			,setR_gyroZF
						 			 			,setR_gyroXF
						 			 			,clockResetR.CLID_C
						 			 			,setR_leftMotorVelocityF
						 			 			,setR_rightMotorVelocityF
						 			 			,setR_angleF
						 			|}) |]
						 ((During)
						  [[ share__ <- x__ | x__ <- {| share__,setL_gyroZF,setL_gyroXF,clockResetL.CLID_C,setL_leftMotorVelocityF,setL_rightMotorVelocityF,setL_angleF |} ]]
						  [[set_gyroZF <- setR_gyroZF,set_gyroXF <- setR_gyroXF,clockReset.CLID_C <- clockResetR.CLID_C,set_leftMotorVelocityF <- setR_leftMotorVelocityF,set_rightMotorVelocityF <- setR_rightMotorVelocityF,set_angleF <- setR_angleF]]
						 )
						)[[setL_gyroZF <- set_gyroZF,setL_gyroXF <- set_gyroXF,clockResetL.CLID_C <- clockReset.CLID_C,setL_leftMotorVelocityF <- set_leftMotorVelocityF,setL_rightMotorVelocityF <- set_rightMotorVelocityF,setL_angleF <- set_angleF]]
						 [[setR_gyroZF <- set_gyroZF,setR_gyroXF <- set_gyroXF,clockResetR.CLID_C <- clockReset.CLID_C,setR_leftMotorVelocityF <- set_leftMotorVelocityF,setR_rightMotorVelocityF <- set_rightMotorVelocityF,setR_angleF <- set_angleF]]
						)\{terminate} 
					)
					During 		= share__choice(([] e__ : enteredSS @ e__ -> SKIP))
							 	  ; entered -> ((CRUN(enteredSS) ||| SKIP ; SStop) /\ interrupt -> share__choice(terminate -> SKIP))
				within
