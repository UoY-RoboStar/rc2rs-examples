stm BalanceSTM {
	uses HallSensorsI uses IMUI uses pkg867_::AnglePIDVars uses pkg867_::SpeedPIDVars uses pkg867_::RotationPIDVars requires MotorsI requires InterruptsI requires PIDs requires I_clone_normal_BalanceSTM_CalculateSpeed_entry requires I_clone_normal_BalanceSTM_CalculateAngle_entry requires I_clone_normal_BalanceSTM_StopMotors_entry requires I_clone_normal_BalanceSTM_Initialisation_entry requires I_clone_normal_BalanceSTM_CalculateRotation_entry requires I_clone_normal_BalanceSTM_SetMotors_entry requires I_clone_normal_BalanceSTM_j1_t5_op requires I_clone_normal_BalanceSTM_CalculateAngle_t3_op const maxAngle : real
	const loopTime : nat
	var currAngle : real , currGyroX : real , currGyroY : real , currGyroZ : real , currLeftVel : real , currRightVel : real
	const startupDelay : nat
	var speedCount : nat , rotationCount : nat
	const speedUpdate : nat , rotationUpdate : nat
	const angleBudget : nat , speedBudget : nat , rotationBudget : nat , motorBudget : nat
	initial i0
	state CalculateAngle {
		initial i
		state EmptyCycle {
		}
		transition tCalculateAngle {
			from i
			to EmptyCycle
		}
		entry clone_normal_BalanceSTM_CalculateAngle_entry ( )
	}
	state CalculateSpeed {
		initial i
		state EmptyCycle {
		}
		transition tCalculateSpeed {
			from i
			to EmptyCycle
		}
		entry clone_normal_BalanceSTM_CalculateSpeed_entry ( )
	}
	state CalculateRotation {
		state EmptyCycle {
		}
		initial i
		transition tCalculateRotation {
			from i
			to EmptyCycle
		}
		entry clone_normal_BalanceSTM_CalculateRotation_entry ( )
	}
	state SetMotors {
		state EmptyCycle {
		}
		initial i
		transition tSetMotors {
			from i
			to EmptyCycle
		}
		entry clone_normal_BalanceSTM_SetMotors_entry ( )
	}
	junction j0
	junction j1
	junction j2
	state StopMotors {
		state EmptyCycle {
		}
		initial i
		transition tStopMotors {
			from i
			to EmptyCycle
		}
		entry clone_normal_BalanceSTM_StopMotors_entry ( )
	}
	state WaitForNextIteration {
		state EmptyCycle {
		}
		initial i
		transition tWaitForNextIteration {
			from i
			to EmptyCycle
		}
	}
	state Initialisation {
		state EmptyCycle {
		}
		initial i
		transition tInitialisation {
			from i
			to EmptyCycle
		}
		entry clone_normal_BalanceSTM_Initialisation_entry ( )
	}
	junction j3
	transition t1 {
		from j0
		to CalculateSpeed
		condition speedCount >= speedUpdate
	}
	transition t2 {
		from CalculateSpeed
		to j1
	}
	transition t3 {
		from CalculateAngle
		to j0
		action clone_normal_BalanceSTM_CalculateAngle_t3_op ( )
	}
	transition t4 {
		from j0
		to j1
		condition speedCount < speedUpdate
	}
	transition t8 {
		from CalculateRotation
		to j2
	}
	transition t9 {
		from j2
		to SetMotors
		condition currAngle <= maxAngle /\ currAngle >= - maxAngle
	}
	transition t10 {
		from j2
		to StopMotors
		condition currAngle > maxAngle \/ currAngle < - maxAngle
	}
	transition t12 {
		from WaitForNextIteration
		to CalculateAngle
		# loopTimer
		condition since ( loopTimer ) >= loopTime
		action disableInterrupts ( )
	}
	transition t7 {
		from StopMotors
		to WaitForNextIteration
	}
	transition t11 {
		from SetMotors
		to WaitForNextIteration
	}
	transition t0 {
		from i0
		to Initialisation
	}
	transition t13 {
		from Initialisation
		to WaitForNextIteration
	}
	transition t5 {
		from j1
		to j3
		action clone_normal_BalanceSTM_j1_t5_op ( )
	}
	transition t6 {
		from j3
		to CalculateRotation
		condition rotationCount >= rotationUpdate
	}
	transition t14 {
		from j3
		to j2
		condition rotationCount < rotationUpdate
	}
	clock loopTimer
}

